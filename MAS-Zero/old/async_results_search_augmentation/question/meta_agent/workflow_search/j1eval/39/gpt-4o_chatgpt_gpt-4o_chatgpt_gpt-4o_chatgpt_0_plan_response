        "example_id": 39,
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u7269\u6743\u7ea0\u7eb7\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u961c\u65b0\u67d0\u67d0\u67d0\u67d0\u6709\u9650\u516c\u53f8\", \"address\": \"\u961c\u65b0\u5e02\u67d0\u67d0\u533a\", \"representative\": \"\u6768\u67d0\", \"gender\": null, \"ethnicity\": null, \"birth_date\": null}, \"defendant\": {\"name\": \"\u8fbd\u5b81\u67d0\u67d0\uff08\u67d0\u67d0\uff09\u5ba2\u8fd0\u6709\u9650\u516c\u53f8\", \"address\": \"\u961c\u65b0\u5e02\u7ec6\u6cb3\u533a\", \"representative\": \"\u4efb\u67d0\u67d0\", \"gender\": null, \"ethnicity\": null, \"birth_date\": null}}, \"plaintiff_claim\": [\"\u8bf7\u6c42\u4eba\u6c11\u6cd5\u9662\u4f9d\u6cd5\u5224\u4ee4\u88ab\u544a\u8fd4\u8fd8\u539f\u544a109000\u5143\uff0c\u5e76\u81ea2024\u5e742\u67082\u65e5\u8d77\u81f3\u4ed8\u6e05\u4e4b\u65e5\u6b62\u6309\u7167\u5168\u56fd\u94f6\u884c\u95f4\u540c\u4e1a\u62c6\u501f\u4e2d\u5fc3\u516c\u5e03\u7684\u8d37\u6b3e\u5e02\u573a\u62a5\u4ef7\u5229\u7387\u652f\u4ed8\u5229\u606f\u3002\", \"\u672c\u6848\u8bc9\u8bbc\u8d39\u7528\u53ca\u5176\u4ed6\u8d39\u7528\u7531\u88ab\u544a\u8d1f\u62c5\u3002\"], \"plaintiff_case_details\": \"\u6d77\u5dde\u533a\u4eba\u6c11\u6cd5\u9662\u4e8e2021\u5e748\u670825\u65e5\u4f5c\u51fa\uff082021)\u8fbd0902\u6c11\u521d2513\u53f7\u6c11\u4e8b\u5224\u51b3\u4e66\uff0c\u5185\u5bb9\u5982\u4e0b\uff1a\u201c\u4e00\u3001\u88ab\u544a\u961c\u65b0\u67d0\u67d0\u67d0\u67d0\u6709\u9650\u516c\u53f8\u4e8e\u672c\u5224\u51b3\u751f\u6548\u540e\u5341\u65e5\u5185\u7ed9\u4ed8\u539f\u544a\u8fbd\u5b81\u67d0\u67d0\uff08\u67d0\u67d0\uff09\u5ba2\u8fd0\u6709\u9650\u516c\u53f8\u7968\u4ef7\u7ed3\u7b97\u6b3e2071419.92\u5143\u53ca\u5229\u606f\uff0c\u5229\u606f\u81ea2021\u5e748\u67089\u65e5\u8d77\u81f3\u5b9e\u9645\u7ed9\u4ed8\u4e4b\u65e5\u6b62\u6309\u7167\u4e00\u5e74\u671f\u5e02\u573a\u8d37\u6b3e\u62a5\u4ef7\u5229\u7387\uff083.85%)\u8ba1\u7b97\u3002\u201d\uff0c\u540e\u67d0\u67d0\u5ba2\u8fd0\u7533\u8bf7\u5f3a\u5236\u6267\u884c\uff0c\u6267\u884c\u8fc7\u7a0b\u4e2d\uff0c\u67d0\u67d0\u603b\u7ad9\u4e8e2024\u5e741\u670824\u65e5\u7ecf\u8d35\u9662\u4f5c\u51fa\uff082024)\u8fbd09\u7834\u75332\u53f7\u6c11\u4e8b\u88c1\u5b9a\u4e66\uff0c\u88c1\u5b9a\u5982\u4e0b\uff1a\u201c\u88c1\u5b9a\u53d7\u7406\u7533\u8bf7\u4eba\u961c\u65b0\u67d0\u67d0\u67d0\u67d0\u6709\u9650\u516c\u53f8\u6e05\u7b97\u7ec4\u5bf9\u88ab\u7533\u8bf7\u4eba\u961c\u65b0\u67d0\u67d0\u67d0\u67d0\u6709\u9650\u516c\u53f8\u7684\u7834\u4ea7\u6e05\u7b97\u7533\u8bf7\u201d\uff0c\u5e76\u4e8e2024\u5e741\u670826\u65e5\u7ecf\u8d35\u9662\u4f5c\u51fa\uff082024)\u8fbd09\u78342\u53f7\u51b3\u5b9a\u4e66\uff0c\u6307\u5b9a\u961c\u65b0\u67d0\u67d0\u67d0\u67d0\u6709\u9650\u516c\u53f8\u6e05\u7b97\u7ec4\u62c5\u4efb\u539f\u544a\u7ba1\u7406\u4eba\uff0c\u67d0\u67d0\u603b\u7ad9\u5df2\u7ecf\u8fdb\u5165\u7834\u4ea7\u7a0b\u5e8f\u30022024\u5e742\u67082\u65e5\uff0c\u961c\u65b0\u5e02\u6d77\u5dde\u533a\u4eba\u6c11\u6cd5\u9662\u8d23\u4ee4\u6267\u884c\uff0c\u67d0\u67d0\u603b\u7ad9\u73b0\u91d1\u5f62\u5f0f\u652f\u4ed8\u81f3\u8be5\u9662\uff0c\u8be5\u9662\u540c\u65e5\u5411\u51fa\u5177\u6536\u6761\uff0c\u5185\u5bb9\u4e3a\uff1a\u201c\u4eca\u6536\u5230\u961c\u65b0\u67d0\u67d0\u516c\u53f8\u7ed9\u4ed8\u67d0\u67d0\u516c\u53f8\u7684\u6267\u884c\u6b3e\u58f9\u62fe\u4e07\u96f6\u7396\u4edf\u5143\u6574?109000\u5143\u3002\u201d\uff0c\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u4f01\u4e1a\u78