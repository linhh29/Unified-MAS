        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u7269\u6743\u7ea0\u7eb7\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u961c\u65b0\u67d0\u67d0\u67d0\u67d0\u6709\u9650\u516c\u53f8\", \"address\": \"\u961c\u65b0\u5e02\u67d0\u67d0\u533a\", \"representative\": \"\u6768\u67d0\", \"gender\": null, \"ethnicity\": null, \"birth_date\": null}, \"defendant\": {\"name\": \"\u8fbd\u5b81\u67d0\u67d0\uff08\u67d0\u67d0\uff09\u5ba2\u8fd0\u6709\u9650\u516c\u53f8\", \"address\": \"\u961c\u65b0\u5e02\u7ec6\u6cb3\u533a\", \"representative\": \"\u4efb\u67d0\u67d0\", \"gender\": null, \"ethnicity\": null, \"birth_date\": null}}, \"plaintiff_claim\": [\"\u8bf7\u6c42\u4eba\u6c11\u6cd5\u9662\u4f9d\u6cd5\u5224\u4ee4\u88ab\u544a\u8fd4\u8fd8\u539f\u544a109000\u5143\uff0c\u5e76\u81ea2024\u5e742\u67082\u65e5\u8d77\u81f3\u4ed8\u6e05\u4e4b\u65e5\u6b62\u6309\u7167\u5168\u56fd\u94f6\u884c\u95f4\u540c\u4e1a\u62c6\u501f\u4e2d\u5fc3\u516c\u5e03\u7684\u8d37\u6b3e\u5e02\u573a\u62a5\u4ef7\u5229\u7387\u652f\u4ed8\u5229\u606f\u3002\", \"\u672c\u6848\u8bc9\u8bbc\u8d39\u7528\u53ca\u5176\u4ed6\u8d39\u7528\u7531\u88ab\u544a\u8d1f\u62c5\u3002\"], \"plaintiff_case_details\": \"\u6d77\u5dde\u533a\u4eba\u6c11\u6cd5\u9662\u4e8e2021\u5e748\u670825\u65e5\u4f5c\u51fa\uff082021)\u8fbd0902\u6c11\u521d2513\u53f7\u6c11\u4e8b\u5224\u51b3\u4e66\uff0c\u5185\u5bb9\u5982\u4e0b\uff1a\u201c\u4e00\