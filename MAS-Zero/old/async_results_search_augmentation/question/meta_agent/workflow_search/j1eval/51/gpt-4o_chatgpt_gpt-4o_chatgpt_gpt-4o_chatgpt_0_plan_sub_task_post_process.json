    {
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u4eba\u683c\u6743\u7ea0\u7eb7\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u8f9b\u67d0\u67d0\", \"address\": \"\u7518\u8083\u7701\u9759\u5b81\u53bf\u4f59\u6e7e\u4e61\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1972\u5e749\u670815\u65e5\"}, \"defendant\": {\"name\": \"\u97e9\u67d0\u67d0\", \"address\": \"\u7518\u8083\u7701\u9759\u5b81\u53bf\u4f59\u6e7e\u4e61\u82d7\u5c98\u6751\u8f9b\u5c71\u7ec4\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1966\u5e744\u670810\u65e5\"}}, \"plaintiff_claim\": [\"\u5224\u4ee4\u88ab\u544a\u8d54\u507f\u539f\u544a\u533b\u7597\u8d396884.04\u5143\u3001\u8bef\u5de5\u8d393086.44\u5143\u3001\u62a4\u7406\u8d393086.44\u5143\u3001\u4f4f\u9662\u4f19\u98df\u8865\u52a9\u8d39560\u5143\u3001\u8425\u517b\u8d39560\u5143\u3001\u4ea4\u901a\u8d39797\u5143\u3001\u75c5\u5386\u590d\u5370\u8d3960\u5143\uff0c\u5408\u8ba115033.92\u5143\", \"\u672c\u6848\u8bc9\u8bbc\u8d39\u7528\u7531\u88ab\u544a\u627f\u62c5\"], \"plaintiff_case_details\": \"\u8f9b\u67d0\u67d0\u4e0e\u97e9\u67d0\u67d0\u7cfb\u540c\u6751\u4eba\u30022024\u5e746\u670827\u65e517\u65f6\u8bb8\uff0c\u8f9b\u67d0\u67d0\u3001\u97e9\u67d0\u67d0\u9152\u540e\u53d1\u751f\u53e3\u89d2\uff0c\u97e9\u67d0\u67d0\u671d\u8f9b