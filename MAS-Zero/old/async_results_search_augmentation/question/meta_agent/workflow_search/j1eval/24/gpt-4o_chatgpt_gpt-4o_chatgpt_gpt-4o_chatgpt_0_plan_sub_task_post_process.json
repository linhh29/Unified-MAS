    {
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u7269\u6743\u7ea0\u7eb7\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u5f20\u67d0\u67d0\", \"address\": \"\u547c\u548c\u6d69\u7279\u5e02\u7389\u6cc9\u533a\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1968\u5e744\u670817\u65e5\"}, \"defendant\": {\"name\": \"\u547c\u548c\u6d69\u7279\u5e02\u9f0e\u76db\u7269\u4e1a\u670d\u52a1\u6709\u9650\u516c\u53f8\", \"address\": \"\u5185\u8499\u53e4\u81ea\u6cbb\u533a\u547c\u548c\u6d69\u7279\u5e02\u8d5b\u7f55\u533a\u5927\u5b66\u8def\uff08\u56fd\u582a\u9662\u5c0f\u533a11\u53f7\u697c5\u5355\u5143101\u5ba4\uff09\", \"representative\": \"\u738b\u65ed\u826f\", \"gender\": null, \"ethnicity\": null, \"birth_date\": null}}, \"plaintiff_claim\": [\"\u5224\u4ee4\u88ab\u544a\u505c\u6b62\u4fb5\u6743\uff0c\u5c06\u539f\u544a\u5916\u5899\u6f0f\u6c34\u6392\u6c34\u7ba1\u9053\u7acb\u5373\u4fee\u590d\u5e76\u8fdb\u884c\u66f4\u6362\", \"\u8d54\u507f\u56e0\u6392\u6c34\u7ba1\u6f0f\u6c34\u5bfc\u81f4\u539f\u544a\u5bb6\u91cc\u5899\u9762\u4e25\u91cd\u6e17\u6c34\uff0c\u5899\u9762\u817b\u5b50\u8131\u843d\u3001\u67dc\u53d7\u6f6e\u53d8\u5f62\u3001\u8863\u7269\u88d8\u76ae\u5927\u8863\u3001\u8695\u4e1d\u88ab\u53d1\u9709\u635f\u574f\u7ecf\u6d4e\u635f\u593171880\u5143\", \"\u672c\u6848\u8bc9\u8bbc\u8d39\u7531\u88ab\u544a\u627f\u