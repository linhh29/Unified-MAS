        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u8d22\u4ea7\u635f\u5bb3\u8d54\u507f\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u5f20\u4f1f\", \"address\": \"\u961c\u65b0\u5e02\u592a\u5e73\u533a\u7ea2\u6811\u8857\u9053\u6d77\u6cb3\u793e\u533a\u6d77\u6cb3\u8def2#-40\uff08302\u5ba4\uff09\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"19xx\u5e74xx\u6708xx\u65e5\"}, \"defendant\": {\"name\": \"\u891a\u660e\u6069\", \"address\": \"\u961c\u65b0\u5e02\u592a\u5e73\u533a\u7ea2\u6811\u8857\u9053\u6d77\u6cb3\u793e\u533a\u6d77\u6cb3\u8def2#-40\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"2008\u5e74\"}}, \"plaintiff_claim\": [\"\u8bf7\u6c42\u6cd5\u9662\u5224\u4ee4\u88ab\u544a\u7acb\u5373\u505c\u6b62\u4fb5\u5bb3\u3001\u6392\u9664\u59a8\u788d\u3001\u6062\u590d\u539f\u72b6\uff0c\u5e76\u8d54\u507f\u539f\u544a\u7ecf\u6d4e\u635f\u59315000\u5143\", \"\u8bf7\u6c42\u6cd5\u9662\u5224\u4ee4\u88ab\u544a\u627f\u62c5\u672c\u6848\u5168\u90e8\u8bc9\u8bbc\u8d39\u7528\"], \"plaintiff_case_details\": \"\u539f\u544a\u4e0e\u88ab\u544a\u7cfb\u4e0a\u4e0b\u697c\u90bb\u5c45\u30022024\u5e748\u670810\u65e5\u88ab\u544a\u5bb6\u6f0f\u6c34\uff0c\u6d41\u8fdb\u4e86\u539f\u544a\u5bb6\u5367\u5ba4\u3001\u9633\u53f0\u7b49\u90e8\u4f4d\uff0c\u5c06\u539f\u544a\u5bb6\u7