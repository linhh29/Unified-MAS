    {
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u8d22\u4ea7\u635f\u5bb3\u8d54\u507f\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u5f20\u4f1f\", \"address\": \"\u961c\u65b0\u5e02\u592a\u5e73\u533a\u7ea2\u6811\u8857\u9053\u6d77\u6cb3\u793e\u533a\u6d77\u6cb3\u8def2#-40\uff08302\u5ba4\uff09\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"19xx\u5e74xx\u6708xx\u65e5\"}, \"defendant\": {\"name\": \"\u891a\u660e\u6069\", \"address\": \"\u961c\u65b0\u5e02\u592a\u5e73\u533a\u7ea2\u6811\u8857\u9053\u6d77\u6cb3\u793e\u533a\u6d77\u6cb3\u8def2#-40\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"2008\u5e74\"}}, \"plaintiff_claim\": [\"\u8bf7\u6c42\u6cd5\u9662\u5224\u4ee4\u88ab\u544a\u7acb\u5373\u505c\u6b62\u4fb5\u5bb3\u3001\u6392\u9664\u59a8\u788d\u3001\u6062\u590d\u539f\u72b6\uff0c\u5e76\u8d54\u507f\u539f\u544a\u7ecf\u6d4e\u635f\u59315000\u5143\", \"\u8bf7\u6c42\u6cd5\u9662\u5224\u4ee4\u88ab\u544a\u627f\u62c5\u672c\u6848\u5168\u90e8\u8bc9\u8bbc\u8d39\u7528\"], \"plaintiff_case_details\": \"\u539f\u544a\u4e0e\u88ab\u544a\u7cfb\u4e0a\u4e0b\u697c\u90bb\u5c45\u30022024\u5e748\u670810\u65e5\u88ab\u544a\u5bb6\u6f0f\u6c34\uff0c\u6d41\u8fdb\u4e86\u539f\u544a\u5bb6\u5367\u5ba4\u3001\u9633\u53f0\u7b49\u90e8\u4f4d\uff0c\u5c06\u539f\u544a\u5bb6\u7684\u7535\u8111\u3001\u97f3\u54cd\u3001\u7a97\u5e18\u7b49\u5168\u90e8\u6d78\u6ce1\uff0c\u9020\u6210\u7ecf\u6d4e\u635f\u5931\u3002\u539f\u544a\u627e\u88ab\u544a\u8981\u6c42\u8d54\u507f\uff0c\u88ab\u544a\u63a8\u8131\u8d23\u4efb\u62d2\u7edd\u8d54\u507f\u3002\u539f\u544a\u4e3a\u7ef4\u62a4\u81ea\u8eab\u5408\u6cd5\u6743\u76ca\uff0c\u7279\u63d0\u8d77\u8bc9\u8bbc\u3002\", \"defendant_defence\": \"1\u3001\u539f\u544a\u5bf9\u6b64\u6b21\u623f\u5c4b\u6e17\u6c34\u8d1f\u4e3b\u8981\u8d23\u4efb\u3002\uff081\uff09\u6e17\u6c34\u7684\u76f4\u63a5\u539f\u56e0\u662f\u88ab\u544a\u5bb6\u5ba4\u5916\u9633\u53f0\u6392\u6c34\u5b54\u4e0a\u7684\u6392\u6c34\u7ba1\u88ab\u4eba\u4e3a\u62d4\u6389\uff0c\u5bfc\u81f4\u5c0f\u533a\u6539\u9020\u65f6\u6392\u6c34\u5b54\u88ab\u5916\u5899\u4fdd\u6e29\u677f\u5c01\u6b7b\uff0c\u79ef\u6c34\u65e0\u6cd5\u6392\u51fa\u6cbf\u5916\u5899\u6e17\u5165\u539f\u544a\u5bb6\u4e2d\u3002\u6b64\u7ba1\u66fe\u7ecf\u88ab\u539f\u544a\u4ee5\u6392\u6c34\u7ba1\u77ed\u4e3a\u7531\u62d4\u6389\uff0c\u81ea\u5df1\u6362\u4e0a\u4e86\u539f\u544a\u8ba4\u4e3a\u5408\u9002\u957f\u5ea6\u7684\u6392\u6c34\u7ba1\u3002\u73b0\u573a\u53ef\u89c1\uff0c\u88ab\u544a\u90bb\u5c45\u5bb6\u3001\u539f\u544a\u5bb6\u7b49\u5176\u4ed6\u7528\u6237\u6392\u6c34\u7ba1\u5e76\u672a\u56e0\u6539\u9020\u800c\u88ab\u4eba\u4e3a\u62c6\u9664\uff0c\u6545\u6b64\u6392\u6c34\u7ba1\u53ea\u80fd\u7531\u539f\u544a\u81ea\u5df1\u62c6\u9664\uff0c\u4ece\u800c\u5bfc\u81f4\u88ab\u544a\u5bb6\u7684\u6392\u6c34\u7ba1\u88ab\u5835\u3002\uff082\uff09\u6b64\u623f\u56e0\u539f\u544a\u539f\u56e0\u65e0\u6cd5\u51fa\u79df\uff0c\u5bfc\u81f4\u5bb6\u4e2d\u65e0\u4eba\uff0c\u4e0d\u80fd\u7b2c\u4e00\u65f6\u95f4\u53d1\u73b0\u5916\u9633\u53f0\u79ef\u6c34\u30022008\u5e74\u88ab\u544a\u642c\u79bb\u540e\u5c31\u5c06\u623f\u5c4b\u51fa\u79df\uff0c\u8fde\u7eed\u51fa\u79df\u4e09\u5bb6\uff0c\u90fd\u88ab\u539f\u544a\u4ee5\u79df\u5ba2\u5f71\u54cd\u5176\u751f\u6d3b\u4e3a\u7531\uff0c\u627e\u5404\u79cd\u7406\u7531\u4e0e\u79df\u5ba2\u53d1\u751f\u4e89\u6267\uff0c\u81f4\u4f7f\u79df\u671f\u672a\u6ee1\u5c31\u89e3\u9664\u79df\u7ea6\u30022\u3001\u5173\u4e8e\u6e17\u6c34\u9020\u6210\u7684\u635f\u5931\uff0c\u539f\u544a\u6ca1\u6709\u5b9e\u4e8b\u6c42\u662f\u3002\u539f\u544a\u8bf4\u7535\u8111\u3001\u97f3\u54cd\u6d78\u6ce1\u4e0d\u5b9e\u30028\u670812\u65e5\u88ab\u544a\u63a5\u5230\u6d3e\u51fa\u6240\u7535\u8bdd\uff0c\u8ba9\u6211\u4eec\u6293\u7d27\u56de\u53bb\u5904\u7406\u6f0f\u6c34\u4e8b\u5b9c\u3002\u7535\u8bdd\u4e2d\u548c\u6211\u4eec\u5230\u8fbe\u73b0\u573a\u65f6\u539f\u544a\u59cb\u7ec8\u672a\u63d0\u53ca\u7535\u8111\u548c\u97f3\u54cd\u88ab\u6d78\u6ce1\u4e00\u4e8b\u3002\u5f53\u65f6\u5728\u73b0\u573a\u6211\u4eec\u672a\u53d1\u73b0\u6709\u6ef4\u6c34\u548c\u6d78\u6ce1\u73b0\u8c61\uff0c\u539f\u544a\u513f\u5b50\u7b49\u5728\u90a3\u91cc\u8bf4\u6f0f\u6c34\u628a\u5899\u9634\u6e7f\u4e86\uff0c\u628a\u4ed6\u591a\u5e74\u524d\u8d2d\u4e70\u7684\u7b14\u8bb0\u672c\u7535\u8111\u6ce1\u4e86\uff0c\u6298\u65e7\u4e09\u5343\u5143\u3002\u6211\u4eec\u8ba4\u4e3a\u7b14\u8bb0\u672c\u7535\u8111\u4e0d\u662f\u539f\u544a\u7684\uff0c\u4e0d\u53ef\u80fd\u6d78\u6ce1\u3002\u539f\u544a\u7684\u513f\u5b50\u662f\u641e\u8f6f\u4ef6\u7684\uff0c\u4e0e\u539f\u544a\u4f4f\u540c\u4e00\u697c\u5c42\uff0c\u4e0d\u53ef\u80fd\u5c06\u81ea\u5df1\u7684\u7535\u8111\u653e\u5728\u539f\u544a\u5bb6\u7a97\u53f0\u4e0a\uff0c\u540e\u539f\u544a\u6539\u53e3\u79f0\u8be5\u7535\u8111\u7cfb\u513f\u5b50\u7ed9\u4e08\u592b\u7092\u80a1\u7528\u7684\u3002\u97f3\u54cd\u7684\u4f4d\u7f6e\u6ca1\u6709\u53d1\u751f\u6ef4\u6c34\u73b0\u8c61\uff0c\u66f4\u4e0d\u53ef\u80fd\u88ab\u6d78\u6ce1\u3002\u539f\u544a\u5bb6\u4e2d\u4e00\u76f4\u6709\u4eba\uff0c\u4e0d\u53ef\u80fd\u53d1\u751f\u6d78\u6ce1\u4e8b\u4ef6\u30023\u3001\u88ab\u544a\u5df2\u7ecf\u4e3b\u52a8\u4f5c\u4e3a\uff0c\u6d88\u9664\u5ba4\u5916\u9633\u53f0\u6e17\u6c34\u9690\u60a3\u3002\u88ab\u544a\u5bb6\u4eba\u5df2\u82b1\u8d39\u4e24\u5343\u4f59\u5143\u5bf9\u5ba4\u5916\u9633\u53f0\u8fdb\u884c\u4e86\u5168\u5c01\u95ed\uff0c\u5f7b\u5e95\u89e3\u51b3\u4e86\u5ba4\u5916\u9633\u53f0\u53ef\u80fd\u96e8\u6c34\u56e4\u