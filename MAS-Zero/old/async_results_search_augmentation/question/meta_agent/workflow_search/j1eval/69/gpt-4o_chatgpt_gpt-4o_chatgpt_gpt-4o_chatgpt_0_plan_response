nt_evidence\": {\"evidence_1\": {\"evidence\": \"\u88ab\u544a\u67d0\u7532\u516c\u53f8\u63d0\u4ea4\u4e00\u5f20\u622a\u56fe\u663e\u793a\u540d\u79f0\u4e3a\u201c\u6ce1\u6cab\u51ac\u666f\u201d\uff0c\u7248\u672c\u53f7\u4e3a2.0.1\u7684\u6e38\u620f\u8f6f\u4ef6\uff0c\u4e0b\u8f7d\u91cf12\uff0c\u6d4f\u89c8\u91cf33\u6b21\u3002\", \"dispute\": \"\u88ab\u544a\u6ca1\u6709\u83b7\u53d6\u4efb\u4f55\u5229\u76ca\uff0c\u4e14\u6d4f\u89c8\u91cf\u3001\u4e0b\u8f7d\u91cf\u6781\u5c0f\u3002\", \"name\": null}, \"evidence_2\": null, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null}}, \"other_statement\": {\"plaintiff\": {\"plaintiff_1\": \"\u539f\u544a\u67d0\u4e59\u516c\u53f8\u4e8e2019\u5e745\u67085\u65e5\u5f00\u53d1\u5b8c\u6210\u6e38\u620f\u8f6f\u4ef6\u201c\u6ce1\u6cab\u51ac\u666f\uff361.0\u201d\uff0c\u5e76\u4e8e2019\u5e745\u670824\u65e5\u9996\u6b21\u53d1\u8868\u30022019\u5e748\u670815\u65e5\u5728\u56fd\u5bb6\u7248\u6743\u5c40\u8fdb\u884c\u4e86\u8ba1\u7b97\u673a\u8f6f\u4ef6\u8457\u4f5c\u6743\u767b\u8bb0\u3002\u8be5\u6e38\u620f\u5728\uff34\uff41\uff50\uff34\uff41\uff50\u3001\u6e38\u4fa0\u7f51\u7b49\u5e73\u53f0\u4e0a\u8fdb\u884c\u8fc7\u53d1\u5e03\u3002\u539f\u544a\u67d0\u4e59\u516c\u53f8\u9648\u8ff0\u8be5\u6e38\u620f\u552e\u4ef7\u4e3a30\u5143\u3002\"}, \"defendant\": {\"defendant_1\": \"\u88ab\u544a\u67d0\u7532\u516c\u53f8\u8ba4\u53ef\u201c\uff57\uff57\uff57.\u67d08.\u67d0\u201d\uff08\u8f6f\u5427\u4e0b\u8f7d\uff09\u7f51\u7ad9\u7cfb\u5176\u7ecf\u8425\uff0c\u8ba4\u53ef\u5176\u63d0\u4f9b\u4e0b\u8f7d\u7684\u6e38\u620f\u4e0e\u539f\u544a\u6d89\u6848\u6743\u5229\u6e38\u620f\u8f6f\u4ef6\u76f8\u540c\u3002\"}}}\n",
