81ea\u76f8\u8ba4\u8bc6\u5e76\u604b\u7231\uff0c2011\u5e7412\u670827\u65e5\u53cc\u65b9\u81ea\u613f\u5728\u96ea\u6797\u4e61\u6c11\u653f\u90e8\u95e8\u767b\u8bb0\u7ed3\u5a5a\u3002\u5a5a\u540e\u5171\u540c\u751f\u80b2\u4e09\u4e2a\u5b69\u5b50\uff0c\u00d7\u00d7\u00d7\u00d7\u5e74\u00d7\u00d7\u6708\u00d7\u00d7\u65e5\u751f\u80b2\u957f\u5b50\u9c8d\u67d0\u660e\uff0c\u73b0\u5e7411\u5c81\uff0c\u5728\u96ea\u6797\u4e61\u4e2d\u5b66\u4e0a\u521d\u4e2d\u3002\u00d7\u00d7\u00d7\u00d7\u5e74\u00d7\u00d7\u6708\u00d7\u00d7\u65e5\u751f\u80b2\u6b21\u5b50\u9c8d\u67d0\u7965\uff0c\u73b0\u5e747\u5c81\uff0c\u5728\u5de6\u90fd\u6751\u4e2d\u5fc3\u5b8c\u5c0f\u4e0a\u5c0f\u5b66\u4e00\u5e74\u7ea7\u3002\u00d7\u00d7\u00d7\u00d7\u5e74\u00d7\u00d7\u6708\u00d7\u00d7\u65e5\u751f\u80b2\u957f\u5973\u9c8d\u67d0\u7434\uff0c\u73b0\u5e745\u5c81\u3002\u5a5a\u540e\u5171\u540c\u751f\u6d3b\u671f\u95f4\uff0c\u88ab\u544a\u5e38\u56e0\u5bb6\u5ead\u7410\u4e8b\u4e0e\u539f\u544a\u53d1\u751f\u4e89\u5435\uff0c\u4e14\u88ab\u544a\u813e\u6c14\u66b4\u8e81\uff0c\u4e00\u8a00\u4e0d\u5408\u5c31\u4f1a\u52a8\u624b\u6bb4\u6253\u539f\u544a\uff0c\u5bfc\u81f4\u539f\u544a\u591a\u5904\u53d7\u4f24\u3002\u56e0\u8003\u8651\u5b69\u5b50\u5e74\u5e7c\uff0c\u9700\u8981\u5b8c\u6574\u7684\u5bb6\u5ead\uff0c\u539f\u544a\u4e0e\u88ab\u544a\u76f8\u5904\u8fc7\u7a0b\u4e2d\u5904\u5904\u5c0f\u5fc3\u3002\u88ab\u544a\u4e0d\u987e\u53ca\u591a\u5e74\u592b\u59bb\u60c5\u5206\uff0c\u5f53\u7740\u5b69\u5b50\u7684\u9762\u4e5f\u4f1a\u65e0\u6545\u6bb4\u6253\u539f\u544a\uff0c\u540c\u65f6\u5bf9\u539f\u544a\u8fdb\u884c\u8a00\u8bed\u4fae\u8fb1\uff0c\u539f\u544a\u65e0\u6cd5\u5fcd\u53d7\u88ab\u544a\u7684\u6b3a\u51cc\uff0c\u4fbf\u5f00\u59cb\u4e0e\u88ab\u544a\u5206\u5c45\u3002\u88ab\u544a\u5728\u539f\u544a\u5916\u51fa\u52a1\u5de5\u671f\u95f4\uff0c\u5c06\u539f\u544a\u8863\u7269\u4e1f\u51fa\u5bb6\u95e8\uff0c\u5e76\u6000\u7591\u539f\u544a\u4e0e\u5176\u4ed6\u5f02\u6027\u5b58\u5728\u4e0d\u6b63\u5f53\u5173\u7cfb\u3002\u539f\u544a\u52a1\u5de5\u56de\u6765\u5728\u5a18\u5bb6\u751f\u6d3b\uff0c\u88ab\u544a\u77e5\u6653\u540e\uff0c\u4fbf\u5c06\u539f\u544a\u4ece\u5a18\u5bb6\u62d6\u56de\u81ea\u5bb6\u4e2d\uff0c\u9650\u5236\u539f\u544a\u7684\u4eba\u8eab\u81ea\u7531\uff0c\u5e76\u5a01\u80c1\u539f\u544a\u8981\u5c06\u539f\u544a\u6740\u6389\uff0c\u62ff\u51fa\u5200\u5177\u5728\u539f\u544a\u9762\u524d\u6643\u52a8\uff0c\u8fd8\u626c\u8a00\u8981\u5c06\u539f\u544a\u7236\u6bcd\u6740\u6389\u3002\u56e0\u6050\u60e7\u88ab\u544a\uff0c\u539f\u544a\u9042\u62a5\u8b66\u5904\u7406\u3002\u88ab\u544a\u7684\u884c\u4e3a\uff0c\u5bfc\u81f4\u539f\u544a\u4e0e\u88ab\u544a\u611f\u60c5\u4e0d\u548c\uff0c\u5bb6\u5ead\u7834\u88c2\uff0c\u7ed9\u539f\u544a\u7cbe\u795e\u53ca\u5fc3\u7406\u9020\u6210\u4e86\u5f71\u54cd\uff0c\u539f\u544a\u4e0e\u88ab\u544a\u63d0\u51fa\u79bb\u5a5a\uff0c\u53cd\u906d\u88ab\u544a\u7684\u5a01\u80c1\uff0c\u73b0\u539f\u544a\u4e0e\u88ab\u544a\u611f\u60c5\u5df2\u7834\u88c2\uff0c\u592b\u59bb\u5173\u7cfb\u540d\u5b58\u5b9e\u4ea1\uff0c\u5df2\u65e0\u548c\u597d\u53ef\u80fd\u3002\", \"defendant_defence\": \"\u539f\u544a\u51fa\u8f68\uff0c\u60f3\u5148\u8d77\u8bc9\u539f\u544a\u91cd\u5a5a\uff0c\u5f85\u91cd\u5a5a\u95ee\u9898\u6709\u7ed3\u679c\u540e\u518d\u51b3\u5b9a\u662f\u5426\u79bb\u5a5a\u3002\u5982\u679c\u79bb\u5a5a\uff0c\u88ab\u544a\u53ea\u629a\u517b\u9c8d\u67d0\u7965\uff0c\u5176\u4ed6\u4e24\u4e2a\u5b69\u5b50\u8ba9\u539f\u544a\u629a\u517b\u4e00\u4e2a\uff0c\u53e6\u4e00\u4e2a\u5b69\u5b50\u65e0\u8bba\u8c01\u629a\u517b\uff0c\u5bf9\u65b9\u90fd\u9700\u8981\u652f\u4ed8\u629a\u517b\u8d39\u3002\", \"evidence\": {\"plaintiff_evidence\": {\"evidence_1\": {\"evidence\": \"\u62a5\u8b66\u8054\u3001\u7167\u7247\uff08\u590d\u5370\u4ef6\uff09\u5171\u8ba14\u9875\", \"dispute\": \"\u88ab\u544a\u5bf9\u8bc1\u636e\u771f\u5b9e\u6027\u65e0\u5f02\u8bae\uff0c\u4f46\u79f0\u62a5\u8b66\u5f53\u5929\u672a\u52a8\u624b\uff0c\u7167\u7247\u4e0a\u7684\u4f24\u5e76\u975e\u88ab\u544a\u9020\u6210\u3002\"}, \"evidence_2\": {\"evidence\": \"\u5149\u76d8\u5171\u8ba11\u9875\", \"dispute\": \"\u88ab\u544a\u5bf9\u89c6\u98911\u4e2d\u4e22\