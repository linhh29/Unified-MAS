        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u7269\u6743\u7ea0\u7eb7\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u5218\u67d0\u751f\", \"address\": \"\u6cb3\u5317\u7701\u5510\u5c71\u5e02\u9ad8\u65b0\u6280\u672f\u4ea7\u4e1a\u5f00\u53d1\u533a\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1968\u5e741\u670814\u65e5\"}, \"defendant\": {\"name\": \"\u6cb3\u5317\u7701\u5510\u5c71\u5e02\u9ad8\u65b0\u6280\u672f\u4ea7\u4e1a\u5f00\u53d1\u533a\u4e09\u5973\u6cb3\u529e\u4e8b\u5904\u9ad8\u5e84\u5b50\u6751\u6c11\u59d4\u5458\u4f1a\", \"address\": \"\u6cb3\u5317\u7701\u5510\u5c71\u5e02\u9ad8\u65b0\u6280\u672f\u4ea7\u4e1a\u5f00\u53d1\u533a\", \"representative\": \"\u97e9\u67d0\u4e49\", \"gender\": null, \"ethnicity\": null, \"birth_date\": null}}, \"plaintiff_claim\": [\"\u5224\u51b3\u88ab\u544a\u7ed9\u4ed8\u539f\u544a\u9752\u82d7\u8865\u507f\u6b3e\u5171\u8ba147600\u5143\", \"\u672c\u6848\u8bc9\u8bbc\u8d39\u7528\u7531\u88ab\u544a\u627f\u62c5\"], \"plaintiff_case_details\": \"\u539f\u544a\u4e8e1999\u5e741\u67081\u65e5\u5f00\u59cb\uff0c\u5f00\u59cb\u8015\u79cd\u4f4d\u4e8e\u9ad8\u5e84\u5b50\u6751\u5f20\u706b\u575f\u571f\u5730\u5171\u8ba11.36\u4ea9\uff0c2018\u5e74\u539f\u544a\u8015\u79cd\u7684\u4e0a\u8ff0\u571f\u5730\u88ab\u5f81\u7528\u3002\u6839\u636e\u76f8\u5173\u653f\u7b56\uff0c\u88ab\u5f81\