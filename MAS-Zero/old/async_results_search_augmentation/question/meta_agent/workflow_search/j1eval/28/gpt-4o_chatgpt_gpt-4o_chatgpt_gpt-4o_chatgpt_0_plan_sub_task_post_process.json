        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u7269\u6743\u7ea0\u7eb7\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u674e\u67d0\", \"address\": \"\u5317\u4eac\u5e02\u5927\u5174\u533a\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"19xx\u5e74xx\u6708xx\u65e5\"}, \"defendant\": {\"name\": \"\u674e\u67d01\", \"address\": \"\u5317\u4eac\u5e02\u5927\u5174\u533a\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"19xx\u5e74xx\u6708xx\u65e5\"}}, \"plaintiff_claim\": [\"\u5224\u4ee4\u88ab\u544a\u8fd4\u8fd8\u4fb5\u5360\u8d22\u4ea7\u4eba\u6c11\u5e0143455\u5143\", \"\u8bc9\u8bbc\u8d39\u7528\u7531\u88ab\u544a\u627f\u62c5\"], \"plaintiff_case_details\": \"\u539f\u544a\u7684\u7231\u4eba\u5218\u67d0\u4e8e2016\u5e741\u67085\u65e5\u53bb\u4e16\uff0c2022\u5e742\u670814\u65e5\u56fd\u5bb6\u8865\u53d1\u4e86\u4e27\u629a\u8d3943455\u5143\uff0c\u6253\u5728\u6211\u7684\u5361\u91cc\uff0c\u56e0\u4e3a\u7231\u4eba\u53bb\u4e16\u540e\u6211\u7684\u5efa\u884c\u5361\u5728\u88ab\u544a\u624b\u91cc\uff0c\u6ca1\u6709\u544a\u77e5\u7684\u60c5\u51b5\u4e0b\u88ab\u544a\u4e8e2022\u5e742\u670815\u65e5\u81f317\u65e5\u5168\u90e8\u53d6\u8d70\uff0c\u81f3\u4eca\u4e0d\u8fd8\u9738\u4e3a\u5df1\u6709\u3002\u8981\u6c42\u88ab\u544a\u8fd4\u8fd8\u539f\u544a\u4ee5\u4e0a\u94b1\u6b3e\u