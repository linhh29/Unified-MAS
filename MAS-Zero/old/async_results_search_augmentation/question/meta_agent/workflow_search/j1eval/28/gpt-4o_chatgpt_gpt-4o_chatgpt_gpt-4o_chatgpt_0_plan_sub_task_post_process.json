    {
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u7269\u6743\u7ea0\u7eb7\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u674e\u67d0\", \"address\": \"\u5317\u4eac\u5e02\u5927\u5174\u533a\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"19xx\u5e74xx\u6708xx\u65e5\"}, \"defendant\": {\"name\": \"\u674e\u67d01\", \"address\": \"\u5317\u4eac\u5e02\u5927\u5174\u533a\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"19xx\u5e74xx\u6708xx\u65e5\"}}, \"plaintiff_claim\": [\"\u5224\u4ee4\u88ab\u544a\u8fd4\u8fd8\u4fb5\u5360\u8d22\u4ea7\u4eba\u6c11\u5e0143455\u5143\", \"\u8bc9\u8bbc\u8d39\u7528\u7531\u88ab\u544a\u627f\u62c5\"], \"plaintiff_case_details\": \"\u539f\u544a\u7684\u7231\u4eba\u5218\u67d0\u4e8e2016\u5e741\u67085\u65e5\u53bb\u4e16\uff0c2022\u5e742\u670814\u65e5\u56fd\u5bb6\u8865\u53d1\u4e86\u4e27\u629a\u8d3943455\u5143\uff0c\u6253\u5728\u6211\u7684\u5361\u91cc\uff0c\u56e0\u4e3a\u7231\u4eba\u53bb\u4e16\u540e\u6211\u7684\u5efa\u884c\u5361\u5728\u88ab\u544a\u624b\u91cc\uff0c\u6ca1\u6709\u544a\u77e5\u7684\u60c5\u51b5\u4e0b\u88ab\u544a\u4e8e2022\u5e742\u670815\u65e5\u81f317\u65e5\u5168\u90e8\u53d6\u8d70\uff0c\u81f3\u4eca\u4e0d\u8fd8\u9738\u4e3a\u5df1\u6709\u3002\u8981\u6c42\u88ab\u544a\u8fd4\u8fd8\u539f\u544a\u4ee5\u4e0a\u94b1\u6b3e\uff0c\u6709\u94f6\u884c\u6d41\u6c34\u6750\u6599\u4e3a\u8bc1\uff0c\u4ee5\u4e0a\u6240\u8bc9\u4e3a\u4e8b\u5b9e\u3002\u674e\u67d01\u8ba4\u53ef\u8be5\u7b1443455\u5143\u662f\u81ea\u5df1\u4ece\u674e\u67d0\u94f6\u884c\u5361\u4e2d\u652f\u53d6\u7684\uff0c\u6709\u5173\u652f\u53d6\u539f\u56e0\uff0c\u674e\u67d01\u89e3\u91ca\u79f0\uff1a\u6211\u56e0\u4e3a\u8981\u4e70\u8f66\uff0c\u7ba1\u6211\u6bcd\u4eb2\u501f\u4e865\u4e07\u5143\uff0c\u6211\u7236\u4eb2\u8bf4\u7ed9\u4ed6\u4e2a\u8d26\u53f7\uff0c\u5c06\u94b1\u76f4\u63a5\u8f6c\u8d26\u7ed9\u6211\uff0c\u6211\u5c31\u5c06\u6211\u5973\u513f\u7684\u8d26\u53f7\u7ed9\u4e86\u6211\u7236\u4eb2\uff1b2012\u5e74\u5e74\u5e95\uff0c\u6211\u6bcd\u4eb2\u548c\u7236\u4eb2\u50ac\u6211\u8fd8\u94b1\uff0c\u6211\u8bf4\u6625\u8282\u524d\u5c31\u8fd8\u7ed9\u4ed6\u4eec\uff0c\u4e4b\u540e\u6211\u5c065\u4e07\u5143\u73b0\u91d1\u7ed9\u4e86\u6211\u7236\u4eb2\u6bcd\u4eb2\uff1b2022\u5e74\u6211\u6bcd\u4eb2\u53bb\u4e16\u540e\u6211\u53d1\u73b0\u6bcd\u4eb2\u4e27\u6276\u8d39\u5927\u7ea6\u67095\u4e07\u5143\uff0c\u6211\u542c\u8bf4\u4ee5\u9632\u8001\u4eba\u53bb\u4e16\u65e0\u6cd5\u53d6\u51fa\uff0c\u6240\u4ee5\u6211\u5c31\u53d6\u8d70\u4e86\u3002\u5728\uff082023\uff09\u4eac0115\u6c11\u521d16863\u53f7\u6848\u4ef6\u8d77\u8bc9\u7684\u65f6\u5019\uff0c\u6211\u624d\u77e5\u90535\u4e07\u5143\u5b9e\u9645\u4e0a\u662f\u4ece\u674e\u67d02\u5904\u8f6c\u8d26\u7ed9\u6211\u5973\u513f\u7684\u30022024\u5e74\uff0c\u674e\u67d02\u5c06\u6211\u5973\u513f\u5835\u5728\u5979\u516c\u53f8\uff08\u8981\u94b1\uff09\uff0c\u6211\u5973\u513f\u4e3a\u4e86\u606f\u4e8b\u5b81\u4eba\uff0c\u5c31\u7ed9\u4e86\u674e\u67d025\u4e07\u5143\uff0c\u4f46\u662f\u8fd9\u4e2a\u94b1\u6211\u4e4b\u524d\u5df2\u7ecf\u8fd8\uff08\u7ed9\u6211\u7236\u6bcd\uff09\u8fc7\u4e86\uff0c\u6211\u89c9\u5f97\u4e0d\u516c\u5e73\uff0c\u6211\u8ba4\u4e3a\u674e\u67d02\u5c5e\u4e8e\u6572\u8bc8\u3002\", \"defendant_defence\": \"\u4e0d\u540c\u610f\u539f\u544a\u7684\u8bc9\u8bbc\u8bf7\u6c42\u3002\u539f\u6765\u6709\u4e2a\u5224\u51b3\u4e66\uff0c\u539f\u544a\u8981\u6c42\u6211