        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u8d22\u4ea7\u635f\u5bb3\u8d54\u507f\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u6768\u67d0\", \"address\": \"\u5929\u6d25\u5e02\u6cb3\u4e1c\u533a\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1983\u5e747\u670813\u65e5\"}, \"defendant\": {\"name\": \"\u5143\u67d0\u67d0\u7269\u8d44\u56de\u6536\uff08\u5929\u6d25\uff09\u6709\u9650\u516c\u53f8\", \"address\": \"\u5929\u6d25\u5e02\u6cb3\u5317\u533a\", \"representative\": \"\u6bb7\u67d0\u4f1f\", \"gender\": null, \"ethnicity\": null, \"birth_date\": null}}, \"plaintiff_claim\": [\"\u5224\u4ee4\u88ab\u544a\u8d54\u507f\u539f\u544a\u56e0\u706b\u707e\u5bfc\u81f4\u7684\u635f\u593186287.08\u5143\", \"\u672c\u6848\u8bc9\u8bbc\u8d39\u7531\u88ab\u544a\u627f\u62c5\"], \"plaintiff_case_details\": \"2024\u5e746\u670812\u65e5\u539f\u544a\u4e0e\u201c\u946b\u9686\u516c\u5bd3\u201d\u7b7e\u8ba2\u623f\u5c4b\u79df\u8d41\u5408\u540c,\u79df\u4f4f\u4f4d\u4e8e\u5929\u6d25\u5e02\u6cb3\u5317\u533a\u00d7\u00d7\u8def\u00d7\u00d7\u53f7\u00d7\u00d7\u53f7\u697c\u00d7\u00d7\u623f\u00d7\u00d7,\u79df\u91d1\u4e3a1200\u5143,\u79df\u671f\u4e3a1\u4e2a\u6708,\u81f32024\u5e747\u670811\u65e5\u6b62\u3002\u7b7e\u8ba2\u5408\u540c\u5f53\u65e5,\u539f\u544a\u5df2\u5411\u51fa\u79df\u65b9\u7f34\u7eb3\u4e86\u62bc\u91d1\u53ca\u79df\u91d1\u30022024\u5e746\u670820\u65e5,\u4e0e\u539f\u544a\u4f4d\u4e8e\u540c\u4e00\u680b\u697c\u5e95\u5546\u7684\u88ab\u544a\u7ad9\u5185\u53d1\u751f\u706b\u707e,\u56e0\u4e8b\u53d1\u7a81\u7136\u4e14\u706b\u52bf\u51f6\u731b,\u88ab\u544a\u6240\u5728\u697c\u5185\u5c45\u6c11\u7eb7\u7eb7\u51fa\u95e8\u9003\u751f,\u539f\u544a\u623f\u5c4b\u5185\u8bbe\u6709\u4e00\u5916\u8de8\u697c\u68af\u76f4\u901a\u5730\u9762,\u5728\u697c\u95e8\u53ca\u697c\u68af\u88ab\u5927\u706b\u5c01\u5835\u7684\u60c5\u51b5\u4e0b,\u662f\u552f\u4e00\u9003\u751f\u901a\u9053,\u539f\u544a\u4e3a\u4e86\u5e7f\u5927\u5c45\u6c11\u7684\u751f\u547d\u5b89\u5168\u7740\u60f3\u5f00\u653e\u5916\u8de8\u697c\u68af,\u56e0\u6b64\u65e0\u6cd5\u9501\u95e8,\u6839\u636e\u623f\u4e1c\u53ca\u5c45\u59d4\u4f1a\u5b89\u6392,\u697c\u5185\u5c45\u6c11\u5f53\u665a\u88ab\u96c6\u4e2d\u5b89\u7f6e\u5728\u67d0\u67d0\u9152\u5e97\u4f4f\u5bbf\u30022024\u5e746\u670821\u65e5\u51cc\u6668,\u6d88\u9632\u4eba\u5458\u6251\u706d\u5927\u706b\u540e,\u5c45\u6c11\u63a5\u5230\u901a\u77e5\u9646\u7eed\u8fd4\u56de\u4f4f\u6240\u5730\u3002\u5f85\u539f\u544a\u56de\u5230\u79df\u4f4f\u623f\u540e,\u53d1\u73b0\u5ba4\u5185\u4f17\u591a\u7269\u54c1\u6bc1\u635f\u53ca\u88ab\u76d7,\u5176\u4e2d\u5305\u62ec\u91d1\u9970\u54c1\u3001\u82f9\u679c\u624b\u673a\u3001\u624b\u8868\u3001\u9ad8\u6863\u5316\u5986\u54c1\u3001\u62a4\u80a4\u54c1\u7b49,\u635f\u5931\u5171\u8ba186287.08\u5143\uff08\u7269\u54c1\u635f\u5931\u660e\u7ec6\u8be6\u89c1\u540e\u9644\u6e05\u5355\uff09\u3002\u6839\u636e\u6cb3\u5317\u533a\u6d88\u9632\u6551\u63f4\u652f\u961f\u51fa\u5177\u7684\u300a\u706b\u707e\u4e8b\u6545\u8ba4\u5b9a\u4e66\u300b\u8868\u660e,\u8d77\u706b\u90e8\u4f4d\u4e3a\u6cb3\u5317\u533a\u671b\u6d77\u697c\u8857\u4e2d\u5c71\u8def163\u53f7\u60a6\u946b\u516c\u5bd3\u65c1\u4e00\u697c\u5357\u4fa7\u5e9f\u54c1\u56de\u6536\u7ad9\u5185\u7684\u4e1c\u4fa7\u533a\u57df,\u5373\u88ab\u544a\u6240\u5728\u5730,\u8d77\u706b\u539f\u56e0\u4e3a\u4e00\u697c\u5357\u4fa7\u5e9f\u54c1\u56de\u6536\u7ad9\u5185\u7684\u7535\u6c14\u7ebf\u8def\