        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u8d22\u4ea7\u635f\u5bb3\u8d54\u507f\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u5f20\u67d0\", \"address\": \"\u65b0\u7586\u7ef4\u543e\u5c14\u81ea\u6cbb\u533a\u4f0a\u7281\u54c8\u8428\u514b\u81ea\u6cbb\u5dde\u4f0a\u5b81\u5e02\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1995\u5e744\u67086\u65e5\"}, \"defendant\": {\"name\": \"\u4f0a\u7281\u67d0\u67d0\u6709\u9650\u516c\u53f8\", \"address\": \"\u65b0\u7586\u7ef4\u543e\u5c14\u81ea\u6cbb\u533a\u4f0a\u7281\u54c8\u8428\u514b\u81ea\u6cbb\u5dde\u4f0a\u5b81\u5e02\", \"representative\": \"\u68a6\u67d0\", \"gender\": null, \"ethnicity\": null, \"birth_date\": null}}, \"plaintiff_claim\": [\"\u4f9d\u6cd5\u5224\u4ee4\u88ab\u544a\u8d54\u507f\u539f\u544a\u8f66\u8f86\u7ef4\u4fee\u7ecf\u6d4e\u635f\u59314,000\u5143\", \"\u672c\u6848\u5168\u90e8\u8bc9\u8bbc\u8d39\u7528\u7531\u88ab\u544a\u627f\u62c5\"], \"plaintiff_case_details\": \"\u539f\u544a\u662f\u88ab\u544a\u6240\u63d0\u4f9b\u7269\u4e1a\u670d\u52a1\u7684\u4f0a\u5b81\u00d7\u00d7\u5c0f\u533a\u5bf9\u7684\u4e1a\u4e3b\uff0c2024\u5e748\u670811\u65e5\u4e0b\u53488\u70b9\u523012\u65e5\u65e9\u4e0a10\u70b9\uff0c\u539f\u544a\u5c06\u8f66\u505c\u5728\u8be5\u5c0f\u533a\u505c\u8f66\u573a\uff0c\u5728\u8f66\u8f86\u505c\u653e\u671f\u95f4\uff0c\u539f\u544a\u76