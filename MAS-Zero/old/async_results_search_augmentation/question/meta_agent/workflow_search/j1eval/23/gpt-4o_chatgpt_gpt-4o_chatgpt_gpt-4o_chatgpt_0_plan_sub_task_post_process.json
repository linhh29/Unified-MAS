    {
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u8d22\u4ea7\u635f\u5bb3\u8d54\u507f\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u5f20\u67d0\", \"address\": \"\u65b0\u7586\u7ef4\u543e\u5c14\u81ea\u6cbb\u533a\u4f0a\u7281\u54c8\u8428\u514b\u81ea\u6cbb\u5dde\u4f0a\u5b81\u5e02\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1995\u5e744\u67086\u65e5\"}, \"defendant\": {\"name\": \"\u4f0a\u7281\u67d0\u67d0\u6709\u9650\u516c\u53f8\", \"address\": \"\u65b0\u7586\u7ef4\u543e\u5c14\u81ea\u6cbb\u533a\u4f0a\u7281\u54c8\u8428\u514b\u81ea\u6cbb\u5dde\u4f0a\u5b81\u5e02\", \"representative\": \"\u68a6\u67d0\", \"gender\": null, \"ethnicity\": null, \"birth_date\": null}}, \"plaintiff_claim\": [\"\u4f9d\u6cd5\u5224\u4ee4\u88ab\u544a\u8d54\u507f\u539f\u544a\u8f66\u8f86\u7ef4\u4fee\u7ecf\u6d4e\u635f\u59314,000\u5143\", \"\u672c\u6848\u5168\u90e8\u8bc9\u8bbc\u8d39\u7528\u7531\u88ab\u544a\u627f\u62c5\"], \"plaintiff_case_details\": \"\u539f\u544a\u662f\u88ab\u544a\u6240\u63d0\u4f9b\u7269\u4e1a\u670d\u52a1\u7684\u4f0a\u5b81\u00d7\u00d7\u5c0f\u533a\u5bf9\u7684\u4e1a\u4e3b\uff0c2024\u5e748\u670811\u65e5\u4e0b\u53488\u70b9\u523012\u65e5\u65e9\u4e0a10\u70b9\uff0c\u539f\u544a\u5c06\u8f66\u505c\u5728\u8be5\u5c0f\u533a\u505c\u8f66\u573a\uff0c\u5728\u8f66\u8f86\u505c\u653e\u671f\u95f4\uff0c\u539f\u544a\u7684\u8f66\u8f86\u8f66\u8eab\u56db\u9762\u88ab\u4eba\u4e3a\u5212\u4f24\uff0c\u800c\u539f\u544a\u505c\u653e\u8f66\u8f86\u5904\u7684\u76d1\u63a7\u56e0\u88ab\u544a\u539f\u56e0\u6ca1\u6709\u5f55\u4e0b\u5212\u4f24\u539f\u544a\u8f66\u8f86\u7684\u4eba\u5458\uff0c\u9020\u6210\u539f\u544a4,000\u5143\u7ecf\u6d4e\u635f\u5931\uff0c\u6839\u636e\u300a\u7269\u4e1a\u7ba1\u7406\u6761\u4f8b\u300b\u7b2c\u4e09\u5341\u4e94\u6761\u4e4b\u89c4\u5b9a\uff0c\u88ab\u544a\u6ca1\u6709\u5c65\u884c\u7269\u4e1a\u670d\u52a1\u7684\u804c\u8d23\uff0c\u672a\u5c3d\u5230\u5b89\u5168\u4fdd\u969c\u4e49\u52a1\uff0c\u5bfc\u81f4\u4e1a\u4e3b\u8d22\u4ea7\u5b89\u5168\u53d7\u5230\u635f\u5bb3\u5bf9\u7684\uff0c\u5e94\u5f53\u4f9d\u6cd5\u627f\u62c5\u7ba1\u7406\u4e0d\u5f53\u7684\u6cd5\u5f8b\u8d23\u4efb\u3002\u539f\u544a\u591a\u6b21\u627e\u5230\u88ab\u544a\u534f\u5546\u89e3\u51b3\u95ee\u9898\uff0c\u88ab\u544a\u4e0d\u4e88\u7406\u4f1a\uff0c\u4e3a\u4e86\u7ef4\u62a4\u81ea\u8eab\u5408\u6cd5\u6743\u76ca\uff0c\u73b0\u8bc9\u81f3\u8d35\u9662\uff0c\u671b\u5224\u5982\u6240\u8bf7\u3002\", \"defendant_defence\": \"1\u3001\u539f\u544a\u8d77\u8bc9\u72b6\u4e8b\u5b9e\u4e0e\u7406\u7531\u81ea\u8ba4\u5176\u8f66\u8f86\u662f\u88ab\u4ed6\u4eba\u5212\u4f24\uff0c\u4e0d\u80fd\u8bc1\u660e\u662f\u7269\u4e1a\u9020\u6210\u7684\uff0c\u65e0\u6cd5\u8bc1\u660e\u88ab\u544a\u5e94\u5f53\u627f\u62c5\u652f\u4ed8\u7ef4\u4fee\u635f\u5931\u7684\u56e0\u679c\u5173\u7cfb\u30022\u3001\u6839\u636e\u300a\u7269\u4e1a\u7ba1\u7406\u6761\u4f8b\u300b\u7b2c\u4e8c\u6761\uff0c\u672c\u6761\u4f8b\u6240\u79f0\u7269\u4e1a\u7ba1\u7406\uff0c\u662f\u6307\u4e1a\u4e3b\u901a\u8fc7\u9009\u8058\u7269\u4e1a\u670d\u52a1\u4f01\u4e1a\uff0c\u6709\u4e1a\u4e3b\u548c\u7269\u4e1a\u670d\u52a1\u4f01\u4e1a\u6309\u7167\u7269\u4e1a\u670d\u52a1\u5408\u540c\u7ea6\u5b9a\uff0c\u5bf9\u623f\u5c4b\u53ca\u914d\u5957\u7684\u8bbe\u65bd\u8bbe\u5907\u548c\u76f8\u5173\u573a\u5730\u8fdb\u884c\u7ef4\u4fee\u3001\u517b\u62a4\u3001\u7ba1\u7406\uff0c\u7ef4\u62a4\u7269\u4e1a\u7ba1\u7406\u533a\u57df\u5185\u7684\u73af\u5883