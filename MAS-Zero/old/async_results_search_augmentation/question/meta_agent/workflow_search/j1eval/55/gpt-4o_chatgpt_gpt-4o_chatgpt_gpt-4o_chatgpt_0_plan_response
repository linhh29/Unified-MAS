        ],
        "n": 4,
        "response": "\u5728\u5206\u6790\u6848\u4ef6\u7684\u5177\u4f53\u60c5\u51b5\u548c\u53cc\u65b9\u63d0\u4f9b\u7684\u8bc1\u636e\u540e\uff0c\u539f\u544a\u672a\u80fd\u63d0\u4f9b\u6709\u529b\u8bc1\u636e\u652f\u6301\u5176\u5173\u4e8e\u8f66\u8f86\u4e3a\u9644\u6761\u4ef6\u8d60\u4e0e\u7684\u4e3b\u5f20\u3002\u88ab\u544a\u63d0\u4f9b\u7684\u901a\u8bdd\u5f55\u97f3\u548c\u534f\u8bae\u663e\u793a\u53cc\u65b9\u5df2\u5c31\u8f66\u8f86\u5f52\u5c5e\u548c\u7ecf\u6d4e\u8865\u507f\u8fbe\u6210\u4e00\u81f4\uff0c\u534f\u8bae\u5185\u5bb9\u660e\u786e\u4e14\u53cc\u65b9\u5747\u8868\u793a\u540c\u610f\u3002\u867d\u7136\u672a\u80fd\u83b7\u5f97\u652f\u4ed8\u8bb0\u5f55\u9a8c\u8bc1\u534f\u8bae\u6267\u884c\u60c5\u51b5\uff0c\u4f46\u6839\u636e\u73b0\u6709\u8bc1\u636e\uff0c\u534f\u8bae\u5e94\u88ab\u89c6\u4e3a\u6709\u6548\u3002\u7136\u800c\uff0c\u7531\u4e8e\u7f3a\u4e4f\u652f\u4ed8\u8bb0\u5f55\uff0c\u65e0\u6cd5\u9a8c\u8bc1\u534f\u8bae\u6267\u884c\u7684\u5177\u4f53\u60c5\u51b5\uff0c\u56e0\u6b64\u65e0\u6cd5\u5bf9\u534f\u8bae\u6267\u884c\u7684\u516c\u5e73\u6027\u8fdb\u884c\u8bc4\u4f30\u3002\n\nAnswer:\u8bf7\u6c42\u539f\u544a\u548c\u88ab\u544a\u63d0\u4f9b\u652f\u4ed8\u8bb0\u5f55\uff0c\u4ee5\u9a8c\u8bc1\u534f\u8bae\u7684\u6267\u884c\u60c5\u51b5\uff0c\u5e76\u8fdb\u4e00\u6b65\u8bc4\u4f30\u534f\u8bae\u6267\u884c\u7684\u516c\u5e73\u6027\u3002\n[TOO_HARD]\n\u8bf7\u6c42\u539f\u544a\u548c\u88ab\u544a\u63d0\u4f9b\u652f\u4ed8\u8bb0\u5f55\uff0c\u4ee5\u9a8c\u8bc1\u534f\u8bae\u7684\u6267\u884c\u60c5\u51b5\uff0c\u5e76\u8fdb\u4e00\u6b65\u8bc4\u4f30\u534f\u8bae\u6267\u884c\u7684\u516c\u5e73\u6027\u3002",
