        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u5a5a\u59fb\u5bb6\u5ead\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u4ee3\u67d0\u4eae\", \"address\": \"\u6cb3\u5317\u7701\u4e09\u6cb3\u5e02\u71d5\u90ca\u5f00\u53d1\u533a\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1984\u5e744\u67087\u65e5\"}, \"defendant\": {\"name\": \"\u6768\u67d0\", \"address\": \"\u6e56\u5317\u7701\u54b8\u4e30\u53bf\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u571f\u5bb6\u65cf\", \"birth_date\": \"1993\u5e743\u67084\u65e5\"}}, \"plaintiff_claim\": [\"\u5224\u4ee4\u88ab\u544a\u7ed9\u4ed8\u539f\u544a\u8f66\u8f86\u6298\u4ef7\u6b3e25\u4e07\u5143\", \"\u8bc9\u8bbc\u8d39\u7528\u7531\u88ab\u544a\u627f\u62c5\"], \"plaintiff_case_details\": \"2022\u5e74\u539f\u88ab\u544a\u901a\u8fc7\u5728\u4e1c\u65b9\u9b45\u529b\uff2b\uff34\uff36\u76f8\u8bc6\uff0c\u5f53\u65f6\u539f\u544a\u548c\u670b\u53cb\u53bb\u5531\u6b4c\uff0c\u88ab\u544a\u5728\uff2b\uff34\uff36\u4f5c\u6709\u507f\u966a\u4f8d\uff0c\u76f8\u8bc6\u540e\u53d1\u5c55\u6210\u604b\u4eba\uff0c\u5728\u53d1\u5c55\u6210\u604b\u4eba\u540e\u88ab\u544a\u5c31\u4e0d\u5728\u505a\u4e4b\u524d\u7684\u5de5\u4f5c\u4e86\u3002\u540e\u539f\u544a\u5728\u5317\u4eac4\uff33\u5e97\u4e70\u4e86\u4e00\u8f86\u5b9d\u9a6c320\uff2c\uff0c\u5168\u989d\u652f\u4ed8\u540e\u8f6