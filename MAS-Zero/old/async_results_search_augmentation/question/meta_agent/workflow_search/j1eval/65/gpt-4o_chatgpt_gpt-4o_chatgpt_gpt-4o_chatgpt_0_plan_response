        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u7269\u6743\u7ea0\u7eb7\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u6731\u5de7\u971e\", \"address\": \"\u9655\u897f\u7701\u6986\u6797\u5e02\u6986\u9633\u533a\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1989\u5e749\u67086\u65e5\"}, \"defendant\": {\"name\": \"\u9655\u897f\u7701\u6986\u6797\u5e02\u795e\u6728\u5e02\u5927\u4fdd\u5f53\u9547\u77f3\u62c9\u754c\u6751\u6751\u6c11\u59d4\u5458\u4f1a\", \"address\": \"\u9655\u897f\u7701\u6986\u6797\u5e02\u795e\u6728\u5e02\u5927\u4fdd\u5f53\u9547\u77f3\u62c9\u754c\u6751\", \"representative\": \"\u738b\u519b\", \"gender\": null, \"ethnicity\": null, \"birth_date\": null}}, \"plaintiff_claim\": [\"\u4f9d\u6cd5\u5224\u4ee4\u539f\u544a\u5177\u6709\u88ab\u544a\u6751\u5c0f\u7ec4\u96c6\u4f53\u7ecf\u6d4e\u7ec4\u7ec7\u6210\u5458\u8d44\u683c\u5e76\u4eab\u6709\u4e0e\u88ab\u544a\u6751\u5c0f\u7ec4\u5176\u4ed6\u6751\u6c11\u540c\u7b49\u7684\u96c6\u4f53\u6536\u76ca\u5206\u914d\u6743\uff0c\u5e76\u7531\u88ab\u544a\u652f\u4ed8\u539f\u544a2023\u5e74\u96c6\u4f53\u7ecf\u6d4e\u6536\u76ca\u5206\u914d\u6b3e30000\u5143\", \"\u672c\u6848\u8bc9\u8bbc\u8d39\u7531\u88ab\u544a\u627f\u62c5\"], \"plaintiff_case_details\": \"\u539f\u544a\u7cfb\u4e8c\u7ea7\u80a2\u4f53\u6b8b\u75be\uff0c\u65e0\u52b3\u52a8\u80fd\u529b\uff0c