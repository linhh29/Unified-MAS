        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u8d22\u4ea7\u635f\u5bb3\u8d54\u507f\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u5510\u67d0\", \"address\": \"\u6c88\u9633\u5e02\u548c\u5e73\u533a\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"19xx\u5e74xx\u6708xx\u65e5\"}, \"defendant\": {\"name\": \"\u5d07\u67d0\u67d0\", \"address\": \"\u6c88\u9633\u5e02\u548c\u5e73\u533a\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"19xx\u5e74xx\u6708xx\u65e5\"}}, \"plaintiff_claim\": [\"\u5224\u4ee4\u88ab\u544a\u539f\u544a\u66f4\u6362\u7535\u8111\u5c4f\u5e55\u6216\u8d54\u507f\u7ef4\u4fee\u8d395,000\u5143\", \"\u8bc9\u8bbc\u8d39\u7528\u7531\u88ab\u544a\u627f\u62c5\"], \"plaintiff_case_details\": \"2024\u5e746\u670817\u65e517\u65f642\u520622\u79d2\uff0c\u88ab\u544a\u9a7e\u9a76\u8f66\u8f86\u5728\u6c88\u9633\u5e02\u548c\u5e73\u533a\u6d51\u5357\u897f\u8def\u81ea\u4e1c\u5411\u897f\u7531\u8f85\u8def\u5e76\u5165\u4e3b\u8def\u7684\u8fc7\u7a0b\u4e2d\uff0c\u8de8\u8d8a\u4e94\u8f66\u9053\u5f3a\u884c\u5e76\u5165\u56db\u8f66\u9053\uff0c\u9020\u6210\u6b63\u5e38\u884c\u4f7f\u7684\u539f\u544a\u8f66\u8f86\u7d27\u6025\u5236\u52a8\uff0c\u56e0\u539f\u544a\u5904\u7f6e\u5f97\u5f53\uff0c\u4e24\u8f66\u672a\u53d1\u751f\u78b0\u649e\uff0c\u4f46\u7d27\u6025\u523