        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u5408\u540c\u7ea0\u7eb7\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u5f20\u67d0\u67f1\", \"address\": \"\u5185\u8499\u53e4\u901a\u8fbd\u5e02\u79d1\u5c14\u6c81\u533a\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1972\u5e748\u67084\u65e5\"}, \"defendant\": {\"name\": \"\u8881\u67d0\u73b2\", \"address\": \"\u5c71\u4e1c\u7701\u8363\u6210\u5e02\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1968\u5e7411\u67081\u65e5\"}}, \"plaintiff_claim\": [\"\u8bf7\u6c42\u5224\u4ee4\u88ab\u544a\u652f\u4ed8\u539f\u544a\u8239\u5458\u5de5\u8d44\u6b3e66500\u5143\", \"\u8bf7\u6c42\u786e\u8ba4\u539f\u544a\u4e0a\u8ff0\u8239\u5458\u5de5\u8d44\u5bf9\u88ab\u544a\u8881\u67d0\u73b2\u6240\u6709\u7684\u201c\u9c81\u67d0\u6e145\uff0a\uff0a\uff0a\uff0a\u201d\u6e14\u8239\u4eab\u6709\u8239\u8236\u4f18\u5148\u6743\"], \"plaintiff_case_details\": \"2023\u5e749\u67081\u65e5,\u539f\u544a\u53d7\u88ab\u544a\u96c7\u4f63\u5728\u5176\u6240\u5c5e\u7684\u201c\u9c81\u67d0\u6e145\uff0a\uff0a\uff0a\uff0a\u201d\u6e14\u8239\u4ece\u4e8b\u8239\u5458\u5de5\u4f5c\uff0c\u53cc\u65b9\u7b7e\u8ba2\u5408\u540c\u7ea6\u5b9a\u81ea2023\u5e749\u67081\u65e5\u81f32024\u5e742\u67082\u65e5\u5de5\u8d44\u6570\u989d\u4e3a68000\u5143\u3002\u539f\