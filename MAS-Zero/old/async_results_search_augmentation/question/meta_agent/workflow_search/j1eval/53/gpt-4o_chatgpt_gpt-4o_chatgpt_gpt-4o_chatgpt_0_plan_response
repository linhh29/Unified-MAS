\u4e00\u76f4\u5728\u8239\u4e0a\u5c45\u4f4f\uff0c\u5e73\u65f6\u88ab\u544a\u9646\u7eed\u5b89\u6392\u4e00\u4e9b\u8239\u8236\u4fee\u7406\u5de5\u4f5c\uff0c\u539f\u544a\u4e00\u76f4\u5728\u8239\u4e0a\u5446\u52302024\u5e742\u67082\u65e5\uff08\u9634\u5386\u5317\u65b9\u5c0f\u5e74\uff09\u3002\u56e0\u4e3a\u539f\u544a\u77e5\u9053\u4e4b\u524d\u6709\u63d0\u524d\u4e0b\u8239\u7684\u8239\u5458\uff0c\u88ab\u544a\u90fd\u4ee5\u63d0\u524d\u4e0b\u8239\u4e3a\u7531\u4e0d\u4e88\u652f\u4ed8\u5de5\u8d44\uff0c\u6240\u4ee5\u539f\u544a\u5e72\u5230\u5408\u540c\u671f\u6ee1\u3002\u539f\u544a\u5728\u8239\u671f\u95f4\uff0c\u8239\u8236\u8fdb\u884c\u7ef4\u4fee\u4e0d\u5177\u5907\u51fa\u6d77\u6761\u4ef6\u3002\u7ef4\u4fee\u7ed3\u675f\u540e\uff0c\u88ab\u544a\u901a\u77e5\u539f\u544a\u5f85\u547d\uff0c\u5177\u4f53\u51fa\u6d77\u65f6\u95f4\u7b49\u5f85\u901a\u77e5\uff0c\u6240\u4ee5\u5e73\u65f6\u539f\u544a\u603b\u662f\u5c45\u4f4f\u5728\u8239\u4e0a\uff0c\u76f4\u5230\u5408\u540c\u671f\u6ee1\u3002\u56e0\u4e3a\u539f\u544a\u5728\u8239\u4e0a\uff0c\u88ab\u544a\u63d0\u4f9b\u4f4f\u5bbf\u548c\u5403\u996d\uff0c\u6240\u4ee5\u5e73\u65f6\u6708\u652f\u8f83\u5c11\uff0c\u53ea\u67091500\u5143\u3002\u5408\u540c\u5230\u671f\u540e\uff0c\u539f\u544a\u5728\u6625\u8282\u524d\u627e\u5230\u88ab\u544a\u7d22\u8981\u5de5\u8d44\uff0c\u5f53\u65f6\u4e5f\u6709\u5176\u4ed6\u8239\u5458\u5728\u573a\u3002\u539f\u544a\u8981\u6c42\u6309\u7167\u5408\u540c\u6807\u51c6\u652f\u4ed8\u5de5\u8d44\uff0c\u88ab\u544a\u548c\u6240\u6709\u8239\u5458\u534f\u5546\u5c0f\u4f19\u8ba1\u6309\u7167\u5e74\u5de5\u8d4440000\u5143\u8ba1\u7b97\uff0c\u539f\u544a\u8981\u6c42\u5f53\u5929\u4ed8\u6e05\uff0c\u4f46\u88ab\u544a\u6ca1\u6709\u80fd\u529b\uff0c\u6240\u4ee5\u534f\u5546\u4e0d\u6210\u3002\u88ab\u544a\u6240\u8ff0\u534f\u5546\u5de5\u8d44\u8fc7\u7a0b\u4e0d\u5c5e\u5b9e\uff0c\u4e5f\u672a\u5411\u539f\u544a\u51fa\u517738500\u5143\u7684\u6b20\u6761\u3002\"}, \"defendant\": {\"defendant_1\": \"\u88ab\u544a\u79f0\uff0c\u5f53\u65f6\u96c7\u4f63\u8239\u5458\u65f6\uff0c\u8239\u51c6\u5907\u51fa\u6d77\uff0c\u5c31\u662f\u4eca\u5929\u5e72\u4e00\u4e0a\u5348\uff0c\u660e\u5929\u5e72\u4e00\u4e0a\u5348\u3002\u540e\u671f\u8239\u4e0d\u51fa\u6d77\uff0c\u6ca1\u6709\u6d3b\u5e72\u5c31\u628a\u8239\u5458\u653e\u56de\u5bb6\u4e86\uff0c\u65f6\u95f4\u662f2024\u5e74\u6625\u8282\u524d\u3002\u6211\u5f53\u65f6\u544a\u8bc9\u539f\u544a\u7b49\u7740\u51fa\u6d77\uff0c\u4f46\u662f\u540e\u6765\u5feb\u5230\u5e74\u5e95\u65f6\uff0c\u6211\u544a\u8bc9\u539f\u544a\u8239\u51fa\u4e0d\u4e86\u6d77\u4e86\uff0c\u5c31\u628a\u4eba\u90fd\u653e\u4e86\u3002\u539f\u544a\u5e94\u8be5\u662f\u6709\u6bb5\u65f6\u95f4\u5728\u8239\u4e0a\u4f4f\uff0c\u540e\u671f\u6ca1\u6709\u6d3b\uff0c\u8239\u5458\u5c31\u90fd\u653e\u56de\u5bb6\u4e86\uff0c\u5c31\u6ca1\u4eba\u5728\u8239\u4e0a\u4f4f\u4e86\uff0c\u539f\u544a\u4e0d\u53ef\u80fd\u4e00\u76f4\u5728\u8239\u4e0a\u5446\u52302024\u5e742\u67082\u65e5\u3002\u534f\u5546\u5de5\u8d44\u65f6\uff0c\u56e0\u4e3a\u8239\u6ca1\u51fa\u6d77\uff0c\u6211\u5546\u91cf\u539f\u544a\u5c0f\u4f19\u8ba1\u7684\u5de5\u8d44\u662f40000\u5143\u3002\u5f53\u65f6\u597d\u51e0\u4e2a\u8239\u5458\u5728\u4e00\u8d77\uff0c\u6ca1\u6709\u8bf4\u5f53\u573a\u5c31\u7ed9\uff0c\u5546\u91cf\u597d\u4e86\u5c31\u662f\u6211\u7684\u94b1\u5230\u4e86\u5c31\u7acb\u9a6c\u7ed9\uff0c\u539f\u544a\u4e5f\u540c\u610f\u4e86\u3002\u56e0\u4e3a\u8239\u5458\u592a\u591a\uff0c\u6211\u5fd8\u8bb0\u4e86\u7ed9\u539f\u544a\u6253\u6b20\u6761\u7684\u5177\u4f53\u65f6\u95f4\u3002\"}}}\n",
        "correct_answer": [
            "\u88ab\u544a\u8881\u67d0\u73b2\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\u5411\u539f\u544a\u5f20\u67d0\u67f1\u652f\u4ed8\u8239\u5458\u5de5\u8d4466500\u5143",
