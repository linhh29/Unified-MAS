        "response": "\u5728\u5206\u6790\u4e86\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u3001\u8bc1\u636e\u4ee5\u53ca\u9002\u7528\u7684\u6cd5\u5f8b\u539f\u5219\u540e\uff0c\u7ed3\u5408\u5404\u4ee3\u7406\u4eba\u7684\u610f\u89c1\uff0c\u53ef\u4ee5\u5f97\u51fa\u4ee5\u4e0b\u7ed3\u8bba\uff1a\u539f\u544a\u5c39\u67d0\u67d0\u4f5c\u4e3a\u623f\u5c4b\u7684\u6309\u4efd\u5171\u6709\u4eba\uff0c\u4f9d\u6cd5\u4eab\u670930%\u7684\u623f\u5c4b\u4efd\u989d\uff0c\u5e76\u6709\u6743\u4e3b\u5f20\u76f8\u5e94\u7684\u51fa\u79df\u6536\u76ca\u3002\\n\u867d\u7136\u539f\u544a\u7684\u8bc1\u636e\u4e0d\u591f\u5b8c\u6574\uff0c\u7279\u522b\u662f\u7f3a\u4e4f\u90e8\u5206\u79df\u91d1\u8bc1\u660e\uff0c\u4f46\u88ab\u544a\u5d14\u67d0\u67d0\u81ea\u8ba4\u7684\u79df\u91d1\u6807\u51c6\u53ef\u4ee5\u4f5c\u4e3a\u6cd5\u9662\u53c2\u8003\u7684\u4f9d\u636e\u3002\\n\u88ab\u544a\u7684\u8fa9\u62a4\u4e3b\u8981\u662f\u8d28\u7591\u539f\u544a\u7684\u8bc1\u636e\u5b8c\u6574\u6027\uff0c\u4f46\u6ca1\u6709\u63d0\u4f9b\u8db3\u591f\u7684\u8bc1\u636e\u6765\u652f\u6301\u5176\u865a\u5047\u8bc9\u8bbc\u7684\u6307\u63a7\u3002\\n\u56e0\u6b64\uff0c\u6cd5\u9662\u53ef\u80fd\u4f1a\u90e8\u5206\u652f\u6301\u539f\u544a\u7684\u8bc9\u6c42\uff0c\u8981\u6c42\u88ab\u544a\u652f\u4ed8\u76f8\u5e94\u7684\u623f\u5c4b\u51fa\u79df\u6536\u76ca\u53ca\u5229\u606f\uff0c\u4f46\u53ef\u80fd\u4e0d\u4f1a\u5b8c\u5168\u652f\u6301\u539f\u544a\u8981\u6c42\u7684\u91d1\u989d\u3002\\nAnswer:\u6cd5\u9662\u53ef\u80fd\u4f1a\u90e8\u5206\u652f\u6301\u539f\u544a\u7684\u8bc9\u6c42\uff0c\u8981\u6c42\u88ab\u544a\u652f\u4ed8\u76f8\u5e94\u7684\u623f\u5c4b\u51fa\u79df\u6536\u76ca\u53ca\u5229\u606f\uff0c\u4f46\u53ef\u80fd\u4e0d\u4f1a\u5b8c\u5168\u652f\u6301\u539f\u544a\u8981\u6c42\u7684\u91d1\u989d\u3002",
        "candidate": "\u5728\u5206\u6790\u4e86\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u3001\u8bc1\u636e\u4ee5\u53ca\u9002\u7528\u7684\u6cd5\u5f8b\u539f\u5219\u540e\uff0c\u7ed3\u5408\u5404\u4ee3\u7406\u4eba\u7684\u610f\u89c1\uff0c\u53ef\u4ee5\u5f97\u51fa\u4ee5\u4e0b\u7ed3\u8bba\uff1a\u539f\u544a\u5c39\u67d0\u67d0\u4f5c\u4e3a\u623f\u5c4b\u7684\u6309\u4efd\u5171\u6709\u4eba\uff0c\u4f9d\u6cd5\u4eab\u670930%\u7684\u623f\u5c4b\u4efd\u989d\uff0c\u5e76\u6709\u6743\u4e3b\u5f20\u76f8\u5e94\u7684\u51fa\u79df\u6536\u76ca\u3002\u867d\u7136\u539f\u544a\u7684\u8bc1\u636e\u4e0d\u591f\u5b8c\u6574\uff0c\u7279\u522b\u662f\u7f3a\u4e4f\u90e8\u5206\u79df\u91d1\u8bc1\u660e\uff0c\u4f46\u88ab\u544a\u5d14\u67d0\u67d0\u81ea\u8ba4\u7684\u79df\u91d1\u6807\u51c6\u53ef\u4ee5\u4f5c\u4e3a\u6cd5\u9662\u53c2\u8003\u7684\u4f9d\u636e\u3002\u88ab\u544a\u7684\u8fa9\u62a4\u4e3b\u8981\u662f\u8d28\u7591\u539f\u544a\u7684\u8bc1\u636e\u5b8c\u6574\u6027\uff0c\u4f46\u6ca1\u6709\u63d0\u4f9b\u8db3\u591f\u7684\u8bc1\u636e\u6765\u652f\u6301\u5176\u865a\u5047\u8bc9\u8bbc\u7684\u6307\u63a7\u3002\u56e0\u6b64\uff0c\u6cd5\u9662\u53ef\u80fd\u4f1a\u90e8\u5206\u652f\u6301\u539f\u544a\u7684\u8bc9\u6c42\uff0c\u8981\u6c42\u88ab\u544a\u652f\u4ed8\u76f8\u5e94\u7684\u623f\u5c4b\u51fa\u79df\u6536\u76ca\u53ca\u5229\u606f\uff0c\u4f46\u53ef\u80fd\u4e0d\u4f1a\u5b8c\u5168\u652f\u6301\u539f\u544a\u8981\u6c42\u7684\u91d1\u989d\u3002\n\nAnswer:\u6cd5\u9662\u53ef\u80fd\u4f1a\u90e8\u5206\u652f\u6301\u539f\u544a\u7684\u8bc9\u6c42\uff0c\u8981\u6c42\u88ab\u544a\u652f\u4ed8\u76f8\u5e94\u7684\u623f\u5c4b\u51fa\u79df\u6536\u76ca\u53ca\u5229\u606f\uff0c\u4f46\u53ef\u80fd\u4e0d\u4f1a\u5b8c\u5168\u652f\u6301\u539f\u544a\u8981\u6c42\u7684\u91d1\u989d\u3002",
