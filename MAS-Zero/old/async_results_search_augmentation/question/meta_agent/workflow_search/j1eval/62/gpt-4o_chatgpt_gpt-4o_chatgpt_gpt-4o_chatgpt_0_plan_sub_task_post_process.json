        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u8d22\u4ea7\u635f\u5bb3\u8d54\u507f\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u5c39\u67d0\u67d0\", \"address\": \"\u5317\u4eac\u5e02\u901a\u5dde\u533a\u4e2d\u4e0a\u56ed\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"19xx\u5e74xx\u6708xx\u65e5\"}, \"defendant\": {\"name\": \"\u5d14\u67d0\u67d0\", \"address\": \"\u5317\u4eac\u5e02xx\u533axx\u56edxx\u53f7\u697cxx\u5c42x\u5355\u5143xxxx\u53f7\u623f\u5c4b\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"19xx\u5e74xx\u6708xx\u65e5\"}}, \"plaintiff_claim\": [\"\u8bf7\u6c42\u8d35\u9662\u5224\u4ee4\u88ab\u544a\u5411\u539f\u544a\u8fd4\u8fd8\u5317\u4eac\u5e02xx\u533axx\u56edxx\u53f7\u697cxx\u5c42x\u5355\u5143xxxx\u53f7\u623f\u5c4b\uff08\u4e0d\u52a8\u4ea7\u6743\u8bc1\u7f16\u53f7\uff1a\uff082021\uff09\u901a\u4e0d\u52a8\u4ea7\u6743\u7b2cxxxx\u53f7\uff092019\u5e7412\u67085\u65e5\u81f32024\u5e745\u67083\u65e5\u7684\u51fa\u79df\u6536\u76ca\u4eba\u6c11\u5e0146080\u5143\", \"\u8bf7\u6c42\u8d35\u9662\u5224\u4ee4\u88ab\u544a\u652f\u4ed8\u539f\u544a\u623f\u5c4b\u51fa\u79df\u6536\u76ca\u7684\u5229\u606f\uff08\u4ee546080\u5143\u4e3a\u57fa\u6570\u81ea2019\u5e7412\u67085\u65e5\u8d77\u81f3\u5b9e\u9645\u652f\u4ed8\u4e4b\u65e5\u6b62\uff0c\u6309\u5168