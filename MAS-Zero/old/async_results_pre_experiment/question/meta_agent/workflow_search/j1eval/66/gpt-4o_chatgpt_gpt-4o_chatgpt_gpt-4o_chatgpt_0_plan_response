        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u7269\u6743\u7ea0\u7eb7\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u674e\u67d01\", \"address\": \"\u6e56\u5357\u7701\u6c38\u5dde\u5e02\u51b7\u6c34\u6ee9\u533a\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1956\u5e7411\u67086\u65e5\"}, \"defendant\": {\"name\": \"\u674e\u67d02\", \"address\": \"\u6e56\u5357\u7701\u6c38\u5dde\u5e02\u51b7\u6c34\u6ee9\u533a\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1962\u5e745\u670812\u65e5\"}}, \"plaintiff_claim\": [\"\u5f3a\u5236\u62c6\u9664\u88ab\u544a\u780c\u5728\u539f\u544a\u5bb6\u95e8\u53e3\u7684\u5c0f\u6742\u623f\uff0c\u505c\u6b62\u4fb5\u6743\uff0c\u4e25\u7981\u5728\u5c0f\u6742\u623f\u5185\u517b\u9e21\u9e2d\u732b\u72d7\uff0c\u5e76\u5bf9\u5176\u6c61\u67d3\u539f\u544a\u5bb6\u5c45\u4f4f\u73af\u5883\uff0c\u8d54\u507f\u539f\u544a\u7cbe\u795e\u635f\u5931\u8d393000\u5143\", \"\u5224\u4ee4\u88ab\u544a\u6076\u610f\u63a8\u5012\u539f\u544a\u5bb6\u623f\u5c4b\u56f4\u5899\uff0c\u8d54\u507f\u7ecf\u6d4e\u635f\u5931\u8d393000\u5143\", \"\u672c\u6848\u8bc9\u8bbc\u8d39\u7531\u88ab\u544a\u627f\u62c5\"], \"plaintiff_case_details\": \"\u539f\u544a\u4e0e\u88ab\u544a\u7684\u623f\u5c4b\u5728xx\u516c\u8defxx\u8def\u6bb5\u7ea2\u7eff\u706f\u5904\u7684\u5317\u8fb9\u3002\u539f\u544a\u7684\u623f\u5c4b\u4e8e1994\u5e74\u5efa\u6210\uff0c\u88ab\u544a\u73b0\u6709\u7684\u623f\u5c4b\u5efa\u5728\u539f\u544a\u623f\u5c4b\u7684\u524d\u9762\uff0c\u662f2016\u5e74\u4fee\u5efaxx\u516c\u8def\u62c6\u8fc1\u65f6\u5efa\u7684\u3002\u5728\u62c6\u8fc1\u548c\u5efa\u623f\u65f6\uff0cxx\u516c\u8def\u51b7\u6c34\u6ee9\u533a\u6307\u6325\u90e8\u6307\u6325\u957f\u73b0\u573a\u660e\u786e\u51b3\u5b9a\uff0c\u4e3a\u4e0d\u5f71\u54cd\u540e\u9762\u90bb\u5c45\u623f\u5c4b\u7684\u901a\u98ce\u91c7\u5149\u548c\u6b63\u5e38\u751f\u6d3b\uff0c\u4e0d\u80fd\u5728\u674e\u67d01\u5bb6\u524d\u9762\u5efa\u6742\u623f\u7b49\u4efb\u4f55\u8fdd\u6cd5\u5efa\u7b51\u7269\uff0c\u88ab\u544a\u5728\u573a\u4e5f\u53e3\u5934\u627f\u8bfa\u4e86\u3002\u4f46\u662f\uff0c\u88ab\u544a\u4e0d\u9075\u5b88\u6307\u6325\u90e8\u7684\u51b3\u5b9a\u548c\u672c\u4eba\u627f\u8bfa\uff0c\u4e8e2018\u5e74\u8d81\u539f\u544a\u5728\u6210\u90fd\u5e26\u5b59\u5b50\u65f6\uff0c\u88ab\u544a\u5728\u539f\u544a\u623f\u5c4b\u524d\u9762\u4e0d\u8db33\u7c73\u8fdc\u7684\u5730\u65b9\u5efa\u4e86\u4e00\u4e2a\u5c0f\u6742\u623f\uff0c\u73b0\u5728\u5173\u9e21\u9e2d\u732b\u72d7\uff0c\u4e0e\u5176\u591a\u6b21\u4ea4\u6d89\u65e0\u679c\uff0c\u6751\u3001\u9547\u9886\u5bfc\u591a\u6b21\u8c03\u89e3\u88ab\u544a\u62d2\u4e0d\u53c2\u52a0\u3002\u5e73\u65e5\u91cc\u8165\u6c14\u81ed\u6c14\u85b0\u5929\uff0c\u6c14\u5473\u523a\u9f3b\uff0c\u590f\u5929\u548c\u522e\u98ce\u5929\u66f4\u751a\uff0c\u5df2\u7ecf\u4e25\u91cd\u5f71\u54cd\u4e86\u539f\u544a\u53ca\u5bb6\u4eba\u7684\u6b63\u5e38\u751f\u6d3b\uff0c\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e8c\u767e\u4e8c\u5341\u4e5d\u6761\u56e0\u4e3a\u6c61\u67d3\u73af\u5883\u3001\u7834\u574f\u751f\u6001\u9020\u6210\u4ed6\u4eba\u635f\u5bb3\u7684\u4fb5\u6743\u4eba\u5e94\u5f53\u627f\u62c5\u4fb5\u6743\u8d23\u4efb\u3002\u8bf7\u6c42\u5224\u4ee4\u88ab\u544a\u62c6\u9664\u5c0f\u6742\u623f\uff0c\u505c\u6b62\u4fb5\u6743\uff0c\u4e25\u7981\u5708\u517b\u9e21\u9e2d\u732b\u72d7\uff0c\u5e76\u8d54\u507f\u539f\u544a\u7cbe\u795e\u635f\u5931\u8d393000\u5143\u30022017\u5e745\u6708\uff0c\u65f6\u4efbxx\u9547\u653f\u5e9c\u4eba\u5927\u4e3b\u5e2d\u5e26\u9886\u9547\u62c6\u8fdd\u529e\u4eba\u5458\u628a\u4e0a\u8ff0\u88ab\u544a\u65b0\u780c\u7684\u5c0f\u6742\u623f\u63a8\u5012\u4e86\uff0c\u56e0\u88ab\u544a\u5948\u548c\u4e0d\u4e86\u653f\u5e9c\uff0c\u51fa\u5e72\u5bf9\u539f\u544a\u7684\u6076\u610f\u62a5\u590d\u7b2c\u4e8c\u5929\u4e0a\u5348\uff0c\u88ab\u544a\u592b\u5987\u5c06\u539f\u544a\u4e8e1994\u5e74\u5efa\u6210\u7684\u623f\u5c4b\u56f4\u5899\u63a8\u5012\uff08\u957f30\u7c73\uff0c\u9ad81.6\u7c73\uff09\u3002\u4e3a\u7ef4\u62a4\u539f\u544a\u7684\u5408\u6cd5\u6743\u76ca\uff0c\u8bf7\u6c42\u5224\u4ee4\u88ab\u544a\u4f9d\u6cd5\u8d54\u507f\u539f\u544a\u7ecf\u6d4e\u635f\u59313000\u5143\u3002\", \"defendant_defence\": \"\u88ab\u544a\u674e\u67d02\u662fxx\u4e00\u7ec4\u4eba\u5458\uff0c\u539f\u544a\u662f\u4e8c\u7ec4\u4eba\u5458\uff0c\u539f\u544a\u8d81\u7b54\u8fa9\u4eba\u4e0d\u5728\u5bb6\uff0c\u5c06\u88ab\u544a\u674e\u67d02\u7684\u56f4\u5899\u3001\u5c0f\u6742\u623f\u62c6\u4e86\uff0c\u88ab\u544a\u674e\u67d02\u89c9\u5f97\u662f\u719f\u6089\u4eba\u62c6\u4e86\u5c31\u7b97\u4e86\uff0c\u4f46\u662f\u539f\u544a\u53cd\u8fc7\u6765\u544a\u88ab\u544a\u674e\u67d02\uff0c\u5b85\u57fa\u5730\u662f\u653f\u5e9c\u5b89\u6392\u7ed9\u88ab\u544a\u674e\u67d02\u7684\uff0c\u539f\u544a\u7684\u5730\u662f\u4fee\u7684\u88ab\u544a\u674e\u67d02\u4e00\u7ec4\u7684\u5730\uff0c\u5728\u519c\u6751\u91cc\u9762\u517b\u9e21\u9e2d\u732b\u72d7\u662f\u6b63\u5e38\u7684\uff0c\u4f46\u662f\u539f\u544a\u90fd\u4e0d\u8ba9\u88ab\u544a\u674e\u67d02\u517b\u3002\u539f\u544a\u5c06\u88ab\u544a\u674e\u67d02\u7684\u56f4\u5899\u62c6\u9664\u540e\uff0c\u88ab\u544a\u674e\u67d02\u586b\u571f\u786c\u5316\u4e86\u8def\u9762\uff0c\u539f\u544a\u4e0d\u51c6\u88ab\u544a\u674e\u67d02\u586b\u571f\u786c\u5316\u3002\", \"evidence\": {\"plaintiff_evidence\": {\"evidence_1\": {\"evidence\": \"\u96c6\u4f53\u571f\u5730\u5efa\u8bbe\u7528\u5730\u4f7f\u7528\u8bc1\", \"dispute\": \"\"}, \"evidence_2\": {\"evidence\": \"\u51b7\u6c34\u6ee9\u533a\u4e2a\u4eba\u5efa\u8bbe\u7528\u5730\u7533\u8bf7\u4e66\", \"dispute\": \"\"}, \"evidence_3\": {\"evidence\": \"\u7167\u7247\", \"dispute\": \"\"}, \"evidence_4\": {\"evidence\": \"\u5904\u7406\u610f\u89c1\u4e66\", \"dispute\": \"\"}, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null, \"evidence_10\": null}, \"defendant_evidence\": {\"evidence_1\": null, \"evidence_2\": null, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null}}, \"other_statement\": {\"plaintiff\": {\"plaintiff_1\": \"\"}, \"defendant\": {\"defendant_1\": \"\"}}}\n",
        "correct_answer": [
            "\u88ab\u544a\u674e\u67d02\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\u62c6\u9664\u5176\u4fee\u5efa\u7684\u4f4d\u4e8e\u539f\u544a\u674e\u67d01\u623f\u5c4b\u65c1\u8fb9\u7684\u6742\u623f",
