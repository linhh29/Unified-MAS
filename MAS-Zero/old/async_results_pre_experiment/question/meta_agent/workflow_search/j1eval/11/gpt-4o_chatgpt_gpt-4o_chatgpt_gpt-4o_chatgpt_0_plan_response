        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u5a5a\u59fb\u5bb6\u5ead\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u8d75\u67d0\", \"address\": \"\u5f00\u539f\u5e02\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"2009\u5e748\u670822\u65e5\"}, \"defendant\": {\"name\": \"\u5218\u67d0\", \"address\": \"\u5f00\u539f\u5e02\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u56de\u65cf\", \"birth_date\": \"1986\u5e744\u670818\u65e5\"}}, \"plaintiff_claim\": [\"\u8bf7\u6c42\u5224\u51b3\u88ab\u544a\u7ed3\u6e05\u629a\u80b2\u8d3920\u4e2a\u6708\u517148485\u5143\", \"\u8bc9\u8bbc\u8d39\u7531\u88ab\u544a\u627f\u62c5\"], \"plaintiff_case_details\": \"\u539f\u544a\u4eca\u5e7415\u5468\u5c81\uff0c\u4eca\u4e0e\u5976\u5976\u97e9\u67d0\u4e00\u8d77\u751f\u6d3b\uff0c\u7531\u5976\u5976\u63d0\u4f9b\u65e5\u5e38\u751f\u6d3b\u8d39\u3002\u539f\u544a\u7cfb\u8d75\u5b9d\u5b81\u3001\u5218\u67d0\u7684\u5a5a\u751f\u5b50\uff0c\u8d75\u5b9d\u5b81\u4e0e\u5218\u67d0\u57282020\u5e741\u67089\u65e5\u767b\u8bb0\u79bb\u5a5a\u3002\u4ece2023\u5e741\u670830\u65e5\u8d77\uff0c\u539f\u544a\u7684\u7236\u4eb2\u8d75\u5b9d\u5b81\u56e0\u6545\u610f\u4f24\u5bb3\u7f6a\u88ab\u4e00\u5ba1\u6cd5\u9662\u5224\u5904\u6709\u671f\u5f92\u5211\u4e94\u5e74\u534a\uff0c\u73b0\u5173\u62bc\u5728\u5f00\u539f\u5e02\u770b\u5b88\u6