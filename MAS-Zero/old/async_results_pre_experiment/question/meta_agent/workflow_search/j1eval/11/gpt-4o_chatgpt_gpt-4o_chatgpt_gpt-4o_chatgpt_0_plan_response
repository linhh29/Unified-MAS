        "correct_answer": [
            "\u88ab\u544a\u5218\u67d0\u4e8e\u672c\u5224\u51b3\u751f\u6548\u540e\u4e94\u65e5\u5185\u7ed9\u4ed8\u539f\u544a\u8d75\u67d02023\u5e741\u670830\u65e5\u81f32024\u5e749\u6708\u671f\u95f4\u7684\u629a\u517b\u8d3923877\u5143",
            "\u9a73\u56de\u539f\u544a\u5176\u5b83\u8bc9\u8bbc\u8bf7\u6c42",
            "\u5982\u679c\u672a\u6309\u672c\u5224\u51b3\u6307\u5b9a\u7684\u671f\u95f4\u5c65\u884c\u7ed9\u4ed8\u91d1\u94b1\u4e49\u52a1\uff0c\u5e94\u5f53\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u4e8c\u767e\u516d\u5341\u56db\u6761\u7684\u89c4\u5b9a\uff0c\u52a0\u500d\u652f\u4ed8\u8fdf\u5ef6\u5c65\u884c\u671f\u95f4\u7684\u503a\u52a1\u5229\u606f",
            "\u6848\u4ef6\u53d7\u7406\u8d39506\u5143\uff0c\u539f\u544a\u5df2\u9884\u4ea4\uff0c\u7531\u88ab\u544a\u8d1f\u62c5\uff0c\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u4e03\u65e5\u5185\u5411\u8fbd\u5b81\u7701\u5f00\u539f\u5e02\u4eba\u6c11\u6cd5\u9662\u7f34\u7eb3\uff0c\u903e\u671f\u672a\u4e88\u7f34\u7eb3\u4f9d\u6cd5\u5f3a\u5236\u6267\u884c",
