        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u7269\u6743\u7ea0\u7eb7\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u674e\u4e07\u6625\", \"address\": \"\u5185\u8499\u53e4\u81ea\u6cbb\u533a\u547c\u4f26\u8d1d\u5c14\u5e02\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1973\u5e742\u670815\u65e5\"}, \"defendant\": {\"name\": \"\u738b\u6c38\u5f3a\", \"address\": \"\u5185\u8499\u53e4\u81ea\u6cbb\u533a\u547c\u4f26\u8d1d\u5c14\u5e02\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1979\u5e746\u670816\u65e5\"}}, \"plaintiff_claim\": [\"\u8981\u6c42\u88ab\u544a\u5c65\u884c\u300a\u571f\u5730\u6d41\u8f6c\u5408\u540c\u534f\u8bae\u4e66\u300b\uff0c\u63a5\u53d7\u539f\u544a\u5411\u5176\u652f\u4ed8\u768410\u4e07\u5143\u5e76\u5c06\u539f\u544a30\u4ea9\u571f\u5730\u8fd4\u8fd8\u7ed9\u539f\u544a\u3002\", \"\u8bf7\u6c42\u5224\u4ee4\u88ab\u544a\u8d54\u507f\u539f\u544a30\u4ea9\u571f\u57302022\u5e74\u7ecf\u6d4e\u635f\u59315\u4e07\u5143\u3002\", \"\u8981\u6c42\u88ab\u544a\u627f\u62c5\u672c\u6848\u7684\u8bc9\u8bbc\u8d39\u7528\u3002\"], \"plaintiff_case_details\": \"2017\u5e741\u67081\u65e5\uff0c\u539f\u544a\u56e0\u6025\u7528\u94b1\u627e\u5230\u88ab\u544a\uff0c\u53cc\u65b9\u7ea6\u5b9a\u539f\u544a\u4ece\u88ab\u544a\u5904\u501f\u6b3e\u5341\u4e07\u5143\u