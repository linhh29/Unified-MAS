        "correct_answer": [
            "\u88ab\u544a\u5434\u9650\u5f97\u7acb\u5373\u505c\u6b62\u5bf9\u539f\u544a\u5f20\u68a6\u6b23\u7684\u6240\u6709\u4fb5\u6743\u884c\u4e3a",
            "\u88ab\u544a\u5434\u9650\u5f97\u4e8e\u672c\u5224\u51b3\u751f\u6548\u540e\u4e94\u65e5\u5185\u5728\u5176\u6301\u6709\u7684\u6296\u97f3\u53ca\u5feb\u624b\u8d26\u53f7\u4e0a\u53d1\u5e03\u5411\u539f\u544a\u5f20\u68a6\u6b23\u8d54\u793c\u9053\u6b49\u7684\u89c6\u9891\u6216\u58f0\u660e\uff0c\u53d1\u5e03\u540e\u4e03\u65e5\u5185\u4e0d\u5f97\u5220\u9664\uff08\u53d1\u5e03\u5185\u5bb9\u987b\u7ecf\u672c\u9662\u5ba1\u6838\uff0c\u5982\u903e\u671f\u672a\u5c65\u884c\u4e0a\u8ff0\u5224\u51b3\u4e49\u52a1\uff0c\u5c06\u7531\u4eba\u6c11\u6cd5\u9662\u9009\u62e9\u5a92\u4f53\u767b\u8f7d\u5224\u51b3\u4e66\u4e3b\u8981\u5185\u5bb9\uff0c\u8d39\u7528\u7531\u88ab\u544a\u5434\u9650\u5f97\u8d1f\u62c5\uff09",
