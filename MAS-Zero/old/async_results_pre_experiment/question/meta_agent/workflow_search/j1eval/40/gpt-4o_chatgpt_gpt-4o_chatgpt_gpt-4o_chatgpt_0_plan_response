        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u7269\u6743\u7ea0\u7eb7\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u9a6c\u6b63\u5bcc\", \"address\": \"\u9655\u897f\u7701\u6986\u6797\u5e02\u7ee5\u5fb7\u53bf\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1971\u5e744\u670825\u65e5\"}, \"defendant\": {\"name\": \"\u8d3a\u5fd7\u521a\", \"address\": \"\u9655\u897f\u7701\u6986\u6797\u5e02\u795e\u6728\u5e02\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1975\u5e742\u67081\u65e5\"}}, \"plaintiff_claim\": [\"\u5224\u4ee4\u88ab\u544a\u8fd4\u8fd8\u539f\u544a\u603b\u91d1\u989d\u4e3a55.4\u4e07\u5143\u7684\u516b\u652f\u7968\u636e\uff08\u7968\u636e\u7f16\u53f7\u4e3a5945\u30015946\u30015947\u30015948\u30018291\u30014526\u30015191\u30015192\uff09\", \"\u672c\u6848\u8bc9\u8bbc\u8d39\u7531\u88ab\u544a\u8d1f\u62c5\"], \"plaintiff_case_details\": \"2013\u5e741\u670825\u65e5\u81f32013\u5e743\u670810\u65e5\u671f\u95f4\uff0c\u539f\u544a\u9a6c\u6b63\u5bcc\u5728\u6986\u6797\u5e02\u4e07\u5174\u6295\u8d44\u6709\u9650\u516c\u53f8\u7d2f\u8ba1\u5b58\u6b3e55.4\u4e07\u5143\uff0c\u5b58\u5165\u65f6\u95f4\u5206\u522b\u4e3a2013\u5e741\u670825\u65e5\u5b58\u5165\u56db\u7b14\u5171\u8ba140\u4e07\u5143\uff08\u7968\u636e\u7f16\u53f7\u4e3a5945\u30015946\u3001594