        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u7269\u6743\u7ea0\u7eb7\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u5317\u4eac\u67d0\u67d0\u96c6\u56e2\u6709\u9650\u516c\u53f8\", \"address\": \"\u5317\u4eac\u5e02\u5927\u5174\u533a\", \"representative\": \"\u9a6c\u67d0\u8363\", \"gender\": null, \"ethnicity\": null, \"birth_date\": null}, \"defendant\": {\"name\": \"\u9999\u6cb3\u53bf\u67d0\u67d0\u623f\u5730\u4ea7\u5f00\u53d1\u6709\u9650\u516c\u53f8\", \"address\": \"\u6cb3\u5317\u7701\u9999\u6cb3\u53bf\uff08\u534e\u590f\u57ce\u5e02\uff09\", \"representative\": \"\u5415\u67d0\u519b\", \"gender\": null, \"ethnicity\": null, \"birth_date\": null}}, \"plaintiff_claim\": [\"\u5224\u4ee4\u88ab\u544a\u5411\u539f\u544a\u652f\u4ed8\u7968\u636e\u91d1\u989d\u76f8\u5f53\u7684\u5229\u76ca300000\u5143\", \"\u5224\u4ee4\u88ab\u544a\u627f\u62c5\u672c\u6848\u8bc9\u8bbc\u8d39\u7528\"], \"plaintiff_case_details\": \"\u539f\u544a\u4e0e\u88ab\u544a2016\u5e74\u7b7e\u8ba2\u4e86\u300a\u5927\u8fd0\u6cb3\u5b54\u96c0\u57ce7.3\u671f\u914d\u7535\u7bb1\u3001\u67dc\u91c7\u8d2d\u5408\u540c\u300b\uff0c2020\u5e7410\u670829\u65e5\u88ab\u544a\u4ea4\u4ed8\u539f\u544a\u4e00\u5f20\u91d1\u989d\u4e3a300000\u5143\u7684\u7535\u5b50\u5546\u4e1a\u627f\u5151\u6c47\u7968\u7528\u4e8e\u652f\u4ed8\u8d27\u6b3e\uff0c\u7968\u53f7230810000530120201030749187\uff0c\u6c47\u7968\u5230\u6