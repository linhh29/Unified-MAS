u8ffd\u7d22\u6743\u3002\u4e8c\u3001\u9274\u4e8e\u539f\u544a\u4e0d\u662f\u6848\u6d89\u7968\u636e\u6700\u7ec8\u5408\u6cd5\u6301\u7968\u4eba\uff0c\u5176\u65e0\u6743\u5411\u9999\u6cb3\u80dc\u5f3a\u67d0\u67d0\u4e3b\u5f20\u7968\u636e\u91d1\u989d\u76f8\u5f53\u5229\u76ca\u3002\u6839\u636e\u300a\u7968\u636e\u6cd5\u300b\u7b2c\u5341\u516b\u6761\u89c4\u5b9a\uff0c\u6301\u7968\u4eba\u56e0\u8d85\u8fc7\u7968\u636e\u6743\u5229\u65f6\u6548\u800c\u4e27\u5931\u7968\u636e\u6743\u5229\u7684\uff0c\u53ef\u4ee5\u8bf7\u6c42\u51fa\u7968\u4eba\u6216\u8005\u627f\u5151\u4eba\u8fd4\u8fd8\u5176\u4e0e\u672a\u652f\u4ed8\u7684\u7968\u636e\u91d1\u989d\u76f8\u5f53\u7684\u5229\u76ca\u3002\u672c\u6848\u4e2d\uff0c\u539f\u544a\u63d0\u4ea4\u7684\u8bc1\u636e\u663e\u793a\u6848\u6d89\u7968\u636e\u6700\u7ec8\u6301\u7968\u4eba\u4e3a\u5317\u4eac\u67d0\u67d0\u5149\u7535\u6c14\u6709\u9650\u516c\u53f8\uff0c\u539f\u544a\u4e0d\u662f\u6848\u6d89\u7968\u636e\u7684\u6700\u7ec8\u6301\u7968\u4eba\u3002\u56e0\u6b64\uff0c\u539f\u544a\u65e0\u6743\u5411\u9999\u6cb3\u80dc\u5f3a\u67d0\u67d0\u4e3b\u5f20\u6848\u6d89\u7968\u636e\u91d1\u989d\u76f8\u5f53\u7684\u5229\u76ca\u3002\u4e09\u3001\u5982\u6cd5\u9662\u5224\u51b3\u9999\u6cb3\u80dc\u5f3a\u67d0\u67d0\u627f\u62c5\u8d23\u4efb\uff0c\u5219\u539f\u544a\u6709\u4e49\u52a1\u5728\u7968\u636e\u7cfb\u7edf\u4e2d\u8fdb\u884c\u5c06\u7968\u636e\u9000\u56de\u9999\u6cb3\u80dc\u5f3a\u67d0\u67d0\u7684\u64cd\u4f5c\u3002\u5426\u5219\uff0c\u9999\u6cb3\u80dc\u5f3a\u67d0\u67d0\u5b58\u5728\u53cc\u91cd\u652f\u4ed8\u7968\u9762\u91d1\u989d\u7684\u98ce\u9669\u3002\u56db\u3001\u5982\u679c\u539f\u544a\u4eab\u6709\u6848\u6d89\u7968\u636e\u518d\u8ffd\u7d22\u6743\u4e14\u6cd5\u9662\u5224\u4ee4\u9999\u6cb3\u80dc\u5f3a\u67d0\u67d0\u627f\u62c5\u8d23\u4efb\uff0c\u8bf7\u6c42\u6cd5\u9662\u7ed9\u4e88\u9999\u6cb3\u80dc\u5f3a\u67d0\u67d0\u4e0d\u5c11\u4e8e\u4e09\u4e2a\u6708\u7684\u5c65\u884c\u671f\u3002\", \"evidence\": {\"plaintiff_evidence\": {\"evidence_1\": {\"evidence\": \"\u7535\u5b50\u5546\u4e1a\u627f\u5151\u6c47\u79