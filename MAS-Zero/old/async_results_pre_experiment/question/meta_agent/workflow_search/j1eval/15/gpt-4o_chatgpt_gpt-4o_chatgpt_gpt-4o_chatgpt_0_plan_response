68\uff0c\u8bc1\u660e\u76ee\u7684\uff1a\u6848\u6d89\u6c47\u7968\u51fa\u7968\u65e5\u671f\u662f2020\u5e7410\u670829\u65e5\uff0c2020\u5e7412\u670817\u65e5\u5317\u4eac\u67d0\u67d0\u516c\u53f8\u80cc\u4e66\u8f6c\u8ba9\u7ed9\u5317\u4eac\u67d0\u67d0\u6709\u9650\u516c\u53f8\u3002\u7968\u636e\u5230\u671f\u65e5\u662f2021\u5e7410\u670829\u65e5\uff0c\u5317\u4eac\u67d0\u67d0\u6709\u9650\u516c\u53f8\u6ca1\u6709\u5151\u4ed8\u3002\", \"dispute\": \"\u8ba4\u53ef\u8bc1\u636e\u4e00\u7968\u9762\u6b63\u9762\u57fa\u7840\u4fe1\u606f\u7684\u771f\u5b9e\u6027\uff0c\u4e0d\u8ba4\u53ef\u8bc1\u660e\u76ee\u7684\u3002\u65e0\u6cd5\u8bc1\u660e\u76ee\u524d\u7684\u7968\u636e\u72b6\u6001\uff0c\u4e14\u7968\u636e\u80cc\u4e66\u4fe1\u606f\u663e\u793a\u539f\u544a\u5df2\u5c06\u6848\u6d89\u7968\u636e\u80cc\u4e66\u8f6c\u8ba9\u7ed9\u5317\u4eac\u67d0\u67d0\u6709\u9650\u516c\u53f8\uff0c\u7968\u636e\u7cfb\u7edf\u672a\u663e\u793a\u8ffd\u7d22\u6e05\u507f\u4fe1\u606f\uff0c\u56e0\u6b64\u539f\u544a\u4e0d\u662f\u7968\u636e\u7684\u6700\u7ec8\u6301\u7968\u4eba\uff0c\u65e0\u6743\u5411\u88ab\u544a\u4e3b\u5f20\u6848\u6d89\u7968\u636e\u76f8\u5173\u7684\u6743\u5229\u3002\"}, \"evidence_2\": {\"evidence\": \"\uff082022\uff09\u4eac0106\u6c11\u521d3400\u53f7\u6c11\u4e8b\u5224\u51b3\u4e66\uff0c\u8bc1\u660e\u76ee\u7684\uff1a\u5317\u4eac\u67d0\u67d0\u6709\u9650\u516c\u53f8\u8d77\u8bc9\u5317\u4eac\u67d0\u67d0\u516c\u53f8\uff0c\u5317\u4eac\u5e02\u4e30\u53f0\u533a\u6cd5\u9662\u5224\u51b3\u5317\u4eac\u67d0\u67d0\u516c\u53f8\u652f\u4ed8\u5317\u4eac\u67d0\u67d0\u6709\u9650\u516c\u53f8304390\u5143\u3002\", \"dispute\": \"\u771f\u5b9e\u6027\u4ee5\u6cd5\u9662\u8ba4\u5b9a\u4e3a\u51c6\uff0c\u4e0d\u8ba4\u53ef\u5173\u8054\u6027\u53ca\u8bc1\u660e\u76ee\u7684\u3002\u7968\u636e\u7cfb\u7edf\u663e\u793a\u7684\u6700\u7ec8\u6301\u7968\u4eba\u4e3a\u5c71\u4e1c\u67d0\u67d0\u7535\u6c14\u6709\u9650\u516c\u53f8\uff0c\u975e\u8be5\u5224\u51b3\u4e2d\u7684\u5317\u4eac\u67d0\u67d0\u6709\u9650\u516c\u53f8\uff0c\u5317\u4eac\u67d0\u67d0\u6709\u9650\u516c\u53f8\u5728\u