    {
        "example_id": 15,
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u7269\u6743\u7ea0\u7eb7\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u5317\u4eac\u67d0\u67d0\u96c6\u56e2\u6709\u9650\u516c\u53f8\", \"address\": \"\u5317\u4eac\u5e02\u5927\u5174\u533a\", \"representative\": \"\u9a6c\u67d0\u8363\", \"gender\": null, \"ethnicity\": null, \"birth_date\": null}, \"defendant\": {\"name\": \"\u9999\u6cb3\u53bf\u67d0\u67d0\u623f\u5730\u4ea7\u5f00\u53d1\u6709\u9650\u516c\u53f8\", \"address\": \"\u6cb3\u5317\u7701\u9999\u6cb3\u53bf\uff08\u534e\u590f\u57ce\u5e02\uff09\", \"representative\": \"\u5415\u67d0\u519b\", \"gender\": null, \"ethnicity\": null, \"birth_date\": null}}, \"plaintiff_claim\": [\"\u5224\u4ee4\u88ab\u544a\u5411\u539f\u544a\u652f\u4ed8\u7968\u636e\u91d1\u989d\u76f8\u5f53\u7684\u5229\u76ca300000\u5143\", \"\u5224\u4ee4\u88ab\u544a\u627f\u62c5\u672c\u6848\u8bc9\u8bbc\u8d39\u7528\"], \"plaintiff_case_details\": \"\u539f\u544a\u4e0e\u88ab\u544a2016\u5e74\u7b7e\u8ba2\u4e86\u300a\u5927\u8fd0\u6cb3\u5b54\u96c0\u57ce7.3\u671f\u914d\u7535\u7bb1\u3001\u67dc\u91c7\u8d2d\u5408\u540c\u300b\uff0c2020\u5e7410\u670829\u65e5\u88ab\u544a\u4ea4\u4ed8\u539f\u544a\u4e00\u5f20\u91d1\u989d\u4e3a300000\u5143\u7684\u7535\u5b50\u5546\u4e1a\u627f\u5151\u6c47\u7968\u7528\u4e8e\u652f\u4ed8\u8d27\u6b3e\uff0c\u7968\u53f7230810000530120201030749187\uff0c\u6c47\u7968\u5230\u671f\u65e52021\u5e7410\u670829\u65e5\uff0c2020\u5e7412\u670816\u65e5\u539f\u544a\u80cc\u4e66\u8f6c\u8ba9\u7ed9\u4e0b\u6e38\u4f9b\u5e94\u5546\u5317\u4eac\u67d0\u67d0\u5149\u7535\u6c14\u6709\u9650\u516c\u53f8\uff0c\u6c47\u7968\u5230\u671f\u540e\u65e0\u6cd5\u627f\u5151\uff0c\u5317\u4eac\u67d0\u67d0\u5149\u7535\u6c14\u6709\u9650\u516c\u53f8\u4ee5\u4e70\u5356\u5408\u540c\u7ea0\u7eb7\u8bc9\u81f3\u5317\u4eac\u5e02\u4e30\u53f0\u533a\u6cd5\u9662\uff0c\u6cd5\u9662\u5224\u51b3\u539f\u544a\u652f\u4ed8\u5317\u4eac\u67d0\u67d0\u5149\u7535\u6c14\u6709\u9650\u516c\u53f8\u8d27\u6b3e\u3002\u56e0\u7968\u636e\u6743\u5229\u5df2\u8fc7\u65f6\u6548,\u539f\u544a\u4f9d\u636e\u300a\u7968\u636e\u6cd5\u300b\u7b2c\u5341\u516b\u6761\u89c4\u5b9a\uff0c\u63d0\u8d77\u7968\u636e\u5229\u76ca\u8fd4\u8fd8\u8bf7\u6c42\u6743\u8bc9\u8bbc\uff0c\u8981\u6c42\u88ab\u544a\u652f\u4ed8\u7968\u636e\u91d1\u989d\u76f8\u5f53\u7684\u5229\u76ca300000\u5143\u3002\", \"defendant_defence\": \"\u4e00\u3001\u539f\u544a\u5e76\u975e\u6848\u6d89\u7968\u636e\u6700\u7ec8\u6301\u7968\u4eba\uff0c\u5e76\u4e14\u672a\u5b8c\u6210\u5411\u5317\u4eac\u67d0\u67d0\u7535\u6c14\u6709\u9650\u516c\u53f8\u6e05\u507f\uff0c\u5176\u672a\u53d6\u5f97\u7968\u636e\u518d\u8ffd\u7d22\u6743\u3002\u6839\u636e\u300a\u7968\u636e\u6cd5\u300b\u7b2c\u4e03\u5341\u6761\u7b2c\u4e8c\u6b3e\u53ca\u7b2c\u4e03\u5341\u4e00\u6761\u89c4\u5b9a\uff0c\u539f\u544a\u53d6\u5f97\u6848\u6d89\u7968\u636e\u518d\u8ffd\u7d22\u6743\u7684\u524d\u63d0\u662f\u539f\u544a\u5b8c\u6210\u5411\u5317\u4eac\u67d0\u67d0\u7535\u6c14\u6709\u9650\u516c\u53f8\u6e05\u507f\u3002\u672c\u6848\u4e2d\uff0c\u539f\u544a\u672a\u63d0\u4ea4\u5411\u5317\u4eac\u67d0\u67d0\u7535\u6c14\u6709\u9650\u516c\u53f8\u7684\u6e05\u507f\u8bb0\u5f55\u3001\u8ffd\u7d22\u4eba\u51fa\u5177\u7684\u6536\u636e\u7b49\u6587\u4ef6\uff0c\u5e76\u4e14\u7968\u636e\u7cfb\u7edf\u4e5f\u672a\u663e\u793a\u6e05\u507f\u8bb0\u5f55\uff0c\u56e0\u6b64\uff0c\u73b0\u6709\u8bc1\u636e\u4e0d\u80fd\u8bc1\u660e\u539f\u544a\u53d6\u5f97\u4e86\u7968\u636e\u518d\