    {
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u7269\u6743\u7ea0\u7eb7\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u738b\u67d0\u82ac\", \"address\": \"\u4e91\u5357\u7701\u5927\u7406\u767d\u65cf\u81ea\u6cbb\u5dde\u7965\u4e91\u53bf\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1974\u5e744\u670811\u65e5\"}, \"defendant\": {\"name\": \"\u4e91\u5357\u7701\u5927\u7406\u67d0\u67d0\u6751\u6c11\u59d4\u5458\u4f1a\u7b2c\u4e8c\u6751\u6c11\u5c0f\u7ec4\", \"address\": \"\u4e91\u5357\u7701\u5927\u7406\u767d\u65cf\u81ea\u6cbb\u5dde\u7965\u4e91\u53bf\", \"representative\": \"\u738b\u67d0\u8d22\", \"gender\": null, \"ethnicity\": null, \"birth_date\": null}}, \"plaintiff_claim\": [\"\u8bf7\u6c42\u5224\u51b3\u88ab\u544a\u5411\u539f\u544a\u652f\u4ed8\u571f\u5730\u8865\u507f\u6b3e23000\u5143\", \"\u8bf7\u6c42\u5224\u51b3\u88ab\u544a\u627f\u62c5\u672c\u6848\u8bc9\u8bbc\u8d39\u7528\"], \"plaintiff_case_details\": \"\u539f\u544a\u4e8e1974\u5e744\u670811\u65e5\u51fa\u751f\u4e8e\u7965\u57ce\u9547\u7f57\u5bb6\u4e8c\u7ec4\uff0c\u7cfb\u571f\u751f\u571f\u957f\u7684\u7f57\u5bb6\u4e8c\u7ec4\u6751\u6c11\u30021994\u5e743\u670825\u65e5\u539f\u544a\u4e0e\u6848\u5916\u4eba\u718a\u67d0\u80dc\u7ed3\u5a5a\u5e76\u5c06\u6237\u53e3\u8fc1\u5f80\u718a\u67d0\u80dc\u6237\u7c4d\u5730\u7965\u4e91\u53bf\u7965\u57ce\u9547\