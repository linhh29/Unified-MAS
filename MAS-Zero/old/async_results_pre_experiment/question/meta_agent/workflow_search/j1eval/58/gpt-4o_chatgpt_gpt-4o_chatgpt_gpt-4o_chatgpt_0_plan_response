        "example_id": 58,
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u5a5a\u59fb\u5bb6\u5ead\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u77f3\u67d0\", \"address\": \"\u961c\u65b0\u5e02\u592a\u5e73\u533a\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1983\u5e744\u670819\u65e5\"}, \"defendant\": {\"name\": \"\u4ed8\u67d0\", \"address\": \"\u961c\u65b0\u5e02\u6d77\u5dde\u533a\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1978\u5e744\u670821\u65e5\"}}, \"plaintiff_claim\": [\"\u8bf7\u6c42\u4f9d\u6cd5\u5224\u51b3\u539f\u544a\u6bcf\u5468\u53ef\u63a2\u671b\u4e00\u6b21\u5a5a\u751f\u5973\u4ed8\u67d0\uff08\u63a2\u671b\u65f6\u95f4\u4e3a\u6bcf\u5468\u4e94\u4e0b\u5348\u4e03\u70b9\u63a5\u8d70\u81f3\u5468\u65e5\u4e0b\u5348\u4e09\u70b9\u9001\u56de\uff09\", \"\u5a5a\u751f\u5973\u4ed8\u67d0\u7684\u6cd5\u5b9a\u5047\u671f\u548c\u5bd2\u6691\u5047\u8981\u6c42\u4e0e\u5a5a\u751f\u5973\u4ed8\u67d0\u5171\u540c\u751f\u6d3b\u4e00\u534a\u65f6\u95f4\", \"\u6bcf\u5e74\u6625\u8282\u8981\u6c42\u4e0e\u88ab\u544a\u8f6e\u6d41\u4e0e\u5a5a\u751f\u5973\u4ed8\u67d0\u5171\u5ea6\u6625\u8282\", \"\u672c\u6848\u5168\u90e8\u8bc9\u8bbc\u8d39\u7528\u7531\u88ab\u544a\u627f\u62c5\"], \"plaintiff_case_details\": \"\u539f\u544a\u4e0e\u88ab\u544a\u4e8e\u00d7\u00d7\u00d7\u00d7\u5e74\u00d7\u00d7\u6708\u00d7\u00d7\u65e5\u534f\u8bae\u7ed3\u5a5a\uff0c\u5a5a\u751f\u5973\u4ed8\u67d0\u7531\u88ab\u544a\u629a\u517b\uff0c\u539f\u544a\u6709\u63a2\u671b\u6743\u3002\u5728\u539f\u544a\u6bcf\u6b21\u53bb\u63a2\u671b\u5b69\u5b50\u7684\u65f6\u5019\uff0c\u88ab\u544a\u90fd\u8981\u6c42\u5fc5\u987b\u5728\u65c1\u8fb9\u770b\u7740\uff0c\u539f\u544a\u60f3\u5e26\u7740\u5b69\u5b50\u53bb\u4ec0\u4e48\u5730\u65b9\uff0c\u88ab\u544a\u4e5f\u8981\u5fc5\u987b\u8ddf\u7740\u3002\u4f46\u81ea2023\u5e749\u6708\u4efd\u5f00\u59cb\uff0c\u539f\u544a\u8054\u7cfb\u88ab\u544a\u5546\u8bae\u5177\u4f53\u63a2\u671b\u5973\u513f\u4ed8\u67d0\u65f6\uff0c\u88ab\u544a\u8981\u4e48\u62d2\u7edd\u63a5\u542c\u7535\u8bdd\uff0c\u8981\u4e48\u4ee5\u5404\u79cd\u7406\u7531\u4e0d\u8ba9\u539f\u544a\u63a2\u671b\u5b69\u5b50\u3002\u6700\u8fd1\uff0c\u539f\u544a\u5728\u8054\u7cfb\u88ab\u544a\u7684\u65f6\u5019\u53c8\u53d1\u73b0\u88ab\u544a\u5df2\u5c06\u539f\u544a\u7684\u7535\u8bdd\u62c9\u9ed1\uff0c\u88ab\u544a\u7684\u79cd\u79cd\u884c\u4e3a\u5df1\u4e25\u91cd\u635f\u5bb3\u4e86\u539f\u544a\u7684\u5408\u6cd5\u6743\u76ca\u3002\", \"defendant_defence\": \"\u9996\u5148\uff0c\u867d\u7136\u6c11\u6cd5\u5178\u7b2c1086\u6761\u89c4\u5b9a\u4e86\u4e0d\u76f4\u63a5\u629a\u517b\u5b50\u5973\u7684\u7236\u6bcd\u6709\u63a2\u89c6\u5b50\u5973\u7684\u6743\u5229\uff0c\u4f46\u8be5\u6761\u7b2c\u4e09\u6b3e\u4e5f\u89c4\u5b9a\u4e86\uff0c\u7236\u6bcd\u63a2\u89c6\u5b50\u5973\uff0c\u4e0d\u5229\u4e8e\u5b50\u5973\u8eab\u5fc3\u5065\u5eb7\u7684\uff0c\u4e2d\u6b62\u63a2\u671b\uff0c\u6545\u5982\u63a2\u89c6\u884c\u4e3a\u5bf9\u5a5a\u751f\u5b50\u5973\u8eab\u5fc3\u5065\u5eb7\u6709\u5bb3\u7684\uff0c\u53ef\u62d2\u7edd\u63a2\u89c6\uff0c\u6240\u4ee5\uff0c\u7b54\u8fa9\u4eba\u4e0d\u540c\u610f\u539f\u544a\u63a2\u89c6\u5a5a\u751f\u5973\uff0c\u8d77\u7801\u5728\u5a5a\u751f\u59738\u5468\u5c81\u524d\u62d2\u7edd\u539f\u544a\u7684\u63a2\u89c6\uff0c\u5177\u4f53\u7406\u7531\u5982\u4e0b\uff1a\\r\u4e00\u3001\u5728\u53cc\u65b9\u79bb\u5a5a\u540e\uff0c\u4ed8\u67d0\u5e76\u672a\u963b\u6b62\u77f3\u67d0\u63a2\u89c6\u5a5a\u751f\u5973\uff0c\u4f46\u6bcf\u6b21\u5a5a\u751f\u5973\u89c1\u5230\u77f3\u67d0\u540e\uff0c\u5747\u51fa\u73b0\u5455\u5410\u3001\u957f\u671f\u54ed\u6ce3\u3001\u6d41\u9f3b\u8840\u7b49\u75c7\u72b6\uff0c\u7279\u522b\u662f\u57282023\u5e74\u5e95\uff0c\u6bcf\u6b21\u89c1\u5b8c\u539f\u544a\u77f3\u67d0\u540e\uff0c\u5747\u4f1a\u51fa\u73b0\u611f\u5192\u3001\u54b3\u55fd\u3001\u5455\u5410\u3001\u4e0d\u5403\u996d\u7b49\u75c7\u72b6\uff0c\u88ab\u544a\u591a\u6b21\u5e26\u4ed8\u67d0\u5230\u533b\u9662\u8fdb\u884c\u68c0\u67e5\uff0c\u5e76\u4f4f\u9662\u6cbb\u7597\uff0c\u7ecf\u8bca\u65ad\u5176\u54b3\u55fd\u867d\u7136\u7cfb\u80ba\u708e\u6240\u5f15\u8d77\uff0c\u4f46\u4e5f\u68c0\u67e5\u51fa\u5a5a\u751f\u5973\u60a3\u6709\u5fc3\u808c\u9176\u8c31\u5f02\u5e38\uff0c\u800c\u8be5\u75c7\u72b6\u6700\u60e7\u6015\u7684\u5c31\u662f\u523a\u6fc0\uff0c\u5e76\u53ef\u5f15\u8d77\u6025\u6027\u5fc3\u808c\u6897\u6b7b\u3001\u75c5\u6bd2\u6027\u5fc3\u808c\u708e\u3001\u5fc3\u5305\u708e\u7b49\u75c7\u72b6\uff0c\u56e0\u6bcf\u6b21\u4ed8\u67d0\u770b\u89c1\u6bcd\u4eb2\u540e\u5747\u51fa\u73b0\u4e0e\u5e73\u5e38\u6781\u5927\u7684\u53cd\u5dee\uff0c\u5982\u6cd5\u9662\u5224\u4ee4\u4ed8\u67d0\u5728\u5fc3\u808c\u9176\u8c31\u6b63\u5e38\u524d\u4e0e\u6bcd\u4eb2\u76f8\u89c1\uff0c\u5219\u6781\u6709\u53ef\u80fd\u4f1a\u5f15\u8d77\u4ed8\u67d0\u7684\u75c5\u53d8\uff0c\u8bf1\u53d1\u66f4\u4e25\u91cd\u7684\u5fc3\u810f\u7c7b\u75be\u75c5\u3002\u6240\u4ee5\uff0c\u8be5\u60c5\u51b5\u5c31\u662f\u6c11\u6cd5\u5178\u7b2c1086\u6761\u7b2c\u4e09\u6b3e\u89c4\u5b9a\u7684\u4e0d\u9002\u7528\u63a2\u89c6\u6743\u7684\u60c5\u5f62\u3002\u5982\u679c\u77f3\u67d0\u4e3a\u4e86\u4ed8\u67d0\u7684\u8eab\u5fc3\u5065\u5eb7\u8003\u8651\uff0c\u5728\u5f97\u5230\u51c6\u786e\u7684\u533b\u9662\u8bca\u65ad\u540e\uff0c\u518d\u884c\u4f7f\u63a2\u89c6\u6743\uff0c\u5c4a\u65f6\u4ed8\u67d0\u4e0d\u4f1a\u52a0\u4ee5\u963b\u62e6\u3002\\r\u4e8c\u3001\u57282023\u5e7411\u6708\u77f3\u67d0\u63a2\u89c6\u4ed8\u67d0\u671f\u95f4\uff0c\u8bf1\u5bfc\u4ed8\u67d0\u8bf4\u51fa\u4ed8\u67d0\u8650\u5f85\u4ed8\u67d0\uff0c\u5e76\u5bf9\u8be5\u8fc7\u7a0b\u8fdb\u884c\u5f55\u50cf\uff0c\u5176\u76ee\u7684\u4e3a\u4e86\u4e89\u593a\u629a\u517b\u6743\uff0c\u8be5\u4e8b\u5b9e\u5728\u6d77\u5dde\u533a\u6cd5\u9662\uff082023\uff09\u8fbd0902\u6c11\u521d1214\u53f7\u6848\u4ef6\u5ba1\u7406\u8fc7\u7a0b\u4e2d\u5f53\u505a\u53d8\u66f4\u629a\u517b\u6743\u7684\u8bc1\u636e\u63d0\u4f9b\uff0c\u77f3\u67d0\u7684\u8be5\u884c\u4e3a\u5b8c\u5168\u6ca1\u6709\u987e\u53ca\u4ed8\u67d0\u7684\u611f\u53d7\uff0c\u5176\u672a\u5e26\u7ed9\u4ed8\u67d0\u6b63\u786e\u7684\u3001\u5065\u5eb7\u6743\u4ef7\u503c\u89c2\u5f15\u5bfc\uff0c\u77f3\u67d0\u4e3a\u4e86\u8fbe\u5230\u76ee\u7684\u4e0d\u62e9\u624b\u6bb5\uff0c\u56db\u5c81\u7684\u5b69\u5b50\u5bb6\u957f\u8ba9\u600e\u4e48\u8bf4\u5c31\u600e\u4e48\u8bf4\uff0c\u6b64\u7c7b\u89c6\u9891\u4ed8\u67d0\u60f3\u505a\u591a\u5c11\u5c31\u505a\u591a\u5c11\uff0c\u4f46\u8fd9\u4e48\u5c0f\u7684\u5b69\u5b50\u8bf1\u5bfc\u5176\u8bf4\u51fa\u8fd9\u4e48\u6b8b\u5fcd\u7684\u8bdd\uff0c\u662f\u5bf9\u5b69\u5b50\u7684\u8eab\u5fc3\u5065\u5eb7\u4f5c\u51fa\u7684\u7279\u522b\u4e0d\u5229\u7684\u884c\u4e3a\uff0c\u6240\u4ee5\uff0c\u5c31\u6b64\u884c\u4e3a\u800c\u8a00\uff0c\u77f3\u67d0\u4e5f\u4e0d\u9002\u5408\u63a2\u89c6\u4ed8\u67d0\u3002\\r\u4e09\u3001\u5728\u65b0\u90b1\u533a\u4eba\u6c11\u6cd5\u9662\uff082024\uff09\u8fbd0903\u6c11\u521d342\u53f7\u4ed8\u67d0\u8d77\u8bc9\u77f3\u67d0\u8981\u6c42\u652f\u4ed8\u629a\u517b\u8d39\u7684\u6848\u4ef6\u4e2d\uff0c\u5224\u51b3\u751f\u6548\u540e\uff0c\u77f3\u67d0\u4ecd\u7136\u62d2\u7edd\u652f\u4ed8\u629a\u517b\u8d39\uff0c\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\uff0c\u77f3\u67d0\u79f0\u5176\u6ca1\u6709\u56fa\u5b9a\u4f4f\u6240\uff0c\u4ed8\u67d0\u5728\u79bb\u5a5a\u65f6\u8d60\u4e0e\u5176\u7684\u623f\u5c4b\u4e00\u5904\u77f3\u67d0\u5df2\u7ecf\u53d8\u5356\uff0c\u6545\u77f3\u67d0\u65e0\u4f4f\u6240\uff0c\u5373\u4f7f\u77f3\u67d0\u53ef\u63a2\u89c6\u4ed8\u67d0\uff0c\u4e3a\u4e86\u4ed8\u67d0\u7684\u5065\u5eb7\u7740\u60f3\uff0c\u5728\u65c5\u9986\u6216\u8005\u662f\u65e0\u56fa\u5b9a\u7684\u5c45\u4f4f\u5730\u751f\u6d3b\uff0c\u65e0\u6cd5\u4fdd\u969c\u4ed8\u67d0\u7684\u5065\u5eb7\uff0c\u6545\u5373\u4f7f\u53ef\u4ee5\u63a2\u89c6\uff0c\u4ed8\u67d0\u4e5f\u4e0d\u80fd\u4e0e\u77f3\u67d0\u5171\u540c\u751f\u6d3b\u3002\\r\u56db\u3001\u4ed8\u67d0\u7684\u751f\u6d3b\u6536\u5165\u662f\u5176\u7ecf\u8425\u7740\u4e00\u5bb6\u9e3d\u5b50\u7528\u54c1\u5e97\uff0c\u57282023\u5e74\u5e95\u52302024\u5e74\u521d\uff0c\u4ed8\u67d0\u591a\u6b21\u751f\u75c5\u5e76\u4e14\u4f4f\u9662\u6cbb\u7597\u671f\u95f4\uff0c\u4ed8\u67d0\u65e0\u6cd5\u5de5\u4f5c\uff0c\u4f46\u77f3\u67d0\u5728\u6b64\u671f\u95f4\u662f\u77e5\u9053\u4ed8\u67d0\u4f4f\u9662\u7684\uff0c\u5982\u679c\u77f3\u67d0\u62c5\u5fc3\u4ed8\u67d0\uff0c\u5176\u5e94\u5f53\u5230\u533b\u9662\u53bb\u7167\u987e\u4ed8\u67d0\uff0c\u5e76\u4e14\u652f\u4ed8\u629a\u517b\u8d39\uff0c\u4f46\u5728\u6b64\u671f\u95f4\uff0c\u77f3\u67d0\u975e\u4f46\u672a\u5230\u533b\u9662\u63a2\u89c6\u8fc7\u4ed8\u67d0\uff0c\u4e5f\u672a\u652f\u4ed8\u629a\u517b\u8d39\u3002\u6240\u4ee5\uff0c\u7b54\u8fa9\u4eba\u8ba4\u4e3a\u5176\u5e76\u975e\u662f\u5173\u5fc3\u7231\u62a4\u4ed8\u67d0\uff0c\u800c\u4ec5\u662f\u6253\u7b97\u62a5\u590d\u4ed8\u67d0\uff0c\u5426\u5219\u5982\u5176\u771f\u5173\u5fc3\u5728\u4e4e\u4ed8\u67d0\uff0c\u4e3a\u4f55\u4e0d\u5728\u79bb\u5a5a\u7684\u65f6\u5019\u9009\u62e9\u8981\u629a\u517b\u6743\uff0c\u800c\u662f\u9009\u62e9\u8981\u623f\u5b50\u3002\\r\u7efc\u4e0a\u6240\u8ff0\uff0c\u4ed8\u67d0\u5ba2\u89c2\u4e0a\u5176\u8eab\u4f53\u539f\u56e0\u4e0d\u9002\u5408\u539f\u544a\u7684\u63a2\u89c6\uff0c\u77f3\u67d0\u4e3b\u89c2\u4e0a\u4e5f\u672a\u5c06\u4ed8\u67d0\u89c6\u4f5c\u638c\u4e0a\u660e\u73e0\uff0c\u90a3\u4e48\u4e3a\u4e86\u4ed8\u67d0\u7684\u5065\u5eb7\u8003\u8651\uff0c\u8bf7\u6c42\u4eba\u6c11\u6cd5\u9662\u9a73\u56de\u77f3\u67d0\u7684\u8bc9\u8bbc\u8bf7\u6c42\u3002\", \"evidence\": {\"plaintiff_evidence\": {\"evidence_1\": {\"evidence\": \"\uff082024\uff09\u8fbd0903\u6c11\u521d342\u53f7\u6c11\u4e8b\u5224\u51b3\u4e66\", \"dispute\": \"\u88ab\u544a\u8ba4\u4e3a\u539f\