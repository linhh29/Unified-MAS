        "example_id": 72,
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u5a5a\u59fb\u5bb6\u5ead\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u674e\u67d0\", \"address\": \"\u5c71\u897f\u8fd0\u57ce\u5e02\u76d0\u6e56\u533a\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1963\u5e7412\u670827\u65e5\"}, \"defendant\": {\"name\": \"\u859b\u67d0\", \"address\": \"\u897f\u5b89\u5e02\u65b0\u57ce\u533a\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1969\u5e747\u670818\u65e5\"}}, \"plaintiff_claim\": [\"\u4f9d\u6cd5\u786e\u8ba4\u539f\u3001\u88ab\u544a\u53cc\u65b9\u7684\u5a5a\u59fb\u65e0\u6548\", \"\u672c\u6848\u7684\u8bc9\u8bbc\u8d39\u7528\u7531\u88ab\u544a\u627f\u62c5\"], \"plaintiff_case_details\": \"1991\u5e7410\u6708\uff0c\u539f\u544a\u674e\u67d0\u4e0e\u7b2c\u4e00\u4efb\u59bb\u5b50\u66f9\u6cc9\u5728\u897f\u5b81\u5e02\u4e1c\u57ce\u533a\u6c11\u653f\u5c40\u529e\u7406\u7ed3\u5a5a\u767b\u8bb0\u624b\u7eed\uff0c1999\u5e742\u6708\u4e8c\u4eba\u7ecf\u56db\u5ddd\u7701\u6210\u90fd\u5e02\u9526\u6c5f\u533a\u4eba\u6c11\u6cd5\u9662\u5224\u51b3\u79bb\u5a5a\u30022001\u5e749\u670820\u65e5\uff0c\u539f\u544a\u4e0e\u7b2c\u4e8c\u4efb\u59bb\u5b50\u5f20\u7ea2\u82f1\u5728\u8fd0\u57ce\u5e02\u76d0\u6e56\u533a\u6c11\u653f\u5c40\u9886\u53d6\u4e86\u7ed3\u5a5a\u8bc1\uff0c\u9886\u53d6\u7ed3\u5a5a\u8bc1\u65f6\u53cc\u65b9\u5747\u4e3a\u73b0\u5f79\u519b\u4eba\uff0c\u4e14\u8be5\u5a5a\u59fb\u5173\u7cfb\u81f3\u4eca\u5c1a\u672a\u89e3\u9664\u3002\u4f46\u88ab\u544a\u859b\u67d0\u5728\u660e\u77e5\u539f\u544a\u540c\u7b2c\u4e8c\u4efb\u59bb\u5b50\u5f20\u7ea2\u82f1\u5b58\u5728\u5a5a\u59fb\u5173\u7cfb\u7684\u60c5\u51b5\u4e0b\uff0c\u4ecd\u5229\u7528\u5f02\u5730\u5a5a\u59fb\u767b\u8bb0\u7684\u6f0f\u6d1e\uff0c\u4ee5\u77e5\u9053\u539f\u544a\u9690\u79c1\u3001\u8ba9\u539f\u544a\u540d\u8a89\u626b\u5730\u3001\u8df3\u697c\u81ea\u6740\u7b49\u4e8b\u7531\u5a01\u80c1\u3001\u903c\u8feb\u539f\u544a\u4e0e\u5176\u53e6\u884c\u529e\u7406\u7ed3\u5a5a\u767b\u8bb0\u30022019\u5e7412\u670818\u65e5\uff0c\u539f\u544a\u8feb\u4e8e\u538b\u529b\uff0c\u540c\u88ab\u544a\u859b\u67d0\u5728\u5728\u897f\u5b89\u5e02\u65b0\u57ce\u533a\u6c11\u653f\u5c40\u518d\u4e00\u6b21\u9886\u53d6\u4e86\u7ed3\u5a5a\u8bc1\uff0c\u7ed3\u5a5a\u8bc1\u53f7\u4e3a\uff1a\uff2a\u00d7\u00d77\u3002\u5728\u9886\u53d6\u7ed3\u5a5a\u8bc1\u8fc7\u7a0b\u4e2d\uff0c\u88ab\u544a\u859b\u67d0\u4ec5\u8ba9\u539f\u544a\u5411\u897f\u5b89\u5e02\u65b0\u57ce\u533a\u6c11\u653f\u5c40\u63d0\u4f9b\u4e86\u539f\u544a\u4e0e\u7b2c\u4e00\u4efb\u59bb\u5b50\u66f9\u6cc9\u7684\u79bb\u5a5a\u4fe1\u606f\uff0c\u523b\u610f\u9690\u7792\u4e86\u539f\u544a\u4e0e\u7b2c\u4e8c\u4efb\u59bb\u5b50\u5f20\u7ea2\u82f1\u9886\u53d6\u7ed3\u5a5a\u8bc1\u4e14\u5a5a\u59fb\u5173\u7cfb\u5c1a\u5b58\u7eed\u7684\u4e8b\u5b9e\uff0c\u4f7f\u5f97\u6c11\u653f\u5c40\u8bef\u4ee5\u4e3a\u539f\u544a\u7684\u5a5a\u59fb\u72b6\u6001\u4e3a\u79bb\u5f02\u3002\u88ab\u544a\u540c\u539f\u544a\u9886\u53d6\u7ed3\u5a5a\u8bc1\u4e4b\u540e\uff0c\u4fbf\u5c06\u539f\u544a\u7684\u5de5\u8d44\u672c\u3001\u533b\u4fdd\u5361\u7b49\u8d22\u7269\u636e\u4e3a\u5df2\u6709\uff0c\u591a\u6b21\u652f\u53d6\u539f\u544a\u7684\u8d22\u4ea7\uff0c\u539f\u544a\u7d22\u8981\u672a\u679c\u540e\u88ab\u544a\u8fd8\u60f3\u8fdb\u4e00\u6b65\u4fb5\u5360\u539f\u544a\u7684\u623f\u5c4b\u3001\u80a1\u6743\u3001\u6295\u8d44\u6b3e\u7b49\u8d22\u4ea7\u3002\u81f3\u6b64\uff0c\u88ab\u544a\u540c\u539f\u544a\u767b\u8bb0\u7ed3\u5a5a\u7684\u76ee\u7684\u5df2\u7ecf\u5f7b\u5e95\u66b4\u9732\uff0c\u5c31\u662f\u8981\u501f\u5a5a\u59fb\u4e4b\u540d\u7d22\u53d6\u539f\u544a\u7684\u8d22\u7269\uff0c\u4e14\u88ab\u544a\u7684\u884c\u4e3a\u5df2\u7ecf\u6d89\u5acc\u7834\u574f\u519b\u5a5a\u3002\u73b0\u539f\u544a\u4f5c\u4e3a\u4e00\u540d\u9000\u4f11\u519b\u4eba\u5df2\u7ecf\u88ab\u903c\u8feb\u5230\u5fcd\u65e0\u53ef\u5fcd\u7684\u5730\u6b65\uff0c\u53ea\u5f97\u5177\u72b6\u8d77\u8bc9\uff0c\u671b\u8d35\u9662\u67e5\u6e05\u4e8b\u5b9e\uff0c\u4f9d\u6cd5\u5224\u5982\u6240\u8bf7\u3002\", \"defendant_defence\": \"1\u3001\u539f\u3001\u88ab\u544a\u7ecf\u5a5a\u59fb\u767b\u8bb0\u673a\u5173\u4e25\u683c\u5ba1\u67e5\u540e\u7b26\u5408\u6cd5\u5f8b\u89c4\u5b9a\u7684\u6761\u4ef6\uff0c\u5728\u4e25\u683c\u5c65\u884c\u4e86\u6cd5\u5b9a\u7684\u7a0b\u5e8f\u540e\uff0c\u51c6\u4e88\u7ed3\u5a5a\u767b\u8bb0\uff0c\u53d1\u7ed9\u7ed3\u5a5a\u8bc1\u3002\u6839\u636e\u300a\u5a5a\u59fb\u767b\u8bb0\u6761\u4f8b\u300b\uff0c\u7ed3\u5a5a\u767b\u8bb0\u5206\u4e3a\u7533\u8bf7\u3001\u5ba1\u67e5\u548c\u767b\u8bb0\u4e09\u4e2a\u73af\u8282\u3002\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u96f6\u56db\u5341\u4e5d\u6761\u89c4\u5b9a\uff0c\u8981\u6c42\u7ed3\u5a5a\u7684\u7537\u5973\u53cc\u65b9\u5e94\u5f53\u4eb2\u81ea\u5230\u5a5a\u59fb\u767b\u8bb0\u673a\u5173\u7533\u8bf7\u7ed3\u5a5a\u767b\u8bb0\u3002\u7b26\u5408\u672c\u6cd5\u89c4\u5b9a\u7684\uff0c\u4e88\u4ee5\u767b\u8bb0\uff0c\u53d1\u7ed9\u7ed3\u5a5a\u8bc1\u3002\u5b8c\u6210\u7ed3\u5a5a\u767b\u8bb0\uff0c\u5373\u786e\u7acb\u5a5a\u59fb\u5173\u7cfb\u30022019\u5e7412\u670818\u65e5\uff0c\u859b\u67d0\u3001\u674e\u67d0\u4e8c\u4eba\u4f9d\u6cd5\u5411\u65b0\u57ce\u533a\u6c11\u653f\u5c40\u7533\u8bf7\u7ed3\u5a5a\u767b\u8bb0\uff0c\u4e8c\u4eba\u5a5a\u59fb\u5173\u7cfb\u5408\u6cd5\u6709\u6548\uff0c\u5e94\u4e88\u4fdd\u62a4\u3002\\r2\u3001\u674e\u67d0\u4e0e\u5f20\u7ea2\u82f1\u4e0d\u5b58\u5728\u5a5a\u59fb\u5173\u7cfb\uff0c\u53e6\u6848\u4e2d\u5f20\u7ea2\u82f1\u5411\u6cd5\u5ead\u63d0\u4ea4\u7684\u7ed3\u5a5a\u8bc1\u7cfb\u5047\u8bc1\u30023\u3001\u672c\u6848\u8d77\u56e0\u662f\u674e\u67d0\u4e3a\u5e72\u6270\u7834\u574f\u53e6\u6848\uff08\u859b\u67d0\u8bc9\u5f20\u6587\u9999\u4e0d\u5f53\u5f97\u5229\u7ea0\u7eb7\uff09\u8bc9\u8bbc\u8fdb\u7a0b\u7684\u6076\u610f\u4e3a\u4e4b\uff0c\u5e94\u4e88\u60e9\u6212\u3002\u674e\u67d0\u4e0e\u6848\u5916\u4eba\u5f20\u6587\u9999\u5728\u539f\u3001\u88ab\u544a\u4e8c\u4eba\u5a5a\u59fb\u5173\u7cfb\u5b58\u7eed\u671f\u95f4\u957f\u671f\u4fdd\u6301\u4e0d\u6b63\u5f53\u7537\u5973\u5173\u7cfb\u3002\u859b\u67d02023\u5e74\u5411\u65b0\u57ce\u533a\u4eba\u6c11\u6cd5\u9662\u8d77\u8bc9\u5f20\u6587\u9999\u8fd4\u8fd8\u674e\u67d0\u5411\u5176\u8d60\u4e0e\u7684\u8d22\u4ea7\uff0c\u6848\u53f7\u4e3a\uff082023\uff09\u96550102\u6c11\u521d2646\u53f7\uff0c\u5728\u8be5\u6848\u4ef6\u5ba1\u7406\u4e2d\uff0c\u859b\u67d0\u5411\u6cd5\u5ead\u63d0\u4ea4\u7684\u7b2c\u4e00\u7ec4\u8bc1\u636e\u5373\u4e3a\u859b\u674e\u4e8c\u4eba\u5408\u6cd5\u5a5a\u59fb\u5173\u7cfb\u8bc1\u660e\uff0c\u674e\u67d0\u5e76\u672a\u5426\u8ba4\u4e8c\u4eba\u5a5a\u59fb\u5173\u7cfb\u6548\u529b\uff0c\u4ec5\u6297\u8fa9\u6848\u6d89\u6b3e\u9879\u5e76\u975e\u8d60\u4e0e\uff0c\u800c\u662f\u5176\u4e0e\u5f20\u6587\u9999\u5408\u4f5c\u6b3e\u9879\uff0c\u540e\u65b0\u57ce\u533a\u4eba\u6c11\u6cd5\u9662\u5c31\u8be5\u6848\u4f5c\u51fa\u4e00\u5ba1\u5224\u51b3\uff1a\u4e00\u3001\u786e\u8ba4\u88ab\u544a\u674e\u67d0\u5c06\u4e0e\u539f\u544a\u859b\u67d0\u7684\u592b\u59bb\u5171\u540c\u8d22\u4ea7150275\u5143\u8d60\u4e0e\u88ab\u544a\u5f20\u6587\u9999\u7684\u884c\u4e3a\u65e0\u6548\uff1b\u4e8c\u3001\u88ab\u544a\u5f20\u6587\u9999\u81ea\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\u8fd4\u8fd8\u539f\u544a\u859b\u67d0150275\u5143\u3002\u4e00\u5ba1\u5224\u51b3\u4f5c\u51fa\u540e\uff0c\u5f20\u6587\u9999\u4e0e\u674e\u67d0\u63d0\u51fa\u4e0a\u8bc9\uff0c\u5728\u4e0a\u8bc9\u671f\u95f4\uff0c\u674e\u67d0\u5728\u8fd0\u57ce\u5e02\u76d0\u6e56\u533a\u4eba\u6c11\u6cd5\u9662\u63d0\u8d77\u672c\u8bc9\uff0c\u8bc9\u8bf7\u786e\u8ba4\u4e0e\u859b\u67d0\u5a5a\u59fb\u65e0\u6548\uff0c\u5e76\u4ee5\u6b64\u4e3a\u7531\u5411\u897f\u5b89\u5e02\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u7533\u8bf7\u4e2d\u6b62\u6848\u4ef6\u7684\u5ba1\u7406\u3002\u7eb5\u89c2\u674e\u67d0\u4e3b\u5f20\u4e0e\u859b\u67d0\u5a5a\u59fb\u65e0\u6548\u7684\u7406\u7531\u662f\u5728\u4e0e\u859b\u67d0\u7684\u5a5a\u59fb\u5173\u7cfb\u786e\u7acb\u4e4b\u524d\u5df2\u7ecf\u201c\u4e0e\u5f20\u7ea2\u82f1\u5b58\u5728\u5a5a\u59fb\u5173\u7cfb\u201d\u3002\u4f46\u4e8b\u5b9e\u4e0a\uff0c2020\u5e74\u674e\u67d0\u5411\u65b0\u57ce\u533a\u4eba\u6c11\u6cd5\u9662\u8d77\u8bc9\u5f20\u7ea2\u82f1\u8fd4\u8fd8\u539f\u7269\u7ea0\u7eb7\uff0c\u4e00\u5ba1\u3001\u4e8c\u5ba1\u5ead\u5ba1\u4e2d\u5747\u575a\u51b3\u5426\u8ba4\u4e0e\u5f20\u7ea2\u82f1\u6709\u5a5a\u59fb\u5173\u7cfb\uff0c\u5e76\u4e14\u5bf9\u5ead\u5ba1\u4e2d\u5f20\u7ea2\u82f1\u63d0\u4ea4\u7684\u7ed3\u5a5a\u8bc1\u771f\u5b9e\u6027\u4e88\u4ee5\u5426\u8ba4\u3002\u6211\u56fd\u6cd5\u5f8b\u89c4\u5b9a\u4e86\u201c\u7981\u6b62\u53cd\u8a00\u201d\u89c4\u5219\uff0c\u662f\u6307\u5f53\u4e8b\u4eba\u5728\u8bc9\u8bbc\u8fc7\u7a0b\u4e2d\u6240\u5b9e\u65bd\u7684\u8bc9\u8bbc\u884c\u4e3a\u5fc5\u987b\u524d\u540e\u4e00\u81f4\uff0c\u9664\u6cd5\u5b9a\u60c5\u5f62\u5916\uff0c\u7981\u6b62\u5176\u4f5c\u51fa\u524d\u540e\u77db\u76fe\u7684\u8bc9\u8bbc\u884c\u4e3a\u3002\u6c11\u4e8b\u8bc9\u8bbc\u8d2f\u5f7b\u201c\u7981\u6b62\u53cd\u8a00\u201d\u7684\u8bc9\u8bbc\u539f\u7406\u548c\u4e3e\u8bc1\u539f\u5219\uff0c\u4ee5\u4fdd\u8bc1\u5404\u65b9\u5f53\u4e8b\u4eba\u6c11\u4e8b\u8bc9\u8bbc\u6743\u5229\u7684\u516c\u5e73\u884c\u4f7f\u3002\u5f53\u4e8b\u4eba\u5728\u6848\u4ef6\u5ba1\u7406\u8fc7\u7a0b\u4e2d\u51fa\u73b0\u524d\u540e\u77db\u76fe\u7684\u9648\u8ff0\u65f6\uff0c\u5982\u4e0d\u80fd\u5bf9\u77db\u76fe\u9648\u8ff0\u4f5c\u51fa\u5408\u7406\u89e3\u91ca\uff0c\u4ea6\u4e0d\u80fd\u63d0\u4f9b\u5176\u4ed6\u8f85\u52a9\u8bc1\u636e\u4ee5\u8bc1\u660e\u540e\u6b21\u9648\u8ff0\u5185\u5bb9\u5177\u6709\u66f4\u5f3a\u7684\u8bc1\u