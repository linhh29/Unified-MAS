        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u5a5a\u59fb\u5bb6\u5ead\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u767d\u67d0\", \"address\": \"\u9655\u897f\u7701\u897f\u54b8\u65b0\u533a\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1997\u5e7411\u670825\u65e5\"}, \"defendant\": {\"name\": \"\u6731\u67d0\", \"address\": \"\u9655\u897f\u7701\u897f\u54b8\u65b0\u533a\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1995\u5e7412\u670828\u65e5\"}}, \"plaintiff_claim\": [\"\u5224\u51b3\u767d\u67d0\u4e0e\u6731\u67d0\u79bb\u5a5a\", \"\u8bc9\u8bbc\u8d39\u7531\u6731\u67d0\u8d1f\u62c5\"], \"plaintiff_case_details\": \"\u767d\u67d0\u4e8e2018\u5e74\u7ecf\u4ecb\u7ecd\u4e0e\u6731\u67d0\u76f8\u8bc6\u30022018\u5e747\u67083\u65e5\u529e\u7406\u7ed3\u5a5a\u767b\u8bb0\u3002\u53cc\u65b9\u5a5a\u524d\u76f8\u5904\u65f6\u95f4\u77ed\uff0c\u5f7c\u6b64\u4e86\u89e3\u4e0d\u6df1\uff0c\u5bfc\u81f4\u5a5a\u540e\u5e38\u4e3a\u5bb6\u5ead\u7410\u4e8b\u53d1\u751f\u4e89\u5435\uff0c\u77db\u76fe\u91cd\u91cd\u3002\u957f\u6b64\u4ee5\u5f80\uff0c\u5bfc\u81f4\u53cc\u65b9\u611f\u60c5\u6de1\u6f20\uff0c\u65e0\u6cd5\u7ee7\u7eed\u5171\u540c\u751f\u6d3b\u3002\u6731\u67d0\u5728\u5a5a\u59fb\u5b58\u7eed\u671f\u95f4\u7ecf\u5e38\u6000\u7591\u767d\u67d0\uff0c\u5bf9\u767d\u67d0\