        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u5a5a\u59fb\u5bb6\u5ead\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u9648\u67d0\", \"address\": \"\u5317\u4eac\u5e02\u4e30\u53f0\u533a\u4e1c\u9ad8\u5730\u4e07\u6e90\u4e1c\u91cc\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"19xx\u5e74xx\u6708xx\u65e5\"}, \"defendant\": {\"name\": \"\u738b\u67d0\", \"address\": \"\u5317\u4eac\u5e02\u4e30\u53f0\u533a\u4e1c\u9ad8\u5730\u4e07\u6e90\u4e1c\u91cc\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"2000\u5e7412\u67081\u65e5\"}}, \"plaintiff_claim\": [\"\u786e\u8ba4\u9648\u67d0\u4eab\u6709\u4f4d\u4e8eXX6\u53f7\u7684\u623f\u5c4b60%\u7684\u4efd\u989d\", \"\u738b\u67d0\u642c\u79bb6\u53f7\u623f\u5c4b\u5927\u623f\u95f4\"], \"plaintiff_case_details\": \"\u9648\u67d0\u4e0e\u738b\u67d0\u539f\u7cfb\u592b\u59bb\uff0c\u4e8c\u4eba\u4e8e2007\u5e7412\u67087\u65e5\u7ecf\u4eba\u6c11\u6cd5\u9662\u5224\u51b3\u79bb\u5a5a\uff0c\u5e76\u5224\u51b36\u53f7\u623f\u5c4b\u7684\u5c0f\u623f\u95f4\u7531\u738b\u67d0\u5c45\u4f4f\uff0c\u5927\u623f\u95f4\u7531\u9648\u67d0\u5c45\u4f4f\uff0c\u540e\u8be5\u623f\u5c4b\u767b\u8bb0\u4e8e\u738b\u67d0\u540d\u4e0b\u3002\u53cc\u65b9\u79bb\u5a5a\u540e\uff0c\u738b\u67d0\u957f\u671f\u975e\u6cd5\u5360\u6709\u5927\u623f\u95f4\uff0c\u9