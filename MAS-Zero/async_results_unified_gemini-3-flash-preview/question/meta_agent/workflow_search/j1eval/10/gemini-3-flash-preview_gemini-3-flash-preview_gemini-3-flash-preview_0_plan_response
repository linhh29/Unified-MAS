        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u5a5a\u59fb\u5bb6\u5ead\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u8bb8\u67d0\u661f\", \"address\": \"\u6cb3\u5357\u7701\u56fa\u59cb\u53bf\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"2001\u5e741\u670819\u65e5\"}, \"defendant\": {\"name\": \"\u718a\u67d0\u83ca\", \"address\": \"\u6cb3\u5357\u7701\u56fa\u59cb\u53bf\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"2001\u5e744\u670826\u65e5\"}}, \"plaintiff_claim\": [\"\u8981\u6c42\u88ab\u544a\u9000\u8fd8\u5f69\u793c102,541\u5143\", \"\u8981\u6c42\u88ab\u544a\u7ed9\u4e88\u7cbe\u795e\u635f\u5bb3\u8d54\u507f\u8d392\u4e07\u5143\", \"\u672c\u6848\u8bc9\u8bbc\u8d39\u7528\u7531\u88ab\u544a\u627f\u62c5\"], \"plaintiff_case_details\": \"\u539f\u3001\u88ab\u544a\u7ecf\u4eba\u4ecb\u7ecd\u8ba4\u8bc6\uff0c\u5e76\u8ba2\u5a5a\u30022023\u5e746\u6708\u81f32024\u5e748\u670815\u65e5\uff0c\u88ab\u544a\u591a\u6b21\u4e0d\u540c\u610f\u53c8\u53cd\u590d\u540c\u610f\uff0c\u5bf9\u539f\u544a\u4e0d\u70ed\u4e0d\u51b7\uff0c\u6ca1\u6709\u4e00\u70b9\u771f\u5fc3\u3002\u671f\u95f4\uff0c\u539f\u544a\u7236\u6bcd\u7ed9\u4ed8\u88ab\u544a\u8ba2\u5a5a\u548c\u5bf9\u88ab\u544a\u6240\u82b1\u7684\u5f69\u793c\u5171\u8ba1102,541\u5143\u3002\u73b0\u88ab\u544a\u53c8\u8981\u6c42\u9000\u5a5a\uff0c\u5bfc\u81f4\u539f\u544a\u7cbe\u795e\u4e0a\u53d7\u5230\u6781\u5927\u6253\u51fb\uff0c\u6574\u5929\u5403\u4e0d\u597d\u7761\u4e0d\u597d\uff0c\u88ab\u544a\u65e2\u4e0d\u613f\u610f\u4e0e\u539f\u544a\u7ed3\u5a5a\uff0c\u4e5f\u4e0d\u9000\u8fd8\u5f69\u793c\u3002\u56e0\u6b64\u539f\u544a\u8feb\u4e8e\u65e0\u5948\uff0c\u7279\u8bc9\u81f3\u6cd5\u9662\uff0c\u8bf7\u6c42\u6cd5\u9662\u4f9d\u6cd5\u53ca\u65f6\u5904\u7406\u3002\", \"defendant_defence\": \"\u539f\u544a\u79f0\u88ab\u544a\u610f\u89c1\u53cd\u590d\u4e0d\u662f\u4e8b\u5b9e\uff0c\u4e8b\u5b9e\u4e0a\u662f\u53cc\u65b9\u5bf9\u5a5a\u671f\u7684\u786e\u5b9a\u610f\u89c1\u4e0d\u4e00\u81f4\u3002\u539f\u544a\u8981\u6c42\u88ab\u544a\u9000\u8fd8\u5f69\u793c102,541\u5143\u53ca\u7cbe\u795e\u635f\u5bb3\u8d54\u507f\u8d39\u6ca1\u6709\u4f9d\u636e\uff0c\u7b54\u8fa9\u4eba\u6309\u7167\u98ce\u4fd7\u6536\u5230\u7684\u5f69\u793c\u662f10,001\u5143\u548c\u4e00\u679a\u6212\u6307\uff0c\u5176\u4ed6\u5f80\u6765\u662f\u53cc\u65b9\u8d60\u4e88\u884c\u4e3a\uff0c\u6ca1\u6709\u5177\u4f53\u5206\u6e05\u695a\u5404\u65b9\u8d60\u4e88\u7684\u793c\u54c1\u79cd\u7c7b\u3001\u6570\u91cf\uff0c\u88ab\u544a\u5411\u539f\u544a\u4e5f\u6709\u76f8\u5173\u7684\u82b1\u8d39\uff0c\u88ab\u544a\u53bb\u5e74\u529e\u7406\u9152\u5e2d\u82b1\u8d393,800\u5143\uff0c\u4eca\u5e74\u6b63\u6708\u529e\u7406\u9152\u5e2d\u82b1\u8d394,100\u5143\uff0c\u521d\u56db\u9152\u5e2d\u82b1\u8d391,500\u5143\uff0c\u539f\u544a\u5230\u88ab\u544a\u5bb6\u6765\u4e5f\u82b1\u4e86\u56db\u4e94\u5343\u5143\uff0c\u6b63\u6708\u88ab\u544a\u5230\u88ab\u544a\u5bb6\u62dc\u5e74\u4e5f\u5e26\u53bb\u793c\u54c1\u82b1\u8d39\u7ea63,000\u5143\u3002\u8be5\u76f8\u5173\u6b3e\u9879\u5747\u662f\u53cc\u65b9\u589e\u8fdb\u4e86\u89e3\u793c\u5c1a\u5f80\u6765\uff0c\u4e0d\u662f\u5a5a\u59fb\u5f69\u793c\u8fd4\u8fd8\u4e4b\u5217\u3002\u88ab\u544a\u540c\u610f\u8fd4\u8fd810,001\u5143\u5f69\u793c\u548c\u6212\u6307\u4e00\u679a\uff0c\u5176\u4e2d\u6709\u4e00\u4e2a8,000\u5143\u662f\u539f\u544a\u7ed9\u88ab\u544a\u4eb2\u621a\u7684\u7ea2\u530