    {
        "\u3010\u4e8b\u5b9e\u8ba4\u5b9a\u3011\n\u7ecf\u5ba1\u7406\u67e5\u660e\uff1a2023\u5e7410\u67089\u65e517\u65f620\u5206\u5de6\u53f3\uff0c\u88ab\u544a\u77f3\u67d0\u5bb6\u4e2d\u53d1\u751f\u6f0f\u6c34\uff0c\u5bfc\u81f4\u4e0b\u65b9\u539f\u544a\u5218\u67d0\u5bb6\u4e2d\u5899\u9762\u53ca\u5bb6\u5177\u88ab\u6d78\u6ce1\uff0c\u65e0\u6cd5\u6b63\u5e38\u751f\u6d3b\u3002\u4e8b\u6545\u53d1\u751f\u540e\uff0c\u7ecf\u5c45\u59d4\u4f1a\u8c03\u89e3\uff0c\u53cc\u65b9\u672a\u80fd\u8fbe\u6210\u4e00\u81f4\u3002\u539f\u544a\u5218\u67d0\u4e3a\u4fee\u590d\u53d7\u635f\u623f\u5c4b\u5e76\u5904\u7406\u76f8\u5173\u4e8b\u5b9c\uff0c\u4ea7\u751f\u4ee5\u4e0b\u5f00\u652f\uff1a\u7c89\u5237\u5899\u9762\u8d398987\u5143\uff08\u9644\u88c5\u4fee\u5408\u540c\u53ca\u53d1\u7968\uff09\u3001\u4f4f\u5bbf\u8d39236.55\u5143\uff08\u9644\u53d1\u7968\uff09\u3001\u4fdd\u6d01\u8d39960\u5143\uff08\u9644\u53d1\u7968\uff09\u3001\u9910\u8d3946\u5143\uff08\u9644\u53d1\u7968\uff09\u3001\u5145\u7535\u5668\u8d2d\u7f6e\u8d39294\u5143\uff08\u9644\u7535\u5b50\u6536\u636e\uff09\u3001\u7a7a\u8c03\u6302\u673a\u6e05\u6d17\u8d39219\u5143\uff08\u9644\u53d1\u7968\uff09\u3001\u8bef\u5de5\u635f\u59313000\u5143\uff08\u9644\u6708\u6536\u5165\u8bc1\u660e\uff09\u3001\u6696\u6c14\u62c6\u88c5\u8d39500\u5143\uff08\u9644\u6536\u636e\uff09\uff0c\u5404\u9879\u8d39\u7528\u5171\u8ba114242.55\u5143\u3002\u88ab\u544a\u77f3\u67d0\u8ba4\u53ef\u6f0f\u6c34\u4e8b\u5b9e\uff0c\u4f46\u4e3b\u5f20\u539f\u544a\u53d7\u635f\u8303\u56f4\u4ec5\u9650\u4e8e\u5c4b\u9876\u4e00\u5708\uff0c\u8ba4\u4e3a\u8d54\u507f\u91d1\u989d\u8fc7\u9ad8\u3002\n\n\u3010\u6cd5\u9662\u8ba4\u4e3a\u3011\n\u672c\u9662\u8ba4\u4e3a\uff0c\u4e0d\u52a8\u4ea7\u7684\u76f8\u90bb\u6743\u5229\u4eba\u5e94\u5f53\u6309\u7167\u6709\u5229\u751f\u4ea7\u3001\u65b9\u4fbf\u751f\u6d3b\u3001\u56e2\u7ed3\u4e92\u52a9\u3001\u516c\u5e73\u5408\u7406\u7684\u539f\u5219\uff0c\u6b63\u786e\u5904\u7406\u76f8\u90bb\u5173\u7cfb\u3002\u56e0\u7528\u6c34\u3001\u6392\u6c34\u3001\u901a\u884c\u3001\u94fa\u8bbe\u7ba1\u7ebf\u7b49\u5229\u7528\u76f8\u90bb\u4e0d\u52a8\u4ea7\u7684\uff0c\u5e94\u5f53\u5c3d\u91cf\u907f\u514d\u5bf9\u76f8\u90bb\u7684\u4e0d\u52a8\u4ea7\u6743\u5229\u4eba\u9020\u6210\u635f\u5bb3\uff1b\u9020\u6210\u635f\u5bb3\u7684\uff0c\u5e94\u5f53\u627f\u62c5\u4fb5\u6743\u8d23\u4efb\u3002\u672c\u6848\u4e2d\uff0c\u88ab\u544a\u77f3\u67d0\u5bf9\u5176\u623f\u5c4b\u6f0f\u6c34\u5bfc\u81f4\u539f\u544a\u5218\u67d0\u623f\u5c4b\u53ca\u8d22\u4ea7\u53d7\u635f\u7684\u4e8b\u5b9e\u5e76\u65e0\u5f02\u8bae\uff0c\u5e94\u5f53\u4f9d\u6cd5\u627f\u62c5\u8d54\u507f\u8d23\u4efb\u3002\n\u5173\u4e8e\u8d54\u507f\u91d1\u989d\uff0c\u539f\u544a\u5218\u67d0\u5df2\u9488\u5bf9\u5176\u4e3b\u5f20\u7684\u4fee\u590d\u8d39\u3001\u4f4f\u5bbf\u8d39\u3001\u8bef\u5de5\u8d39\u7b49\u63d0\u4ea4\u4e86\u76f8\u5e94\u7684\u53d1\u7968\u3001\u6536\u636e\u53ca\u6536\u5165\u8bc1\u660e\u3002\u5176\u4e2d\uff0c\u5237\u5899\u3001\u6696\u6c14\u62c6\u88c5\u53ca\u4fdd\u6d01\u5c5e\u4e8e\u6062\u590d\u539f\u72b6\u7684\u5fc5\u8981\u652f\u51fa\uff1b\u4f4f\u5bbf\u53ca\u9910\u8d39\u7cfb\u56e0\u623f\u5c4b\u7ef4\u4fee\u671f\u95f4\u65e0\u6cd5\u5c45\u4f4f\u4ea7\u751f\u7684\u5408\u7406\u907f\u5c45\u8d39\u7528\uff1b\u8bef\u5de5\u8d39\u7ed3\u5408\u539f\u544a\u6708\u6536\u5165\u6c34\u5e73\u53ca\u5904\u7406\u7ea0\u7eb7\u3001\u65bd\u5de5\u6240\u9700\u65f6\u95f4\u6838\u5b9a\uff0c\u6570\u989d\u5408\u7406\u3002\u88ab\u544a\u867d\u6297\u8fa9\u539f\u544a\u4e3b\u5f20\u7684\u91d1\u989d\u8fc7\u9ad8\uff0c\u4f46\u672a\u80fd\u63d0\u4f9b\u76f8\u53cd\u8bc1\u636e\u8bc1\u660e\u5404\u9879\u8d39\u7528\u7684\u4e0d\u5408\u7406\u6027\u6216\u5173\u8054\u6027\u7f3a\u5931\u3002\u4f9d\u636e\u300a\u6700\u9ad8\u4eba\u6c11\u6cd5\u9662\u5173\u4e8e\u9002\u7528\u3008\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u3009\u7684\u89e3\u91ca\u300b\u7b2c\u4e5d\u5341\u6761\u4e4b\u89c4\u5b9a\uff0c\u88ab\u544a\u5e94\u627f\u62c5\u4e3e\u8bc1\u4e0d\u5229\u7684\u540e\u679c\u3002\u6545\u672c\u9662\u5bf9\u539f\u544a\u4e3b\u5f20\u7684\u5404\u9879\u635f\u5931\u91d1\u989d\u4e88\u4ee5\u5168\u989d\u652f\u6301\u3002\n\n\u3010\u5224\u51b3\u7ed3\u679c\u3011\n\u5224\u51b3\u5982\u4e0b\uff1a\n\u4e00\u3001\u88ab\u544a\u77f3\u67d0\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\u8d54\u507f\u539f\u544a\u5218\u67d0\u7c89\u5237\u5899\u9762\u8d39\u3001\u4f4f\u5bbf\u8d39\u3001\u4fdd\u6d01\u8d39\u3001\u9910\u8d39\u3001\u5145\u7535\u5668\u8d39\u3001\u7a7a\u8c03\u6e05\u6d17\u8d39\u3001\u8bef\u5de5\u8d39\u3001\u6696\u6c14\u62c6\u88c5\u8d39\u5171\u8ba114242.55\u5143\uff1b\n\u4e8c\u3001\u9a73\u56de\u539f\u544a\u5218\u67d0\u7684\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42\u3002\n\n\u5982\u679c\u672a\u6309\u672c\u5224\u51b3\u6307\u5b9a\u7684\u671f\u95f4\u5c65\u884c\u7ed9\u4ed8\u91d1\u94b1\u4e49\u52a1\uff0c\u5e94\u5f53\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u4e8c\u767e\u516d\u5341\u56db\u6761\u4e4b\u89c4\u5b9a\uff0c\u52a0\u500d\u652f\u4ed8\u8fdf\u5ef6\u5c65\u884c\u671f\u95f4\u7684\u503a\u52a1\u5229\u606f\u3002\n\u6848\u4ef6\u53d7\u7406\u8d39\u7531\u88ab\u544a\u77f3\u67d0\u8d1f\u62c5\u3002": "95% Bootstrap Confidence Interval: (0.0%, 0.0%), Median: 0.0%"
    },
    {
        "\u5317\u4eac\u5e02\u5927\u5174\u533a\u4eba\u6c11\u6cd5\u9662\n\u6c11\u4e8b\u5224\u51b3\u4e66\n\n\uff082024\uff09\u4eac0115\u6c11\u521dXXXX\u53f7\n\n\u539f\u544a\uff1a\u5218\u67d0\uff0c\u5973\uff0c19xx\u5e74xx\u6708xx\u65e5\u51fa\u751f\uff0c\u6c49\u65cf\uff0c\u4f4f\u5317\u4eac\u5e02\u5927\u5174\u533a\u3002\n\u88ab\u544a\uff1a\u77f3\u67d0\uff0c\u7537\uff0c19xx\u5e74xx\u6708xx\u65e5\u51fa\u751f\uff0c\u6c49\u65cf\uff0c\u4f4f\u5317\u4eac\u5e02\u5927\u5174\u533a\u3002\n\n\u539f\u544a\u5218\u67d0\u4e0e\u88ab\u544a\u77f3\u67d0\u8d22\u4ea7\u635f\u5bb3\u8d54\u507f\u7ea0\u7eb7\u4e00\u6848\uff0c\u672c\u9662\u4f9d\u6cd5\u9002\u7528\u666e\u901a\u7a0b\u5e8f\uff0c\u516c\u5f00\u5f00\u5ead\u8fdb\u884c\u4e86\u5ba1\u7406\u3002\u672c\u6848\u73b0\u5df2\u5ba1\u7406\u7ec8\u7ed3\u3002\n\n\u539f\u544a\u5218\u67d0\u5411\u672c\u9662\u63d0\u51fa\u8bc9\u8bbc\u8bf7\u6c42\uff1a1. \u5224\u4ee4\u88ab\u544a\u8d54\u507f\u5237\u5899\u8d39\u75288987\u5143\u3001\u4f4f\u5bbf\u8d39236.55\u5143\u3001\u4fdd\u6d01\u8d39960\u5143\u3001\u9910\u8d3946\u5143\u3001\u5145\u7535\u5668294\u5143\u3001\u7a7a\u8c03\u6e05\u6d17\u8d39219\u5143\u3001\u8bef\u5de5\u8d393000\u5143\u3001\u6696\u6c14\u62c6\u88c5\u8d39500\u5143\uff0c\u5171\u8ba114242.55\u5143\uff1b2. \u8bc9\u8bbc\u8d39\u7528\u7531\u88ab\u544a\u627f\u62c5\u3002\n\n\u88ab\u544a\u77f3\u67d0\u8fa9\u79f0\uff1a\u8ba4\u53ef\u6f0f\u6c34\u4e8b\u5b9e\uff0c\u4f46\u8ba4\u4e3a\u539f\u544a\u4e3b\u5f20\u7684\u8d54\u507f\u6570\u989d\u8fc7\u9ad8\uff0c\u90e8\u5206\u9879\u76ee\u7f3a\u4e4f\u4f9d\u636e\uff0c\u4ec5\u540c\u610f\u8d54\u507f\u5408\u7406\u635f\u5931\u3002\n\n\u672c\u9662\u8ba4\u4e3a\uff1a\u4e0d\u52a8\u4ea7\u7684\u76f8\u90bb\u6743\u5229\u4eba\u5e94\u5f53\u6309\u7167\u6709\u5229\u751f\u4ea7\u3001\u65b9\u4fbf\u751f\u6d3b\u3001\u56e2\u7ed3\u4e92\u52a9\u3001\u516c\u5e73\u5408\u7406\u7684\u539f\u5219\uff0c\u6b63\u786e\u5904\u7406\u76f8\u90bb\u5173\u7cfb\u3002\u7ed9\u76f8\u90bb\u65b9\u9020\u6210\u59a8\u788d\u6216\u8005\u635f\u5931\u7684\uff0c\u5e94\u5f53\u505c\u6b62\u4fb5\u5bb3\uff0c\u6392\u9664\u59a8\u788d\uff0c\u8d54\u507f\u635f\u5931\u3002\u672c\u6848\u4e2d\uff0c\u88ab\u544a\u77f3\u67d0\u5bb6\u53d1\u751f\u6f0f\u6c34\u5bfc\u81f4\u539f\u544a\u5218\u67d0\u5bb6\u53d7\u635f\uff0c\u7406\u5e94\u627f\u62c5\u8d54\u507f\u8d23\u4efb\u3002\n\n\u5173\u4e8e\u5177\u4f53\u8d54\u507f\u6570\u989d\uff0c\u672c\u9662\u8ba4\u5b9a\u5982\u4e0b\uff1a1. \u7c89\u5237\u5899\u9762\u8d39\uff1a\u539f\u544a\u867d\u4e3b\u5f208987\u5143\u5e76\u63d0\u4ea4\u88c5\u4fee\u5408\u540c\uff0c\u4f46\u88ab\u544a\u63d0\u4ea4\u7684\u7167\u7247\u663e\u793a\u53d7\u635f\u90e8\u4f4d\u96c6\u4e2d\u4e8e\u5c4b\u9876\u5c40\u90e8\u3002\u672c\u9662\u7ed3\u5408\u5b9e\u9645\u53d7\u635f\u60c5\u51b5\u53ca\u5e02\u573a\u4ef7\u683c\uff0c\u914c\u60c5\u8ba4\u5b9a\u4e3a3000\u5143\u30022. \u4f4f\u5bbf\u8d39\uff1a\u7cfb\u4fee\u590d\u671f\u95f4\u4ea7\u751f\u7684\u5fc5\u8981\u652f\u51fa\uff0c\u51ed\u53d1\u7968\u8ba4\u5b9a\u4e3a236.55\u5143\u30023. \u4fdd\u6d01\u8d39\uff1a\u539f\u544a\u4e3b\u5f20960\u5143\uff0c\u672c\u9662\u6839\u636e\u623f\u5c4b\u4fee\u590d\u89c4\u6a21\u914c\u60c5\u8ba4\u5b9a\u4e3a300\u5143\u30024. \u8bef\u5de5\u8d39\uff1a\u539f\u544a\u867d\u63d0\u4ea4\u6536\u5165\u8bc1\u660e\uff0c\u4f46\u672a\u80fd\u8bc1\u660e\u5176\u56e0\u672c\u6848\u4fee\u590d\u4e8b\u5b9c\u5bfc\u81f4\u5b9e\u9645\u6536\u5165\u51cf\u5c11\uff0c\u672c\u9662\u4e0d\u4e88\u652f\u6301\u30025. \u7a7a\u8c03\u6e05\u6d17\u8d39\u3001\u6696\u6c14\u62c6\u88c5\u8d39\u3001\u9910\u8d39\u53ca\u5145\u7535\u5668\u8d39\uff1a\u539f\u544a\u63d0\u4ea4\u7684\u8bc1\u636e\u4e0d\u8db3\u4ee5\u8bc1\u660e\u4e0a\u8ff0\u652f\u51fa\u7cfb\u56e0\u6f0f\u6c34\u4e8b\u6545\u5bfc\u81f4\u7684\u5fc5\u8981\u635f\u5931\u6216\u5177\u6709\u76f4\u63a5\u56e0\u679c\u5173\u7cfb\uff0c\u672c\u9662\u5747\u4e0d\u4e88\u652f\u6301\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e8c\u767e\u4e09\u5341\u516b\u6761\u3001\u7b2c\u4e8c\u767e\u516b\u5341\u516b\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u516d\u5341\u4e94\u6761\uff0c\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u516d\u5341\u4e03\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n\u4e00\u3001\u88ab\u544a\u77f3\u67d0\u4e8e\u672c\u5224\u51b3\u751f\u6548\u540e\u5341\u65e5\u5185\u8d54\u507f\u539f\u544a\u5218\u67d0\u7c89\u5237\u5899\u9762\u8d39\u75283000\u5143\u3001\u4f4f\u5bbf\u8d39236.55\u5143\u3001\u4fdd\u6d01\u8d39300\u5143\uff0c\u4ee5\u4e0a\u5171\u8ba13536.55\u5143\uff1b\n\u4e8c\u3001\u9a73\u56de\u539f\u544a\u5218\u67d0\u7684\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42\u3002\n\n\u5982\u679c\u672a\u6309\u672c\u5224\u51b3\u6307\u5b9a\u7684\u671f\u95f4\u5c65\u884c\u7ed9\u4ed8\u91d1\u94b1\u4e49\u52a1\uff0c\u5e94\u5f53\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u4e8c\u767e\u516d\u5341\u56db\u6761\u4e4b\u89c4\u5b9a\uff0c\u52a0\u500d\u652f\u4ed8\u8fdf\u5ef6\u5c65\u884c\u671f\u95f4\u7684\u503a\u52a1\u5229\u606f\u3002\n\n\u6848\u4ef6\u53d7\u7406\u8d3979\u5143\uff0c\u7531\u539f\u544a\u5218\u67d0\u8d1f\u62c569\u5143\uff08\u5df2\u4ea4\u7eb3\uff09\uff0c\u7531\u88ab\u544a\u77f3\u67d0\u8d1f\u62c510\u5143\uff08\u4e8e\u672c\u5224\u51b3\u751f\u6548\u540e\u4e03\u65e5\u5185\u4ea4\u7eb3\uff09\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u5317\u4eac\u5e02\u7b2c\u4e8c\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002\n\n\u5ba1\u5224\u957f XXX\n\u4e8c\u3007\u4e8c\u56db\u5e74 X \u6708 X \u65e5\n\u4e66\u8bb0\u5458 XXX": "95% Bootstrap Confidence Interval: (0.0%, 0.0%), Median: 0.0%"
    },
    {
        "\u5317\u4eac\u5e02\u5927\u5174\u533a\u4eba\u6c11\u6cd5\u9662\n\u6c11\u4e8b\u5224\u51b3\u4e66\n\n\uff082024\uff09\u4eac0115\u6c11\u521dXXXX\u53f7\n\n\u539f\u544a\uff1a\u5218\u67d0\uff0c\u5973\uff0c\u6c49\u65cf\uff0c\u73b0\u4f4f\u5317\u4eac\u5e02\u5927\u5174\u533a\u3002\n\u88ab\u544a\uff1a\u77f3\u67d0\uff0c\u7537\uff0c\u6c49\u65cf\uff0c\u73b0\u4f4f\u5317\u4eac\u5e02\u5927\u5174\u533a\u3002\n\n\u539f\u544a\u5218\u67d0\u4e0e\u88ab\u544a\u77f3\u67d0\u8d22\u4ea7\u635f\u5bb3\u8d54\u507f\u7ea0\u7eb7\u4e00\u6848\uff0c\u672c\u9662\u7acb\u6848\u540e\uff0c\u4f9d\u6cd5\u9002\u7528\u7b80\u6613\u7a0b\u5e8f\uff0c\u516c\u5f00\u5f00\u5ead\u8fdb\u884c\u4e86\u5ba1\u7406\u3002\u672c\u6848\u73b0\u5df2\u5ba1\u7406\u7ec8\u7ed3\u3002\n\n\u539f\u544a\u5218\u67d0\u5411\u672c\u9662\u63d0\u51fa\u8bc9\u8bbc\u8bf7\u6c42\uff1a1. \u5224\u4ee4\u88ab\u544a\u8d54\u507f\u623f\u5c4b\u4fee\u7f2e\u53ca\u76f8\u5173\u8d39\u7528\u5171\u8ba114242.55\u5143\uff08\u5305\u62ec\u5237\u5899\u8d398987\u5143\u3001\u6696\u6c14\u62c6\u88c5\u8d39500\u5143\u3001\u7a7a\u8c03\u6e05\u6d17\u8d39219\u5143\u3001\u4f4f\u5bbf\u8d39236.55\u5143\u3001\u9910\u8d3946\u5143\u3001\u4fdd\u6d01\u8d39960\u5143\u3001\u5145\u7535\u5668294\u5143\u3001\u8bef\u5de5\u8d393000\u5143\uff09\uff1b2. \u672c\u6848\u8bc9\u8bbc\u8d39\u7531\u88ab\u544a\u627f\u62c5\u3002\n\n\u88ab\u544a\u77f3\u67d0\u8fa9\u79f0\uff1a\u8ba4\u53ef\u6f0f\u6c34\u4e8b\u5b9e\uff0c\u4f46\u539f\u544a\u4e3b\u5f20\u7684\u8d54\u507f\u91d1\u989d\u8fc7\u9ad8\u3002\u53d7\u635f\u8303\u56f4\u4ec5\u9650\u4e8e\u5c4b\u9876\u4e00\u5708\uff0c\u65e0\u9700\u5168\u5c4b\u7c89\u5237\uff0c\u4e14\u591a\u9879\u884d\u751f\u8d39\u7528\u7f3a\u4e4f\u4e8b\u5b9e\u4f9d\u636e\u3002\n\n\u672c\u9662\u8ba4\u4e3a\uff0c\u4e0d\u52a8\u4ea7\u7684\u76f8\u90bb\u6743\u5229\u4eba\u5e94\u5f53\u6309\u7167\u6709\u5229\u751f\u4ea7\u3001\u65b9\u4fbf\u751f\u6d3b\u3001\u56e2\u7ed3\u4e92\u52a9\u3001\u516c\u5e73\u5408\u7406\u7684\u539f\u5219\uff0c\u6b63\u786e\u5904\u7406\u76f8\u90bb\u5173\u7cfb\u3002\u88ab\u544a\u77f3\u67d0\u5bb6\u53d1\u751f\u6f0f\u6c34\u9020\u6210\u539f\u544a\u5218\u67d0\u5bb6\u5899\u9762\u53ca\u5bb6\u5177\u53d7\u635f\uff0c\u88ab\u544a\u7406\u5e94\u627f\u62c5\u8d54\u507f\u8d23\u4efb\u3002\u5173\u4e8e\u8d54\u507f\u6570\u989d\uff0c\u672c\u9662\u7ed3\u5408\u53d7\u635f\u7a0b\u5ea6\u3001\u7ef4\u4fee\u5fc5\u8981\u6027\u53ca\u5e02\u573a\u4ef7\u683c\u6838\u5b9a\u5982\u4e0b\uff1a\n1. \u5173\u4e8e\u623f\u5c4b\u4fee\u7f2e\u7c7b\uff1a\u5237\u5899\u8d39\u7528\u3002\u6839\u636e\u88ab\u544a\u63d0\u4ea4\u7684\u7167\u7247\u8bc1\u636e\uff0c\u539f\u544a\u5bb6\u53d7\u635f\u8303\u56f4\u96c6\u4e2d\u5728\u5c4b\u9876\u5c40\u90e8\uff0c\u539f\u544a\u4e3b\u5f20\u5168\u5c4b\u7c89\u5237\u5c5e\u4e8e\u6269\u5927\u635f\u5931\uff0c\u672c\u9662\u7ed3\u5408\u5c40\u90e8\u53d7\u635f\u60c5\u51b5\u914c\u60c5\u652f\u63013000\u5143\u3002\n2. \u5173\u4e8e\u8bbe\u65bd\u7ef4\u62a4\u53ca\u6e05\u7406\u7c7b\uff1a\u6696\u6c14\u62c6\u88c5\u8d39\u53ca\u7a7a\u8c03\u6e05\u6d17\u8d39\u867d\u975e\u76f4\u63a5\u53d7\u635f\uff0c\u4f46\u7cfb\u7ef4\u4fee\u5899\u9762\u7684\u5fc5\u8981\u8f85\u52a9\u652f\u51fa\uff0c\u672c\u9662\u6839\u636e\u5b9e\u9645\u5de5\u4f5c\u91cf\u914c\u60c5\u5206\u522b\u652f\u6301200\u5143\u3001100\u5143\uff1b\u4fdd\u6d01\u8d39\u6309\u5c40\u90e8\u6e05\u7406\u7684\u5e02\u573a\u6807\u51c6\u914c\u5b9a\u4e3a300\u5143\u3002\n3. \u5173\u4e8e\u751f\u6d3b\u652f\u51fa\u7c7b\uff1a\u56e0\u7ef4\u4fee\u671f\u95f4\u786e\u5b9e\u5bf9\u5c45\u4f4f\u9020\u6210\u4e0d\u4fbf\uff0c\u4f4f\u5bbf\u8d39236.55\u5143\u51ed\u7968\u4e88\u4ee5\u652f\u6301\uff1b\u9910\u8d39\u5c5e\u4e8e\u57fa\u672c\u751f\u6d3b\u652f\u51fa\uff0c\u65e0\u8bba\u662f\u5426\u53d1\u751f\u6f0f\u6c34\u5747\u9700\u4ea7\u751f\uff0c\u6545\u4e0d\u4e88\u652f\u6301\u3002\n4. \u5173\u4e8e\u8d22\u7269\u91cd\u7f6e\u7c7b\uff1a\u539f\u544a\u4e3b\u5f20\u5145\u7535\u5668\u635f\u574f\uff0c\u4f46\u672a\u80fd\u63d0\u4ea4\u8bc1\u636e\u8bc1\u660e\u5176\u635f\u574f\u4e0e\u6f0f\u6c34\u4e4b\u95f4\u5b58\u5728\u76f4\u63a5\u56e0\u679c\u5173\u7cfb\uff0c\u672c\u9662\u4e0d\u4e88\u652f\u6301\u3002\n5. \u5173\u4e8e\u6536\u5165\u635f\u5931\u7c7b\uff1a\u6839\u636e\u539f\u544a\u63d0\u4f9b\u7684\u6536\u5165\u8bc1\u660e\uff0c\u5176\u6708\u5747\u6536\u5165\u4e3a8920\u5143\uff0c\u672c\u9662\u6839\u636e\u65bd\u5de5\u5468\u671f\u786e\u5b9a\u8bef\u5de5\u65f6\u95f4\u4e3a3\u5929\uff0c\u6838\u5b9a\u8bef\u5de5\u8d39\u4e3a892\u5143\u3002\n\u7efc\u4e0a\uff0c\u88ab\u544a\u5e94\u8d54\u507f\u539f\u544a\u5404\u9879\u8d39\u7528\u5171\u8ba14728.55\u5143\u3002\n\n\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e8c\u767e\u516b\u5341\u516b\u6761\u3001\u7b2c\u4e8c\u767e\u4e5d\u5341\u516d\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u516d\u5341\u4e94\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u516b\u5341\u56db\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n\u4e00\u3001\u88ab\u544a\u77f3\u67d0\u4e8e\u672c\u5224\u51b3\u751f\u6548\u540e\u5341\u65e5\u5185\u8d54\u507f\u539f\u544a\u5218\u67d0\u623f\u5c4b\u4fee\u7f2e\u8d39\u7528\u3001\u4f4f\u5bbf\u8d39\u3001\u4fdd\u6d01\u8d39\u3001\u7a7a\u8c03\u6e05\u6d17\u8d39\u3001\u8bef\u5de5\u8d39\u3001\u6696\u6c14\u62c6\u88c5\u8d39\u7b49\u5171\u8ba14728.55\u5143\uff1b\n\u4e8c\u3001\u9a73\u56de\u539f\u544a\u5218\u67d0\u7684\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42\u3002\n\n\u5982\u672a\u6309\u672c\u5224\u51b3\u6307\u5b9a\u7684\u671f\u95f4\u5c65\u884c\u7ed9\u4ed8\u91d1\u94b1\u4e49\u52a1\uff0c\u5e94\u5f53\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u4e8c\u767e\u516d\u5341\u56db\u6761\u4e4b\u89c4\u5b9a\uff0c\u52a0\u500d\u652f\u4ed8\u8fdf\u5ef6\u5c65\u884c\u671f\u95f4\u7684\u503a\u52a1\u5229\u606f\u3002\n\n\u6848\u4ef6\u53d7\u7406\u8d39\uff08\u6309\u6bd4\u4f8b\u6298\u7b97\uff09\uff0c\u7531\u539f\u544a\u5218\u67d0\u8d1f\u62c5\u90e8\u5206\uff0c\u88ab\u544a\u77f3\u67d0\u8d1f\u62c5\u90e8\u5206\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u4ee5\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u5317\u4eac\u5e02\u7b2c\u4e00\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002": "95% Bootstrap Confidence Interval: (0.0%, 0.0%), Median: 0.0%"
    },
    {
        "\u5317\u4eac\u5e02\u5927\u5174\u533a\u4eba\u6c11\u6cd5\u9662\n\u6c11\u4e8b\u5224\u51b3\u4e66\n\n\u539f\u544a\uff1a\u5218\u67d0\uff0c\u5973\uff0c\u6c49\u65cf\uff0c19xx\u5e74xx\u6708xx\u65e5\u51fa\u751f\uff0c\u4f4f\u5317\u4eac\u5e02\u5927\u5174\u533a\u3002\n\u88ab\u544a\uff1a\u77f3\u67d0\uff0c\u7537\uff0c\u6c49\u65cf\uff0c19xx\u5e74xx\u6708xx\u65e5\u51fa\u751f\uff0c\u4f4f\u5317\u4eac\u5e02\u5927\u5174\u533a\u3002\n\n\u539f\u544a\u5218\u67d0\u4e0e\u88ab\u544a\u77f3\u67d0\u8d22\u4ea7\u635f\u5bb3\u8d54\u507f\u7ea0\u7eb7\u4e00\u6848\uff0c\u672c\u9662\u7acb\u6848\u540e\uff0c\u4f9d\u6cd5\u9002\u7528\u7b80\u6613\u7a0b\u5e8f\u516c\u5f00\u5f00\u5ead\u8fdb\u884c\u4e86\u5ba1\u7406\u3002\u672c\u6848\u73b0\u5df2\u5ba1\u7406\u7ec8\u7ed3\u3002\n\n\u539f\u544a\u5218\u67d0\u5411\u672c\u9662\u63d0\u51fa\u8bc9\u8bbc\u8bf7\u6c42\uff1a1.\u8981\u6c42\u88ab\u544a\u8d54\u507f\u539f\u544a\u5237\u5899\u8d39\u75288987\u5143\uff0c\u4f4f\u5bbf\u8d39236.55\u5143\uff0c\u4fdd\u6d01\u8d39960\u5143\uff0c\u9910\u8d3946\u5143\uff0c\u5145\u7535\u5668294\u5143\uff0c\u7a7a\u8c03\u6e05\u6d17219\u5143\uff0c\u8bef\u5de5\u8d393000\u5143\uff0c\u6696\u6c14\u62c6\u88c5\u8d39500\u5143\uff0c\u5171\u8ba114242.55\u5143\uff1b2.\u8bc9\u8bbc\u8d39\u7528\u7531\u88ab\u544a\u627f\u62c5\u3002\u4e8b\u5b9e\u548c\u7406\u7531\uff1a2023\u5e7410\u67089\u65e5\uff0c\u88ab\u544a\u77f3\u67d0\u5bb6\u4e2d\u6f0f\u6c34\u5bfc\u81f4\u539f\u544a\u5bb6\u4e2d\u5899\u9762\u53ca\u5bb6\u5177\u6d78\u6ce1\uff0c\u5f71\u54cd\u6b63\u5e38\u751f\u6d3b\u3002\u7ecf\u8c03\u89e3\u65e0\u6548\uff0c\u6545\u8bc9\u81f3\u6cd5\u9662\u3002\n\n\u88ab\u544a\u77f3\u67d0\u8fa9\u79f0\uff1a\u8ba4\u53ef\u6f0f\u6c34\u4e8b\u5b9e\uff0c\u4f46\u4e0d\u540c\u610f\u539f\u544a\u7684\u5168\u90e8\u8d54\u507f\u8bf7\u6c42\u3002\u6839\u636e\u5c45\u59d4\u4f1a\u62cd\u7167\u8bb0\u5f55\uff0c\u6f0f\u6c34\u4ec5\u9020\u6210\u539f\u544a\u623f\u5c4b\u9876\u9762\u8fb9\u7f18\u53d7\u635f\uff0c\u5e76\u975e\u5168\u5c4b\u53d7\u4fb5\u3002\u539f\u544a\u4e3b\u5f20\u7684\u90e8\u5206\u8d39\u7528\u7f3a\u4e4f\u8bc1\u636e\u652f\u6301\u4e14\u6570\u989d\u8fc7\u9ad8\uff0c\u4ec5\u540c\u610f\u8d54\u507f\u5408\u7406\u635f\u5931\u90e8\u5206\u3002\n\n\u672c\u9662\u7ecf\u5ba1\u7406\u67e5\u660e\uff1a2023\u5e7410\u67089\u65e517\u65f620\u5206\u5de6\u53f3\uff0c\u88ab\u544a\u77f3\u67d0\u5bb6\u4e2d\u53d1\u751f\u6f0f\u6c34\uff0c\u5bfc\u81f4\u697c\u4e0b\u539f\u544a\u5218\u67d0\u5bb6\u4e2d\u5899\u9762\u53ca\u8d22\u4ea7\u53d7\u635f\u3002\u539f\u544a\u4e3a\u4fee\u590d\u53d7\u635f\u5899\u9762\u53ca\u5904\u7406\u76f8\u5173\u4e8b\u5b9c\uff0c\u53d1\u751f\u4e86\u88c5\u4fee\u3001\u4f4f\u5bbf\u3001\u4fdd\u6d01\u7b49\u8d39\u7528\u3002\u53e6\u67e5\u660e\uff0c\u6839\u636e\u73b0\u573a\u7167\u7247\u663e\u793a\uff0c\u539f\u544a\u623f\u5c4b\u53d7\u635f\u90e8\u4f4d\u4e3b\u8981\u96c6\u4e2d\u4e8e\u5c4b\u9876\u8fb9\u7f18\u4e00\u5708\uff0c\u5e76\u672a\u8fbe\u5230\u5168\u5c4b\u6d78\u6ce1\u6216\u5927\u89c4\u6a21\u53d7\u635f\u7684\u7a0b\u5ea6\u3002\n\n\u672c\u9662\u8ba4\u4e3a\uff0c\u4e0d\u52a8\u4ea7\u7684\u76f8\u90bb\u6743\u5229\u4eba\u5e94\u5f53\u6309\u7167\u6709\u5229\u751f\u4ea7\u3001\u65b9\u4fbf\u751f\u6d3b\u3001\u56e2\u7ed3\u4e92\u52a9\u3001\u516c\u5e73\u5408\u7406\u7684\u539f\u5219\uff0c\u6b63\u786e\u5904\u7406\u76f8\u90bb\u5173\u7cfb\u3002\u88ab\u544a\u5bb6\u4e2d\u6f0f\u6c34\u7ed9\u539f\u544a\u8d22\u4ea7\u9020\u6210\u635f\u5bb3\uff0c\u5e94\u5f53\u627f\u62c5\u4fb5\u6743\u8d54\u507f\u8d23\u4efb\u3002\u5173\u4e8e\u8d54\u507f\u91d1\u989d\u7684\u8ba4\u5b9a\uff0c\u672c\u9662\u9075\u5faa\u5408\u7406\u6027\u53ca\u56e0\u679c\u5173\u7cfb\u539f\u5219\uff1a\n1. \u5237\u5899\u8d39\uff1a\u539f\u544a\u4e3b\u5f20\u5168\u5c4b\u5237\u65b0\u8d39\u75288987\u5143\uff0c\u4f46\u6839\u636e\u73b0\u573a\u53d7\u635f\u60c5\u51b5\uff0c\u6f0f\u6c34\u5f71\u54cd\u533a\u57df\u8f83\u4e3a\u5c40\u9650\uff0c\u5e76\u975e\u5168\u5c4b\u53d7\u635f\u3002\u672c\u9662\u6839\u636e\u53d7\u635f\u9762\u79ef\u3001\u5e02\u573a\u4fee\u8865\u4ef7\u683c\uff0c\u914c\u60c5\u652f\u63013000\u5143\u3002\n2. \u4fdd\u6d01\u8d39\uff1a\u7ed3\u5408\u6e05\u7406\u53ca\u65bd\u5de5\u96be\u5ea6\uff0c\u672c\u9662\u5c06\u539f\u544a\u4e3b\u5f20\u7684960\u5143\u914c\u60c5\u8c03\u6574\u4e3a300\u5143\u3002\n3. \u4f4f\u5bbf\u8d39\uff1a\u7cfb\u539f\u544a\u5728\u5899\u9762\u65bd\u5de5\u671f\u95f4\u4ea7\u751f\u7684\u5fc5\u8981\u5408\u7406\u8d39\u7528\uff0c\u672c\u9662\u51ed\u7968\u636e\u652f\u6301236.55\u5143\u3002\n4. \u5176\u4ed6\u8d39\u7528\uff1a\u5173\u4e8e\u9910\u8d39\u3001\u5145\u7535\u5668\u8d39\uff0c\u975e\u56e0\u6f0f\u6c34\u76f4\u63a5\u5bfc\u81f4\u7684\u5fc5\u8981\u635f\u5931\uff1b\u5173\u4e8e\u7a7a\u8c03\u6e05\u6d17\u8d39\u53ca\u6696\u6c14\u62c6\u88c5\u8d39\uff0c\u539f\u544a\u672a\u80fd\u8bc1\u660e\u5176\u7cfb\u4fee\u590d\u6f0f\u6c34\u635f\u4f24\u7684\u5fc5\u8981\u652f\u51fa\uff1b\u5173\u4e8e\u8bef\u5de5\u8d39\uff0c\u539f\u544a\u63d0\u4f9b\u7684\u8bc1\u636e\u4e0d\u8db3\u4ee5\u8bc1\u660e\u5176\u56e0\u5904\u7406\u672c\u6848\u7ea0\u7eb7\u4ea7\u751f\u4e86\u5b9e\u9645\u7684\u6536\u5165\u635f\u5931\u3002\u6545\u5bf9\u4e0a\u8ff0\u8bf7\u6c42\uff0c\u672c\u9662\u4e0d\u4e88\u652f\u6301\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e8c\u767e\u516b\u5341\u516b\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u516d\u5341\u4e94\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u516b\u5341\u56db\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n\u4e00\u3001\u88ab\u544a\u77f3\u67d0\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\u8d54\u507f\u539f\u544a\u5218\u67d0\u5237\u5899\u8d39\u3001\u4fdd\u6d01\u8d39\u3001\u4f4f\u5bbf\u8d39\u5171\u8ba13536.55\u5143\uff1b\n\u4e8c\u3001\u9a73\u56de\u539f\u544a\u5218\u67d0\u7684\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42\u3002\n\n\u5982\u672a\u6309\u672c\u5224\u51b3\u6307\u5b9a\u7684\u671f\u95f4\u5c65\u884c\u7ed9\u4ed8\u91d1\u94b1\u4e49\u52a1\uff0c\u5e94\u5f53\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u4e8c\u767e\u516d\u5341\u56db\u6761\u4e4b\u89c4\u5b9a\uff0c\u52a0\u500d\u652f\u4ed8\u8fdf\u5ef6\u5c65\u884c\u671f\u95f4\u7684\u503a\u52a1\u5229\u606f\u3002\n\n\u6848\u4ef6\u53d7\u7406\u8d39\uff08\u6309\u89c4\u5b9a\u51cf\u534a\u6536\u53d6\uff09\uff0c\u7531\u539f\u544a\u8d1f\u62c5\u90e8\u5206\uff0c\u88ab\u544a\u8d1f\u62c5\u90e8\u5206\u3002\n\n\u672c\u5224\u51b3\u4e3a\u7ec8\u5ba1\u5224\u51b3\u3002": "95% Bootstrap Confidence Interval: (0.0%, 0.0%), Median: 0.0%"
    },
    {
        "\u5317\u4eac\u5e02\u5927\u5174\u533a\u4eba\u6c11\u6cd5\u9662\n\u6c11\u4e8b\u5224\u51b3\u4e66\n\n\u539f\u544a\uff1a\u5218\u67d0\uff0c\u5973\uff0c\u6c49\u65cf\uff0c19xx\u5e74xx\u6708xx\u65e5\u51fa\u751f\uff0c\u4f4f\u5317\u4eac\u5e02\u5927\u5174\u533a\u3002\n\u88ab\u544a\uff1a\u77f3\u67d0\uff0c\u7537\uff0c\u6c49\u65cf\uff0c19xx\u5e74xx\u6708xx\u65e5\u51fa\u751f\uff0c\u4f4f\u5317\u4eac\u5e02\u5927\u5174\u533a\u3002\n\n\u539f\u544a\u5218\u67d0\u4e0e\u88ab\u544a\u77f3\u67d0\u8d22\u4ea7\u635f\u5bb3\u8d54\u507f\u7ea0\u7eb7\u4e00\u6848\uff0c\u672c\u9662\u53d7\u7406\u540e\uff0c\u4f9d\u6cd5\u9002\u7528\u7b80\u6613\u7a0b\u5e8f\uff0c\u516c\u5f00\u5f00\u5ead\u8fdb\u884c\u4e86\u5ba1\u7406\u3002\u672c\u6848\u73b0\u5df2\u5ba1\u7406\u7ec8\u7ed3\u3002\n\n\u539f\u544a\u5218\u67d0\u5411\u672c\u9662\u63d0\u51fa\u8bc9\u8bbc\u8bf7\u6c42\uff1a1.\u5224\u4ee4\u88ab\u544a\u8d54\u507f\u5237\u5899\u8d398987\u5143\u3001\u4f4f\u5bbf\u8d39236.55\u5143\u3001\u4fdd\u6d01\u8d39960\u5143\u3001\u9910\u8d3946\u5143\u3001\u5145\u7535\u5668294\u5143\u3001\u7a7a\u8c03\u6e05\u6d17219\u5143\u3001\u8bef\u5de5\u8d393000\u5143\u3001\u6696\u6c14\u62c6\u88c5\u8d39500\u5143\uff0c\u5171\u8ba114242.55\u5143\uff1b2.\u8bc9\u8bbc\u8d39\u7531\u88ab\u544a\u627f\u62c5\u3002\n\n\u88ab\u544a\u77f3\u67d0\u8fa9\u79f0\uff1a\u8ba4\u53ef\u6f0f\u6c34\u4e8b\u5b9e\uff0c\u4f46\u539f\u544a\u4e3b\u5f20\u91d1\u989d\u8fc7\u9ad8\u3002\u7167\u7247\u663e\u793a\u4ec5\u5c4b\u9876\u4e00\u5708\u53d7\u635f\uff0c\u4e0d\u540c\u610f\u8d54\u507f\u5168\u5c4b\u5237\u65b0\u8d39\u7528\u53ca\u5176\u4ed6\u65e0\u4f9d\u636e\u8d39\u7528\u3002\n\n\u672c\u9662\u7ecf\u5ba1\u7406\u8ba4\u5b9a\u4e8b\u5b9e\u5982\u4e0b\uff1a2023\u5e7410\u67089\u65e5\uff0c\u88ab\u544a\u77f3\u67d0\u5bb6\u53d1\u751f\u6f0f\u6c34\uff0c\u5bfc\u81f4\u539f\u544a\u5218\u67d0\u5bb6\u53d7\u635f\u3002\u53cc\u65b9\u56e0\u8d54\u507f\u4e8b\u5b9c\u534f\u5546\u672a\u679c\u3002\u5ead\u5ba1\u4e2d\uff0c\u539f\u544a\u63d0\u4ea4\u4e86\u88c5\u4fee\u5408\u540c\u3001\u53d1\u7968\u53ca\u76f8\u5173\u7968\u636e\u3002\u88ab\u544a\u63d0\u4ea4\u4e86\u5c45\u59d4\u4f1a\u62cd\u6444\u7684\u73b0\u573a\u7167\u7247\u3002\n\n\u672c\u9662\u8ba4\u4e3a\uff0c\u4e0d\u52a8\u4ea7\u7684\u76f8\u90bb\u6743\u5229\u4eba\u5e94\u5f53\u6309\u7167\u6709\u5229\u751f\u4ea7\u3001\u65b9\u4fbf\u751f\u6d3b\u3001\u56e2\u7ed3\u4e92\u52a9\u3001\u516c\u5e73\u5408\u7406\u7684\u539f\u5219\uff0c\u6b63\u786e\u5904\u7406\u76f8\u90bb\u5173\u7cfb\u3002\u88ab\u544a\u77f3\u67d0\u5bb6\u6f0f\u6c34\u7ed9\u539f\u544a\u9020\u6210\u635f\u5931\uff0c\u5e94\u5f53\u627f\u62c5\u8d54\u507f\u8d23\u4efb\u3002\u5173\u4e8e\u8d54\u507f\u6570\u989d\uff0c\u672c\u9662\u8ba4\u5b9a\u5982\u4e0b\uff1a1. \u5237\u5899\u8d39\uff1a\u539f\u544a\u63d0\u4ea4\u4e86\u5168\u5c4b\u5237\u65b0\u7684\u5408\u540c\u53ca\u53d1\u7968\uff0c\u4f46\u6839\u636e\u73b0\u573a\u7167\u7247\u663e\u793a\uff0c\u53d7\u635f\u90e8\u4f4d\u4e3b\u8981\u96c6\u4e2d\u4e8e\u5c4b\u9876\u5c40\u90e8\u3002\u539f\u544a\u4e3b\u5f20\u5168\u5c4b\u5237\u65b0\u8d39\u7528\u7f3a\u4e4f\u5408\u7406\u6027\uff0c\u672c\u9662\u6839\u636e\u5b9e\u9645\u53d7\u635f\u9762\u79ef\u53ca\u5e02\u573a\u4ef7\u683c\uff0c\u914c\u5b9a\u652f\u63013000\u5143\u30022. \u4fdd\u6d01\u8d39\uff1a\u7ed3\u5408\u623f\u5c4b\u6e05\u7406\u7684\u5fc5\u8981\u6027\uff0c\u672c\u9662\u914c\u5b9a\u652f\u6301300\u5143\u30023. \u4f4f\u5bbf\u8d39\uff1a\u786e\u7cfb\u56e0\u7ef4\u4fee\u4ea7\u751f\u7684\u5fc5\u8981\u652f\u51fa\uff0c\u672c\u9662\u6839\u636e\u53d1\u7968\u4e88\u4ee5\u652f\u6301236.55\u5143\u30024. \u8bef\u5de5\u8d39\uff1a\u539f\u544a\u672a\u63d0\u4ea4\u5355\u4f4d\u5b9e\u9645\u6263\u53d1\u5de5\u8d44\u7684\u8bc1\u660e\uff0c\u4e0d\u4e88\u652f\u6301\u30025. \u9910\u8d39\u3001\u5145\u7535\u5668\u3001\u7a7a\u8c03\u6e05\u6d17\u8d39\u3001\u6696\u6c14\u62c6\u88c5\u8d39\uff1a\u539f\u544a\u672a\u80fd\u8bc1\u660e\u4e0a\u8ff0\u8d39\u7528\u4e0e\u672c\u6b21\u6f0f\u6c34\u4e8b\u6545\u5b58\u5728\u76f4\u63a5\u56e0\u679c\u5173\u7cfb\uff0c\u672c\u9662\u4e0d\u4e88\u652f\u6301\u3002\u7efc\u4e0a\uff0c\u88ab\u544a\u5e94\u8d54\u507f\u539f\u544a\u5404\u9879\u8d39\u7528\u5171\u8ba13536.55\u5143\u3002\n\n\u636e\u6b64\uff0c\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e8c\u767e\u516b\u5341\u516b\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u516d\u5341\u4e94\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u516b\u5341\u56db\u6761\uff0c\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u516d\u5341\u4e03\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n\u4e00\u3001\u88ab\u544a\u77f3\u67d0\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u4e03\u65e5\u5185\u8d54\u507f\u539f\u544a\u5218\u67d0\u5404\u9879\u635f\u5931\u5171\u8ba13536.55\u5143\uff1b\n\u4e8c\u3001\u9a73\u56de\u539f\u544a\u5218\u67d0\u7684\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42\u3002\n\n\u5982\u679c\u672a\u6309\u672c\u5224\u51b3\u6307\u5b9a\u7684\u671f\u95f4\u5c65\u884c\u7ed9\u4ed8\u91d1\u94b1\u4e49\u52a1\uff0c\u5e94\u5f53\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u4e8c\u767e\u516d\u5341\u6761\u4e4b\u89c4\u5b9a\uff0c\u52a0\u500d\u652f\u4ed8\u8fdf\u5ef6\u5c65\u884c\u671f\u95f4\u7684\u503a\u52a1\u5229\u606f\u3002\n\n\u672c\u5224\u51b3\u4e3a\u7ec8\u5ba1\u5224\u51b3\u3002\n\n\u5ba1\u5224\u957f\uff1aXXX\n\u4e8c\u3007\u4e8c\u56db\u5e74X\u6708X\u65e5\n\u4e66\u8bb0\u5458\uff1aXXX": "95% Bootstrap Confidence Interval: (0.0%, 0.0%), Median: 0.0%"
