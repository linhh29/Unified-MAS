    {
        "\u9655\u897f\u7701\u5bcc\u5e73\u53bf\u4eba\u6c11\u6cd5\u9662\n\u6c11\u4e8b\u5224\u51b3\u4e66\n\n\uff08202X\uff09\u96550528\u6c11\u521dXXXX\u53f7\n\n\u539f\u544a\uff1a\u738b\u67d0\uff0c\u5973\uff0c1984\u5e7410\u67087\u65e5\u51fa\u751f\uff0c\u6c49\u65cf\uff0c\u4f4f\u9655\u897f\u7701\u6e2d\u5357\u5e02\u5bcc\u5e73\u53bf\u3002\n\u88ab\u544a\uff1a\u6881\u67d01\uff0c\u7537\uff0c1981\u5e7410\u670819\u65e5\u51fa\u751f\uff0c\u6c49\u65cf\uff0c\u4f4f\u9655\u897f\u7701\u6e2d\u5357\u5e02\u5bcc\u5e73\u53bf\u3002\n\n\u539f\u544a\u738b\u67d0\u4e0e\u88ab\u544a\u6881\u67d01\u79bb\u5a5a\u7ea0\u7eb7\u4e00\u6848\uff0c\u672c\u9662\u4e8eXXXX\u5e74X\u6708X\u65e5\u7acb\u6848\u540e\uff0c\u4f9d\u6cd5\u9002\u7528\u7b80\u6613\u7a0b\u5e8f\uff0c\u516c\u5f00\u5f00\u5ead\u8fdb\u884c\u4e86\u5ba1\u7406\u3002\u539f\u544a\u738b\u67d0\u3001\u88ab\u544a\u6881\u67d01\u5747\u5230\u5ead\u53c2\u52a0\u8bc9\u8bbc\u3002\u672c\u6848\u73b0\u5df2\u5ba1\u7406\u7ec8\u7ed3\u3002\n\n\u539f\u544a\u738b\u67d0\u5411\u672c\u9662\u63d0\u51fa\u8bc9\u8bbc\u8bf7\u6c42\uff1a1.\u4f9d\u6cd5\u5224\u4ee4\u539f\u3001\u88ab\u544a\u79bb\u5a5a\uff1b2.\u5a5a\u751f\u5973\u6881\u67d02\u7531\u539f\u544a\u629a\u517b\uff0c\u88ab\u544a\u6bcf\u6708\u627f\u62c51500\u5143\u629a\u517b\u8d39\u81f3\u5b69\u5b50\u5e74\u6ee1\u5341\u516b\u5468\u5c81\u6b62\uff1b3.\u4f9d\u6cd5\u5206\u5272\u592b\u59bb\u5171\u540c\u8d22\u4ea7\uff1b4.\u4f9d\u6cd5\u5206\u5272\u592b\u59bb\u5171\u540c\u503a\u6743\uff1b5.\u6848\u4ef6\u53d7\u7406\u8d39\u7531\u88ab\u544a\u627f\u62c5\u3002\n\u4e8b\u5b9e\u548c\u7406\u7531\uff1a\u539f\u3001\u88ab\u544a\u4e8e2011\u5e745\u6708\u7ecf\u4eba\u4ecb\u7ecd\u76f8\u8bc6\uff0c\u540c\u5e749\u670829\u65e5\u767b\u8bb0\u7ed3\u5a5a\u3002\u00d7\u00d7\u00d7\u00d7\u5e74\u00d7\u00d7\u6708\u00d7\u00d7\u65e5\u751f\u80b2\u4e00\u5973\u3002\u5a5a\u540e\u7531\u4e8e\u53cc\u65b9\u76f8\u8bc6\u65f6\u95f4\u77ed\uff0c\u611f\u60c5\u57fa\u7840\u8584\u5f31\uff0c\u88ab\u544a\u66fe\u5b58\u5728\u4e0d\u5fe0\u884c\u4e3a\u4e14\u957f\u671f\u7f3a\u4e4f\u6c9f\u901a\uff0c\u5bfc\u81f4\u592b\u59bb\u611f\u60c5\u51b7\u6de1\u3002\u81ea2022\u5e7410\u67086\u65e5\u8d77\u539f\u544a\u642c\u51fa\u5c45\u4f4f\uff0c\u53cc\u65b9\u5206\u5c45\u81f3\u4eca\uff0c\u611f\u60c5\u5df2\u5f7b\u5e95\u7834\u88c2\u3002\n\n\u88ab\u544a\u6881\u67d01\u8fa9\u79f0\uff1a\u4e0d\u540c\u610f\u79bb\u5a5a\u3002\u539f\u544a\u4e3b\u5f20\u7684\u5a5a\u59fb\u7ecf\u8fc7\u53ca\u5b69\u5b50\u60c5\u51b5\u5c5e\u5b9e\uff0c\u4f46\u5426\u8ba4\u5b58\u5728\u51fa\u8f68\u884c\u4e3a\u3002\u867d\u7136\u53cc\u65b9\u8fd1\u671f\u6c9f\u901a\u8f83\u5c11\uff0c\u4e14\u539f\u544a\u642c\u81f3\u8001\u623f\u5b50\u5c45\u4f4f\uff0c\u4f46\u88ab\u544a\u7ecf\u5e38\u524d\u5f80\u770b\u671b\u5b69\u5b50\u5e76\u4fee\u7f2e\u623f\u5c4b\uff0c\u53cc\u65b9\u5e76\u672a\u771f\u6b63\u65ad\u7edd\u5f80\u6765\uff0c\u611f\u60c5\u5c1a\u672a\u7834\u88c2\uff0c\u5e0c\u671b\u80fd\u591f\u548c\u597d\u3002\n\n\u672c\u9662\u7ecf\u5ba1\u7406\u8ba4\u5b9a\u4e8b\u5b9e\u5982\u4e0b\uff1a\u539f\u3001\u88ab\u544a\u4e8e2011\u5e749\u670829\u65e5\u767b\u8bb0\u7ed3\u5a5a\uff0c\u5a5a\u540e\u4e8e\u00d7\u00d7\u00d7\u00d7\u5e74\u00d7\u00d7\u6708\u00d7\u00d7\u65e5\u751f\u80b2\u4e00\u5973\u6881\u67d02\u3002\u53cc\u65b9\u5171\u540c\u751f\u6d3b\u671f\u95f4\uff0c\u56e0\u751f\u6d3b\u7410\u4e8b\u53ca\u6c9f\u901a\u95ee\u9898\u4ea7\u751f\u8fc7\u77db\u76fe\u30022022\u5e7410\u6708\uff0c\u539f\u544a\u4ece\u5bb6\u4e2d\u642c\u51fa\u3002\u76ee\u524d\uff0c\u539f\u544a\u672a\u80fd\u63d0\u4f9b\u6709\u6548\u8bc1\u636e\u8bc1\u660e\u88ab\u544a\u5b58\u5728\u91cd\u5a5a\u3001\u4e0e\u4ed6\u4eba\u540c\u5c45\u3001\u5b9e\u65bd\u5bb6\u5ead\u66b4\u529b\u7b49\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u89c4\u5b9a\u7684\u6cd5\u5b9a\u79bb\u5a5a\u60c5\u5f62\u3002\n\n\u672c\u9662\u8ba4\u4e3a\uff0c\u592b\u59bb\u5e94\u5f53\u4e92\u76f8\u5fe0\u5b9e\uff0c\u4e92\u76f8\u5c0a\u91cd\uff0c\u4e92\u76f8\u5173\u7231\u3002\u539f\u3001\u88ab\u544a\u767b\u8bb0\u7ed3\u5a5a\u5341\u4f59\u8f7d\uff0c\u80b2\u6709\u5b50\u5973\uff0c\u4e14\u5171\u540c\u751f\u6d3b\u591a\u5e74\uff0c\u5df2\u5efa\u7acb\u8d77\u4e00\u5b9a\u7684\u611f\u60c5\u57fa\u7840\u3002\u867d\u7136\u53cc\u65b9\u8fd1\u671f\u56e0\u6c9f\u901a\u4e0d\u7545\u53ca\u6027\u683c\u5dee\u5f02\u4ea7\u751f\u77db\u76fe\uff0c\u4f46\u5e76\u672a\u5bfc\u81f4\u592b\u59bb\u611f\u60c5\u5f7b\u5e95\u7834\u88c2\u3002\u539f\u544a\u4e3b\u5f20\u88ab\u544a\u51fa\u8f68\u53ca\u5206\u5c45\u6ee1\u4e24\u5e74\uff0c\u4f46\u672a\u63d0\u4f9b\u5145\u5206\u8bc1\u636e\u4e88\u4ee5\u8bc1\u5b9e\u3002\u5728\u88ab\u544a\u8868\u8fbe\u548c\u597d\u610f\u613f\u7684\u60c5\u51b5\u4e0b\uff0c\u539f\u544a\u5e94\u7ed9\u53cc\u65b9\u4e00\u4e2a\u4fee\u590d\u611f\u60c5\u3001\u6539\u5584\u6c9f\u901a\u7684\u673a\u4f1a\uff0c\u5171\u540c\u7ef4\u62a4\u5bb6\u5ead\u7684\u548c\u8c10\u4e0e\u5b50\u5973\u7684\u6210\u957f\u3002\u6545\u539f\u544a\u8981\u6c42\u79bb\u5a5a\u7684\u8bc9\u8bbc\u8bf7\u6c42\uff0c\u672c\u9662\u4e0d\u4e88\u652f\u6301\u3002\u56e0\u79bb\u5a5a\u8bf7\u6c42\u672a\u83b7\u652f\u6301\uff0c\u5176\u5173\u4e8e\u5b50\u5973\u629a\u517b\u53ca\u8d22\u4ea7\u5206\u5272\u7684\u8bf7\u6c42\uff0c\u672c\u6848\u4ea6\u4e0d\u4e88\u5904\u7406\u3002\n\n\u636e\u6b64\uff0c\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u96f6\u4e03\u5341\u4e5d\u6761\u3001\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u516d\u5341\u4e03\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n\u9a73\u56de\u539f\u544a\u738b\u67d0\u7684\u5168\u90e8\u8bc9\u8bbc\u8bf7\u6c42\u3002\n\n\u6848\u4ef6\u53d7\u7406\u8d39\uff08\u5df2\u51cf\u534a\u6536\u53d6\uff09\u7531\u539f\u544a\u738b\u67d0\u8d1f\u62c5\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u9655\u897f\u7701\u6e2d\u5357\u5e02\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002\n\n\u5ba1\u5224\u5458\uff1a\u00d7\u00d7\u00d7\n\u4e8c\u3007\u4e8cX\u5e74X\u6708X\u65e5\n\u4e66\u8bb0\u5458\uff1a\u00d7\u00d7\u00d7": "95% Bootstrap Confidence Interval: (0.0%, 0.0%), Median: 0.0%"
    },
    {
        "\u9655\u897f\u7701\u5bcc\u5e73\u53bf\u4eba\u6c11\u6cd5\u9662\n\u6c11\u4e8b\u5224\u51b3\u4e66\n\n\uff082023\uff09\u96550528\u6c11\u521dXXX\u53f7\n\n\u539f\u544a\uff1a\u738b\u67d0\uff0c\u5973\uff0c1984\u5e7410\u67087\u65e5\u51fa\u751f\uff0c\u6c49\u65cf\uff0c\u4f4f\u9655\u897f\u7701\u6e2d\u5357\u5e02\u5bcc\u5e73\u53bf\u3002\n\u88ab\u544a\uff1a\u6881\u67d01\uff0c\u7537\uff0c1981\u5e7410\u670819\u65e5\u51fa\u751f\uff0c\u6c49\u65cf\uff0c\u4f4f\u9655\u897f\u7701\u6e2d\u5357\u5e02\u5bcc\u5e73\u53bf\u3002\n\n\u539f\u544a\u738b\u67d0\u4e0e\u88ab\u544a\u6881\u67d01\u79bb\u5a5a\u7ea0\u7eb7\u4e00\u6848\uff0c\u672c\u9662\u4e8e2023\u5e74X\u6708X\u65e5\u7acb\u6848\u540e\uff0c\u4f9d\u6cd5\u9002\u7528\u7b80\u6613\u7a0b\u5e8f\uff0c\u516c\u5f00\u5f00\u5ead\u8fdb\u884c\u4e86\u5ba1\u7406\u3002\u539f\u544a\u738b\u67d0\u3001\u88ab\u544a\u6881\u67d01\u5747\u5230\u5ead\u53c2\u52a0\u8bc9\u8bbc\u3002\u672c\u6848\u73b0\u5df2\u5ba1\u7406\u7ec8\u7ed3\u3002\n\n\u539f\u544a\u738b\u67d0\u5411\u672c\u9662\u63d0\u51fa\u8bc9\u8bbc\u8bf7\u6c42\uff1a1.\u4f9d\u6cd5\u5224\u4ee4\u539f\u3001\u88ab\u544a\u79bb\u5a5a\uff1b2.\u5a5a\u751f\u5973\u6881\u67d02\u7531\u539f\u544a\u629a\u517b\uff0c\u88ab\u544a\u6bcf\u6708\u627f\u62c51500\u5143\u629a\u517b\u8d39\u81f3\u5b69\u5b50\u5e74\u6ee1\u5341\u516b\u5468\u5c81\u6b62\uff1b3.\u4f9d\u6cd5\u5206\u5272\u592b\u59bb\u5171\u540c\u8d22\u4ea7\uff1b4.\u4f9d\u6cd5\u5206\u5272\u592b\u59bb\u5171\u540c\u503a\u6743\uff1b5.\u6848\u4ef6\u53d7\u7406\u8d39\u7531\u88ab\u544a\u627f\u62c5\u3002\u4e8b\u5b9e\u548c\u7406\u7531\uff1a\u539f\u88ab\u544a\u4e8e2011\u5e74\u76f8\u8bc6\u5e76\u7ed3\u5a5a\uff0c\u5a5a\u540e\u611f\u60c5\u57fa\u7840\u8584\u5f31\u3002\u88ab\u544a\u66fe\u5728\u539f\u544a\u6000\u5b55\u671f\u95f4\u51fa\u8f68\uff0c\u4e14\u957f\u671f\u4e0d\u5c65\u884c\u5bb6\u5ead\u4e49\u52a1\uff0c\u53cc\u65b9\u81ea2022\u5e7410\u6708\u8d77\u5206\u5c45\uff0c\u611f\u60c5\u5df2\u5f7b\u5e95\u7834\u88c2\u3002\n\n\u88ab\u544a\u6881\u67d01\u8fa9\u79f0\uff1a\u4e0d\u540c\u610f\u79bb\u5a5a\u3002\u53cc\u65b9\u611f\u60c5\u5e76\u672a\u7834\u88c2\uff0c\u867d\u6709\u6c9f\u901a\u6b20\u7f3a\uff0c\u4f46\u672c\u4eba\u5e76\u65e0\u51fa\u8f68\u884c\u4e3a\u3002\u53cc\u65b9\u5e76\u672a\u771f\u6b63\u5206\u5c45\uff0c\u672c\u4eba\u4e5f\u5c65\u884c\u4e86\u5bb6\u5ead\u8d23\u4efb\uff0c\u5e0c\u671b\u80fd\u591f\u548c\u597d\uff0c\u5171\u540c\u629a\u517b\u5b69\u5b50\u3002\n\n\u7ecf\u5ba1\u7406\u67e5\u660e\uff1a\u539f\u3001\u88ab\u544a\u4e8e2011\u5e745\u6708\u7ecf\u4eba\u4ecb\u7ecd\u76f8\u8bc6\uff0c2011\u5e749\u670829\u65e5\u767b\u8bb0\u7ed3\u5a5a\u3002\u00d7\u00d7\u00d7\u00d7\u5e74\u00d7\u00d7\u6708\u00d7\u00d7\u65e5\u751f\u80b2\u4e00\u5973\u6881\u67d02\u3002\u5a5a\u540e\u521d\u671f\u53cc\u65b9\u611f\u60c5\u5c1a\u53ef\uff0c\u540e\u56e0\u6027\u683c\u5dee\u5f02\u53ca\u6c9f\u901a\u95ee\u9898\u4ea7\u751f\u77db\u76fe\u30022022\u5e7410\u67086\u65e5\uff0c\u539f\u544a\u642c\u79bb\u53cc\u65b9\u5171\u540c\u4f4f\u5904\u3002\u53e6\u67e5\u660e\uff0c\u539f\u544a\u4e3b\u5f20\u88ab\u544a\u66fe\u6709\u4e0d\u5fe0\u884c\u4e3a\uff0c\u4f46\u672a\u80fd\u63d0\u4f9b\u5145\u5206\u8bc1\u636e\u8bc1\u660e\uff0c\u4e14\u53cc\u65b9\u5728\u6b64\u540e\u4ecd\u5171\u540c\u751f\u6d3b\u591a\u5e74\u3002\n\n\u672c\u9662\u8ba4\u4e3a\uff1a\u592b\u59bb\u4e4b\u95f4\u5e94\u5f53\u4e92\u76f8\u5c0a\u91cd\u3001\u4e92\u76f8\u7406\u89e3\u3001\u4e92\u76f8\u4ea4\u6d41\u3002\u539f\u3001\u88ab\u544a\u767b\u8bb0\u7ed3\u5a5a\u5341\u4f59\u5e74\uff0c\u4e14\u80b2\u6709\u4e00\u5973\uff0c\u5171\u540c\u5efa\u7acb\u4e86\u957f\u671f\u7684\u5bb6\u5ead\u751f\u6d3b\uff0c\u5e94\u5f53\u5177\u6709\u8f83\u4e3a\u6df1\u539a\u7684\u611f\u60c5\u57fa\u7840\u3002\u867d\u7136\u539f\u544a\u4e3b\u5f20\u53cc\u65b9\u611f\u60c5\u7834\u88c2\uff0c\u4f46\u5176\u63d0\u4f9b\u7684\u8bc1\u636e\u4e0d\u8db3\u4ee5\u8bc1\u660e\u53cc\u65b9\u5b58\u5728\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u96f6\u4e03\u5341\u4e5d\u6761\u89c4\u5b9a\u7684\u5982\u91cd\u5a5a\u3001\u540c\u5c45\u3001\u5bb6\u5ead\u66b4\u529b\u6216\u5206\u5c45\u6ee1\u4e24\u5e74\u7b49\u6cd5\u5b9a\u5e94\u5f53\u51c6\u4e88\u79bb\u5a5a\u7684\u60c5\u5f62\u3002\u76ee\u524d\u53cc\u65b9\u867d\u56e0\u7410\u4e8b\u4ea7\u751f\u77db\u76fe\u5e76\u4ea7\u751f\u5206\u5c45\uff0c\u4f46\u65f6\u95f4\u8f83\u77ed\uff0c\u4e14\u88ab\u544a\u8868\u8fbe\u4e86\u548c\u597d\u610f\u613f\uff0c\u53cc\u65b9\u611f\u60c5\u5c1a\u672a\u8fbe\u5230\u786e\u5df2\u7834\u88c2\u3001\u65e0\u6cd5\u633d\u56de\u7684\u7a0b\u5ea6\u3002\u539f\u544a\u5e94\u7ed9\u88ab\u544a\u6539\u8fc7\u673a\u4f1a\uff0c\u53cc\u65b9\u52a0\u5f3a\u6c9f\u901a\uff0c\u5171\u540c\u7ecf\u8425\u5bb6\u5ead\uff0c\u66f4\u6709\u5229\u4e8e\u672a\u6210\u5e74\u5b50\u5973\u7684\u5065\u5eb7\u6210\u957f\u3002\u7efc\u4e0a\uff0c\u5bf9\u539f\u544a\u8981\u6c42\u79bb\u5a5a\u7684\u8bc9\u8bbc\u8bf7\u6c42\uff0c\u672c\u9662\u4e0d\u4e88\u652f\u6301\u3002\u9274\u4e8e\u79bb\u5a5a\u8bf7\u6c42\u88ab\u9a73\u56de\uff0c\u539f\u544a\u5173\u4e8e\u5b50\u5973\u629a\u517b\u53ca\u8d22\u4ea7\u5206\u5272\u7684\u8bc9\u8bbc\u8bf7\u6c42\uff0c\u672c\u9662\u4ea6\u4e0d\u4e88\u5ba1\u7406\u3002\n\n\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u96f6\u4e03\u5341\u4e5d\u6761\u3001\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u516d\u5341\u4e03\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n\u9a73\u56de\u539f\u544a\u738b\u67d0\u8981\u6c42\u4e0e\u88ab\u544a\u6881\u67d01\u79bb\u5a5a\u7684\u8bc9\u8bbc\u8bf7\u6c42\u3002\n\n\u6848\u4ef6\u53d7\u7406\u8d39\uff08\u5df2\u51cf\u534a\u6536\u53d6\uff09\uff0c\u7531\u539f\u544a\u738b\u67d0\u8d1f\u62c5\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u9655\u897f\u7701\u6e2d\u5357\u5e02\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002\n\n\u5ba1\u5224\u957f\uff1aXXX\n\u4e8c\u3007\u4e8c\u4e09\u5e74X\u6708X\u65e5\n\u4e66\u8bb0\u5458\uff1aXXX": "95% Bootstrap Confidence Interval: (0.0%, 0.0%), Median: 0.0%"
    },
    {
        "\u9655\u897f\u7701\u5bcc\u5e73\u53bf\u4eba\u6c11\u6cd5\u9662\n\u6c11\u4e8b\u5224\u51b3\u4e66\n\n\uff08202X\uff09\u96550528\u6c11\u521dXXX\u53f7\n\n\u539f\u544a\uff1a\u738b\u67d0\uff0c\u5973\uff0c1984\u5e7410\u67087\u65e5\u751f\uff0c\u6c49\u65cf\uff0c\u4f4f\u9655\u897f\u7701\u6e2d\u5357\u5e02\u5bcc\u5e73\u53bf\u3002 \n\u88ab\u544a\uff1a\u6881\u67d01\uff0c\u7537\uff0c1981\u5e7410\u670819\u65e5\u751f\uff0c\u6c49\u65cf\uff0c\u4f4f\u9655\u897f\u7701\u6e2d\u5357\u5e02\u5bcc\u5e73\u53bf\u3002\n\n\u539f\u544a\u738b\u67d0\u4e0e\u88ab\u544a\u6881\u67d01\u79bb\u5a5a\u7ea0\u7eb7\u4e00\u6848\uff0c\u672c\u9662\u53d7\u7406\u540e\uff0c\u4f9d\u6cd5\u7531\u5ba1\u5224\u5458\u72ec\u4efb\u5ba1\u5224\uff0c\u516c\u5f00\u5f00\u5ead\u8fdb\u884c\u4e86\u5ba1\u7406\u3002\u539f\u544a\u738b\u67d0\u3001\u88ab\u544a\u6881\u67d01\u5747\u5230\u5ead\u53c2\u52a0\u4e86\u8bc9\u8bbc\u3002\u672c\u6848\u73b0\u5df2\u5ba1\u7406\u7ec8\u7ed3\u3002\n\n\u539f\u544a\u738b\u67d0\u5411\u672c\u9662\u63d0\u51fa\u8bc9\u8bbc\u8bf7\u6c42\uff1a1.\u4f9d\u6cd5\u5224\u4ee4\u539f\u3001\u88ab\u544a\u79bb\u5a5a\uff1b2.\u5a5a\u751f\u5973\u6881\u67d02\u7531\u539f\u544a\u629a\u517b\uff0c\u88ab\u544a\u6bcf\u6708\u627f\u62c51500\u5143\u629a\u517b\u8d39\u81f3\u5b69\u5b50\u5e74\u6ee1\u5341\u516b\u5468\u5c81\u6b62\uff1b3.\u4f9d\u6cd5\u5206\u5272\u592b\u59bb\u5171\u540c\u8d22\u4ea7\uff1b4.\u4f9d\u6cd5\u5206\u5272\u592b\u59bb\u5171\u540c\u503a\u6743\uff1b5.\u6848\u4ef6\u53d7\u7406\u8d39\u7531\u88ab\u544a\u627f\u62c5\u3002\n\u4e8b\u5b9e\u4e0e\u7406\u7531\uff1a\u539f\u3001\u88ab\u544a\u4e8e2011\u5e745\u6708\u76f8\u8bc6\uff0c\u540c\u5e749\u670829\u65e5\u767b\u8bb0\u7ed3\u5a5a\u3002\u5a5a\u540e\u80b2\u6709\u4e00\u5973\u6881\u67d02\u3002\u539f\u544a\u79f0\u53cc\u65b9\u611f\u60c5\u57fa\u7840\u8584\u5f31\uff0c\u4e14\u88ab\u544a\u66fe\u5728\u5176\u6000\u5b55\u671f\u95f4\u51fa\u8f68\uff0c\u5a5a\u540e\u6c9f\u901a\u6781\u5c11\uff0c\u611f\u60c5\u6de1\u6f20\u3002\u81ea2022\u5e7410\u67086\u65e5\u81f3\u4eca\uff0c\u53cc\u65b9\u5df2\u5206\u5c45\u3002\u539f\u544a\u8ba4\u4e3a\u88ab\u544a\u957f\u671f\u4e0d\u5c65\u884c\u5bb6\u5ead\u4e49\u52a1\uff0c\u592b\u59bb\u611f\u60c5\u5df2\u5b8c\u5168\u7834\u88c2\u3002\n\n\u88ab\u544a\u6881\u67d01\u8fa9\u79f0\uff1a\u4e0d\u540c\u610f\u79bb\u5a5a\u3002\u53cc\u65b9\u611f\u60c5\u5e76\u672a\u7834\u88c2\uff0c\u867d\u6c9f\u901a\u8f83\u5c11\u4f46\u611f\u60c5\u5c1a\u53ef\u3002\u88ab\u544a\u5426\u8ba4\u51fa\u8f68\uff0c\u4e14\u4e3b\u5f20\u53cc\u65b9\u5e76\u672a\u5b9e\u8d28\u5206\u5c45\uff0c\u5176\u4e00\u76f4\u627f\u62c5\u5bb6\u5ead\u4e49\u52a1\u5e76\u7167\u987e\u5b69\u5b50\uff0c\u5e0c\u671b\u4e0e\u539f\u544a\u548c\u597d\u3002\n\n\u672c\u9662\u7ecf\u5ba1\u7406\u8ba4\u5b9a\u4e8b\u5b9e\u5982\u4e0b\uff1a\u539f\u3001\u88ab\u544a\u4e8e2011\u5e749\u670829\u65e5\u767b\u8bb0\u7ed3\u5a5a\uff0c\u00d7\u00d7\u00d7\u00d7\u5e74\u00d7\u00d7\u6708\u00d7\u00d7\u65e5\u751f\u80b2\u4e00\u5973\u6881\u67d02\u3002\u5ead\u5ba1\u4e2d\uff0c\u539f\u544a\u4e3b\u5f20\u53cc\u65b9\u56e0\u88ab\u544a\u8fc7\u9519\u53ca\u6c9f\u901a\u4e0d\u7545\u5bfc\u81f4\u611f\u60c5\u7834\u88c2\uff0c\u5e76\u81ea2022\u5e7410\u6708\u8d77\u5206\u5c45\uff0c\u4f46\u672a\u63d0\u4ea4\u8db3\u4ee5\u8bc1\u660e\u4e0a\u8ff0\u4e8b\u5b9e\u53ca\u592b\u59bb\u611f\u60c5\u786e\u5df2\u7834\u88c2\u7684\u76f8\u5173\u8bc1\u636e\u3002\u88ab\u544a\u8868\u8fbe\u4e86\u4e0d\u613f\u79bb\u5a5a\u53ca\u6539\u5584\u5173\u7cfb\u7684\u610f\u613f\u3002\n\n\u672c\u9662\u8ba4\u4e3a\uff0c\u592b\u59bb\u5e94\u5f53\u4e92\u76f8\u5fe0\u5b9e\uff0c\u4e92\u76f8\u5c0a\u91cd\uff0c\u4e92\u76f8\u5173\u7231\u3002\u539f\u544a\u738b\u67d0\u4e0e\u88ab\u544a\u6881\u67d01\u7ed3\u5a5a\u591a\u5e74\u5e76\u80b2\u6709\u4e00\u5973\uff0c\u5df2\u5efa\u7acb\u8d77\u4e00\u5b9a\u7684\u592b\u59bb\u611f\u60c5\u3002\u539f\u544a\u867d\u4e3b\u5f20\u592b\u59bb\u611f\u60c5\u5df2\u7834\u88c2\uff0c\u4f46\u672a\u5411\u672c\u9662\u63d0\u4f9b\u5145\u5206\u8bc1\u636e\u8bc1\u660e\u88ab\u544a\u5b58\u5728\u6cd5\u5b9a\u8fc7\u9519\u6216\u53cc\u65b9\u5206\u5c45\u6ee1\u4e24\u5e74\u7b49\u6cd5\u5b9a\u79bb\u5a5a\u60c5\u5f62\u3002\u5728\u88ab\u544a\u8868\u8fbe\u633d\u56de\u610f\u613f\u7684\u60c5\u51b5\u4e0b\uff0c\u539f\u544a\u5e94\u7ed9\u53cc\u65b9\u4e00\u4e2a\u6c9f\u901a\u548c\u6539\u5584\u5173\u7cfb\u7684\u673a\u4f1a\u3002\u672c\u7740\u7ef4\u62a4\u5a5a\u59fb\u5bb6\u5ead\u7a33\u5b9a\u3001\u4fdd\u62a4\u672a\u6210\u5e74\u5b50\u5973\u5065\u5eb7\u6210\u957f\u7684\u539f\u5219\uff0c\u672c\u9662\u5bf9\u539f\u544a\u79bb\u5a5a\u7684\u8bc9\u6c42\u4e0d\u4e88\u652f\u6301\u3002\u56e0\u79bb\u5a5a\u8bf7\u6c42\u88ab\u9a73\u56de\uff0c\u539f\u544a\u5173\u4e8e\u5b50\u5973\u629a\u517b\u3001\u8d22\u4ea7\u53ca\u503a\u6743\u5206\u5272\u7684\u8bc9\u6c42\u4ea6\u5931\u53bb\u4e86\u6cd5\u5f8b\u524d\u63d0\uff0c\u672c\u9662\u4e00\u5e76\u4e88\u4ee5\u9a73\u56de\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u96f6\u4e03\u5341\u4e5d\u6761\uff0c\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u516d\u5341\u4e03\u6761\u7b2c\u4e00\u6b3e\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n\u4e00\u3001\u9a73\u56de\u539f\u544a\u738b\u67d0\u8981\u6c42\u4e0e\u88ab\u544a\u6881\u67d01\u79bb\u5a5a\u7684\u8bc9\u8bbc\u8bf7\u6c42\uff1b\n\u4e8c\u3001\u9a73\u56de\u539f\u544a\u738b\u67d0\u7684\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42\u3002\n\n\u6848\u4ef6\u53d7\u7406\u8d39\uff08\u6309\u89c4\u5b9a\u51cf\u534a\u6536\u53d6\uff09\uff0c\u7531\u539f\u544a\u738b\u67d0\u8d1f\u62c5\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u9655\u897f\u7701\u6e2d\u5357\u5e02\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002\n\n\u5ba1  \u5224  \u957f  XXX\n\u4e8c\u3007\u4e8cX\u5e74X\u6708X\u65e5\n\u4e66  \u8bb0  \u5458  XXX": "95% Bootstrap Confidence Interval: (0.0%, 0.0%), M