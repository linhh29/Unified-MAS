        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u5a5a\u59fb\u5bb6\u5ead\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u738b\u67d0\", \"address\": \"\u9655\u897f\u7701\u6e2d\u5357\u5e02\u5bcc\u5e73\u53bf\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1984\u5e7410\u67087\u65e5\"}, \"defendant\": {\"name\": \"\u6881\u67d01\", \"address\": \"\u9655\u897f\u7701\u6e2d\u5357\u5e02\u5bcc\u5e73\u53bf\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1981\u5e7410\u670819\u65e5\"}}, \"plaintiff_claim\": [\"\u8bf7\u6c42\u4f9d\u6cd5\u5224\u4ee4\u539f\u3001\u88ab\u544a\u79bb\u5a5a\", \"\u8bf7\u6c42\u4f9d\u6cd5\u5224\u4ee4\u5a5a\u751f\u5973\u6881\u67d02\u7531\u539f\u544a\u629a\u517b\uff0c\u88ab\u544a\u6bcf\u6708\u627f\u62c51500\u5143\u629a\u517b\u8d39\u81f3\u5b69\u5b50\u5e74\u6ee1\u5341\u516b\u5468\u5c81\u6b62\", \"\u8bf7\u6c42\u4f9d\u6cd5\u5224\u4ee4\u5206\u5272\u592b\u59bb\u5171\u540c\u8d22\u4ea7\", \"\u8bf7\u6c42\u4f9d\u6cd5\u5224\u4ee4\u5206\u5272\u592b\u59bb\u5171\u540c\u503a\u6743\", \"\u6848\u4ef6\u53d7\u7406\u8d39\u7531\u88ab\u544a\u627f\u62c5\"], \"plaintiff_case_details\": \"\u539f\u3001\u88ab\u544a\u4e8e2011\u5e745\u6708\u7ecf\u4eba\u4ecb\u7ecd\u76f8\u8bc6\uff0c\u4e8e2011\u5e747\u6708\u4efd\u6309\u7167\u519c\u6751\u4e60\u4fd7\u