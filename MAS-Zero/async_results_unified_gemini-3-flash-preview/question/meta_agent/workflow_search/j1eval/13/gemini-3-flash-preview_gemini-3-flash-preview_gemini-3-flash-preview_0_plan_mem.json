    {
        "\u91cd\u5e86\u5e02\u9149\u9633\u571f\u5bb6\u65cf\u82d7\u65cf\u81ea\u6cbb\u53bf\u4eba\u6c11\u6cd5\u9662\n\u6c11\u4e8b\u5224\u51b3\u4e66\n\n\u6848\u53f7\uff1a\uff082024\uff09\u6e1d 0242 \u6c11\u521d XX \u53f7\n\n\u539f\u544a\uff1a\u5189\u67d0\u67d0\uff0c\u5973\uff0c1985\u5e745\u670821\u65e5\u51fa\u751f\uff0c\u571f\u5bb6\u65cf\uff0c\u4f4f\u91cd\u5e86\u5e02\u9149\u9633\u571f\u5bb6\u65cf\u82d7\u65cf\u81ea\u6cbb\u53bf\u3002\n\u88ab\u544a\uff1a\u5189\u67d0\uff0c\u5973\uff0c1971\u5e743\u67086\u65e5\u51fa\u751f\uff0c\u571f\u5bb6\u65cf\uff0c\u4f4f\u91cd\u5e86\u5e02\u6c5f\u6d25\u533a\u3002\n\n\u539f\u544a\u5189\u67d0\u67d0\u4e0e\u88ab\u544a\u5189\u67d0\u8d22\u4ea7\u635f\u5bb3\u8d54\u507f\u7ea0\u7eb7\u4e00\u6848\uff0c\u672c\u9662\u4e8e2024\u5e74\u4f9d\u6cd5\u53d7\u7406\u540e\uff0c\u9002\u7528\u7b80\u6613\u7a0b\u5e8f\u516c\u5f00\u5f00\u5ead\u8fdb\u884c\u4e86\u5ba1\u7406\u3002\u672c\u6848\u73b0\u5df2\u5ba1\u7406\u7ec8\u7ed3\u3002\n\n\u539f\u544a\u8bc9\u79f0\uff1a2024\u5e741\u670825\u65e5\u665a\uff0c\u88ab\u544a\u524d\u5f80\u539f\u544a\u4f4d\u4e8e\u9149\u9633\u53bf\u6c47\u5347\u5e7f\u573a1\u5e6214-2\u7684\u623f\u5c4b\u5904\uff0c\u6301\u7269\u5c06\u539f\u544a\u6240\u6709\u7684\u9632\u76d7\u95e8\u780d\u574f\u3002\u539f\u544a\u62a5\u8b66\u540e\uff0c\u7531\u6c11\u8b66\u5904\u7406\u3002\u6545\u539f\u544a\u8bc9\u81f3\u6cd5\u9662\u8bf7\u6c42\uff1a1. \u5224\u4ee4\u88ab\u544a\u8d54\u507f\u9632\u76d7\u95e8\u635f\u59314000\u5143\uff1b2. \u672c\u6848\u8bc9\u8bbc\u8d39\u7531\u88ab\u544a\u627f\u62c5\u3002\n\n\u88ab\u544a\u8fa9\u79f0\uff1a\u5176\u60a3\u6709\u80a2\u4f53\u6b8b\u75be\uff0c\u6ca1\u6709\u80fd\u529b\u4e5f\u672a\u5bf9\u623f\u95e8\u9020\u6210\u635f\u5bb3\u3002\n\n\u672c\u9662\u7ecf\u5ba1\u7406\u8ba4\u5b9a\u4e8b\u5b9e\u5982\u4e0b\uff1a2024\u5e741\u670825\u65e5\uff0c\u88ab\u544a\u5189\u67d0\u4e0e\u539f\u544a\u53d1\u751f\u4e89\u6267\uff0c\u81f4\u539f\u544a\u4f4d\u4e8e\u9149\u9633\u53bf\u6c47\u5347\u5e7f\u573a1\u5e6214-2\u623f\u5c4b\u7684\u9632\u76d7\u95e8\u53d7\u635f\u3002\u539f\u544a\u5f53\u65e5\u5411\u91cd\u5e86\u5e02\u9149\u9633\u53bf\u516c\u5b89\u5c40\u57ce\u5357\u6d3e\u51fa\u6240\u62a5\u8b66\uff0c\u6c11\u8b66\u5230\u573a\u8fdb\u884c\u4e86\u5904\u7f6e\u3002\u539f\u544a\u4e3a\u652f\u6301\u5176\u4e3b\u5f20\uff0c\u5411\u672c\u9662\u63d0\u4ea4\u4e86\u62a5\u8b66\u56de\u6267\u53ca\u53d7\u635f\u7167\u7247\u3002\u88ab\u544a\u867d\u8fa9\u79f0\u5176\u65e0\u529b\u9020\u6210\u635f\u5bb3\uff0c\u4f46\u672a\u63d0\u4ea4\u5145\u5206\u8bc1\u636e\u8bc1\u660e\u5176\u4e3b\u5f20\u3002\n\n\u672c\u9662\u8ba4\u4e3a\uff1a\u884c\u4e3a\u4eba\u56e0\u8fc7\u9519\u4fb5\u5bb3\u4ed6\u4eba\u6c11\u4e8b\u6743\u76ca\u9020\u6210\u635f\u5bb3\u7684\uff0c\u5e94\u5f53\u627f\u62c5\u4fb5\u6743\u8d23\u4efb\u3002\u4fb5\u5bb3\u4ed6\u4eba\u8d22\u4ea7\u7684\uff0c\u8d22\u4ea7\u635f\u5931\u6309\u7167\u635f\u5931\u53d1\u751f\u65f6\u7684\u5e02\u573a\u4ef7\u683c\u6216\u8005\u5176\u4ed6\u5408\u7406\u65b9\u5f0f\u8ba1\u7b97\u3002\u672c\u6848\u4e2d\uff0c\u88ab\u544a\u56e0\u8fc7\u9519\u5bfc\u81f4\u539f\u544a\u9632\u76d7\u95e8\u53d7\u635f\u7684\u4e8b\u5b9e\uff0c\u6709\u62a5\u8b66\u56de\u6267\u53ca\u7167\u7247\u4f50\u8bc1\uff0c\u8bc1\u636e\u94fe\u5b8c\u6574\uff0c\u672c\u9662\u4e88\u4ee5\u786e\u8ba4\u3002\u88ab\u544a\u5173\u4e8e\u81ea\u8eab\u6b8b\u75be\u65e0\u6cd5\u9020\u6210\u635f\u5bb3\u7684\u6297\u8fa9\u7406\u7531\u7f3a\u4e4f\u8bc1\u636e\u652f\u6301\uff0c\u672c\u9662\u4e0d\u4e88\u91c7\u4fe1\u3002\u539f\u544a\u4e3b\u5f20\u7684\u8d54\u507f\u91d1\u989d4000\u5143\uff0c\u7b26\u5408\u53d7\u635f\u6807\u7684\u7269\u7684\u4ef7\u503c\u5c5e\u6027\u53ca\u5b9e\u9645\u53d7\u635f\u60c5\u51b5\uff0c\u672c\u9662\u4e88\u4ee5\u652f\u6301\u3002\n\n\u636e\u6b64\uff0c\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u516d\u5341\u4e94\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u516b\u5341\u56db\u6761\uff0c\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u516d\u5341\u4e03\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n\u4e00\u3001 \u88ab\u544a\u5189\u67d0\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\u8d54\u507f\u539f\u544a\u5189\u67d0\u67d0\u9632\u76d7\u95e8\u635f\u59314000\u5143\uff1b\n\u4e8c\u3001 \u672c\u6848\u6848\u4ef6\u53d7\u7406\u8d3950\u5143\uff0c\u7531\u88ab\u544a\u5189\u67d0\u8d1f\u62c5\u3002\n\n\u5982\u679c\u672a\u6309\u672c\u5224\u51b3\u6307\u5b9a\u7684\u671f\u95f4\u5c65\u884c\u7ed9\u4ed8\u91d1\u94b1\u4e49\u52a1\uff0c\u5e94\u5f53\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u4e8c\u767e\u516d\u5341\u56db\u6761\u4e4b\u89c4\u5b9a\uff0c\u52a0\u500d\u652f\u4ed8\u8fdf\u5ef6\u5c65\u884c\u671f\u95f4\u7684\u503a\u52a1\u5229\u606f\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u91cd\u5e86\u5e02\u7b2c\u56db\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002\n\n\u5ba1\u5224\u5458\uff1aXXX\n\n\u4e8c\u3007\u4e8c\u56db\u5e74 X \u6708 X \u65e5\n\n\u4e66\u8bb0\u5458\uff1aXXX": "95% Bootstrap Confidence Interval: (0.0%, 0.0%), Median: 0.0%"
