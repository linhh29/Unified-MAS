        "example_id": 7,
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u5a5a\u59fb\u5bb6\u5ead\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u767d\u67d0\", \"address\": \"\u9655\u897f\u7701\u897f\u54b8\u65b0\u533a\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1997\u5e7411\u670825\u65e5\"}, \"defendant\": {\"name\": \"\u6731\u67d0\", \"address\": \"\u9655\u897f\u7701\u897f\u54b8\u65b0\u533a\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1995\u5e7412\u670828\u65e5\"}}, \"plaintiff_claim\": [\"\u5224\u51b3\u767d\u67d0\u4e0e\u6731\u67d0\u79bb\u5a5a\", \"\u8bc9\u8bbc\u8d39\u7531\u6731\u67d0\u8d1f\u62c5\"], \"plaintiff_case_details\": \"\u767d\u67d0\u4e8e2018\u5e74\u7ecf\u4ecb\u7ecd\u4e0e\u6731\u67d0\u76f8\u8bc6\u30022018\u5e747\u67083\u65e5\u529e\u7406\u7ed3\u5a5a\u767b\u8bb0\u3002\u53cc\u65b9\u5a5a\u524d\u76f8\u5904\u65f6\u95f4\u77ed\uff0c\u5f7c\u6b64\u4e86\u89e3\u4e0d\u6df1\uff0c\u5bfc\u81f4\u5a5a\u540e\u5e38\u4e3a\u5bb6\u5ead\u7410\u4e8b\u53d1\u751f\u4e89\u5435\uff0c\u77db\u76fe\u91cd\u91cd\u3002\u957f\u6b64\u4ee5\u5f80\uff0c\u5bfc\u81f4\u53cc\u65b9\u611f\u60c5\u6de1\u6f20\uff0c\u65e0\u6cd5\u7ee7\u7eed\u5171\u540c\u751f\u6d3b\u3002\u6731\u67d0\u5728\u5a5a\u59fb\u5b58\u7eed\u671f\u95f4\u7ecf\u5e38\u6000\u7591\u767d\u67d0\uff0c\u5bf9\u767d\u67d0\u5404\u79cd\u731c\u5fcc\uff0c\u7ed9\u767d\u67d0\u9020\u6210\u5de8\u5927\u7cbe\u795e\u538b\u529b\u3002\u6731\u67d0\u5bf9\u5bb6\u5ead\u4ed8\u51fa\u751a\u5c11\uff0c\u4e5f\u5f88\u5c11\u7ed9\u4ed8\u767d\u67d0\u751f\u6d3b\u8d39\u3002\u6731\u67d0\u5bf9\u767d\u67d0\u65e5\u5e38\u751f\u6d3b\u8d77\u5c45\u758f\u4e8e\u7167\u987e\uff0c\u5bf9\u5bb6\u5ead\u6781\u5ea6\u4e0d\u8d1f\u8d23\u4efb\u3002\u516c\u5a46\u4e5f\u5bf9\u767d\u67d0\u6307\u6307\u70b9\u70b9\u3001\u6076\u8bed\u76f8\u52a0\u3002\u767d\u67d0\u7684\u7236\u6bcd\u591a\u6b21\u4ece\u4e2d\u8c03\u548c\uff0c\u6545\u767d\u67d0\u767e\u822c\u5fcd\u8ba9\uff0c\u4f46\u5374\u65e0\u6d4e\u4e8e\u4e8b\u3002\u767d\u67d0\u65e0\u6cd5\u5fcd\u53d7\u8fd9\u79cd\u6ca1\u6709\u611f\u60c5\u3001\u6ca1\u6709\u6e29\u6696\u7684\u592b\u59bb\u751f\u6d3b\uff0c\u5bf9\u5a5a\u59fb\u6781\u5176\u5931\u671b\u3001\u5fc3\u75db\u4e0d\u5df2\u3002\u767d\u67d0\u3001\u6731\u67d0\u6700\u7ec8\u4e8e2020\u5e748\u6708\u5f00\u59cb\u5206\u5c45\uff0c\u53cc\u65b9\u4e92\u76f8\u4e0d\u5c3d\u592b\u59bb\u4e49\u52a1\u3002\u6731\u67d0\u672a\u5c31\u6539\u5584\u53cc\u65b9\u5173\u7cfb\u505a\u51fa\u4efb\u4f55\u52aa\u529b\u3002\u53cc\u65b9\u6240\u5728\u7684\u5317\u675c\u5357\u6731\u5218\u6751\u8fdb\u884c\u62c6\u8fc1\uff0c\u6731\u67d0\u53ca\u5176\u5bb6\u4eba\u672a\u5c06\u767d\u67d0\u5e94\u5f97\u7684\u90e8\u5206\u5411\u767d\u67d0\u7ed9\u4ed8\u3002\u6cd5\u9662\u66fe\u5224\u51b3\u4e0d\u51c6\u79bb\u5a5a\uff0c\u4f46\u5176\u540e\u53cc\u65b9\u4ecd\u7136\u5904\u4e8e\u5206\u5c45\u72b6\u6001\uff0c\u5206\u5c45\u65f6\u95f4\u5df2\u6ee1\u4e00\u5e74\u3002\u767d\u67d0\u4f9d\u6cd5\u8bc9\u81f3\u6cd5\u9662\uff0c\u671b\u5c3d\u5feb\u7ed3\u675f\u8fd9\u6bb5\u4e0d\u5e78\u798f\u7684\u5a5a\u59fb\u3002\", \"defendant_defence\": \"\u4e0d\u540c\u610f\u79bb\u5a5a\u3002\u53cc\u65b9\u4e8e2018\u5e74\u76f8\u8bc6\u7ed3\u5a5a\uff0c2019\u5e745\u6708\u4e3e\u529e\u7ed3\u5a5a\u4eea\u5f0f\u30022020\u5e74\u521d\uff0c\u767d\u67d0\u56e0\u6545\u79bb\u5bb6\u81f3\u4eca\u3002\u767d\u67d0\u9648\u8ff0\u7684\u4e0e\u516c\u5a46\u6709\u5173\u7684\u5185\u5bb9\u4e0e\u4e8b\u5b9e\u4e0d\u7b26\u3002\u867d\u7136\u767d\u67d0\u66fe\u8d77\u8bc9\u79bb\u5a5a\uff0c\u4f46\u53cc\u65b9\u4ecd\u7136\u53ef\u4ee5\u7ee7\u7eed\u751f\u6d3b\uff0c\u53cc\u65b9\u611f\u60c5\u4ecd\u6709\u633d\u56de\u7684\u53ef\u80fd\u3002\u5982\u679c\u79bb\u5a5a\uff0c\u767d\u67d0\u5e94\u8be5\u8fd4\u8fd889000\u5143\u5f69\u793c\uff0c\u5e76\u7ed9\u4e88\u6731\u67d0\u751f\u6d3b\u5e2e\u52a9\u91d1\u548c\u7cbe\u795e\u635f\u5bb3\u629a\u6170\u91d1\u540420000\u5143\u3002\", \"evidence\": {\"plaintiff_evidence\": {\"evidence_1\": {\"evidence\": \"\u5a5a\u59fb\u767b\u8bb0\u5ba1\u67e5\u88681\u5f20\", \"dispute\": \"\"}, \"evidence_2\": {\"evidence\": \"\u8bc1\u660e1\u5f20\u3001\u6c11\u4e8b\u5224\u51b3\u4e661\u4efd\", \"dispute\": \"\"}, \"evidence_3\": {\"evidence\": \"215\u533b\u9662\u4f4f\u9662\u75c5\u6848\u8d39\u7528\u6e05\u53551\u4efd\u3001\u533b\u7597\u8d39\u4f4f\u9662\u6536\u8d39\u7968\u636e1\u5f20\", \"dispute\": \"\u4e0d\u5177\u6709\u5173\u8054\u6027\"}, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null, \"evidence_10\": null}, \"defendant_evidence\": {\"evidence_1\": {\"evidence\": \"\u8bc1\u660e1\u5f20\u3001\u8bc1\u4eba\u8eab\u4efd\u8bc1\u590d\u5370\u4ef61\u5f20\", \"dispute\": \"\u8bc1\u636e\u5f62\u5f0f\u4e0d\u5408\u6cd5\", \"name\": null}, \"evidence_2\": {\"evidence\": \"\u75c5\u68483\u5957\", \"dispute\": \"\"}, \"evidence_3\": {\"evidence\": \"\u5feb\u624b\u7167\u7247\u622a\u56fe7\u5f20\", \"dispute\": \"\u627f\u8ba4\u56fe\u4e2d\u5973\u6027\u4e3a\u81ea\u5df1\"}, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null}}, \"other_statement\": {\"plaintiff\": {\"plaintiff_1\": \"\"}, \"defendant\": {\"defendant_1\": \"\"}}}\n\u6700\u540e\u5728\u65b0\u7684\u4e00\u884c\u4ee5 'Answer:' \u5f00\u5934\u7ed9\u51fa\u7b80\u6d01\u7684\u6700\u7ec8\u88c1\u5224\u4e3b\u6587\u3002",
        "correct_answer": [
            "\u51c6\u8bb8\u767d\u67d0\u4e0e\u6731\u67d0\u79bb\u5a5a\u3002",
            "\u767d\u67d0\u4e8e\u672c\u5224\u51b3\u4e66\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\uff0c\u5411\u6731\u67d0\u8fd4\u8fd8\u5f69\u793c9000\u5143\u3002",
            "\u6731\u67d0\u4e8e\u672c\u5224\u51b3\u4e66\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\uff0c\u5411\u767d\u67d0\u7ed9\u4ed8\u966a\u5ac1\u7269\u6298\u4ef7\u6b3e2000\u5143\u3002",
            "\u767d\u67d0\u4e8e\u672c\u5224\u51b3\u4e66\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\uff0c\u5411\u6731\u67d0\u7ed9\u4ed8\u7ecf\u6d4e\u5e2e\u52a915000\u5143\u3002",
            "\u767d\u67d0\u4e8e\u672c\u5224\u51b3\u4e66\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\uff0c\u5411\u6731\u67d0\u7ed9\u4ed8\u635f\u5bb3\u8d54\u507f15000\u5143\u3002",
            "\u5982\u679c\u672a\u6309\u672c\u5224\u51b3\u6307\u5b9a\u7684\u671f\u95f4\u5c65\u884c\u7ed9\u4ed8\u4e49\u52a1\uff0c\u5e94\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u4e8c\u767e\u516d\u5341\u56db\u6761\u4e4b\u89c4\u5b9a\uff0c\u52a0\u500d\u652f\u4ed8\u8fdf\u5ef6\u5c65\u884c\u671f\u95f4\u7684\u503a\u52a1\u5229\u606f\u3002",
            "\u6848\u4ef6\u53d7\u7406\u8d39300\u5143\uff0c\u51cf\u534a\u6536\u53d6150\u5143\uff0c\u7531\u767d\u67d0\u548c\u6731\u67d0\u5404\u534a\u8d1f\u62c5\u3002",
            "\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u672c\u5224\u51b3\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u4eba\u6570\u63d0\u4ea4\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u9655\u897f\u7701\u54b8\u9633\u5e02\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002"
        ],
        "n": 0,
        "response": "**\u9655\u897f\u7701\u897f\u54b8\u65b0\u533a\u4eba\u6c11\u6cd5\u9662**\n**\u6c11\u4e8b\u5224\u51b3\u4e66**\n\n**\u672c\u9662\u7ecf\u5ba1\u7406\u67e5\u660e\uff1a**\n\u539f\u544a\u767d\u67d0\u4e0e\u88ab\u544a\u6731\u67d0\u4e8e2018\u5e74\u7ecf\u4eba\u4ecb\u7ecd\u76f8\u8bc6\uff0c\u4e8e2018\u5e747\u67083\u65e5\u767b\u8bb0\u7ed3\u5a5a\u3002\u5a5a\u540e\u53cc\u65b9\u56e0\u6027\u683c\u5dee\u5f02\u3001\u5bb6\u5ead\u7410\u4e8b\u53ca\u6c9f\u901a\u4e0d\u7545\u7b49\u539f\u56e0\uff0c\u672a\u80fd\u5efa\u7acb\u6df1\u539a\u7684\u592b\u59bb\u611f\u60c5\uff0c\u77db\u76fe\u65e5\u76ca\u79ef\u7d2f\u3002\u539f\u544a\u66fe\u5411\u672c\u9662\u63d0\u8d77\u79bb\u5a5a\u8bc9\u8bbc\uff0c\u672c\u9662\u4e8e\u524d\u6b21\u5224\u51b3\u4e2d\u4e0d\u4e88\u51c6\u8bb8\u79bb\u5a5a\u3002\u4f46\u5728\u8be5\u5224\u51b3\u751f\u6548\u540e\uff0c\u53cc\u65b9\u5e76\u672a\u6539\u5584\u5173\u7cfb\uff0c\u4ecd\u6301\u7eed\u5206\u5c45\u751f\u6d3b\u81f3\u4eca\u5df2\u903e\u4e00\u5e74\uff0c\u4e92\u4e0d\u5c65\u884c\u592b\u59bb\u4e49\u52a1\uff0c\u592b\u59bb\u5173\u7cfb\u540d\u5b58\u5b9e\u4ea1\u3002\n\n**\u672c\u9662\u8ba4\u4e3a\uff1a**\n\u592b\u59bb\u611f\u60c5\u662f\u5426\u786e\u5df2\u7834\u88c2\u662f\u5224\u51b3\u51c6\u4e88\u79bb\u5a5a\u7684\u6cd5\u5b9a\u6807\u51c6\u3002\u5728\u672c\u6848\u4e2d\uff0c\u539f\u3001\u88ab\u544a\u5a5a\u524d\u4e86\u89e3\u4e0d\u8db3\uff0c\u5a5a\u540e\u672a\u5efa\u7acb\u8d77\u7a33\u56fa\u7684\u611f\u60c5\u57fa\u7840\u3002\u5728\u6cd5\u9662\u5224\u51b3\u4e0d\u51c6\u79bb\u5a5a\u540e\uff0c\u53cc\u65b9\u53c8\u5206\u5c45\u6ee1\u4e00\u5e74\uff0c\u4e14\u539f\u544a\u518d\u6b21\u63d0\u8d77\u79bb\u5a5a\u8bc9\u8bbc\u3002\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u96f6\u4e03\u5341\u4e5d\u6761\u7b2c\u4e94\u6b3e\u4e4b\u89c4\u5b9a\uff1a\u201c\u7ecf\u4eba\u6c11\u6cd5\u9662\u5224\u51b3\u4e0d\u51c6\u79bb\u5a5a\u540e\uff0c\u53cc\u65b9\u53c8\u5206\u5c45\u6ee1\u4e00\u5e74\uff0c\u4e00\u65b9\u518d\u6b21\u63d0\u8d77\u79bb\u5a5a\u8bc9\u8bbc\u7684\uff0c\u5e94\u5f53\u51c6\u4e88\u79bb\u5a5a\u3002\u201d\u6545\u539f\u544a\u767d\u67d0\u8981\u6c42\u79bb\u5a5a\u7684\u8bc9\u8bbc\u8bf7\u6c42\uff0c\u7b26\u5408\u6cd5\u5f8b\u89c4\u5b9a\uff0c\u672c\u9662\u4e88\u4ee5\u652f\u6301\u3002\n\n\u5173\u4e8e\u88ab\u544a\u6731\u67d0\u4e3b\u5f20\u8fd4\u8fd8\u5f69\u793c89000\u5143\u7684\u8bc9\u6c42\uff0c\u9274\u4e8e\u53cc\u65b9\u5df2\u767b\u8bb0\u7ed3\u5a5a\u5e76\u5171\u540c\u751f\u6d3b\u591a\u5e74\uff0c\u4e0d\u7b26\u5408\u6cd5\u5b9a\u7684\u5f69\u793c\u8fd4\u8fd8\u6761\u4ef6\uff0c\u672c\u9662\u4e0d\u4e88\u652f\u6301\u3002\u5173\u4e8e\u88ab\u544a\u4e3b\u5f20\u7684\u751f\u6d3b\u5e2e\u52a9\u91d1\u53ca\u7cbe\u795e\u635f\u5bb3\u629a\u6170\u91d1\uff0c\u56e0\u88ab\u544a\u672a\u63d0\u4f9b\u5145\u5206\u8bc1\u636e\u8bc1\u660e\u539f\u544a\u5b58\u5728\u6cd5\u5b9a\u8fc7\u9519\u6216\u5176\u81ea\u8eab\u751f\u6d3b\u786e\u6709\u56f0\u96be\u4e14\u7b26\u5408\u6cd5\u5b9a\u6551\u6d4e\u6761\u4ef6\uff0c\u6545\u672c\u9662\u4ea6\u4e0d\u4e88\u652f\u6301\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u96f6\u4e03\u5341\u4e5d\u6761\uff0c\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u516d\u5341\u4e03\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n\u4e00\u3001\u51c6\u4e88\u539f\u544a\u767d\u67d0\u4e0e\u88ab\u544a\u6731\u67d0\u79bb\u5a5a\uff1b\n\u4e8c\u3001\u9a73\u56de\u88ab\u544a\u6731\u67d0\u7684\u5176\u4ed6\u8bc9\u6c42\u3002\n\n\u6848\u4ef6\u53d7\u7406\u8d39\u7531\u88ab\u544a\u6731\u67d0\u8d1f\u62c5\uff08\u539f\u544a\u5df2\u9884\u4ea4\uff0c\u7531\u88ab\u544a\u76f4\u63a5\u5411\u539f\u544a\u652f\u4ed8\uff09\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u9655\u897f\u7701\u54b8\u9633\u5e02\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002\n\nAnswer: \u51c6\u4e88\u539f\u544a\u767d\u67d0\u4e0e\u88ab\u544a\u6731\u67d0\u79bb\u5a5a\u3002",
