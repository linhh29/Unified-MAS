    {
        "example_id": 8,
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u4eba\u683c\u6743\u7ea0\u7eb7\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u5eb7\u67d0\u7532\", \"address\": \"\u7518\u8083\u7701\u6f33\u53bf\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1980\u5e741\u670818\u65e5\"}, \"defendant\": {\"name\": \"\u5eb7\u67d0\u4e59\", \"address\": \"\u7518\u8083\u7701\u6f33\u53bf\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1986\u5e7410\u670819\u65e5\"}}, \"plaintiff_claim\": [\"\u4f9d\u6cd5\u5224\u4ee4\u88ab\u544a\u8d54\u507f\u539f\u544a\u5404\u9879\u7ecf\u6d4e\u635f\u5931\u4eba\u6c11\u5e0111478.45\u5143\uff0c\u5176\u4e2d\u533b\u7597\u8d392922.94\u5143\uff0c\u8bef\u5de5\u8d395070.47\u5143\uff0823\u5929\u00d7220.47\u5143\uff09\uff0c\u62a4\u7406\u8d391984.23\u5143\uff089\u5929\u00d7220.47\u5143\uff09\uff0c\u8425\u517b\u8d39180\u5143\uff0c\u4ea4\u901a\u8d39200\u5143\u3002\", \"\u672c\u6848\u8bc9\u8bbc\u8d39\u7531\u88ab\u544a\u627f\u62c5\u3002\"], \"plaintiff_case_details\": \"\u539f\u544a\u7cfb\u88ab\u544a\u7684\u59d0\u59d0\u3002\u539f\u544a\u6bcd\u4eb2\u53bb\u4e16\u540e\uff0c\u56e0\u539f\u544a\u7236\u4eb2\u7231\u9157\u9152\uff0c\u539f\u544a\u4f5c\u4e3a\u5bb6\u4e2d\u957f\u5973\u627f\u62c5\u8d77\u7167\u987e\u5168\u90e8\u5bb6\u4eba\u7684\u8d23\u4efb\uff0c\u64cd\u52b3\u5bb6\u4e2d\u5927\u5c0f\u4e8b\u52a1\uff0c\u4e3a\u5bb6\u5ead\u53ef\u8c13\u662f\u5455\u5fc3\u6ca5\u8840\u3001\u8f9b\u52b3\u4ed8\u51fa\u3002\u539f\u544a\u7ed3\u5a5a\u540e\uff0c\u4e5f\u548c\u5176\u4e08\u592b\u4e00\u8d77\u7ee7\u7eed\u5206\u62c5\u8d77\u4e86\u5a18\u5bb6\u7684\u5bb6\u52a1\uff0c\u5e76\u64cd\u52b3\u59b9\u59b9\u4eec\u7684\u51fa\u5ac1\u4e8b\u5b9c\u3002\u968f\u7740\u539f\u544a\u7236\u4eb2\u5e74\u8fc8\uff0c\u539f\u544a\u7ecf\u5e38\u7ed9\u539f\u544a\u7236\u4eb2\u94b1\u6b3e\u548c\u8d2d\u4e70\u4e1c\u897f\u30022023\u5e745\u6708\u4efd\uff0c\u539f\u544a\u7236\u4eb2\u751f\u75c5\uff0c\u539f\u544a\u5e26\u539f\u544a\u7236\u4eb2\u770b\u75c5\uff0c\u539f\u544a\u7236\u4eb2\u5728\u539f\u544a\u5bb6\u4f11\u517b\u4e00\u6708\uff0c\u8eab\u4f53\u75ca\u6108\u4e4b\u540e\u4fbf\u56de\u6f33\u53bf\u8001\u5bb6\u751f\u6d3b\u3002\u540e\u88ab\u544a\u79f0\u539f\u544a\u65e0\u6743\u62e8\u6253\u539f\u544a\u7236\u4eb2\u7535\u8bdd\uff0c\u6b64\u540e\u539f\u544a\u7236\u4eb2\u7684\u7535\u8bdd\u4fbf\u65e0\u6cd5\u6253\u901a\u3002\u540e\u539f\u544a\u4ecd\u7136\u5bf9\u81ea\u5df1\u7684\u7236\u4eb2\u5c3d\u8d61\u517b\u4e49\u52a1\uff0c\u4f46\u88ab\u544a\u7ecf\u5e38\u53d1\u77ed\u4fe1\u8fb1\u9a82\u539f\u544a\uff0c\u5bf9\u539f\u544a\u975e\u5e38\u4ec7\u89c6\u30022024\u5e74\u519c\u5386\u6b63\u6708\u521d\u516d\uff0c\u88ab\u544a\u5c06\u539f\u544a\u7236\u4eb2\u63a5\u5230\u5979\u5bb6\u751f\u6d3b\u4e86\u51e0\u4e2a\u6708\u30022024\u5e746\u6708\u4efd\uff0c\u539f\u544a\u7236\u4eb2\u5728\u6587\u5cf0\u9547\u5f00\u53d1\u533a\u79df\u623f\u5c45\u4f4f\u30022024\u5e746\u670826\u65e5\uff0c\u539f\u544a\u5728\u51fa\u79df\u5c4b\u770b\u671b\u539f\u544a\u7236\u4eb2\uff0c\u88ab\u544a\u56de\u6765\u540e\u770b\u89c1\u539f\u544a\uff0c\u4fbf\u8fb1\u9a82\u539f\u544a\uff0c\u539f\u544a\u4e0d\u60f3\u4e0e\u5176\u53d1\u751f\u4e89\u6267\uff0c\u51c6\u5907\u79bb\u5f00\u65f6\uff0c\u88ab\u544a\u62c9\u7740\u539f\u544a\u7684\u80f3\u818a\u4e0d\u8ba9\u539f\u544a\u79bb\u5f00\u3002\u4e3a\u4e86\u6446\u8131\u88ab\u544a\u7684\u7ea0\u7f20\uff0c\u539f\u544a\u7528\u529b\u6323\u624e\u88ab\u544a\u62c9\u626f\u65f6\uff0c\u88ab\u544a\u5f00\u59cb\u6bb4\u6253\u539f\u544a\uff0c\u5bf9\u539f\u544a\u811a\u8e22\u62f3\u6253\uff0c\u81f4\u4f7f\u539f\u544a\u9762\u90e8\u3001\u9888\u90e8\u7b49\u591a\u5904\u53d7\u4f24\u3002\u539f\u544a\u6323\u8131\u88ab\u544a\u7684\u6bb4\u6253\u540e\u8dd1\u51fa\u4e86\u51fa\u79df\u5c4b\uff0c\u968f\u540e\u62e8\u6253110\u62a5\u8b66\u3002\u540e\u539f\u544a\u5230\u9647\u897f\u53bf\u7b2c\u4e00\u4eba\u6c11\u533b\u9662\u4f4f\u9662\u6cbb\u7597\uff0c\u7ecf\u533b\u751f\u8bca\u65ad\uff0c\u539f\u544a\u5168\u8eab\u591a\u5904\u8f6f\u7ec4\u7ec7\u635f\u4f24\uff0c\u539f\u544a\u4f4f\u9662\u6cbb\u75979\u5929\u3002\u75c5\u60c5\u7a0d\u5fae\u597d\u8f6c\u540e\uff0c\u539f\u544a\u51fa\u9662\uff0c\u533b\u5631\u539f\u544a\u51fa\u9662\u540e\u4f11\u517b14\u5929\uff0c\u539f\u544a\u4fbf\u7ee7\u7eed\u5728\u5bb6\u4f11\u517b\u6cbb\u7597\u3002\u539f\u544a\u6cbb\u7597\u671f\u95f4\u548c\u4f11\u517b\u671f\u95f4\uff0c\u88ab\u544a\u672a\u652f\u4ed8\u4efb\u4f55\u8d39\u7528\uff0c\u4e5f\u672a\u63a2\u671b\u8fc7\u539f\u544a\u3002\u540e\u7ecf\u9647\u897f\u53bf\u516c\u5b89\u5c40\u53f8\u6cd5\u9274\u5b9a\u4e2d\u5fc3\u9274\u5b9a\uff0c\u539f\u544a\u7684\u4f24\u60c5\u4e3a\u8f7b\u5fae\u4f24\uff0c\u9647\u897f\u53bf\u516c\u5b89\u5c40\u6587\u5cf0\u6d3e\u51fa\u6240\u5bf9\u88ab\u544a\u8fdb\u884c\u884c\u653f\u5904\u7f5a\uff0c\u7f5a\u6b3e500\u5143\u3002\u56e0\u4f24\u60c5\u5f71\u54cd\u539f\u544a\u4e00\u76f4\u8bef\u5de5\u81f3\u4eca\u3002\u88ab\u544a\u4e0d\u4f46\u4e0d\u611f\u6069\u539f\u544a\u7684\u8f9b\u52b3\u4ed8\u51fa\uff0c\u8fd8\u6069\u5c06\u4ec7\u62a5\uff0c\u5bf9\u539f\u544a\u5404\u79cd\u62a5\u590d\u3002\u7efc\u4e0a\uff0c\u88ab\u544a\u5bf9\u539f\u544a\u6784\u6210\u4e86\u4e25\u91cd\u4fb5\u6743\uff0c\u81f4\u4f7f\u539f\u544a\u8eab\u4f53\u906d\u5230\u635f\u4f24\uff0c\u88ab\u544a\u4f9d\u6cd5\u5e94\u5f53\u8d54\u507f\u539f\u544a\u7684\u7ecf\u6d4e\u635f\u5931\uff0c\u4e3a\u4e86\u7ef4\u62a4\u539f\u544a\u7684\u5408\u6cd5\u6743\u76ca\uff0c\u4f9d\u6cd5\u63d0\u8d77\u6c11\u4e8b\u8bc9\u8bbc\u3002\", \"defendant_defence\": \"\u7cfb\u539f\u544a\u5148\u52a8\u624b\u5c06\u5176\u53e3\u90e8\u6253\u4f24\uff0c\u4e4b\u540e\u53cc\u65b9\u53d1\u751f\u6495\u6253\uff0c\u5176\u5728\u539f\u544a\u9762\u90e8\u6293\u4e86\u51e0\u4e0b\uff0c\u5c06\u539f\u544a\u6293\u4f24\uff0c\u539f\u544a\u5bf9\u81ea\u5df1\u53d7\u4f24\u4e5f\u8d1f\u6709\u8d23\u4efb\uff0c\u5176\u53ea\u540c\u610f\u8d54\u507f\u539f\u544a\u7684\u533b\u7597\u8d39\u7b49\u8d39\u7528\u5171\u8ba15000\u5143\uff0c\u6848\u4ef6\u53d7\u7406\u8d39\u539f\u544a\u4e0e\u5176\u5404\u627f\u62c550\u5143\u3002\", \"evidence\": {\"plaintiff_evidence\": {\"evidence_1\": {\"evidence\": \"\u539f\u544a\u63d0\u4f9b\u7684\u533b\u9662\u8bca\u65ad\u8bc1\u660e\u548c\u4f4f\u9662\u75c5\u5386\", \"dispute\": \"\u88ab\u544a\u5bf9\u539f\u544a\u53d7\u4f24\u81ea\u5df1\u6709\u8d23\u4efb\"}, \"evidence_2\": null, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null, \"evidence_10\": null}, \"defendant_evidence\": {\"evidence_1\": {\"evidence\": \"\u5eb7\u67d0\u4e59\u8be2\u95ee\u7b14\u5f55\", \"dispute\": \"\u539f\u544a\u6301\u5f02\u8bae\", \"name\": null}, \"evidence_2\": null, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null}}, \"other_statement\": {\"plaintiff\": {\"plaintiff_1\": \"\"}, \"defendant\": {\"defendant_1\": \"\"}}}\n\u6700\u540e\u5728\u65b0\u7684\u4e00\u884c\u4ee5 'Answer:' \u5f00\u5934\u7ed9\u51fa\u7b80\u6d01\u7684\u6700\u7ec8\u88c1\u5224\u4e3b\u6587\u3002",
        "correct_answer": [
            "\u88ab\u544a\u5eb7\u67d0\u4e59\u4e8e\u5224\u51b3\u751f\u6548\u540e\u5341\u4e94\u65e5\u5185\u652f\u4ed8\u539f\u544a\u5eb7\u67d0\u7532\u533b\u7597\u8d39\u3001\u8bef\u5de5\u8d39\u3001\u62a4\u7406\u8d39\u3001\u4f4f\u9662\u4f19\u98df\u8865\u52a9\u8d39\u5408\u8ba17282.35\u5143\u3002",
            "\u9a73\u56de\u539f\u544a\u5eb7\u67d0\u7532\u7684\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42\u3002",
            "\u6848\u4ef6\u53d7\u7406\u8d39100\u5143\uff0c\u7531\u88ab\u544a\u5eb7\u67d0\u4e59\u8d1f\u62c580\u5143\uff0c\u7531\u539f\u544a\u5eb7\u67d0\u7532\u8d1f\u62c520\u5143\u3002"
        ],
        "n": 0,
        "response": "### \u6c11\u4e8b\u5224\u51b3\u4e66\n\n**\u6848\u4ef6\u80cc\u666f\uff1a**\n\u539f\u544a\u5eb7\u67d0\u7532\u4e0e\u88ab\u544a\u5eb7\u67d0\u4e59\u7cfb\u4eb2\u59d0\u59b9\u5173\u7cfb\u30022024\u5e746\u670826\u65e5\uff0c\u539f\u544a\u524d\u5f80\u6587\u5cf0\u9547\u4e00\u51fa\u79df\u5c4b\u770b\u671b\u5176\u7236\u4eb2\uff0c\u671f\u95f4\u4e0e\u88ab\u544a\u53d1\u751f\u8a00\u8bed\u4e89\u6267\u3002\u539f\u544a\u6b32\u79bb\u5f00\u65f6\uff0c\u53cc\u65b9\u53d1\u751f\u80a2\u4f53\u51b2\u7a81\u3002\u6839\u636e\u9647\u897f\u53bf\u516c\u5b89\u5c40\u7684\u8c03\u67e5\u53ca\u9274\u5b9a\uff0c\u539f\u544a\u53d7\u8f7b\u5fae\u4f24\uff0c\u88ab\u544a\u88ab\u5904\u4ee5\u884c\u653f\u7f5a\u6b3e500\u5143\u3002\u539f\u544a\u56e0\u4f24\u4f4f\u96629\u5929\uff0c\u5e76\u9075\u533b\u5631\u4f11\u517b14\u5929\u3002\u73b0\u539f\u544a\u5411\u672c\u9662\u63d0\u8d77\u8bc9\u8bbc\uff0c\u8981\u6c42\u88ab\u544a\u8d54\u507f\u5404\u9879\u7ecf\u6d4e\u635f\u5931\u5171\u8ba111,478.45\u5143\u3002\n\n**\u6cd5\u9662\u8ba4\u4e3a\uff1a**\n\u672c\u6848\u7cfb\u5065\u5eb7\u6743\u7ea0\u7eb7\u3002\u516c\u6c11\u4eab\u6709\u751f\u547d\u5065\u5eb7\u6743\uff0c\u53d7\u6cd5\u5f8b\u4fdd\u62a4\u3002\u884c\u4e3a\u4eba\u56e0\u8fc7\u9519\u4fb5\u5bb3\u4ed6\u4eba\u6c11\u4e8b\u6743\u76ca\uff0c\u5e94\u5f53\u627f\u62c5\u4fb5\u6743\u8d23\u4efb\u3002\n\n1.  **\u5173\u4e8e\u4fb5\u6743\u8d23\u4efb\u7684\u8ba4\u5b9a\uff1a** \u88ab\u544a\u5eb7\u67d0\u4e59\u56e0\u5bb6\u5ead\u7410\u4e8b\u4e0e\u539f\u544a\u53d1\u751f\u4e89\u6267\uff0c\u5e76\u5728\u51b2\u7a81\u4e2d\u9020\u6210\u539f\u544a\u53d7\u4f24\uff0c\u8be5\u4e8b\u5b9e\u6709\u516c\u5b89\u673a\u5173\u7684\u8be2\u95ee\u7b14\u5f55\u3001\u9274\u5b9a\u610f\u89c1\u4e66\u53ca\u884c\u653f\u5904\u7f5a\u51b3\u5b9a\u4e66\u4e88\u4ee5\u8bc1\u5b9e\u3002\u88ab\u544a\u4e3b\u5f20\u539f\u544a\u5148\u52a8\u624b\u5e76\u8d1f\u6709\u8d23\u4efb\uff0c\u867d\u5176\u5728\u8be2\u95ee\u7b14\u5f55\u4e2d\u6709\u6240\u9648\u8ff0\uff0c\u4f46\u672a\u80fd\u63d0\u4f9b\u76f8\u5e94\u7684\u533b\u7597\u8bc1\u660e\u6216\u8bc1\u636e\u8bc1\u5b9e\u5176\u4f24\u60c5\u53ca\u539f\u544a\u8fc7\u9519\u7684\u7a0b\u5ea6\u3002\u4f5c\u4e3a\u5177\u6709\u5b8c\u5168\u6c11\u4e8b\u884c\u4e3a\u80fd\u529b\u7684\u6210\u5e74\u4eba\uff0c\u88ab\u544a\u5728\u5904\u7406\u5bb6\u5ead\u77db\u76fe\u65f6\u672a\u80fd\u91c7\u53d6\u7406\u6027\u65b9\u5f0f\uff0c\u800c\u662f\u8bc9\u8bf8\u66b4\u529b\uff0c\u5176\u884c\u4e3a\u5177\u6709\u8fc7\u9519\uff0c\u5e94\u5f53\u5bf9\u539f\u544a\u7684\u635f\u5931\u627f\u62c5\u6c11\u4e8b\u8d54\u507f\u8d23\u4efb\u3002\n\n2.  **\u5173\u4e8e\u8d54\u507f\u9879\u76ee\u7684\u6570\u989d\u786e\u5b9a\uff1a**\n    *   **\u533b\u7597\u8d39\uff1a** \u539f\u544a\u4e3b\u5f202,922.94\u5143\uff0c\u6709\u4f4f\u9662\u75c5\u5386\u3001\u8bca\u65ad\u8bc1\u660e\u53ca\u533b\u7597\u8d39\u7968\u636e\u652f\u6301\uff0c\u672c\u9662\u4e88\u4ee5\u786e\u8ba4\u3002\n    *   **\u8bef\u5de5\u8d39\uff1a** \u539f\u544a\u4f4f\u96629\u5929\uff0c\u533b\u5631\u4f11\u517b14\u5929\uff0c\u5171\u8ba123\u5929\u3002\u539f\u544a\u53c2\u7167\u4e0a\u4e00\u5e74\u5ea6\u7518\u8083\u7701\u57ce\u9547\u79c1\u8425\u5355\u4f4d\u5c31\u4e1a\u4eba\u5458\u5e74\u5e73\u5747\u5de5\u8d44\u6807\u51c6\uff08\u65e5\u5747220.47\u5143\uff09\u8ba1\u7b97\uff0c\u603b\u8ba15,070.47\u5143\uff0c\u7b26\u5408\u6cd5\u5f8b\u89c4\u5b9a\uff0c\u672c\u9662\u4e88\u4ee5\u652f\u6301\u3002\n    *   **\u62a4\u7406\u8d39\uff1a** \u539f\u544a\u4f4f\u9662\u671f\u95f4\uff089\u5929\uff09\u786e\u9700\u62a4\u7406\uff0c\u6309\u65e5\u5747220.47\u5143\u8ba1\u7b97\uff0c\u5171\u8ba11,984.23\u5143\uff0c\u672c\u9662\u4e88\u4ee5\u652f\u6301\u3002\n    *   **\u8425\u517b\u8d39\uff1a** \u539f\u544a\u4e3b\u5f20180\u5143\uff08\u6bcf\u65e520\u5143\uff0c\u51719\u5929\uff09\uff0c\u7b26\u5408\u5176\u5b9e\u9645\u4f24\u60c5\u548c\u4f4f\u9662\u60c5\u51b5\uff0c\u672c\u9662\u4e88\u4ee5\u652f\u6301\u3002\n    *   **\u4ea4\u901a\u8d39\uff1a** \u539f\u544a\u4e3b\u5f20200\u5143\uff0c\u8003\u8651\u5176\u5b9e\u9645\u5c31\u533b\u53ca\u5f80\u8fd4\u9700\u8981\uff0c\u6570\u989d\u5408\u7406\uff0c\u672c\u9662\u4e88\u4ee5\u652f\u6301\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u539f\u544a\u4e3b\u5f20\u7684\u5404\u9879\u635f\u5931\u5171\u8ba111,478.45\u5143\uff0c\u8bc1\u636e\u5145\u5206\uff0c\u8ba1\u7b97\u6807\u51c6\u5408\u7406\uff0c\u672c\u9662\u5168\u989d\u4e88\u4ee5\u652f\u6301\u3002\n\n**\u88c1\u5224\u4f9d\u636e\uff1a**\n\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u516d\u5341\u4e94\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u4e03\u5341\u4e5d\u6761\uff1b\u300a\u6700\u9ad8\u4eba\u6c11\u6cd5\u9662\u5173\u4e8e\u5ba1\u7406\u4eba\u8eab\u635f\u5bb3\u8d54\u507f\u6848\u4ef6\u9002\u7528\u6cd5\u5f8b\u82e5\u5e72\u95ee\u9898\u7684\u89e3\u91ca\u300b\u76f8\u5173\u6761\u6b3e\u3002\n\n**\u5224\u51b3\u5982\u4e0b\uff1a**\n\n\u4e00\u3001\u88ab\u544a\u5eb7\u67d0\u4e59\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\u8d54\u507f\u539f\u544a\u5eb7\u67d0\u7532\u533b\u7597\u8d39\u3001\u8bef\u5de5\u8d39\u3001\u62a4\u7406\u8d39\u3001\u8425\u517b\u8d39\u3001\u4ea4\u901a\u8d39\u5171\u8ba1\u4eba\u6c11\u5e0111,478.45\u5143\uff1b\n\u4e8c\u3001\u9a73\u56de\u539f\u544a\u5eb7\u67d0\u7532\u7684\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42\uff08\u5982\u6709\uff09\u3002\n\n\u672c\u6848\u8bc9\u8bbc\u8d39\u7531\u88ab\u544a\u5eb7\u67d0\u4e59\u627f\u62c5\u3002\n\n\u5982\u672a\u6309\u672c\u5224\u51b3\u6307\u5b9a\u7684\u671f\u95f4\u5c65\u884c\u91d1\u94b1\u7ed9\u4ed8\u4e49\u52a1\uff0c\u5e94\u5f53\u6309\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u4e8c\u767e\u516d\u5341\u6761\u4e4b\u89c4\u5b9a\uff0c\u52a0\u500d\u652f\u4ed8\u8fdf\u5ef6\u5c65\u884c\u671f\u95f4\u7684\u503a\u52a1\u5229\u606f\u3002\n\nAnswer:\n\u4e00\u3001\u88ab\u544a\u5eb7\u67d0\u4e59\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\u8d54\u507f\u539f\u544a\u5eb7\u67d0\u7532\u5404\u9879\u7ecf\u6d4e\u635f\u5931\u5171\u8ba1\u4eba\u6c11\u5e0111,478.45\u5143\uff1b\n\u4e8c\u3001\u672c\u6848\u8bc9\u8bbc\u8d39\u7531\u88