        "example_id": 9,
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u5a5a\u59fb\u5bb6\u5ead\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u7a0b\u67d01\", \"address\": \"\u4e0a\u6d77\u5e02\u677e\u6c5f\u533a\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1979\u5e743\u67083\u65e5\"}, \"defendant\": {\"name\": \"\u7a0b\u67d02\", \"address\": \"\u4e0a\u6d77\u5e02\u9ec4\u6d66\u533a\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1974\u5e747\u670829\u65e5\"}}, \"plaintiff_claim\": [\"\u8981\u6c42\u7ee7\u627f\u88ab\u7ee7\u627f\u4eba\u7a0b\u67d03\u3001\u5f20\u67d02\u5728\u4e0a\u6d77\u5e02\u9759\u5b89\u533a\u623f\u5c4b\u4e2d\u7684\u5404\u4e09\u5206\u4e4b\u4e00\u4ea7\u6743\u4efd\u989d\uff0c\u7531\u539f\u544a\u53d6\u5f97\u623f\u5c4b\uff0c\u7ed9\u4ed8\u88ab\u544a\u623f\u5c4b\u6298\u4ef7\u6b3e855,334\u5143\u3002\"], \"plaintiff_case_details\": \"\u88ab\u7ee7\u627f\u4eba\u7a0b\u67d03\u3001\u5f20\u67d02\u7cfb\u592b\u59bb\u5173\u7cfb\uff0c\u80b2\u6709\u4e24\u540d\u5b50\u5973\uff0c\u5373\u539f\u3001\u88ab\u544a\u3002\u4e0a\u6d77\u5e02\u9759\u5b89\u533a\u623f\u5c4b\uff08\u4ee5\u4e0b\u7b80\u79f0\u7cfb\u4e89\u623f\u5c4b\uff09\u4ea7\u6743\u767b\u8bb0\u5728\u7a0b\u67d03\u3001\u5f20\u67d02\u53ca\u539f\u544a\u540d\u4e0b\uff0c\u6bcf\u4eba\u5404\u5360\u4e09\u5206\u4e4b\u4e00\u3002\u7a0b\u67d03\u7acb\u6709\u81ea\u4e66\u9057\u5631\uff0c\u8a00\u660e\u5176\u623f\u4ea7\u4efd\u989d\u7531\u539f\u544a\u7ee7\u627f\u3002\u5f20\u67d02\u7acb\u6709\u516c\u8bc1\u9057\u5631\uff0c\u5c06\u5176\u4efd\u989d\u7559\u7ed9\u88ab\u544a\uff0c\u6545\u7a0b\u67d03\u7684\u4e09\u5206\u4e4b\u4e00\u4efd\u989d\u7531\u539f\u544a\u7ee7\u627f\uff0c\u5f20\u67d02\u7684\u4e09\u5206\u4e4b\u4e00\u4efd\u989d\u7531\u88ab\u544a\u7ee7\u627f\u3002\u539f\u544a\u8981\u6c42\u53d6\u5f97\u7cfb\u4e89\u623f\u5c4b\uff0c\u6309\u8bc4\u4f30\u4ef7\u652f\u4ed8\u88ab\u544a\u6298\u4ef7\u6b3e\u3002\", \"defendant_defence\": \"\u4e0d\u540c\u610f\u539f\u544a\u8bc9\u8bf7\u3002\u5bf9\u9057\u4ea7\u8303\u56f4\u65e0\u5f02\u8bae\uff0c\u5f20\u67d02\u7684\u4efd\u989d\u6309\u516c\u8bc1\u9057\u5631\u7531\u88ab\u544a\u7ee7\u627f\u3002\u7a0b\u67d03\u867d\u7559\u6709\u81ea\u4e66\u9057\u5631\uff0c\u4f46\u9057\u5631\u4eba\u4e0e\u89c1\u8bc1\u4eba\u7684\u843d\u6b3e\u65e5\u671f\u4e0d\u4e00\u81f4\uff0c\u4ece\u89c1\u8bc1\u5185\u5bb9\u6765\u770b\uff0c\u4e24\u540d\u89c1\u8bc1\u4eba\u5f53\u65f6\u5728\u7acb\u9057\u5631\u73b0\u573a\uff0c\u56e0\u65e0\u6cd5\u786e\u5b9a\u9057\u5631\u7684\u5f62\u6210\u65e5\u671f\uff0c\u6545\u9057\u5631\u65e0\u6548\uff0c\u7a0b\u67d03\u7684\u4efd\u989d\u5e94\u6309\u6cd5\u5b9a\u7ee7\u627f\u7531\u539f\u3001\u88ab\u544a\u5747\u7b49\u5206\u5272\u3002\", \"evidence\": {\"plaintiff_evidence\": {\"evidence_1\": {\"evidence\": \"\u6237\u7c4d\u6458\u6284\u3001\u6237\u7c4d\u8bc1\u660e\u3001\u4e0a\u6d77\u5e02\u4e0d\u52a8\u4ea7\u767b\u8bb0\u7c3f\u3001\u81ea\u4e66\u9057\u5631\u3001\u516c\u8bc1\u9057\u5631\u3001\u4f30\u4ef7\u62a5\u544a\u3001\u5f53\u4e8b\u4eba\u7684\u9648\u8ff0\", \"dispute\": \"\u88ab\u544a\u8ba4\u4e3a\u7a0b\u67d03\u7684\u81ea\u4e66\u9057\u5631\u56e0\u89c1\u8bc1\u4eba\u843d\u6b3e\u65e5\u671f\u4e0d\u4e00\u81f4\u800c\u65e0\u6548\"}, \"evidence_2\": null, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null, \"evidence_10\": null}, \"defendant_evidence\": {\"evidence_1\": null, \"evidence_2\": null, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null}}, \"other_statement\": {\"plaintiff\": {\"plaintiff_1\": \"\"}, \"defendant\": {\"defendant_1\": \"\"}}}\n\u6700\u540e\u5728\u65b0\u7684\u4e00\u884c\u4ee5 'Answer:' \u5f00\u5934\u7ed9\u51fa\u7b80\u6d01\u7684\u6700\u7ec8\u88c1\u5224\u4e3b\u6587\u3002",
        "correct_answer": [
            "\u73b0\u767b\u8bb0\u5728\u88ab\u7ee7\u627f\u4eba\u5f20\u67d02\u3001\u7a0b\u67d03\u3001\u539f\u544a\u7a0b\u67d01\u540d\u4e0b\u7684\u4e0a\u6d77\u5e02\u9759\u5b89\u533a\u623f\u5c4b\uff0c\u5f52\u539f\u544a\u7a0b\u67d01\u6240\u6709\uff1b",
            "\u539f\u544a\u7a0b\u67d01\u5e94\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\u7ed9\u4ed8\u88ab\u544a\u7a0b\u67d02\u623f\u5c4b\u6298\u4ef7\u6b3e855,334\u5143\uff0c\u5f85\u539f\u544a\u7a0b\u67d01\u4ed8\u6e05\u4e0a\u8ff0\u6b3e\u9879\u540e\u5341\u65e5\u5185\u8d1f\u8d23\u529e\u7406\u4e0a\u5740\u623f\u5c4b\u4ea7\u6743\u53d8\u66f4\u624b\u7eed\uff08\u76f8\u5173\u7a0e\u8d39\u7531\u5f53\u4e8b\u4eba\u6309\u56fd\u5bb6\u653f\u7b56\u8d1f\u62c5\uff09\u3002",
            "\u5982\u679c\u672a\u6309\u672c\u5224\u51b3\u6307\u5b9a\u7684\u671f\u95f4\u5c65\u884c\u7ed9\u4ed8\u91d1\u94b1\u4e49\u52a1\uff0c\u5e94\u5f53\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u4e8c\u767e\u516d\u5341\u56db\u6761\u4e4b\u89c4\u5b9a\uff0c\u52a0\u500d\u652f\u4ed8\u8fdf\u5ef6\u5c65\u884c\u671f\u95f4\u7684\u503a\u52a1\u5229\u606f\u3002",
            "\u6848\u4ef6\u53d7\u7406\u8d3920,190\u5143\u3001\u8bc4\u4f30\u8d397,132\u5143\uff08\u539f\u544a\u5df2\u9884\u7f34\uff09\uff0c\u7531\u539f\u544a\u7a0b\u67d01\u3001\u88ab\u544a\u7a0b\u67d02\u5404\u534a\u8d1f\u62c5\u3002",
            "\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u6216\u8005\u4ee3\u8868\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u4e0a\u6d77\u5e02\u7b2c\u4e8c\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002"
        ],
        "n": 0,
        "response": "**\u6c11\u4e8b\u5224\u51b3\u4e66\uff08\u8282\u9009\uff09**\n\n**\u672c\u9662\u8ba4\u4e3a\uff1a**\n\n\u672c\u6848\u4e89\u8bae\u7684\u7126\u70b9\u5728\u4e8e\u88ab\u7ee7\u627f\u4eba\u7a0b\u67d03\u3001\u5f20\u67d02\u7684\u9057\u4ea7\u7ee7\u627f\u5904\u7406\u3002\u7cfb\u4e89\u623f\u5c4b\u539f\u767b\u8bb0\u5728\u7a0b\u67d03\u3001\u5f20\u67d02\u53ca\u539f\u544a\u7a0b\u67d01\u540d\u4e0b\uff0c\u5404\u5360\u4e09\u5206\u4e4b\u4e00\u4efd\u989d\u3002\u6545\u7a0b\u67d03\u3001\u5f20\u67d02\u6b7b\u4ea1\u540e\uff0c\u5176\u5404\u81ea\u6301\u6709\u7684\u4e09\u5206\u4e4b\u4e00\u4efd\u989d\u5e94\u4f5c\u4e3a\u9057\u4ea7\u8fdb\u884c\u5206\u5272\u3002\n\n\u5173\u4e8e\u88ab\u7ee7\u627f\u4eba\u5f20\u67d02\u7684\u9057\u4ea7\uff1a\u5176\u751f\u524d\u7559\u6709\u516c\u8bc1\u9057\u5631\uff0c\u660e\u786e\u5c06\u5176\u540d\u4e0b\u7684\u623f\u4ea7\u4efd\u989d\u7559\u7ed9\u88ab\u544a\u7a0b\u67d02\u7ee7\u627f\u3002\u8be5\u516c\u8bc1\u9057\u5631\u5408\u6cd5\u6709\u6548\uff0c\u672c\u9662\u4e88\u4ee5\u786e\u8ba4\u3002\n\n\u5173\u4e8e\u88ab\u7ee7\u627f\u4eba\u7a0b\u67d03\u7684\u9057\u4ea7\uff1a\u539f\u544a\u63d0\u4ea4\u4e86\u7a0b\u67d03\u7684\u81ea\u4e66\u9057\u5631\u3002\u88ab\u544a\u867d\u5bf9\u8be5\u9057\u5631\u7684\u6548\u529b\u63d0\u51fa\u8d28\u7591\uff0c\u8ba4\u4e3a\u9057\u5631\u4eba\u4e0e\u89c1\u8bc1\u4eba\u7684\u843d\u6b3e\u65e5\u671f\u4e0d\u4e00\u81f4\u5bfc\u81f4\u9057\u5631\u65e0\u6548\u3002\u4f46\u6839\u636e\u6cd5\u5f8b\u89c4\u5b9a\uff0c\u81ea\u4e66\u9057\u5631\u7531\u9057\u5631\u4eba\u4eb2\u7b14\u4e66\u5199\uff0c\u7b7e\u540d\uff0c\u6ce8\u660e\u5e74\u3001\u6708\u3001\u65e5\u5373\u53ef\u6210\u7acb\uff0c\u6cd5\u5f8b\u5e76\u672a\u5f3a\u5236\u8981\u6c42\u81ea\u4e66\u9057\u5631\u5fc5\u987b\u6709\u89c1\u8bc1\u4eba\u5728\u573a\u3002\u672c\u6848\u4e2d\uff0c\u5373\u4fbf\u89c1\u8bc1\u4eba\u7684\u843d\u6b3e\u65e5\u671f\u5b58\u5728\u7455\u75b5\uff0c\u4f46\u5728\u65e0\u76f8\u53cd\u8bc1\u636e\u8bc1\u660e\u9057\u5631\u975e\u7a0b\u67d03\u4eb2\u7b14\u4e66\u5199\u6216\u5176\u7acb\u9057\u5631\u65f6\u65e0\u6c11\u4e8b\u884c\u4e3a\u80fd\u529b\u7684\u60c5\u51b5\u4e0b\uff0c\u8be5\u9057\u5631\u7b26\u5408\u81ea\u4e66\u9057\u5631\u7684\u6cd5\u5b9a\u8981\u4ef6\u3002\u56e0\u6b64\uff0c\u7a0b\u67d03\u6301\u6709\u7684\u7cfb\u4e89\u623f\u5c4b\u4e09\u5206\u4e4b\u4e00\u4efd\u989d\u5e94\u6309\u5176\u9057\u5631\u7531\u539f\u544a\u7a0b\u67d01\u7ee7\u627f\u3002\n\n\u7efc\u4e0a\uff0c\u539f\u544a\u5408\u8ba1\u6301\u6709\u7cfb\u4e89\u623f\u5c4b\u4e09\u5206\u4e4b\u4e8c\u4efd\u989d\uff08\u81ea\u67091/3+\u7ee7\u627f1/3\uff09\uff0c\u88ab\u544a\u5408\u8ba1\u6301\u6709\u7cfb\u4e89\u623f\u5c4b\u4e09\u5206\u4e4b\u4e00\u4efd\u989d\uff08\u7ee7\u627f1/3\uff09\u3002\u8003\u8651\u5230\u539f\u544a\u76ee\u524d\u6301\u6709\u8f83\u591a\u4efd\u989d\uff0c\u4e14\u5176\u8868\u8fbe\u4e86\u53d6\u5f97\u623f\u5c4b\u4ea7\u6743\u5e76\u652f\u4ed8\u6298\u4ef7\u6b3e\u7684\u610f\u613f\uff0c\u672c\u9662\u4e88\u4ee5\u51c6\u8bb8\u3002\u6839\u636e\u8bc4\u4f30\u62a5\u544a\uff0c\u7cfb\u4e89\u623f\u5c4b\u603b\u4ef7\u503c\u7684\u7406\u8bba\u4e09\u5206\u4e4b\u4e00\u4efd\u989d\u4e3a855,334\u5143\uff0c\u539f\u544a\u5e94\u636e\u6b64\u5411\u88ab\u544a\u652f\u4ed8\u6298\u4ef7\u6b3e\u3002\n\n\u636e\u6b64\uff0c\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u4e8c\u5341\u4e09\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u4e09\u5341\u4e09\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u4e09\u5341\u56db\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\nAnswer: \u4e00\u3001\u4f4d\u4e8e\u4e0a\u6d77\u5e02\u9759\u5b89\u533a\u7cfb\u4e89\u623f\u5c4b\u4ea7\u6743\u7531\u539f\u544a\u7a0b\u67d01\u7ee7\u627f\u6240\u5f97\uff1b\u4e8c\u3001\u539f\u544a\u7a0b\u67d01\u5e94\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u4e09\u5341\u65e5\u5185\u7ed9\u4ed8\u88ab\u544a\u7a0b\u67d02\u623f\u5c4b\u6298\u4ef7\u6b3e\u4eba\u6c11\u5e01855,334\u5143\uff1b\u4e09\u3001\u88ab\u544a\u7a0b\u67d02\u5e94\u4e8e\u6536\u5230\u4e0a\u8ff0\u6b3e\u9879\u540e\u914d\u5408\u539f\u544a\u529e\u7406\u4ea7\u6743\u8fc7\u6237\u624b\u7eed\u3002",
        "sub_tasks_text": null
    }
