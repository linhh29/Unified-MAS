[
    {
        "example_id": 6,
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u5a5a\u59fb\u5bb6\u5ead\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u738b\u67d0\", \"address\": \"\u9655\u897f\u7701\u6e2d\u5357\u5e02\u5bcc\u5e73\u53bf\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1984\u5e7410\u67087\u65e5\"}, \"defendant\": {\"name\": \"\u6881\u67d01\", \"address\": \"\u9655\u897f\u7701\u6e2d\u5357\u5e02\u5bcc\u5e73\u53bf\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1981\u5e7410\u670819\u65e5\"}}, \"plaintiff_claim\": [\"\u8bf7\u6c42\u4f9d\u6cd5\u5224\u4ee4\u539f\u3001\u88ab\u544a\u79bb\u5a5a\", \"\u8bf7\u6c42\u4f9d\u6cd5\u5224\u4ee4\u5a5a\u751f\u5973\u6881\u67d02\u7531\u539f\u544a\u629a\u517b\uff0c\u88ab\u544a\u6bcf\u6708\u627f\u62c51500\u5143\u629a\u517b\u8d39\u81f3\u5b69\u5b50\u5e74\u6ee1\u5341\u516b\u5468\u5c81\u6b62\", \"\u8bf7\u6c42\u4f9d\u6cd5\u5224\u4ee4\u5206\u5272\u592b\u59bb\u5171\u540c\u8d22\u4ea7\", \"\u8bf7\u6c42\u4f9d\u6cd5\u5224\u4ee4\u5206\u5272\u592b\u59bb\u5171\u540c\u503a\u6743\", \"\u6848\u4ef6\u53d7\u7406\u8d39\u7531\u88ab\u544a\u627f\u62c5\"], \"plaintiff_case_details\": \"\u539f\u3001\u88ab\u544a\u4e8e2011\u5e745\u6708\u7ecf\u4eba\u4ecb\u7ecd\u76f8\u8bc6\uff0c\u4e8e2011\u5e747\u6708\u4efd\u6309\u7167\u519c\u6751\u4e60\u4fd7\u4e3e\u529e\u7ed3\u5a5a\u4eea\u5f0f\uff0c\u4e8e2011\u5e749\u670829\u65e5\u767b\u8bb0\u7ed3\u5a5a\u3002\u00d7\u00d7\u00d7\u00d7\u5e74\u00d7\u00d7\u6708\u00d7\u00d7\u65e5\u751f\u80b2\u4e00\u5973\u5b69\u53d6\u540d\u6881\u67d02\u3002\u539f\u88ab\u544a\u4e4b\u95f4\u76f8\u8bc6\u65f6\u95f4\u8f83\u77ed\uff0c\u611f\u60c5\u57fa\u7840\u8584\u5f31\u3002\u539f\u544a\u6000\u5b55\u671f\u95f4\uff0c\u56e0\u88ab\u544a\u51fa\u8f68\uff0c\u5b69\u5b50\u51fa\u751f\u540e\u539f\u544a\u5c31\u53bb\u5916\u5730\u4e0a\u73ed\uff0c\u540e\u56e0\u88ab\u544a\u7ed9\u539f\u544a\u9053\u6b49\uff0c\u53cc\u65b9\u548c\u597d\u3002\u5a5a\u540e\u88ab\u544a\u4e0e\u539f\u544a\u4ea4\u6d41\u5f88\u5c11\uff0c\u53cc\u65b9\u4e3b\u8981\u77db\u76fe\u662f\u88ab\u544a\u4e0d\u548c\u539f\u544a\u6c9f\u901a\u4ea4\u6d41\uff0c\u88ab\u544a\u4e3a\u4eba\u5904\u4e16\u6709\u6240\u6b20\u7f3a\uff0c\u53cc\u65b9\u4e4b\u95f4\u611f\u60c5\u6de1\u6f20\u30022022\u5e7410\u67086\u65e5\u81f3\u4eca\uff0c\u539f\u544a\u5df2\u7ecf\u4ece\u5bb6\u4e2d\u642c\u51fa\uff0c\u539f\u544a\u4ece\u5bb6\u642c\u8d70\u540e\uff0c\u88ab\u544a\u5c31\u642c\u5230\u4ed6\u7236\u6bcd\u5bb6\u4f4f\u4e86\u3002\u88ab\u544a\u4e5f\u4ece\u672a\u627e\u539f\u544a\u548c\u597d\u3002\u88ab\u544a\u957f\u671f\u4e0d\u5c65\u884c\u5bb6\u5ead\u4e49\u52a1\u3001\u7f3a\u4e4f\u5bb6\u5ead\u8d23\u4efb\u611f\u3002\", \"defendant_defence\": \"\u88ab\u544a\u4e0d\u540c\u610f\u79bb\u5a5a\uff0c\u539f\u544a\u4e3b\u5f20\u7684\u5a5a\u59fb\u7ecf\u8fc7\u53ca\u5b69\u5b50\u60c5\u51b5\u5c5e\u5b9e\uff0c\u5176\u4ed6\u4e0d\u5c5e\u5b9e\u3002\u53cc\u65b9\u5a5a\u540e\u6c9f\u901a\u6bd4\u8f83\u5c11\uff0c\u611f\u60c5\u4e00\u822c\uff0c\u4f46\u88ab\u544a\u6ca1\u6709\u51fa\u8f68\uff0c\u53cc\u65b9\u611f\u60c5\u6ca1\u6709\u5f7b\u5e95\u7834\u88c2\u3002\u539f\u544a\u867d\u4e8e2022\u5e7410\u67086\u65e5\u4ece\u5bb6\u91cc\u642c\u5230\u8001\u623f\u5b50\u53bb\u5c45\u4f4f\uff0c\u4f46\u5e73\u65f6\u88ab\u544a\u4f1a\u4e3b\u52a8\u6216\u8005\u539f\u544a\u53eb\u88ab\u544a\u53bb\u5176\u4f4f\u5904\uff0c\u88ab\u544a\u4e5f\u4e3b\u52a8\u8fc7\u53bb\u770b\u5b69\u5b50\uff0c\u6709\u65f6\u623f\u5b50\u6709\u9700\u8981\u7ef4\u4fee\u7684\u5730\u65b9\u88ab\u544a\u4e5f\u8fc7\u53bb\uff0c\u53cc\u65b9\u6ca1\u6709\u5206\u5c45\u3002\u88ab\u544a\u4e5f\u7ed9\u539f\u544a\u548c\u5b69\u5b50\u751f\u6d3b\u8d39\uff0c\u4e5f\u7167\u987e\u5b69\u5b50\uff0c\u5b69\u5b50\u662f\u8fd1\u4e24\u5e74\u624d\u548c\u539f\u544a\u751f\u6d3b\u7684\uff0c\u4ee5\u524d\u539f\u544a\u5728\u5916\u5730\u4e0a\u73ed\u6709\u4e00\u5e74\u65f6\u95f4\u662f\u88ab\u544a\u7167\u7ba1\u7684\uff0c\u5176\u4f59\u65f6\u95f4\u90fd\u662f\u7531\u88ab\u544a\u7236\u6bcd\u7167\u7ba1\u7684\u3002\", \"evidence\": {\"plaintiff_evidence\": {\"evidence_1\": {\"evidence\": \"\u539f\u3001\u88ab\u544a\u8eab\u4efd\u8bc1\u590d\u5370\u4ef6\", \"dispute\": \"\"}, \"evidence_2\": {\"evidence\": \"\u539f\u544a\u7ed3\u5a5a\u767b\u8bb0\u5ba1\u67e5\u5904\u7406\u8868\", \"dispute\": \"\"}, \"evidence_3\": {\"evidence\": \"\u5f00\u5ead\u7b14\u5f55\", \"dispute\": \"\"}, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null, \"evidence_10\": null}, \"defendant_evidence\": {\"evidence_1\": null, \"evidence_2\": null, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null}}, \"other_statement\": {\"plaintiff\": {\"plaintiff_1\": \"\"}, \"defendant\": {\"defendant_1\": \"\"}}}\n\u6700\u540e\u5728\u65b0\u7684\u4e00\u884c\u4ee5 'Answer:' \u5f00\u5934\u7ed9\u51fa\u7b80\u6d01\u7684\u6700\u7ec8\u88c1\u5224\u4e3b\u6587\u3002",
        "correct_answer": [
            "\u4e0d\u51c6\u4e88\u539f\u544a\u738b\u67d0\u4e0e\u88ab\u544a\u6881\u67d01\u79bb\u5a5a\u3002",
            "\u6848\u4ef6\u53d7\u7406\u8d39300\u5143\uff0c\u51cf\u534a\u6536\u53d6\u8ba1150\u5143\uff0c\u7531\u539f\u544a\u738b\u67d0\u8d1f\u62c5\u3002",
            "\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u4ee5\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u6e2d\u5357\u5e02\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002"
        ],
        "n": 0,
        "response": "**\u6c11\u4e8b\u5224\u51b3\u4e66**\n\n**\u5ba1\u5224\u957f\u8bf4\u7406\u5185\u5bb9\uff1a**\n\n\u672c\u9662\u8ba4\u4e3a\uff0c\u89e3\u9664\u5a5a\u59fb\u5173\u7cfb\u7684\u6cd5\u5b9a\u6761\u4ef6\u662f\u592b\u59bb\u611f\u60c5\u786e\u5df2\u7834\u88c2\u3002\u5728\u672c\u6848\u4e2d\uff0c\u539f\u3001\u88ab\u544a\u4e8e2011\u5e74\u767b\u8bb0\u7ed3\u5a5a\uff0c\u5a5a\u59fb\u5173\u7cfb\u5b58\u7eed\u81f3\u4eca\u5df2\u6709\u5341\u4f59\u5e74\uff0c\u4e14\u80b2\u6709\u4e00\u5973\uff0c\u5177\u6709\u8f83\u6df1\u539a\u7684\u611f\u60c5\u57fa\u7840\u3002\u539f\u544a\u738b\u67d0\u867d\u4e3b\u5f20\u88ab\u544a\u6881\u67d01\u66fe\u6709\u51fa\u8f68\u884c\u4e3a\u4e14\u53cc\u65b9\u5206\u5c45\u3001\u611f\u60c5\u6de1\u6f20\uff0c\u4f46\u88ab\u544a\u5bf9\u6b64\u4e88\u4ee5\u5426\u8ba4\uff0c\u539f\u544a\u4ea6\u672a\u80fd\u63d0\u4f9b\u5145\u5206\u7684\u8bc1\u636e\u8bc1\u660e\u88ab\u544a\u5b58\u5728\u6cd5\u5b9a\u8fc7\u9519\uff08\u5982\u91cd\u5a5a\u3001\u4e0e\u4ed6\u4eba\u540c\u5c45\u3001\u5bb6\u5ead\u66b4\u529b\u7b49\uff09\u6216\u53cc\u65b9\u5df2\u56e0\u611f\u60c5\u4e0d\u548c\u8fde\u7eed\u5206\u5c45\u6ee1\u4e24\u5e74\u3002\n\n\u4ece\u5ead\u5ba1\u60c5\u51b5\u770b\uff0c\u53cc\u65b9\u4e4b\u95f4\u786e\u5b9e\u5b58\u5728\u6c9f\u901a\u4e0d\u7545\u3001\u5904\u7406\u5bb6\u52a1\u4e8b\u65b9\u5f0f\u6b20\u59a5\u7b49\u95ee\u9898\uff0c\u5bfc\u81f4\u4ea7\u751f\u9694\u9602\uff0c\u4f46\u8fd9\u4e9b\u77db\u76fe\u5c5e\u4e8e\u592b\u59bb\u5171\u540c\u751f\u6d3b\u4e2d\u7684\u6469\u64e6\uff0c\u5c1a\u672a\u8fbe\u5230\u592b\u59bb\u611f\u60c5\u5f7b\u5e95\u7834\u88c2\u3001\u65e0\u548c\u597d\u53ef\u80fd\u7684\u7a0b\u5ea6\u3002\u88ab\u544a\u5728\u5ead\u5ba1\u4e2d\u660e\u786e\u8868\u8fbe\u4e86\u4e0d\u540c\u610f\u79bb\u5a5a\u7684\u610f\u613f\uff0c\u5e76\u8868\u793a\u613f\u610f\u6539\u5584\u6c9f\u901a\u3001\u627f\u62c5\u5bb6\u5ead\u8d23\u4efb\uff0c\u53ef\u89c1\u53cc\u65b9\u4ecd\u6709\u4fee\u590d\u5173\u7cfb\u7684\u53ef\u80fd\u3002\n\n\u5a5a\u59fb\u5e94\u4ee5\u611f\u60c5\u4e3a\u57fa\u7840\uff0c\u592b\u59bb\u53cc\u65b9\u5728\u957f\u671f\u7684\u5171\u540c\u751f\u6d3b\u4e2d\uff0c\u5e94\u5f53\u76f8\u4e92\u4fe1\u4efb\u3001\u76f8\u4e92\u5305\u5bb9\u3001\u52a0\u5f3a\u6c9f\u901a\u3002\u539f\u3001\u88ab\u544a\u4f5c\u4e3a\u6210\u5e74\u4eba\uff0c\u4e14\u8eab\u4e3a\u7236\u6bcd\uff0c\u5e94\u672c\u7740\u5bf9\u5bb6\u5ead\u548c\u5b50\u5973\u8d1f\u8d23\u7684\u6001\u5ea6\uff0c\u73cd\u60dc\u591a\u5e74\u5efa\u7acb\u7684\u592b\u59bb\u611f\u60c5\u3002\u76ee\u524d\u539f\u544a\u63d0\u4f9b\u7684\u8bc1\u636e\u4e0d\u8db3\u4ee5\u8bc1\u660e\u592b\u59bb\u611f\u60c5\u5df2\u7ecf\u5b8c\u5168\u7834\u88c2\uff0c\u6545\u5bf9\u5176\u79bb\u5a5a\u8bc9\u8bf7\uff0c\u672c\u9662\u4e0d\u4e88\u652f\u6301\u3002\u56e0\u79bb\u5a5a\u8bf7\u6c42\u88ab\u9a73\u56de\uff0c\u539f\u544a\u5173\u4e8e\u5b50\u5973\u629a\u517b\u53ca\u8d22\u4ea7\u5206\u5272\u7684\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42\uff0c\u672c\u9662\u4e00\u5e76\u4e88\u4ee5\u9a73\u56de\u3002\n\n\u7efc\u4e0a\uff0c\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u96f6\u4e03\u5341\u4e5d\u6761\uff0c\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u516d\u5341\u4e03\u6761\u7b2c\u4e00\u6b3e\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\nAnswer: \u9a73\u56de\u539f\u544a\u738b\u67d0\u7684\u5168\u90e8\u8bc9\u8bbc\u8bf7\u6c42\u3002",
        "sub_tasks_text": null
    }
