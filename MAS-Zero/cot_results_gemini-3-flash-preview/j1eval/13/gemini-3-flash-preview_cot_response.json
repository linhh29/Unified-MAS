        "example_id": 13,
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u8d22\u4ea7\u635f\u5bb3\u8d54\u507f\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u5189\u67d0\u67d0\", \"address\": \"\u91cd\u5e86\u5e02\u9149\u9633\u571f\u5bb6\u65cf\u82d7\u65cf\u81ea\u6cbb\u53bf\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u571f\u5bb6\u65cf\", \"birth_date\": \"1985\u5e745\u670821\u65e5\"}, \"defendant\": {\"name\": \"\u5189\u67d0\", \"address\": \"\u91cd\u5e86\u5e02\u6c5f\u6d25\u533a\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u571f\u5bb6\u65cf\", \"birth_date\": \"1971\u5e743\u67086\u65e5\"}}, \"plaintiff_claim\": [\"\u5224\u4ee4\u88ab\u544a\u8d54\u507f\u539f\u544a\u9632\u76d7\u95e8\u635f\u59314000\u5143\", \"\u672c\u6848\u8bc9\u8bbc\u8d39\u7531\u88ab\u544a\u627f\u62c5\"], \"plaintiff_case_details\": \"2024\u5e741\u670825\u65e5\u665a\uff0c\u88ab\u544a\u65e0\u6545\u5230\u539f\u544a\u6240\u6709\u7684\u4f4d\u4e8e\u9149\u9633\u53bf\u6c47\u5347\u5e7f\u573a1\u5e6214-2\u623f\u5c4b\u5916\u627e\u539f\u544a\u95f9\u4e8b\uff0c\u5e76\u5c06\u539f\u544a\u9632\u76d7\u95e8\u780d\u574f\uff0c\u539f\u544a\u53d7\u5230\u60ca\u5413\u4e0d\u6562\u51fa\u95e8\uff0c\u7acb\u5373\u62a5\u8b66\u3002\u968f\u540e\uff0c\u88ab\u544a\u88ab\u6c11\u8b66\u5e26\u81f3\u9149\u9633\u53bf\u57ce\u5357\u6d3e\u51fa\u6240\u63a7\u5236\u3002\u7ecf\u8c03\u89e3\uff0c\u88ab\u544a\u62d2\u4e0d\u8d54\u507f\u539f\u544a\u9632\u76d7\u95e8\u7684\u635f\u5931\u3002\u7efc\u4e0a\uff0c\u6839\u636e\u300a\u6c11\u6cd5\u5178\u300b\u300a\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b49\u76f8\u5173\u6cd5\u5f8b\u7684\u89c4\u5b9a\uff0c\u539f\u544a\u4f9d\u6cd5\u8bc9\u81f3\u8d35\u9662\uff0c\u8bf7\u6c42\u5224\u5982\u6240\u8bf7\u3002\", \"defendant_defence\": \"\u5bf9\u62a5\u8b66\u56de\u6267\u6709\u610f\u89c1\uff0c\u6211\u662f\u80a2\u4f53\u6b8b\u75be\uff0c\u6ca1\u6709\u80fd\u529b\u53bb\u635f\u5bb3\u623f\u95e8\uff0c\u6ca1\u6709\u5bf9\u95e8\u9020\u6210\u635f\u5bb3\u3002\", \"evidence\": {\"plaintiff_evidence\": {\"evidence_1\": {\"evidence\": \"\u62a5\u8b66\u56de\u6267\", \"dispute\": \"\u539f\u544a\u4e3e\u793a\u7684\u62a5\u8b66\u56de\u6267\u53ca\u623f\u95e8\u635f\u5bb3\u7167\u7247\u65e0\u6cd5\u8bc1\u660e\u9020\u6210\u539f\u544a\u623f\u95e8\u635f\u574f\u7cfb\u88ab\u544a\u5189\u67d0\u884c\u4e3a\u6240\u81f4\u3002\"}, \"evidence_2\": {\"evidence\": \"\u623f\u95e8\u635f\u5bb3\u7167\u7247\", \"dispute\": \"\u539f\u544a\u4e3e\u793a\u7684\u62a5\u8b66\u56de\u6267\u53ca\u623f\u95e8\u635f\u5bb3\u7167\u7247\u65e0\u6cd5\u8bc1\u660e\u9020\u6210\u539f\u544a\u623f\u95e8\u635f\u574f\u7cfb\u88ab\u544a\u5189\u67d0\u884c\u4e3a\u6240\u81f4\u3002\"}, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null, \"evidence_10\": null}, \"defendant_evidence\": {\"evidence_1\": null, \"evidence_2\": null, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null}}, \"other_statement\": {\"plaintiff\": {\"plaintiff_1\": \"\"}, \"defendant\": {\"defendant_1\": \"\"}}}\n\u6700\u540e\u5728\u65b0\u7684\u4e00\u884c\u4ee5 'Answer:' \u5f00\u5934\u7ed9\u51fa\u7b80\u6d01\u7684\u6700\u7ec8\u88c1\u5224\u4e3b\u6587\u3002",
        "correct_answer": [
            "\u9a73\u56de\u539f\u544a\u5189\u67d0\u67d0\u7684\u8bc9\u8bbc\u8bf7\u6c42",
            "\u6848\u4ef6\u53d7\u7406\u8d3950\u5143\uff0c\u56e0\u9002\u7528\u5c0f\u989d\u8bc9\u8bbc\u5ba1\u7406\u630940%\u6536\u53d620\u5143\uff0c\u7531\u539f\u544a\u5189\u67d0\u67d0\u8d1f\u62c5\u3002",
            "\u672c\u5224\u51b3\u4e3a\u7ec8\u5ba1\u5224\u51b3"
        ],
        "n": 0,
        "response": "**\u91cd\u5e86\u5e02\u67d0\u67d0\u4eba\u6c11\u6cd5\u9662**\n**\u6c11\u4e8b\u5224\u51b3\u4e66**\n\n**\uff08\u6848\u53f7\uff1a2024\u6e1dXXXX\u6c11\u521dXXXX\u53f7\uff09**\n\n**\u539f\u544a\uff1a**\u5189\u67d0\u67d0\uff0c\u5973\uff0c\u571f\u5bb6\u65cf\uff0c1985\u5e745\u670821\u65e5\u51fa\u751f\uff0c\u4f4f\u91cd\u5e86\u5e02\u9149\u9633\u571f\u5bb6\u65cf\u82d7\u65cf\u81ea\u6cbb\u53bf\u3002\n**\u88ab\u544a\uff1a**\u5189\u67d0\uff0c\u5973\uff0c\u571f\u5bb6\u65cf\uff0c1971\u5e743\u67086\u65e5\u51fa\u751f\uff0c\u4f4f\u91cd\u5e86\u5e02\u6c5f\u6d25\u533a\u3002\n\n\u539f\u544a\u5189\u67d0\u67d0\u4e0e\u88ab\u544a\u5189\u67d0\u8d22\u4ea7\u635f\u5bb3\u8d54\u507f\u7ea0\u7eb7\u4e00\u6848\uff0c\u672c\u9662\u53d7\u7406\u540e\uff0c\u4f9d\u6cd5\u7531\u5ba1\u5224\u5458\u72ec\u4efb\u5ba1\u5224\uff0c\u73b0\u5df2\u5ba1\u7406\u7ec8\u7ed3\u3002\n\n**\u539f\u544a\u8bc9\u79f0\uff1a**2024\u5e741\u670825\u65e5\u665a\uff0c\u88ab\u544a\u65e0\u6545\u5230\u539f\u544a\u4f4d\u4e8e\u9149\u9633\u53bf\u6c47\u5347\u5e7f\u573a1\u5e6214-2\u623f\u5c4b\u5916\u95f9\u4e8b\uff0c\u5e76\u5c06\u539f\u544a\u9632\u76d7\u95e8\u780d\u574f\u3002\u539f\u544a\u62a5\u8b66\u540e\uff0c\u88ab\u544a\u88ab\u8b66\u65b9\u63a7\u5236\uff0c\u4f46\u62d2\u4e0d\u8d54\u507f\u635f\u5931\u3002\u8bf7\u6c42\u5224\u4ee4\uff1a1. \u88ab\u544a\u8d54\u507f\u539f\u544a\u9632\u76d7\u95e8\u635f\u59314000\u5143\uff1b2. \u672c\u6848\u8bc9\u8bbc\u8d39\u7531\u88ab\u544a\u627f\u62c5\u3002\n\n**\u88ab\u544a\u8fa9\u79f0\uff1a**\u88ab\u544a\u5e76\u672a\u5bf9\u539f\u544a\u623f\u95e8\u9020\u6210\u635f\u5bb3\u3002\u88ab\u544a\u7cfb\u80a2\u4f53\u6b8b\u75be\uff0c\u4e0d\u5177\u5907\u635f\u6bc1\u623f\u95e8\u7684\u80fd\u529b\uff0c\u4e14\u539f\u544a\u63d0\u4f9b\u7684\u8bc1\u636e\u4e0d\u80fd\u8bc1\u660e\u7cfb\u88ab\u544a\u6240\u4e3a\u3002\n\n**\u672c\u9662\u7ecf\u5ba1\u7406\u8ba4\u5b9a\uff1a**\n\u6839\u636e\u5f53\u4e8b\u4eba\u9648\u8ff0\u548c\u7ecf\u5f53\u5ead\u8d28\u8bc1\u7684\u8bc1\u636e\uff0c\u672c\u9662\u8ba4\u5b9a\u4e8b\u5b9e\u5982\u4e0b\uff1a2024\u5e741\u670825\u65e5\uff0c\u539f\u544a\u66fe\u5c31\u623f\u95e8\u53d7\u635f\u60c5\u51b5\u5411\u516c\u5b89\u673a\u5173\u62a5\u8b66\u3002\u539f\u544a\u4e3e\u793a\u4e86\u62a5\u8b66\u56de\u6267\u53ca\u623f\u95e8\u53d7\u635f\u7167\u7247\uff0c\u8bc1\u660e\u5176\u623f\u95e8\u5b58\u5728\u635f\u574f\u4e8b\u5b9e\u3002\u88ab\u544a\u5bf9\u8be5\u4e8b\u5b9e\u4e0d\u4e88\u8ba4\u53ef\uff0c\u4e3b\u5f20\u5176\u5e76\u672a\u5b9e\u65bd\u4fb5\u6743\u884c\u4e3a\u3002\n\n**\u672c\u9662\u8ba4\u4e3a\uff1a**\n\u672c\u6848\u7cfb\u8d22\u4ea7\u635f\u5bb3\u8d54\u507f\u7ea0\u7eb7\uff0c\u7126\u70b9\u5728\u4e8e\u88ab\u544a\u662f\u5426\u5b9e\u65bd\u4e86\u4fb5\u6743\u884c\u4e3a\u4ee5\u53ca\u539f\u544a\u4e3b\u5f20\u7684\u635f\u5931\u91d1\u989d\u662f\u5426\u6709\u4e8b\u5b9e\u4f9d\u636e\u3002\n\n\u9996\u5148\uff0c\u5173\u4e8e\u4fb5\u6743\u884c\u4e3a\u7684\u8ba4\u5b9a\u3002\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u516d\u5341\u4e03\u6761\u4e4b\u89c4\u5b9a\uff0c\u5f53\u4e8b\u4eba\u5bf9\u81ea\u5df1\u63d0\u51fa\u7684\u4e3b\u5f20\uff0c\u6709\u8d23\u4efb\u63d0\u4f9b\u8bc1\u636e\u3002\u539f\u544a\u4e3b\u5f20\u88ab\u544a\u5c06\u5176\u9632\u76d7\u95e8\u780d\u574f\uff0c\u867d\u63d0\u4f9b\u4e86\u201c\u62a5\u8b66\u56de\u6267\u201d\u53ca\u201c\u623f\u95e8\u635f\u5bb3\u7167\u7247\u201d\uff0c\u4f46\u62a5\u8b66\u56de\u6267\u4ec5\u80fd\u8bc1\u660e\u539f\u544a\u66fe\u5411\u516c\u5b89\u673a\u5173\u62a5\u6848\uff0c\u5e76\u4e0d\u7b49\u540c\u4e8e\u516c\u5b89\u673a\u5173\u5bf9\u88ab\u544a\u4fb5\u6743\u4e8b\u5b9e\u7684\u5b9a\u6027\u8ba4\u5b9a\uff1b\u623f\u95e8\u635f\u5bb3\u7167\u7247\u4ec5\u80fd\u8bc1\u660e\u635f\u5bb3\u7ed3\u679c\u7684\u5b58\u5728\uff0c\u65e0\u6cd5\u76f4\u63a5\u5173\u8054\u81f3\u88ab\u544a\u7684\u4fb5\u6743\u884c\u4e3a\u3002\u5728\u88ab\u544a\u660e\u786e\u5426\u8ba4\u5b9e\u65bd\u4e86\u635f\u6bc1\u884c\u4e3a\u7684\u60c5\u51b5\u4e0b\uff0c\u539f\u544a\u672a\u63d0\u4ea4\u8bf8\u5982\u516c\u5b89\u673a\u5173\u7684\u8be2\u95ee\u7b14\u5f55\u3001\u884c\u653f\u5904\u7f5a\u51b3\u5b9a\u4e66\u6216\u73b0\u573a\u76d1\u63a7\u89c6\u9891\u7b49\u8fdb\u4e00\u6b65\u8bc1\u636e\u8bc1\u660e\u88ab\u544a\u7cfb\u8be5\u635f\u5bb3\u7684\u5b9e\u65bd\u4e3b\u4f53\u3002\n\n\u5176\u6b21\uff0c\u5173\u4e8e\u635f\u5bb3\u8d54\u507f\u91d1\u989d\u7684\u8ba4\u5b9a\u3002\u539f\u544a\u4e3b\u5f20\u9632\u76d7\u95e8\u635f\u5931\u4e3a4000\u5143\uff0c\u4f46\u672a\u5411\u672c\u9662\u63d0\u4ea4\u8d2d\u4e70\u8be5\u95e8\u7684\u539f\u59cb\u51ed\u8bc1\u3001\u7ef4\u4fee\u53d1\u7968\u6216\u7ecf\u7b2c\u4e09\u65b9\u9274\u5b9a\u673a\u6784\u51fa\u5177\u7684\u4ef7\u503c\u8bc4\u4f30\u62a5\u544a\u3002\u5728\u65e0\u8bc1\u636e\u4f50\u8bc1\u635f\u5931\u5177\u4f53\u6570\u989d\u7684\u60c5\u51b5\u4e0b\uff0c\u539f\u544a\u5e94\u627f\u62c5\u4e3e\u8bc1\u4e0d\u80fd\u7684\u6cd5\u5f8b\u540e\u679c\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u539f\u544a\u5189\u67d0\u67d0\u63d0\u4f9b\u7684\u8bc1\u636e\u4e0d\u8db3\u4ee5\u8bc1\u660e\u88ab\u544a\u5189\u67d0\u5b9e\u65bd\u4e86\u4fb5\u6743\u884c\u4e3a\uff0c\u4ea6\u672a\u80fd\u8bc1\u660e\u5176\u4e3b\u5f20\u7684\u635f\u5931\u91d1\u989d\u5177\u6709\u5408\u7406\u6027\u3002\u5176\u8bc9\u8bbc\u8bf7\u6c42\u7f3a\u4e4f\u4e8b\u5b9e\u548c\u6cd5\u5f8b\u4f9d\u636e\uff0c\u672c\u9662\u4e0d\u4e88\u652f\u6301\u3002\u636e\u6b64\uff0c\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u516d\u5341\u4e94\u6761\u3001\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u516d\u5341\u4e03\u6761\u7b2c\u4e00\u6b3e\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n\u9a73\u56de\u539f\u544a\u5189\u67d0\u67d0\u7684\u5168\u90e8\u8bc9\u8bbc\u8bf7\u6c42\u3002\n\n\u6848\u4ef6\u53d7\u7406\u8d39\uff08\u5982\u5df2\u4ea7\u751f\uff09\uff0c\u7531\u539f\u544a\u5189\u67d0\u67d0\u8d1f\u62c5\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u91cd\u5e86\u5e02\u7b2c\u56db\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002\n\n\u5ba1\u5224\u957f\uff1a[\u59d3\u540d]\n\u4e8c\u3007\u4e8c\u56db\u5e74 X \u6708 X \u65e5\n\uff08\u9662\u5370\uff09\n\nAnswer: \u9a73\u56de\u539f\u544a\u5189\u67d0\u67d0\u7684\u5168\u90e8\u8bc9\u8bbc\u8bf7\u6c42\u3002\u6848\u4ef6\u53d7\u7406\u8d39\u7531\u539f\u544a\u627f\u62c5\u3002",
        "sub_tasks_text": null
    }
]