[
    {
        "example_id": 3,
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u5a5a\u59fb\u5bb6\u5ead\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u6731\u67d0\", \"address\": \"\u5bcc\u5e73\u53bf\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1992\u5e742\u67087\u65e5\"}, \"defendant\": {\"name\": \"\u515a\u67d01\", \"address\": \"\u5bcc\u5e73\u53bf\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1992\u5e7412\u670828\u65e5\"}}, \"plaintiff_claim\": [\"\u4f9d\u6cd5\u5224\u4ee4\u539f\u3001\u88ab\u544a\u79bb\u5a5a\", \"\u5a5a\u751f\u5973\u515a\u67d02\u7531\u539f\u544a\u629a\u517b\uff0c\u88ab\u544a\u6bcf\u6708\u652f\u4ed8\u5b69\u5b50\u629a\u517b\u8d391000\u5143\uff0c\u81f3\u5b69\u5b50\u5e74\u6ee118\u5468\u5c81\", \"\u88ab\u544a\u7684\u5b69\u5b50\u515a\u4f69\u598d\u7531\u88ab\u544a\u629a\u517b\", \"\u9655\uff35\uff26\u00d7\u00d7\u00d7\u00d7\u53f7\u8f66\u8f86\u7684\u5269\u4f59\u8d37\u6b3e\u7531\u88ab\u544a\u627f\u62c5\", \"\u8bc9\u8bbc\u8d39\u7531\u88ab\u544a\u627f\u62c5\"], \"plaintiff_case_details\": \"\u539f\u3001\u88ab\u544a\u7ecf\u4eba\u4ecb\u7ecd\u767b\u8bb0\u7ed3\u5a5a\uff0c\u5a5a\u540e\u751f\u80b2\u4e00\u5973\u3002\u56e0\u5a5a\u524d\u7f3a\u4e4f\u4e86\u89e3\uff0c\u611f\u60c5\u57fa\u7840\u8584\u5f31\uff0c\u5a5a\u540e\u6027\u683c\u4e0d\u548c\uff0c\u5e38\u56e0\u7410\u4e8b\u53d1\u751f\u4e89\u5435\uff0c\u88ab\u544a\u4e0d\u4f46\u5bf9\u539f\u544a\u5b9e\u65bd\u5bb6\u66b4\uff0c\u8fd8\u4e0e\u5979\u4eba\u4fdd\u6301\u4e0d\u6b63\u5f53\u5173\u7cfb\uff0c\u9891\u7e41\u7ed9\u7f51\u7edc\u4e3b\u64ad\u53ca\u5176\u5979\u5973\u6027\u8f6c\u8d26\uff0c\u4e25\u91cd\u8fdd\u80cc\u4e86\u592b\u59bb\u7684\u5fe0\u8bda\u4e49\u52a1\uff1b\u4e14\u88ab\u544a\u79c1\u81ea\u5c06\u5a5a\u540e\u6309\u63ed\u8d2d\u7f6e\u7684\u8f66\u8f86\u51fa\u552e\uff0c\u5e76\u672a\u7ecf\u539f\u544a\u540c\u610f\u5229\u7528\u539f\u544a\u7684\u8eab\u4efd\u4fe1\u606f\u7533\u8bf7\u8d37\u6b3e\uff0c\u4e25\u91cd\u4fb5\u5bb3\u4e86\u88ab\u544a\u7684\u8d22\u4ea7\u6743\u76ca\u30022024\u5e747\u670812\u65e5\uff0c\u53cc\u65b9\u56e0\u518d\u6b21\u4e89\u5435\uff0c\u88ab\u544a\u5bf9\u539f\u544a\u62f3\u811a\u76f8\u52a0\uff0c\u5e76\u66f4\u6362\u95e8\u9501\uff0c\u53cc\u65b9\u5206\u5c45\u751f\u6d3b\u3002\", \"defendant_defence\": \"\u867d\u56e0\u5bb6\u5ead\u77db\u76fe\u53ca\u539f\u544a\u7684\u65bd\u538b\uff0c\u88ab\u544a\u5728\u8c08\u8bdd\u65f6\u8868\u8ff0\u540c\u610f\u79bb\u5a5a\uff0c\u4f46\u57fa\u4e8e\u53cc\u65b9\u4e4b\u95f4\u611f\u60c5\u5e76\u672a\u5f7b\u5e95\u7834\u88c2\uff0c\u73b0\u575a\u51b3\u4e0d\u540c\u610f\u79bb\u5a5a\u3002\u5a5a\u540e\u88ab\u544a\u867d\u4e0e\u5176\u5979\u5f02\u6027\u5b58\u6709\u8a00\u8bed\u7684\u4e0d\u5f53\uff0c\u4f46\u5e76\u4e0d\u5b58\u5728\u4e0d\u6b63\u5f53\u5173\u7cfb\u7684\u51fa\u8f68\uff0c\u4e5f\u672a\u5bf9\u539f\u544a\u5b9e\u65bd\u5bb6\u66b4\u30022022\u5e7410\u6708\u4efd\u88ab\u544a\u867d\u79c1\u81ea\u5c06\u5a5a\u540e\u767b\u8bb0\u5728\u539f\u544a\u540d\u4e0b\u6309\u63ed\u8d2d\u7f6e\u7684\u8f66\u8f86\u53d8\u5356\uff0c\u4f46\u88ab\u544a\u7ed9\u4ed8\u539f\u544a\u7684\u94b1\u6b3e\u8fdc\u8fdc\u5927\u4e8e\u8f66\u8d37\u7684\u91d1\u989d\uff0c\u800c\u8be5\u94b1\u6b3e\u7684\u6765\u6e90\u5373\u662f\u5411\u4fe1\u7528\u793e\u768460\u4e07\u5143\u8d37\u6b3e\uff0c\u53e6\u5728\u53cc\u65b9\u5a5a\u5185\uff0c\u539f\u544a\u5411\u88ab\u544a\u7236\u6bcd\u5b58\u6709\u5927\u91cf\u4e3e\u503a\u3002\", \"evidence\": {\"plaintiff_evidence\": {\"evidence_1\": {\"evidence\": \"\u88ab\u544a\u4e0e\u5979\u4eba\u7684\u5fae\u4fe1\u804a\u5929\u622a\u56fe\u3001\u7167\u7247\", \"dispute\": \"\u88ab\u544a\u5bf9\u4e0a\u8ff0\u8bc1\u636e\u7684\u771f\u5b9e\u6027\u5747\u65e0\u5f02\u8bae\uff0c\u4f46\u8ba4\u4e3a\u804a\u5929\u622a\u56fe\u7684\u5185\u5bb9\u4ec5\u5b58\u5728\u8a00\u8bed\u7684\u4e0d\u5f53\uff0c\u800c\u88ab\u544a\u4e0e\u5979\u4eba\u7684\u7167\u7247\u7a7f\u7740\u5f97\u4f53\u4e5f\u4e0d\u8db3\u4ee5\u8fbe\u5230\u539f\u544a\u7684\u8bc1\u660e\u76ee\u7684\"}, \"evidence_2\": {\"evidence\": \"\u539f\u544a\u7528\u4e8e\u8bc1\u660e\u88ab\u544a\u5bb6\u66b4\u7684\u63a5\u62a5\u8b66\u56de\u6267\u3001\u73b0\u573a\u7b14\u5f55\u53ca\u89c6\u9891\", \"dispute\": \"\u5e76\u65e0\u516c\u5b89\u673a\u5173\u5bf9\u4e8b\u4ef6\u7684\u67e5\u660e\u53ca\u5b9a\u6027\u8ba4\u5b9a\uff0c\u4e14\u89c6\u9891\u7cfb\u88ab\u544a\u4e4b\u7236\u4e0e\u539f\u544a\u53d1\u751f\u80a2\u4f53\u51b2\u7a81\u7684\u5f71\u50cf\uff0c\u6545\u4e0d\u8db3\u4ee5\u8bc1\u660e\u88ab\u544a\u5bf9\u539f\u544a\u5b9e\u65bd\u5bb6\u5ead\u66b4\u529b\"}, \"evidence_3\": {\"evidence\": \"\u88ab\u544a\u88ab\u516c\u5b89\u673a\u5173\u53d6\u4fdd\u5019\u5ba1\u7684\u901a\u77e5\u4e66\", \"dispute\": \"\u4ec5\u53ef\u8bc1\u660e\u88ab\u544a\u6d89\u5acc\u5211\u4e8b\u72af\u7f6a\uff0c\u4f46\u5e76\u672a\u7ecf\u4eba\u6c11\u6cd5\u9662\u8ba4\u5b9a\u6784\u6210\u72af\u7f6a\uff0c\u4e14\u8be5\u60c5\u51b5\u5e76\u4e0d\u5c5e\u8ba4\u5b9a\u592b\u59bb\u611f\u60c5\u786e\u5df2\u7834\u88c2\u7684\u6cd5\u5b9a\u60c5\u5f62\"}, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null, \"evidence_10\": null}, \"defendant_evidence\": {\"evidence_1\": null, \"evidence_2\": null, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null}}, \"other_statement\": {\"plaintiff\": {\"plaintiff_1\": \"\u53cc\u65b9\u572823\u5e74\u81f324\u5e74\u671f\u95f4\u786e\u5b9e\u6ca1\u6709\u4ec0\u4e48\u77db\u76fe\uff0c\u9020\u6210\u6fc0\u5316\u7684\u7f18\u7531\u57fa\u4e8e\u88ab\u544a\u7684\u7236\u4eb2\u6240\u81f4\"}, \"defendant\": {\"defendant_1\": \"\"}}}\n\u6700\u540e\u5728\u65b0\u7684\u4e00\u884c\u4ee5 'Answer:' \u5f00\u5934\u7ed9\u51fa\u7b80\u6d01\u7684\u6700\u7ec8\u88c1\u5224\u4e3b\u6587\u3002",
        "correct_answer": [
            "\u4e0d\u51c6\u539f\u544a\u6731\u67d0\u4e0e\u88ab\u544a\u515a\u67d01\u79bb\u5a5a\u3002",
            "\u6848\u4ef6\u53d7\u7406\u8d39300\u5143\uff0c\u51cf\u534a\u6536\u53d6150\u5143\uff0c\u7531\u539f\u544a\u6731\u67d0\u8d1f\u62c5\u3002"
        ],
        "n": 0,
        "response": "**\u9655\u897f\u7701\u5bcc\u5e73\u53bf\u4eba\u6c11\u6cd5\u9662**\n**\u6c11\u4e8b\u5224\u51b3\u4e66**\n\n**\uff082024\uff09\u96550528\u6c11\u521d\u5b57\u7b2cXXXX\u53f7**\n\n**\u539f\u544a\uff1a**\u6731\u67d0\uff0c\u5973\uff0c1992\u5e742\u67087\u65e5\u51fa\u751f\uff0c\u6c49\u65cf\uff0c\u4f4f\u5bcc\u5e73\u53bf\u3002\n**\u88ab\u544a\uff1a**\u515a\u67d01\uff0c\u7537\uff0c1992\u5e7412\u670828\u65e5\u51fa\u751f\uff0c\u6c49\u65cf\uff0c\u4f4f\u5bcc\u5e73\u53bf\u3002\n\n\u539f\u544a\u6731\u67d0\u4e0e\u88ab\u544a\u515a\u67d01\u79bb\u5a5a\u7ea0\u7eb7\u4e00\u6848\uff0c\u672c\u9662\u53d7\u7406\u540e\uff0c\u4f9d\u6cd5\u7531\u5ba1\u5224\u5458\u9002\u7528\u7b80\u6613\u7a0b\u5e8f\u516c\u5f00\u5f00\u5ead\u8fdb\u884c\u4e86\u5ba1\u7406\u3002\u539f\u544a\u6731\u67d0\u3001\u88ab\u544a\u515a\u67d01\u5747\u5230\u5ead\u53c2\u52a0\u4e86\u8bc9\u8bbc\u3002\u672c\u6848\u73b0\u5df2\u5ba1\u7406\u7ec8\u7ed3\u3002\n\n**\u672c\u9662\u7ecf\u5ba1\u7406\u8ba4\u5b9a\u4e8b\u5b9e\u5982\u4e0b\uff1a**\n\u539f\u3001\u88ab\u544a\u7ecf\u4eba\u4ecb\u7ecd\u76f8\u8bc6\uff0c\u767b\u8bb0\u7ed3\u5a5a\u540e\u751f\u80b2\u4e00\u5973\u515a\u67d02\u3002\u5a5a\u540e\u521d\u671f\u53cc\u65b9\u611f\u60c5\u5c1a\u53ef\uff0c\u4f46\u968f\u7740\u751f\u6d3b\u63a8\u79fb\uff0c\u53cc\u65b9\u56e0\u5bb6\u5ead\u7410\u4e8b\u4ea7\u751f\u77db\u76fe\u3002\u539f\u544a\u8bc9\u79f0\u88ab\u544a\u5b58\u5728\u5bb6\u66b4\u3001\u5a5a\u5916\u4e0d\u6b63\u5f53\u5173\u7cfb\u53ca\u64c5\u81ea\u5904\u5206\u8d22\u4ea7\u7b49\u884c\u4e3a\uff0c\u5e76\u63d0\u4ea4\u4e86\u5fae\u4fe1\u804a\u5929\u622a\u56fe\u3001\u63a5\u62a5\u8b66\u56de\u6267\u53ca\u89c6\u9891\u3001\u53d6\u4fdd\u5019\u5ba1\u901a\u77e5\u4e66\u7b49\u8bc1\u636e\u3002\u88ab\u544a\u5bf9\u5fae\u4fe1\u804a\u5929\u8bb0\u5f55\u7684\u771f\u5b9e\u6027\u4e88\u4ee5\u8ba4\u53ef\uff0c\u4f46\u5426\u8ba4\u5b58\u5728\u4e0d\u6b63\u5f53\u5173\u7cfb\u53ca\u5bb6\u66b4\uff0c\u5e76\u8868\u8fbe\u4e86\u575a\u51b3\u4e0d\u540c\u610f\u79bb\u5a5a\u3001\u5e0c\u671b\u6539\u5584\u5173\u7cfb\u7684\u610f\u613f\u3002\u539f\u544a\u5728\u5ead\u5ba1\u4e2d\u4ea6\u8ba4\u53ef\u53cc\u65b9\u57282023\u5e74\u81f32024\u5e74\u671f\u95f4\u77db\u76fe\u8f83\u5c11\u3002\n\n**\u672c\u9662\u8ba4\u4e3a\uff1a**\n\u5a5a\u59fb\u5e94\u4ee5\u611f\u60c5\u4e3a\u57fa\u7840\u3002\u672c\u6848\u4e2d\uff0c\u539f\u3001\u88ab\u544a\u867d\u56e0\u5bb6\u5ead\u7410\u4e8b\u53ca\u5904\u7406\u5bb6\u5ead\u5173\u7cfb\u4e0d\u5f53\u4ea7\u751f\u77db\u76fe\uff0c\u4f46\u53cc\u65b9\u5a5a\u59fb\u57fa\u7840\u8f83\u597d\uff0c\u4e14\u57282023\u5e74\u81f32024\u5e74\u671f\u95f4\u66fe\u6709\u8fc7\u8f83\u957f\u65f6\u95f4\u7684\u5e73\u7a33\u751f\u6d3b\u3002\u539f\u544a\u63d0\u4ea4\u7684\u8bc1\u636e\u867d\u80fd\u53cd\u6620\u88ab\u544a\u5728\u4e0e\u5f02\u6027\u4ea4\u5f80\u4e2d\u5b58\u5728\u8a00\u8bed\u5931\u5f53\u53ca\u7ecf\u6d4e\u5f80\u6765\u4e0d\u5ba1\u614e\u7684\u95ee\u9898\uff0c\u4e0d\u8db3\u4ee5\u8ba4\u5b9a\u6cd5\u5f8b\u610f\u4e49\u4e0a\u7684\u201c\u4ed6\u4eba\u540c\u5c45\u201d\u6216\u201c\u4e25\u91cd\u8fdd\u80cc\u5fe0\u8bda\u4e49\u52a1\u201d\u5bfc\u81f4\u611f\u60c5\u786e\u5df2\u7834\u88c2\u7684\u60c5\u5f62\uff1b\u5173\u4e8e\u5bb6\u66b4\uff0c\u539f\u544a\u63d0\u4f9b\u7684\u63a5\u62a5\u8b66\u8bb0\u5f55\u53ca\u89c6\u9891\u663e\u793a\u53cc\u65b9\u5bb6\u5ead\u6210\u5458\u4e4b\u95f4\u5b58\u5728\u80a2\u4f53\u51b2\u7a81\uff0c\u4f46\u5c1a\u4e0d\u8db3\u4ee5\u8ba4\u5b9a\u88ab\u544a\u5bf9\u539f\u544a\u5b9e\u65bd\u4e86\u5e38\u6001\u5316\u6216\u4e25\u91cd\u7684\u5bb6\u5ead\u66b4\u529b\uff1b\u88ab\u544a\u867d\u6d89\u5acc\u5211\u4e8b\u72af\u7f6a\u88ab\u53d6\u4fdd\u5019\u5ba1\uff0c\u4f46\u8fd9\u5e76\u975e\u6cd5\u5f8b\u89c4\u5b9a\u7684\u8ba4\u5b9a\u592b\u59bb\u611f\u60c5\u786e\u5df2\u7834\u88c2\u7684\u6cd5\u5b9a\u5fc5\u7136\u6761\u4ef6\u3002\n\n\u8003\u8651\u5230\u88ab\u544a\u8868\u8fbe\u4e86\u5f3a\u70c8\u7684\u6094\u6539\u610f\u613f\u53ca\u7ef4\u7cfb\u5bb6\u5ead\u7684\u51b3\u5fc3\uff0c\u4e14\u539f\u544a\u4e5f\u627f\u8ba4\u53cc\u65b9\u8fd1\u671f\u66fe\u6709\u548c\u7766\u76f8\u5904\u7684\u9636\u6bb5\uff0c\u8bf4\u660e\u592b\u59bb\u611f\u60c5\u5c1a\u672a\u5b8c\u5168\u7834\u88c2\u3002\u53cc\u65b9\u5e94\u5728\u4eca\u540e\u7684\u751f\u6d3b\u4e2d\u52a0\u5f3a\u6c9f\u901a\uff0c\u88ab\u544a\u5e94\u6df1\u523b\u53cd\u7701\u5176\u5728\u5904\u7406\u5f02\u6027\u5173\u7cfb\u53ca\u5bb6\u5ead\u77db\u76fe\u4e2d\u7684\u9519\u8bef\uff0c\u539f\u544a\u4ea6\u5e94\u7ed9\u4e88\u53cc\u65b9\u611f\u60c5\u4fee\u590d\u7684\u673a\u4f1a\u3002\u5728\u592b\u59bb\u611f\u60c5\u5c1a\u672a\u5b8c\u5168\u7834\u88c2\u7684\u60c5\u51b5\u4e0b\uff0c\u4ece\u7ef4\u62a4\u5bb6\u5ead\u7a33\u5b9a\u3001\u6709\u5229\u4e8e\u5b50\u5973\u5065\u5eb7\u6210\u957f\u7684\u89d2\u5ea6\u51fa\u53d1\uff0c\u672c\u9662\u5bf9\u539f\u544a\u8981\u6c42\u79bb\u5a5a\u7684\u8bc9\u8bf7\u4e0d\u4e88\u652f\u6301\u3002\u56e0\u79bb\u5a5a\u8bf7\u6c42\u672a\u83b7\u51c6\u8bb8\uff0c\u539f\u544a\u5173\u4e8e\u5b50\u5973\u629a\u517b\u53ca\u8d22\u4ea7\u5206\u5272\u7684\u8bc9\u8bbc\u8bf7\u6c42\uff0c\u672c\u9662\u4e00\u5e76\u4e88\u4ee5\u9a73\u56de\u3002\n\n\u636e\u6b64\uff0c\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u96f6\u4e03\u5341\u4e5d\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n\u9a73\u56de\u539f\u544a\u6731\u67d0\u8981\u6c42\u4e0e\u88ab\u544a\u515a\u67d01\u79bb\u5a5a\u7684\u8bc9\u8bbc\u8bf7\u6c42\u3002\n\n\u6848\u4ef6\u53d7\u7406\u8d39\uff08\u5df2\u51cf\u534a\u6536\u53d6\uff09\uff0c\u7531\u539f\u544a\u6731\u67d0\u8d1f\u62c5\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u9655\u897f\u7701\u6e2d\u5357\u5e02\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002\n\n\u5ba1\u5224\u957f\uff1aXXX\n\u4e8c\u3007\u4e8c\u56db\u5e74X\u6708X\u65e5\n\u4e66\u8bb0\u5458\uff1aXXX\n\nAnswer: \u9a73\u56de\u539f\u544a\u6731\u67d0\u8981\u6c42\u4e0e\u88ab\u544a\u515a\u67d01\u79bb\u5a5a\u7684\u8bc9\u8bbc\u8bf7\u6c42\u3002",
        "sub_tasks_text": null
    }
]