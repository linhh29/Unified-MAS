[
    {
        "example_id": 15,
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u7269\u6743\u7ea0\u7eb7\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u5317\u4eac\u67d0\u67d0\u96c6\u56e2\u6709\u9650\u516c\u53f8\", \"address\": \"\u5317\u4eac\u5e02\u5927\u5174\u533a\", \"representative\": \"\u9a6c\u67d0\u8363\", \"gender\": null, \"ethnicity\": null, \"birth_date\": null}, \"defendant\": {\"name\": \"\u9999\u6cb3\u53bf\u67d0\u67d0\u623f\u5730\u4ea7\u5f00\u53d1\u6709\u9650\u516c\u53f8\", \"address\": \"\u6cb3\u5317\u7701\u9999\u6cb3\u53bf\uff08\u534e\u590f\u57ce\u5e02\uff09\", \"representative\": \"\u5415\u67d0\u519b\", \"gender\": null, \"ethnicity\": null, \"birth_date\": null}}, \"plaintiff_claim\": [\"\u5224\u4ee4\u88ab\u544a\u5411\u539f\u544a\u652f\u4ed8\u7968\u636e\u91d1\u989d\u76f8\u5f53\u7684\u5229\u76ca300000\u5143\", \"\u5224\u4ee4\u88ab\u544a\u627f\u62c5\u672c\u6848\u8bc9\u8bbc\u8d39\u7528\"], \"plaintiff_case_details\": \"\u539f\u544a\u4e0e\u88ab\u544a2016\u5e74\u7b7e\u8ba2\u4e86\u300a\u5927\u8fd0\u6cb3\u5b54\u96c0\u57ce7.3\u671f\u914d\u7535\u7bb1\u3001\u67dc\u91c7\u8d2d\u5408\u540c\u300b\uff0c2020\u5e7410\u670829\u65e5\u88ab\u544a\u4ea4\u4ed8\u539f\u544a\u4e00\u5f20\u91d1\u989d\u4e3a300000\u5143\u7684\u7535\u5b50\u5546\u4e1a\u627f\u5151\u6c47\u7968\u7528\u4e8e\u652f\u4ed8\u8d27\u6b3e\uff0c\u7968\u53f7230810000530120201030749187\uff0c\u6c47\u7968\u5230\u671f\u65e52021\u5e7410\u670829\u65e5\uff0c2020\u5e7412\u670816\u65e5\u539f\u544a\u80cc\u4e66\u8f6c\u8ba9\u7ed9\u4e0b\u6e38\u4f9b\u5e94\u5546\u5317\u4eac\u67d0\u67d0\u5149\u7535\u6c14\u6709\u9650\u516c\u53f8\uff0c\u6c47\u7968\u5230\u671f\u540e\u65e0\u6cd5\u627f\u5151\uff0c\u5317\u4eac\u67d0\u67d0\u5149\u7535\u6c14\u6709\u9650\u516c\u53f8\u4ee5\u4e70\u5356\u5408\u540c\u7ea0\u7eb7\u8bc9\u81f3\u5317\u4eac\u5e02\u4e30\u53f0\u533a\u6cd5\u9662\uff0c\u6cd5\u9662\u5224\u51b3\u539f\u544a\u652f\u4ed8\u5317\u4eac\u67d0\u67d0\u5149\u7535\u6c14\u6709\u9650\u516c\u53f8\u8d27\u6b3e\u3002\u56e0\u7968\u636e\u6743\u5229\u5df2\u8fc7\u65f6\u6548,\u539f\u544a\u4f9d\u636e\u300a\u7968\u636e\u6cd5\u300b\u7b2c\u5341\u516b\u6761\u89c4\u5b9a\uff0c\u63d0\u8d77\u7968\u636e\u5229\u76ca\u8fd4\u8fd8\u8bf7\u6c42\u6743\u8bc9\u8bbc\uff0c\u8981\u6c42\u88ab\u544a\u652f\u4ed8\u7968\u636e\u91d1\u989d\u76f8\u5f53\u7684\u5229\u76ca300000\u5143\u3002\", \"defendant_defence\": \"\u4e00\u3001\u539f\u544a\u5e76\u975e\u6848\u6d89\u7968\u636e\u6700\u7ec8\u6301\u7968\u4eba\uff0c\u5e76\u4e14\u672a\u5b8c\u6210\u5411\u5317\u4eac\u67d0\u67d0\u7535\u6c14\u6709\u9650\u516c\u53f8\u6e05\u507f\uff0c\u5176\u672a\u53d6\u5f97\u7968\u636e\u518d\u8ffd\u7d22\u6743\u3002\u6839\u636e\u300a\u7968\u636e\u6cd5\u300b\u7b2c\u4e03\u5341\u6761\u7b2c\u4e8c\u6b3e\u53ca\u7b2c\u4e03\u5341\u4e00\u6761\u89c4\u5b9a\uff0c\u539f\u544a\u53d6\u5f97\u6848\u6d89\u7968\u636e\u518d\u8ffd\u7d22\u6743\u7684\u524d\u63d0\u662f\u539f\u544a\u5b8c\u6210\u5411\u5317\u4eac\u67d0\u67d0\u7535\u6c14\u6709\u9650\u516c\u53f8\u6e05\u507f\u3002\u672c\u6848\u4e2d\uff0c\u539f\u544a\u672a\u63d0\u4ea4\u5411\u5317\u4eac\u67d0\u67d0\u7535\u6c14\u6709\u9650\u516c\u53f8\u7684\u6e05\u507f\u8bb0\u5f55\u3001\u8ffd\u7d22\u4eba\u51fa\u5177\u7684\u6536\u636e\u7b49\u6587\u4ef6\uff0c\u5e76\u4e14\u7968\u636e\u7cfb\u7edf\u4e5f\u672a\u663e\u793a\u6e05\u507f\u8bb0\u5f55\uff0c\u56e0\u6b64\uff0c\u73b0\u6709\u8bc1\u636e\u4e0d\u80fd\u8bc1\u660e\u539f\u544a\u53d6\u5f97\u4e86\u7968\u636e\u518d\u8ffd\u7d22\u6743\u3002\u4e8c\u3001\u9274\u4e8e\u539f\u544a\u4e0d\u662f\u6848\u6d89\u7968\u636e\u6700\u7ec8\u5408\u6cd5\u6301\u7968\u4eba\uff0c\u5176\u65e0\u6743\u5411\u9999\u6cb3\u80dc\u5f3a\u67d0\u67d0\u4e3b\u5f20\u7968\u636e\u91d1\u989d\u76f8\u5f53\u5229\u76ca\u3002\u6839\u636e\u300a\u7968\u636e\u6cd5\u300b\u7b2c\u5341\u516b\u6761\u89c4\u5b9a\uff0c\u6301\u7968\u4eba\u56e0\u8d85\u8fc7\u7968\u636e\u6743\u5229\u65f6\u6548\u800c\u4e27\u5931\u7968\u636e\u6743\u5229\u7684\uff0c\u53ef\u4ee5\u8bf7\u6c42\u51fa\u7968\u4eba\u6216\u8005\u627f\u5151\u4eba\u8fd4\u8fd8\u5176\u4e0e\u672a\u652f\u4ed8\u7684\u7968\u636e\u91d1\u989d\u76f8\u5f53\u7684\u5229\u76ca\u3002\u672c\u6848\u4e2d\uff0c\u539f\u544a\u63d0\u4ea4\u7684\u8bc1\u636e\u663e\u793a\u6848\u6d89\u7968\u636e\u6700\u7ec8\u6301\u7968\u4eba\u4e3a\u5317\u4eac\u67d0\u67d0\u5149\u7535\u6c14\u6709\u9650\u516c\u53f8\uff0c\u539f\u544a\u4e0d\u662f\u6848\u6d89\u7968\u636e\u7684\u6700\u7ec8\u6301\u7968\u4eba\u3002\u56e0\u6b64\uff0c\u539f\u544a\u65e0\u6743\u5411\u9999\u6cb3\u80dc\u5f3a\u67d0\u67d0\u4e3b\u5f20\u6848\u6d89\u7968\u636e\u91d1\u989d\u76f8\u5f53\u7684\u5229\u76ca\u3002\u4e09\u3001\u5982\u6cd5\u9662\u5224\u51b3\u9999\u6cb3\u80dc\u5f3a\u67d0\u67d0\u627f\u62c5\u8d23\u4efb\uff0c\u5219\u539f\u544a\u6709\u4e49\u52a1\u5728\u7968\u636e\u7cfb\u7edf\u4e2d\u8fdb\u884c\u5c06\u7968\u636e\u9000\u56de\u9999\u6cb3\u80dc\u5f3a\u67d0\u67d0\u7684\u64cd\u4f5c\u3002\u5426\u5219\uff0c\u9999\u6cb3\u80dc\u5f3a\u67d0\u67d0\u5b58\u5728\u53cc\u91cd\u652f\u4ed8\u7968\u9762\u91d1\u989d\u7684\u98ce\u9669\u3002\u56db\u3001\u5982\u679c\u539f\u544a\u4eab\u6709\u6848\u6d89\u7968\u636e\u518d\u8ffd\u7d22\u6743\u4e14\u6cd5\u9662\u5224\u4ee4\u9999\u6cb3\u80dc\u5f3a\u67d0\u67d0\u627f\u62c5\u8d23\u4efb\uff0c\u8bf7\u6c42\u6cd5\u9662\u7ed9\u4e88\u9999\u6cb3\u80dc\u5f3a\u67d0\u67d0\u4e0d\u5c11\u4e8e\u4e09\u4e2a\u6708\u7684\u5c65\u884c\u671f\u3002\", \"evidence\": {\"plaintiff_evidence\": {\"evidence_1\": {\"evidence\": \"\u7535\u5b50\u5546\u4e1a\u627f\u5151\u6c47\u7968\uff0c\u8bc1\u660e\u76ee\u7684\uff1a\u6848\u6d89\u6c47\u7968\u51fa\u7968\u65e5\u671f\u662f2020\u5e7410\u670829\u65e5\uff0c2020\u5e7412\u670817\u65e5\u5317\u4eac\u67d0\u67d0\u516c\u53f8\u80cc\u4e66\u8f6c\u8ba9\u7ed9\u5317\u4eac\u67d0\u67d0\u6709\u9650\u516c\u53f8\u3002\u7968\u636e\u5230\u671f\u65e5\u662f2021\u5e7410\u670829\u65e5\uff0c\u5317\u4eac\u67d0\u67d0\u6709\u9650\u516c\u53f8\u6ca1\u6709\u5151\u4ed8\u3002\", \"dispute\": \"\u8ba4\u53ef\u8bc1\u636e\u4e00\u7968\u9762\u6b63\u9762\u57fa\u7840\u4fe1\u606f\u7684\u771f\u5b9e\u6027\uff0c\u4e0d\u8ba4\u53ef\u8bc1\u660e\u76ee\u7684\u3002\u65e0\u6cd5\u8bc1\u660e\u76ee\u524d\u7684\u7968\u636e\u72b6\u6001\uff0c\u4e14\u7968\u636e\u80cc\u4e66\u4fe1\u606f\u663e\u793a\u539f\u544a\u5df2\u5c06\u6848\u6d89\u7968\u636e\u80cc\u4e66\u8f6c\u8ba9\u7ed9\u5317\u4eac\u67d0\u67d0\u6709\u9650\u516c\u53f8\uff0c\u7968\u636e\u7cfb\u7edf\u672a\u663e\u793a\u8ffd\u7d22\u6e05\u507f\u4fe1\u606f\uff0c\u56e0\u6b64\u539f\u544a\u4e0d\u662f\u7968\u636e\u7684\u6700\u7ec8\u6301\u7968\u4eba\uff0c\u65e0\u6743\u5411\u88ab\u544a\u4e3b\u5f20\u6848\u6d89\u7968\u636e\u76f8\u5173\u7684\u6743\u5229\u3002\"}, \"evidence_2\": {\"evidence\": \"\uff082022\uff09\u4eac0106\u6c11\u521d3400\u53f7\u6c11\u4e8b\u5224\u51b3\u4e66\uff0c\u8bc1\u660e\u76ee\u7684\uff1a\u5317\u4eac\u67d0\u67d0\u6709\u9650\u516c\u53f8\u8d77\u8bc9\u5317\u4eac\u67d0\u67d0\u516c\u53f8\uff0c\u5317\u4eac\u5e02\u4e30\u53f0\u533a\u6cd5\u9662\u5224\u51b3\u5317\u4eac\u67d0\u67d0\u516c\u53f8\u652f\u4ed8\u5317\u4eac\u67d0\u67d0\u6709\u9650\u516c\u53f8304390\u5143\u3002\", \"dispute\": \"\u771f\u5b9e\u6027\u4ee5\u6cd5\u9662\u8ba4\u5b9a\u4e3a\u51c6\uff0c\u4e0d\u8ba4\u53ef\u5173\u8054\u6027\u53ca\u8bc1\u660e\u76ee\u7684\u3002\u7968\u636e\u7cfb\u7edf\u663e\u793a\u7684\u6700\u7ec8\u6301\u7968\u4eba\u4e3a\u5c71\u4e1c\u67d0\u67d0\u7535\u6c14\u6709\u9650\u516c\u53f8\uff0c\u975e\u8be5\u5224\u51b3\u4e2d\u7684\u5317\u4eac\u67d0\u67d0\u6709\u9650\u516c\u53f8\uff0c\u5317\u4eac\u67d0\u67d0\u6709\u9650\u516c\u53f8\u5728\u63d0\u8d77\u8be5\u8bc9\u8bbc\u65f6\uff0c\u5176\u4e0d\u4eab\u6709\u6848\u6d89\u7968\u636e\u6743\u5229\uff0c\u65e0\u6743\u5411\u539f\u544a\u884c\u4f7f\u8ffd\u7d22\u6743\u3002\u5982\u679c\u539f\u544a\u5411\u4e0d\u4eab\u6709\u7968\u636e\u6743\u5229\u7684\u5317\u4eac\u67d0\u67d0\u6709\u9650\u516c\u53f8\u8fdb\u884c\u6e05\u507f\uff0c\u65e0\u6743\u53d6\u5f97\u6848\u6d89\u7968\u636e\u7684\u518d\u8ffd\u7d22\u6743\u3002\u8be5\u5224\u51b3\u4e2d\u4ec5\u786e\u5b9a\u4e86\u539f\u544a\u7684\u4ed8\u6b3e\u4e49\u52a1\uff0c\u672a\u89c1\u539f\u544a\u5b9e\u9645\u5c65\u884c\u5224\u51b3\u4e49\u52a1\u7684\u4ed8\u6b3e\u51ed\u8bc1\u7b49\u76f8\u5173\u6750\u6599\uff0c\u4e0d\u80fd\u8bc1\u660e\u539f\u544a\u6e05\u507f\u60c5\u51b5\u3002\"}, \"evidence_3\": {\"evidence\": \"\uff082022\uff09\u518010\u6c11\u521d1681\u53f7\u53ca\uff082023\uff09\u5180\u6c11\u7ec81025\u53f7\u6c11\u4e8b\u5224\u51b3\u4e66\uff0c\u8bc1\u660e\u76ee\u7684\uff1a\u56e0\u7968\u636e\u672a\u5151\u4ed8\uff0c\u5317\u4eac\u67d0\u67d0\u516c\u53f8\u8d77\u8bc9\u9999\u6cb3\u80dc\u5f3a\u67d0\u67d0\uff0c\u6cd5\u9662\u5224\u51b3\u8981\u6c42\u5317\u4eac\u67d0\u67d0\u516c\u53f8\u53e6\u6848\u4e3b\u5f20\u3002\", \"dispute\": \"\u8ba4\u53ef\u8bc1\u636e\u4e09\u7684\u771f\u5b9e\u6027\uff0c\u8be5\u5224\u51b3\u5df2\u7ecf\u786e\u8ba4\u539f\u544a\u975e\u6848\u6d89\u7968\u636e\u7684\u6700\u7ec8\u6301\u7968\u4eba\uff0c\u672a\u652f\u6301\u5176\u76f8\u5173\u8bc9\u8bf7\u3002\"}, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null, \"evidence_10\": null}, \"defendant_evidence\": {\"evidence_1\": {\"evidence\": \"\u7535\u5b50\u5546\u4e1a\u627f\u5151\u6c47\u7968\u7968\u9762\u4fe1\u606f\", \"dispute\": \"\u8ba4\u53ef\u771f\u5b9e\u6027\uff0c\u6750\u6599\u663e\u793a\u6848\u6d89\u6700\u7ec8\u6301\u7968\u4eba\u3001\u63d0\u793a\u4ed8\u6b3e\u4eba\u4e3a\u5c71\u4e1c\u67d0\u67d0\u7535\u6c14\u6709\u9650\u516c\u53f8\uff0c\u5e76\u975e\u539f\u544a\u3002\u7968\u636e\u7cfb\u7edf\u672a\u8bb0\u8f7d\u8ffd\u7d22\u6e05\u507f\u4fe1\u606f\uff0c\u5373\u5c71\u4e1c\u67d0\u67d0\u7535\u6c14\u6709\u9650\u516c\u53f8\u4ecd\u4e3a\u6700\u7ec8\u6301\u7968\u4eba\uff0c\u6545\u539f\u544a\u65e0\u6743\u4e3b\u5f20\u7968\u636e\u6743\u5229\u3002\", \"name\": null}, \"evidence_2\": null, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null}}, \"other_statement\": {\"plaintiff\": {\"plaintiff_1\": \"\"}, \"defendant\": {\"defendant_1\": \"\"}}}\n\u6700\u540e\u5728\u65b0\u7684\u4e00\u884c\u4ee5 'Answer:' \u5f00\u5934\u7ed9\u51fa\u7b80\u6d01\u7684\u6700\u7ec8\u88c1\u5224\u4e3b\u6587\u3002",
        "correct_answer": [
            "\u9a73\u56de\u539f\u544a\u5317\u4eac\u67d0\u67d0\u96c6\u56e2\u6709\u9650\u516c\u53f8\u7684\u5168\u90e8\u8bc9\u8bbc\u8bf7\u6c42\u3002",
            "\u6848\u4ef6\u53d7\u7406\u8d395800\u5143\uff0c\u7531\u5317\u4eac\u67d0\u67d0\u96c6\u56e2\u6709\u9650\u516c\u53f8\u8d1f\u62c5\u3002",
            "\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u4ee5\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u8bc9\u8bbc\u670d\u52a1\u4e2d\u5fc3\u9012\u4ea4\u6216\u90ae\u5bc4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u6cb3\u5317\u7701\u9ad8\u7ea7\u4eba\u6c11\u6cd5\u9662\uff1b\u4e5f\u53ef\u4ee5\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u6cb3\u5317\u7701\u9ad8\u7ea7\u4eba\u6c11\u6cd5\u9662\u5728\u7ebf\u63d0\u4ea4\u4e0a\u8bc9\u72b6\u3002"
        ],
        "n": 0,
        "response": "**\u5317\u4eac\u5e02\u5927\u5174\u533a\u4eba\u6c11\u6cd5\u9662**\n\n**\u6c11\u4e8b\u5224\u51b3\u4e66**\n\n\uff08\u6848\u53f7\uff1a2023\u4eac0115\u6c11\u521dXXXX\u53f7\uff09\n\n**\u539f\u544a\uff1a** \u5317\u4eac\u67d0\u67d0\u96c6\u56e2\u6709\u9650\u516c\u53f8\n**\u6cd5\u5b9a\u4ee3\u8868\u4eba\uff1a** \u9a6c\u67d0\u8363\n**\u88ab\u544a\uff1a** \u9999\u6cb3\u53bf\u67d0\u67d0\u623f\u5730\u4ea7\u5f00\u53d1\u6709\u9650\u516c\u53f8\n**\u6cd5\u5b9a\u4ee3\u8868\u4eba\uff1a** \u5415\u67d0\u519b\n\n\u672c\u9662\u5ba1\u7406\u7684\u539f\u544a\u5317\u4eac\u67d0\u67d0\u96c6\u56e2\u6709\u9650\u516c\u53f8\uff08\u4ee5\u4e0b\u7b80\u79f0\u201c\u67d0\u67d0\u96c6\u56e2\u201d\uff09\u8bc9\u88ab\u544a\u9999\u6cb3\u53bf\u67d0\u67d0\u623f\u5730\u4ea7\u5f00\u53d1\u6709\u9650\u516c\u53f8\uff08\u4ee5\u4e0b\u7b80\u79f0\u201c\u9999\u6cb3\u516c\u53f8\u201d\uff09\u7968\u636e\u5229\u76ca\u8fd4\u8fd8\u8bf7\u6c42\u6743\u7ea0\u7eb7\u4e00\u6848\uff0c\u73b0\u5df2\u5ba1\u7406\u7ec8\u7ed3\u3002\n\n**\u5ba1\u7406\u67e5\u660e\uff1a**\n2016\u5e74\uff0c\u539f\u3001\u88ab\u544a\u7b7e\u8ba2\u300a\u5927\u8fd0\u6cb3\u5b54\u96c0\u57ce7.3\u671f\u914d\u7535\u7bb1\u3001\u67dc\u91c7\u8d2d\u5408\u540c\u300b\u30022020\u5e7410\u670829\u65e5\uff0c\u88ab\u544a\u4e3a\u652f\u4ed8\u8d27\u6b3e\uff0c\u5411\u539f\u544a\u7b7e\u53d1\u91d1\u989d\u4e3a300,000\u5143\u7684\u7535\u5b50\u5546\u4e1a\u627f\u5151\u6c47\u7968\u4e00\u5f20\uff08\u7968\u53f7\uff1a230810000530120201030749187\uff09\uff0c\u5230\u671f\u65e5\u4e3a2021\u5e7410\u670829\u65e5\u3002\n2020\u5e7412\u670816\u65e5\uff0c\u539f\u544a\u5c06\u8be5\u6c47\u7968\u80cc\u4e66\u8f6c\u8ba9\u7ed9\u4e0b\u6e38\u4f9b\u5e94\u5546\u5317\u4eac\u67d0\u67d0\u5149\u7535\u6c14\u6709\u9650\u516c\u53f8\uff08\u4ee5\u4e0b\u7b80\u79f0\u201c\u67d0\u67d0\u5149\u516c\u53f8\u201d\uff09\u3002\u6c47\u7968\u5230\u671f\u540e\uff0c\u56e0\u6545\u672a\u83b7\u5151\u4ed8\u3002\u6b64\u540e\uff0c\u67d0\u67d0\u5149\u516c\u53f8\u56e0\u4e70\u5356\u5408\u540c\u7ea0\u7eb7\u5c06\u539f\u544a\u8d77\u8bc9\u81f3\u5317\u4eac\u5e02\u4e30\u53f0\u533a\u4eba\u6c11\u6cd5\u9662\uff0c\u6cd5\u9662\u5224\u51b3\u539f\u544a\u5411\u67d0\u67d0\u5149\u516c\u53f8\u652f\u4ed8\u76f8\u5e94\u6b3e\u9879\u3002\n\u56e0\u6d89\u6848\u7968\u636e\u6743\u5229\u5df2\u8fc7\u65f6\u6548\uff0c\u539f\u544a\u9042\u4f9d\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u7968\u636e\u6cd5\u300b\u7b2c\u5341\u516b\u6761\u4e4b\u89c4\u5b9a\u63d0\u8d77\u672c\u6848\u8bc9\u8bbc\uff0c\u8981\u6c42\u88ab\u544a\u8fd4\u8fd8\u4e0e\u7968\u636e\u91d1\u989d\u76f8\u5f53\u7684\u5229\u76ca300,000\u5143\u3002\n\n**\u672c\u9662\u8ba4\u4e3a\uff1a**\n\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u7968\u636e\u6cd5\u300b\u7b2c\u5341\u516b\u6761\u89c4\u5b9a\uff1a\u201c\u6301\u7968\u4eba\u56e0\u8d85\u8fc7\u7968\u636e\u6743\u5229\u65f6\u6548\u6216\u8005\u56e0\u7968\u636e\u8bb0\u8f7d\u4e8b\u9879\u6b20\u7f3a\u800c\u4e27\u5931\u7968\u636e\u6743\u5229\u7684\uff0c\u4ecd\u4eab\u6709\u6c11\u4e8b\u6743\u5229\uff0c\u53ef\u4ee5\u8bf7\u6c42\u51fa\u7968\u4eba\u6216\u8005\u627f\u5151\u4eba\u8fd4\u8fd8\u5176\u4e0e\u672a\u4ed8\u7684\u7968\u636e\u91d1\u989d\u76f8\u5f53\u7684\u5229\u76ca\u3002\u201d\n\n\u672c\u6848\u7684\u4e89\u8bae\u7126\u70b9\u5728\u4e8e\uff1a\u539f\u544a\u662f\u5426\u5177\u5907\u4e3b\u5f20\u7968\u636e\u5229\u76ca\u8fd4\u8fd8\u8bf7\u6c42\u6743\u7684\u4e3b\u4f53\u8d44\u683c\uff0c\u4ee5\u53ca\u88ab\u544a\u662f\u5426\u5e94\u5f53\u627f\u62c5\u652f\u4ed8\u8d23\u4efb\u3002\n\n\u7b2c\u4e00\uff0c\u5173\u4e8e\u4e3b\u4f53\u8d44\u683c\u3002\u88ab\u544a\u8fa9\u79f0\u539f\u544a\u975e\u6700\u7ec8\u6301\u7968\u4eba\uff0c\u4e14\u672a\u8bc1\u660e\u5df2\u5b9e\u9645\u5c65\u884c\u8ffd\u7d22\u6743\u4e0b\u7684\u6e05\u507f\u4e49\u52a1\u3002\u672c\u9662\u8ba4\u4e3a\uff0c\u7968\u636e\u5229\u76ca\u8fd4\u8fd8\u8bf7\u6c42\u6743\u662f\u4e3a\u4e86\u8865\u6551\u56e0\u65f6\u6548\u7b49\u539f\u56e0\u4e27\u5931\u7968\u636e\u6743\u5229\u7684\u6301\u7968\u4eba\uff0c\u9632\u6b62\u51fa\u7968\u4eba\u6216\u627f\u5151\u4eba\u83b7\u53d6\u4e0d\u5f53\u5229\u76ca\u3002\u867d\u7136\u7535\u5b50\u7968\u636e\u7cfb\u7edf\u663e\u793a\u7684\u6700\u7ec8\u6301\u7968\u4eba\u4e3a\u4ed6\u4eba\uff0c\u4f46\u6839\u636e\u5df2\u751f\u6548\u7684\uff082022\uff09\u4eac0106\u6c11\u521d3400\u53f7\u6c11\u4e8b\u5224\u51b3\u4e66\uff0c\u539f\u544a\u4f5c\u4e3a\u80cc\u4e66\u4eba\u5df2\u88ab\u5224\u4ee4\u5411\u524d\u624b\u627f\u62c5\u57fa\u7840\u6c11\u4e8b\u5173\u7cfb\u7684\u4ed8\u6b3e\u8d23\u4efb\u3002\u8fd9\u610f\u5473\u7740\u6848\u6d89\u7968\u636e\u672a\u80fd\u5151\u4ed8\u7684\u6cd5\u5f8b\u540e\u679c\u53ca\u5b9e\u9645\u7ecf\u6d4e\u635f\u5931\u6700\u7ec8\u7531\u539f\u544a\u627f\u62c5\u3002\u539f\u544a\u867d\u56e0\u65f6\u6548\u4e27\u5931\u4e86\u7968\u636e\u6743\u5229\uff0c\u4f46\u5176\u4f5c\u4e3a\u5b9e\u9645\u5229\u76ca\u53d7\u635f\u65b9\uff0c\u6709\u6743\u5411\u6848\u6d89\u7968\u636e\u7684\u7b7e\u53d1\u4eba\u53ca\u627f\u5151\u4eba\uff08\u5373\u88ab\u544a\uff09\u4e3b\u5f20\u8fd4\u8fd8\u4e0e\u7968\u636e\u91d1\u989d\u76f8\u5f53\u7684\u5229\u76ca\u3002\n\n\u7b2c\u4e8c\uff0c\u5173\u4e8e\u88ab\u544a\u7684\u652f\u4ed8\u8d23\u4efb\u3002\u88ab\u544a\u7b7e\u53d1\u6848\u6d89\u6c47\u7968\u7528\u4e8e\u652f\u4ed8\u4e0e\u539f\u544a\u4e4b\u95f4\u7684\u5408\u540c\u8d27\u6b3e\u3002\u88ab\u544a\u4f5c\u4e3a\u51fa\u7968\u4eba\u548c\u627f\u5151\u4eba\uff0c\u5728\u7968\u636e\u672a\u5b9e\u9645\u5151\u4ed8\u4e14\u7968\u636e\u6743\u5229\u56e0\u65f6\u6548\u5c4a\u6ee1\u800c\u6d88\u706d\u7684\u60c5\u51b5\u4e0b\uff0c\u5176\u539f\u672c\u5e94\u5f53\u652f\u4ed8\u7684\u5bf9\u4ef7\u5e76\u672a\u5b9e\u9645\u6d41\u51fa\uff0c\u7531\u6b64\u83b7\u5f97\u4e86\u4e0e\u7968\u636e\u91d1\u989d\u76f8\u5f53\u7684\u5229\u76ca\u3002\u8fd9\u79cd\u5229\u76ca\u83b7\u53d6\u7f3a\u4e4f\u5408\u6cd5\u7684\u6700\u7ec8\u4f9d\u636e\uff0c\u5e94\u4e88\u8fd4\u8fd8\u3002\n\n\u7b2c\u4e09\uff0c\u5173\u4e8e\u88ab\u544a\u63d0\u51fa\u7684\u53cc\u91cd\u652f\u4ed8\u98ce\u9669\u3002\u672c\u6848\u5224\u51b3\u88ab\u544a\u5411\u539f\u544a\u652f\u4ed8\u5229\u76ca\u540e\uff0c\u539f\u544a\u5e94\u5728\u7535\u5b50\u5546\u4e1a\u6c47\u7968\u7cfb\u7edf\u4e2d\u914d\u5408\u5b8c\u6210\u76f8\u5e94\u7684\u6807\u6ce8\u6216\u6ce8\u9500\u64cd\u4f5c\u3002\u7531\u4e8e\u7968\u636e\u6743\u5229\u5df2\u8fc7\u65f6\u6548\uff0c\u5176\u4ed6\u6301\u7968\u4eba\u5df2\u65e0\u6cd5\u901a\u8fc7\u7968\u636e\u6743\u5229\u5411\u88ab\u544a\u4e3b\u5f20\u6743\u5229\u3002\u82e5\u88ab\u544a\u62c5\u5fc3\u540e\u7eed\u98ce\u9669\uff0c\u53ef\u5728\u5c65\u884c\u672c\u5224\u51b3\u4e49\u52a1\u7684\u540c\u65f6\uff0c\u8981\u6c42\u539f\u544a\u51fa\u5177\u7968\u636e\u76f8\u5173\u6743\u76ca\u5df2\u7ed3\u6e05\u7684\u8bc1\u660e\u6216\u901a\u8fc7\u53f8\u6cd5\u7a0b\u5e8f\u4e88\u4ee5\u660e\u786e\u3002\u88ab\u544a\u8981\u6c42\u7684\u201c\u4e09\u4e2a\u6708\u5c65\u884c\u671f\u201d\u7f3a\u4e4f\u6cd5\u5f8b\u4f9d\u636e\uff0c\u672c\u9662\u4e0d\u4e88\u652f\u6301\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u539f\u544a\u7684\u8bc9\u8bbc\u8bf7\u6c42\u5177\u6709\u6cd5\u5f8b\u4f9d\u636e\uff0c\u672c\u9662\u4e88\u4ee5\u652f\u6301\u3002\n\n**\u5224\u51b3\u5982\u4e0b\uff1a**\n\u88ab\u544a\u9999\u6cb3\u53bf\u67d0\u67d0\u623f\u5730\u4ea7\u5f00\u53d1\u6709\u9650\u516c\u53f8\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\uff0c\u5411\u539f\u544a\u5317\u4eac\u67d0\u67d0\u96c6\u56e2\u6709\u9650\u516c\u53f8\u652f\u4ed8\u7968\u636e\u5229\u76ca\u8fd4\u8fd8\u6b3e300,000\u5143\u3002\n\n\u5982\u672a\u6309\u672c\u5224\u51b3\u6307\u5b9a\u7684\u671f\u95f4\u5c65\u884c\u91d1\u94b1\u7ed9\u4ed8\u4e49\u52a1\uff0c\u5e94\u5f53\u6309\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u4e8c\u767e\u516d\u5341\u6761\u4e4b\u89c4\u5b9a\uff0c\u52a0\u500d\u652f\u4ed8\u8fdf\u5ef6\u5c65\u884c\u671f\u95f4\u7684\u503a\u52a1\u5229\u606f\u3002\n\u6848\u4ef6\u53d7\u7406\u8d39\u7531\u88ab\u544a\u627f\u62c5\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u5317\u4eac\u5e02\u7b2c\u4e00\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002\n\n\u5ba1\u5224\u957f\uff1a[\u59d3\u540d]\n\u4e8c\u3007\u4e8c\u4e09\u5e74 [\u6708] [\u65e5]\n\uff08\u6cd5\u9662\u516c\u7ae0\uff09\n\nAnswer: \u5224\u4ee4\u88ab\u544a\u5411\u539f\u544a\u652f\u4ed8\u7968\u636e\u91d1\u989d\u76f8\u5f53\u7684\u5229\u76ca300,000\u5143\uff1b\u7531\u88ab\u544a\u627f\u62c5\u672c\u6848\u8bc9\u8bbc\u8d39\u7528\u3002",
        "sub_tasks_text": null
