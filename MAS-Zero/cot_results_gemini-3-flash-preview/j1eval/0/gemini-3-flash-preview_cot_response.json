        "example_id": 0,
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u4eba\u683c\u6743\u7ea0\u7eb7\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u5b8b\u67d0\", \"address\": \"\u5317\u4eac\u5e02\u5e73\u8c37\u533a\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"19xx\u5e74xx\u6708xx\u65e5\"}, \"defendant\": {\"name\": \"\u5317\u4eac\u5e02\u67d0\u5e7c\u513f\u56ed\", \"address\": \"\u5317\u4eac\u5e02\u5e73\u8c37\u533a\", \"representative\": \"\u80e1\u67d0\", \"gender\": null, \"ethnicity\": null, \"birth_date\": null}}, \"plaintiff_claim\": [\"\u5e7c\u513f\u56ed\u652f\u4ed8\u533b\u836f\u8d396900\u5143\", \"\u8bef\u5de5\u8d394000\u5143\", \"\u4ea4\u901a\u8d393000\u5143\", \"\u5b8b\u67d0\u7684\u7cbe\u795e\u635f\u5931\u8d3910000\u5143\", \"\u5b8b\u67d0\u540e\u671f\u6cbb\u7597\u8d3940000\u5143\"], \"plaintiff_case_details\": \"\u5b8b\u67d0\u662f\u5317\u4eac\u5e02\u67d0\u5e7c\u513f\u56ed\u7684\u5b66\u751f\u30022023\u5e744\u670821\u65e5\uff0c\u5317\u4eac\u5e02\u67d0\u5e7c\u513f\u56ed\u7ec4\u7ec7\u5b66\u751f\u5230\u5e73\u8c37\u533a\u4e16\u7eaa\u5e7f\u573a\u653e\u98ce\u7b5d\u3002\u5728\u653e\u98ce\u7b5d\u6d3b\u52a8\u671f\u95f4\uff0c\u5b8b\u67d0\u88ab\u5e7c\u513f\u56ed\u5176\u4ed6\u5b66\u751f\u7684\u98ce\u7b5d\u7ebf\u5272\u4f24\u9762\u90e8\uff08\u773c\u775b\u4e0b\u65b9\uff09\u3002\u5317\u4eac\u5e02\u67d0\u5e7c\u513f\u56ed\u5bf9\u5e7c\u513f\u56ed\u5b66\u751f\u6709\u76d1\u62a4\u804c\u8d23\uff0c\u5e94\u4fdd\u969c\u5b66\u751f\u7684\u4eba\u8eab\u5b89\u5168\u3002\u4f46\u7531\u4e8e\u5317\u4eac\u5e02\u67d0\u5e7c\u513f\u56ed\u672a\u5c3d\u5230\u5b89\u5168\u4fdd\u969c\u4e49\u52a1\uff0c\u5bfc\u81f4\u5b8b\u67d0\u906d\u53d7\u4eba\u8eab\u635f\u5bb3\u3002\", \"defendant_defence\": \"\u4e0d\u540c\u610f\u5b8b\u67d0\u7684\u8bc9\u8bbc\u8bf7\u6c42\u3002\u5b8b\u67d0\u53d7\u4f24\u5c5e\u4e8e\u610f\u5916\u4e8b\u4ef6\uff0c\u4e8b\u6545\u53d1\u751f\u540e\uff0c\u5e7c\u513f\u56ed\u79ef\u6781\u914d\u5408\u5bb6\u957f\u5c31\u533b\uff0c\u5317\u4eac\u5e02\u67d0\u5e7c\u513f\u56ed\u5df2\u7ecf\u5c3d\u5230\u6559\u80b2\u548c\u7ba1\u7406\u4e49\u52a1\uff0c\u65e0\u9700\u8d54\u507f\u3002\", \"evidence\": {\"plaintiff_evidence\": {\"evidence_1\": {\"evidence\": \"\u5b8b\u67d0\u63d0\u4ea4\u7684\u533b\u7597\u7968\u636e\", \"dispute\": \"\u5317\u4eac\u5e02\u67d0\u5e7c\u513f\u56ed\u66fe\u652f\u4ed8\u90e8\u5206\u533b\u7597\u8d39\u7528\"}, \"evidence_2\": {\"evidence\": \"\u4e2d\u56fd\u533b\u5b66\u79d1\u5b66\u9662\u6574\u5f62\u5916\u79d1\u533b\u96622024\u5e745\u670816\u65e5\u51fa\u5177\u7684\u95e8\u8bca\u75c5\u5386\", \"dispute\": \"\u7528\u4ee5\u652f\u6301\u540e\u7eed\u6cbb\u7597\u7684\u4e3b\u5f20\"}, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null, \"evidence_10\": null}, \"defendant_evidence\": {\"evidence_1\": {\"evidence\": \"\u5317\u4eac\u5e02\u67d0\u5e7c\u513f\u56ed\u63d0\u4ea4\u5173\u4e8e\u6d3b\u52a8\u7684\u5fae\u4fe1\u7fa4\u901a\u77e5\u8bb0\u5f55\", \"dispute\": \"\u672a\u63d0\u4f9b\u539f\u59cb\u8f7d\u4f53\uff0c\u539f\u544a\u5b8b\u67d0\u4e0d\u4e88\u8ba4\u53ef\", \"name\": null}, \"evidence_2\": null, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null}}, \"other_statement\": {\"plaintiff\": {\"plaintiff_1\": \"\u5b8b\u67d0\u539f\u5c31\u8bfb\u4e8e\u5317\u4eac\u5e02\u67d0\u5e7c\u513f\u56ed\uff0c2023\u5e744\u670821\u65e5\u4e0a\u5348\uff0c\u5b8b\u67d0\u6240\u5728\u4e2d\u4e8c\u73ed\u7ec4\u7ec7\u524d\u5f80\u5e73\u8c37\u4e16\u7eaa\u5e7f\u573a\u8fdb\u884c\u653e\u98ce\u7b5d\uff0c\u5728\u6d3b\u52a8\u4e2d\u5b8b\u67d0\u88ab\u98ce\u7b5d\u7ebf\u5212\u4f24\u773c\u775b\u5468\u8fb9\u76ae\u80a4\u3002\u4e8b\u6545\u53d1\u751f\u540e\u5b8b\u67d0\u5148\u540e\u524d\u5f80\u9996\u90fd\u533b\u79d1\u5927\u5b66\u9644\u5c5e\u5317\u4eac\u540c\u4ec1\u533b\u9662\u3001\u9996\u90fd\u533b\u79d1\u5927\u5b66\u9644\u5c5e\u5317\u4eac\u513f\u7ae5\u533b\u9662\u3001\u4e2d\u56fd\u533b\u5b66\u79d1\u5b66\u9662\u6574\u5f62\u5916\u79d1\u533b\u9662\u5c31\u8bca\uff0c\u5171\u82b1\u8d39\u533b\u7597\u8d394109.25\u5143\uff0c\u5176\u4e2d\u5317\u4eac\u5e02\u67d0\u5e7c\u513f\u56ed\u5df2\u7ecf\u652f\u4ed81859.17\u5143\uff0c\u5269\u4f592250.08\u5143\u662f\u5b8b\u67d0\u652f\u4ed8\u3002\u5b8b\u67d0\u4e3b\u5f20\u540e\u7eed\u8fd8\u9700\u8981\u505a\u5c04\u9891\uff0c\u9700\u82b1\u8d394649.92\u5143\uff0c\u6545\u52a0\u4e0a2250.08\u5143\u5c31\u662f\u7b2c\u4e00\u9879\u8bc9\u6c42\u7684\u91d1\u989d\uff0c\u5b8b\u67d0\u8868\u793a\u533b\u751f\u8bf4\u4ee5\u540e\u8981\u591a\u6b21\u5c04\u9891\uff0c\u6bcf\u6b21\u5c04\u9891\u82b1\u8d392250\u5143\uff0c\u505a\u5b8c\u5c04\u9891\u8981\u8d34\u7f8e\u80a4\u8d34\uff0c\u4e00\u5f20570\u5143\u3002\u8868\u793a\u540e\u7eed\u6cbb\u7597\u8d39\u7528\u662f\u6839\u636e\u540e\u7eed\u5b8b\u67d0\u505a\u5c04\u9891\u7684\u4ef7\u683c\u4f30\u7b97\u7684\uff0c\u73b0\u5728\u4e0d\u51c6\u5907\u8ba9\u5b8b\u67d0\u505a\u5c04\u9891\uff0c\u60f3\u7b49\u5b8b\u67d0\u6709\u81ea\u6211\u610f\u8bc6\u7231\u7f8e\u4e4b\u540e\u518d\u505a\u3002\"}, \"defendant\": {\"defendant_1\": \"\"}}}\n\u6700\u540e\u5728\u65b0\u7684\u4e00\u884c\u4ee5 'Answer:' \u5f00\u5934\u7ed9\u51fa\u7b80\u6d01\u7684\u6700\u7ec8\u88c1\u5224\u4e3b\u6587\u3002",
        "correct_answer": [
            "\u5317\u4eac\u5e02\u5e73\u8c37\u533a\u5317\u4eac\u5e02\u67d0\u5e7c\u513f\u56ed\u652f\u4ed8\u5b8b\u67d0\u533b\u7597\u8d39\u3001\u4ea4\u901a\u8d39\u3001\u7cbe\u795e\u635f\u5bb3\u629a\u6170\u91d1\u5171\u8ba16909.25\u5143\uff0c\u5176\u4e2d\u5df2\u652f\u4ed81859.17\u5143\uff0c\u5269\u4f595050.08\u5143\u4e8e\u672c\u5224\u51b3\u751f\u6548\u540e\u4e03\u65e5\u5185\u652f\u4ed8",
            "\u9a73\u56de\u5b8b\u67d0\u7684\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42",
            "\u672a\u6309\u672c\u5224\u51b3\u6307\u5b9a\u7684\u671f\u95f4\u5c65\u884c\u7ed9\u4ed8\u91d1\u94b1\u4e49\u52a1\uff0c\u5e94\u5f53\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u4e8c\u767e\u516d\u5341\u56db\u6761\u4e4b\u89c4\u5b9a\uff0c\u52a0\u500d\u652f\u4ed8\u8fdf\u5ef6\u5c65\u884c\u671f\u95f4\u7684\u503a\u52a1\u5229\u606f",
            "\u6848\u4ef6\u53d7\u7406\u8d3910\u5143\uff0c\u7531\u5317\u4eac\u5e02\u5e73\u8c37\u533a\u5317\u4eac\u5e02\u67d0\u5e7c\u513f\u56ed\u8d1f\u62c5\uff08\u4e8e\u672c\u5224\u51b3\u751f\u6548\u540e\u4e03\u65e5\u5185\u4ea4\u7eb3\uff09",
            "\u672c\u5224\u51b3\u4e3a\u7ec8\u5ba1\u5224\u51b3"
        ],
        "n": 0,
        "response": "**\u5317\u4eac\u5e02\u5e73\u8c37\u533a\u4eba\u6c11\u6cd5\u9662**\n**\u6c11\u4e8b\u5224\u51b3\u4e66**\n\n**\u6848\u53f7\uff1a(2024)\u4eac0117\u6c11\u521dXXXX\u53f7**\n\n**\u539f\u544a\uff1a** \u5b8b\u67d0\uff0c\u5973\uff0c\u6c49\u65cf\uff0c20xx\u5e74xx\u6708xx\u65e5\u51fa\u751f\uff0c\u4f4f\u5317\u4eac\u5e02\u5e73\u8c37\u533a\u3002\n**\u88ab\u544a\uff1a** \u5317\u4eac\u5e02\u67d0\u5e7c\u513f\u56ed\uff0c\u4f4f\u6240\u5730\u5317\u4eac\u5e02\u5e73\u8c37\u533a\u3002\n**\u6cd5\u5b9a\u4ee3\u8868\u4eba\uff1a** \u80e1\u67d0\u3002\n\n\u672c\u9662\u5ba1\u7406\u7684\u539f\u544a\u5b8b\u67d0\u4e0e\u88ab\u544a\u5317\u4eac\u5e02\u67d0\u5e7c\u513f\u56ed\u4eba\u683c\u6743\u7ea0\u7eb7\uff08\u5065\u5eb7\u6743\u7ea0\u7eb7\uff09\u4e00\u6848\uff0c\u73b0\u5df2\u5ba1\u7406\u7ec8\u7ed3\u3002\n\n**\u6cd5\u9662\u7ecf\u5ba1\u7406\u67e5\u660e\uff1a**\n2023\u5e744\u670821\u65e5\u4e0a\u5348\uff0c\u88ab\u544a\u5317\u4eac\u5e02\u67d0\u5e7c\u513f\u56ed\u7ec4\u7ec7\u5b66\u751f\u524d\u5f80\u5e73\u8c37\u533a\u4e16\u7eaa\u5e7f\u573a\u8fdb\u884c\u653e\u98ce\u7b5d\u6d3b\u52a8\u3002\u6d3b\u52a8\u671f\u95f4\uff0c\u539f\u544a\u5b8b\u67d0\u88ab\u5176\u4ed6\u5b66\u751f\u7684\u98ce\u7b5d\u7ebf\u5212\u4f24\u9762\u90e8\uff08\u773c\u775b\u4e0b\u65b9\uff09\u3002\u4e8b\u53d1\u540e\uff0c\u5b8b\u67d0\u5148\u540e\u524d\u5f80\u591a\u5bb6\u533b\u9662\u5c31\u8bca\uff0c\u5171\u4ea7\u751f\u533b\u7597\u8d394109.25\u5143\u3002\u5176\u4e2d\uff0c\u88ab\u544a\u5df2\u652f\u4ed81859.17\u5143\uff0c\u539f\u544a\u81ea\u884c\u57ab\u4ed82250.08\u5143\u3002\u539f\u544a\u4e3b\u5f20\u540e\u7eed\u4ecd\u9700\u8fdb\u884c\u591a\u6b21\u5c04\u9891\u6cbb\u7597\u53ca\u4f7f\u7528\u7f8e\u80a4\u8d34\uff0c\u5e76\u636e\u6b64\u4e3b\u5f20\u540e\u7eed\u6cbb\u7597\u8d39\u53ca\u76f8\u5173\u7684\u533b\u7597\u8d39\u5dee\u989d\u3002\u88ab\u544a\u5bf9\u4e8b\u6545\u4e8b\u5b9e\u65e0\u5f02\u8bae\uff0c\u4f46\u8fa9\u79f0\u5176\u5df2\u5c3d\u5230\u6559\u80b2\u7ba1\u7406\u4e49\u52a1\uff0c\u4e14\u5df2\u914d\u5408\u5c31\u533b\uff0c\u8ba4\u4e3a\u8be5\u4e8b\u4ef6\u5c5e\u4e8e\u610f\u5916\uff0c\u4e0d\u5e94\u627f\u62c5\u8d54\u507f\u8d23\u4efb\u3002\n\n**\u672c\u9662\u8ba4\u4e3a\uff1a**\n\u672c\u6848\u7cfb\u65e0\u6c11\u4e8b\u884c\u4e3a\u80fd\u529b\u4eba\u5728\u5e7c\u513f\u56ed\u5b66\u4e60\u3001\u751f\u6d3b\u671f\u95f4\u53d7\u5230\u4eba\u8eab\u635f\u5bb3\u5f15\u8d77\u7684\u7ea0\u7eb7\u3002\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u4e5d\u5341\u4e5d\u6761\u4e4b\u89c4\u5b9a\uff0c\u65e0\u6c11\u4e8b\u884c\u4e3a\u80fd\u529b\u4eba\u5728\u5e7c\u513f\u56ed\u3001\u5b66\u6821\u6216\u8005\u5176\u4ed6\u6559\u80b2\u673a\u6784\u5b66\u4e60\u3001\u751f\u6d3b\u671f\u95f4\u53d7\u5230\u4eba\u8eab\u635f\u5bb3\u7684\uff0c\u5e7c\u513f\u56ed\u3001\u5b66\u6821\u6216\u8005\u5176\u4ed6\u6559\u80b2\u673a\u6784\u5e94\u5f53\u627f\u62c5\u4fb5\u6743\u8d23\u4efb\uff1b\u4f46\u662f\uff0c\u80fd\u591f\u8bc1\u660e\u5c3d\u5230\u6559\u80b2\u3001\u7ba1\u7406\u804c\u8d23\u7684\uff0c\u4e0d\u627f\u62c5\u4fb5\u6743\u8d23\u4efb\u3002\n\n\u9996\u5148\uff0c\u5173\u4e8e\u8d23\u4efb\u8ba4\u5b9a\u3002\u88ab\u544a\u7ec4\u7ec7\u5e7c\u513f\u5728\u516c\u5171\u5e7f\u573a\u8fdb\u884c\u653e\u98ce\u7b5d\u6d3b\u52a8\uff0c\u5e94\u5f53\u9884\u89c1\u5230\u98ce\u7b5d\u7ebf\u5728\u7279\u5b9a\u73af\u5883\u4e0b\u5bf9\u5e7c\u513f\u9762\u90e8\u53ca\u8eab\u4f53\u53ef\u80fd\u4ea7\u751f\u7684\u5b89\u5168\u98ce\u9669\u3002\u88ab\u544a\u867d\u4e3b\u5f20\u5176\u5df2\u5c3d\u5230\u6559\u80b2\u7ba1\u7406\u4e49\u52a1\uff0c\u5e76\u63d0\u4ea4\u4e86\u5fae\u4fe1\u7fa4\u901a\u77e5\u8bb0\u5f55\u4f5c\u4e3a\u8bc1\u636e\uff0c\u4f46\u7531\u4e8e\u5176\u672a\u80fd\u63d0\u4f9b\u539f\u59cb\u8f7d\u4f53\u4e14\u539f\u544a\u4e0d\u4e88\u8ba4\u53ef\uff0c\u5176\u8bc1\u660e\u529b\u8f83\u5f31\u3002\u66f4\u91cd\u8981\u7684\u662f\uff0c\u5728\u5b9e\u9645\u6d3b\u52a8\u8fc7\u7a0b\u4e2d\uff0c\u88ab\u544a\u672a\u80fd\u6709\u6548\u9694\u79bb\u98ce\u9669\u6216\u91c7\u53d6\u5145\u5206\u7684\u9884\u9632\u63aa\u65bd\uff0c\u5bfc\u81f4\u539f\u544a\u9762\u90e8\u53d7\u4f24\u3002\u88ab\u544a\u6240\u8fa9\u79f0\u7684\u201c\u610f\u5916\u4e8b\u4ef6\u201d\u4e0d\u80fd\u514d\u9664\u5176\u6cd5\u5b9a\u7684\u5b89\u5168\u4fdd\u969c\u53ca\u6559\u80b2\u7ba1\u7406\u804c\u8d23\u3002\u6545\u88ab\u544a\u5bf9\u539f\u544a\u7684\u635f\u5bb3\u5e94\u627f\u62c5\u5168\u90e8\u8d54\u507f\u8d23\u4efb\u3002\n\n\u5176\u6b21\uff0c\u5173\u4e8e\u5404\u9879\u8bc9\u8bbc\u8bf7\u6c42\u7684\u6838\u5b9a\uff1a\n1. **\u533b\u7597\u8d39\uff1a** \u539f\u544a\u5df2\u53d1\u751f\u7684\u533b\u7597\u8d39\u603b\u8ba14109.25\u5143\uff0c\u6263\u9664\u88ab\u544a\u5df2\u652f\u4ed8\u76841859.17\u5143\uff0c\u88ab\u544a\u5e94\u8865\u8db3\u539f\u544a\u57ab\u4ed8\u76842250.08\u5143\u3002\u5173\u4e8e\u539f\u544a\u4e3b\u5f20\u7684\u989d\u5916\u533b\u7597\u8d39\u53ca\u540e\u7eed\u6cbb\u7597\u8d39\uff0840000\u5143\u53ca\u5c04\u9891\u8d39\u7528\u4f30\u7b97\uff09\uff0c\u539f\u544a\u660e\u786e\u8868\u793a\u76ee\u524d\u4e0d\u51c6\u5907\u8fdb\u884c\u6cbb\u7597\uff0c\u4e14\u76f8\u5173\u8d39\u7528\u5c1a\u672a\u5b9e\u9645\u53d1\u751f\u3002\u6839\u636e\u53f8\u6cd5\u5b9e\u8df5\uff0c\u5bf9\u4e8e\u5c1a\u672a\u53d1\u751f\u7684\u6cbb\u7597\u8d39\u7528\uff0c\u9664\u786e\u9700\u9884\u4ed8\u7684\u4ee5\u5916\uff0c\u5e94\u5f53\u5f85\u5b9e\u9645\u53d1\u751f\u540e\u53e6\u884c\u884c\u4f7f\u8bc9\u6743\u3002\u6545\u672c\u6848\u4e2d\u5bf9\u672a\u5b9e\u9645\u53d1\u751f\u7684\u540e\u7eed\u6cbb\u7597\u8d39\u4e0d\u4e88\u652f\u6301\u3002\n2. **\u8bef\u5de5\u8d39\uff1a** \u539f\u544a\u672a\u63d0\u4ea4\u5176\u6cd5\u5b9a\u4ee3\u7406\u4eba\u56e0\u62a4\u7406\u5bfc\u81f4\u7684\u5b9e\u9645\u51cf\u5c11\u6536\u5165\u7684\u8bc1\u636e\uff0c\u6545\u5bf94000\u5143\u8bef\u5de5\u8d39\u4e3b\u5f20\uff0c\u672c\u9662\u4e0d\u4e88\u652f\u6301\u3002\n3. **\u4ea4\u901a\u8d39\uff1a** \u539f\u544a\u867d\u672a\u63d0\u4ea4\u6b63\u5f0f\u7968\u636e\uff0c\u4f46\u8003\u8651\u5230\u5176\u591a\u6b21\u5f80\u8fd4\u5317\u4eac\u5e02\u533a\u533b\u9662\u5c31\u8bca\u7684\u5b9e\u9645\u9700\u8981\uff0c\u672c\u9662\u6839\u636e\u5c31\u8bca\u6b21\u6570\u53ca\u8ddd\u79bb\uff0c\u914c\u60c5\u652f\u6301500\u5143\u3002\n4. **\u7cbe\u795e\u635f\u5bb3\u629a\u6170\u91d1\uff1a** \u539f\u544a\u7cfb\u5e7c\u5973\uff0c\u9762\u90e8\u53d7\u635f\u5bf9\u5176\u8eab\u5fc3\u5065\u5eb7\u786e\u4f1a\u9020\u6210\u4e00\u5b9a\u8d1f\u9762\u5f71\u54cd\u3002\u8003\u8651\u5230\u4f24\u60c5\u4f4d\u4e8e\u9762\u90e8\u53ca\u88ab\u544a\u7684\u8fc7\u9519\u7a0b\u5ea6\uff0c\u672c\u9662\u914c\u60c5\u652f\u63012000\u5143\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u88ab\u544a\u5317\u4eac\u5e02\u67d0\u5e7c\u513f\u56ed\u5e94\u8d54\u507f\u539f\u544a\u5b8b\u67d0\u533b\u7597\u8d392250.08\u5143\u3001\u4ea4\u901a\u8d39500\u5143\u3001\u7cbe\u795e\u635f\u5bb3\u629a\u6170\u91d12000\u5143\uff0c\u5171\u8ba14750.08\u5143\u3002\n\n**\u5224\u51b3\u5982\u4e0b\uff1a**\n\n\u4e00\u3001\u88ab\u544a\u5317\u4eac\u5e02\u67d0\u5e7c\u513f\u56ed\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u4e03\u65e5\u5185\u8d54\u507f\u539f\u544a\u5b8b\u67d0\u533b\u7597\u8d39\u4e8c\u5343\u4e8c\u767e\u4e94\u5341\u5143\u96f6\u516b\u5206\uff1b\n\u4e8c\u3001\u88ab\u544a\u5317\u4eac\u5e02\u67d0\u5e7c\u513f\u56ed\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u4e03\u65e5\u5185\u8d54\u507f\u539f\u544a\u5b8b\u67d0\u4ea4\u901a\u8d39\u4e94\u767e\u5143\uff1b\n\u4e09\u3001\u88ab\u544a\u5317\u4eac\u5e02\u67d0\u5e7c\u513f\u56ed\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u4e03\u65e5\u5185\u8d54\u507f\u539f\u544a\u5b8b\u67d0\u7cbe\u795e\u635f\u5bb3\u629a\u6170\u91d1\u4e8c\u5343\u5143\uff1b\n\u56db\u3001\u9a73\u56de\u539f\u544a\u5b8b\u67d0\u7684\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42\u3002\n\n\u5982\u679c\u672a\u6309\u672c\u5224\u51b3\u6307\u5b9a\u7684\u671f\u95f4\u5c65\u884c\u7ed9\u4ed8\u91d1\u94b1\u4e49\u52a1\uff0c\u5e94\u5f53\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u4e8c\u767e\u516d\u5341\u6761\u4e4b\u89c4\u5b9a\uff0c\u52a0\u500d\u652f\u4ed8\u8fdf\u5ef6\u5c65\u884c\u671f\u95f4\u7684\u503a\u52a1\u5229\u606f\u3002\n\n\u6848\u4ef6\u53d7\u7406\u8d39\u7531\u88ab\u544a\u627f\u62c5\uff08\u6309\u6bd4\u4f8b\u8ba1\u7b97\uff09\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u5317\u4eac\u5e02\u7b2c\u4e09\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002\n\n\u5ba1\u5224\u957f\uff1aXXX\n\u4e8c\u3007\u4e8c\u56db\u5e74X\u6708X\u65e5\n\nAnswer: \n\u4e00\u3001\u88ab\u544a\u5317\u4eac\u5e02\u67d0\u5e7c\u513f\u56ed\u8d54\u507f\u539f\u544a\u5b8b\u67d0\u533b\u7597\u8d392250.08\u5143\uff1b\u4e8c\u3001\u88ab\u544a\u8d54\u507f\u539f\u544a\u4ea4\u901a\u8d39500\u5143\uff1b\u4e09\u3001\u88ab\u544a\u8d54\u507f\u539f\u544a\u7cbe\u795e\u635f\u5bb3\u629a\u6170\u91d12000\u5143\uff1b\u56db\u3001\u9a73\u56de\u539f\u544a\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42\u3002",
        "sub_tasks_text": null
    }
]