[
    {
        "example_id": 1,
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u5a5a\u59fb\u5bb6\u5ead\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u5f90\u67d0\", \"address\": \"\u6e56\u5317\u7701\u949f\u7965\u5e02\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1987\u5e746\u670827\u65e5\"}, \"defendant\": {\"name\": \"\u6768\u67d0\u5a1f\", \"address\": \"\u6e56\u5317\u7701\u949f\u7965\u5e02\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1989\u5e7410\u670817\u65e5\"}}, \"plaintiff_claim\": [\"\u4f9d\u6cd5\u5224\u4ee4\u88ab\u544a\u5411\u539f\u544a\u8fd4\u8fd8\u5f69\u793c160000\u5143\", \"\u672c\u6848\u7684\u8bc9\u8bbc\u8d39\u3001\u4fdd\u5168\u8d39\u7531\u88ab\u544a\u627f\u62c5\"], \"plaintiff_case_details\": \"\u539f\u544a\u4e0e\u88ab\u544a\u4e8e2022\u5e74\u56fd\u5e86\u671f\u95f4\u901a\u8fc7\u4eb2\u621a\u4ecb\u7ecd\u76f8\u4eb2\u8ba4\u8bc6\uff0c\u4e8e2022\u5e7412\u6708\u4efd\u786e\u5b9a\u604b\u7231\u5173\u7cfb\u3002\u6309\u7167\u88ab\u544a\u63d0\u51fa\u7684\u5f69\u793c\u8981\u6c42\uff0c\u539f\u544a\u59d4\u6258\u7236\u4eb2\u5b59\u67d0\u7965\u5411\u88ab\u544a\u652f\u4ed8\u4e86\u5f69\u793c160000\u5143\uff0c\u5177\u4f53\u660e\u7ec6\u4e3a\uff1a\u4e8e2023\u5e742\u670821\u65e5\u5411\u88ab\u544a\u652f\u4ed8\u4e86\u5f69\u793c100000\u5143\uff0c\u4e8e2023\u5e744\u670810\u65e5\u5411\u88ab\u544a\u652f\u4ed8\u4e86\u5f69\u793c60000\u5143\u30022023\u5e74\u4e94\u4e00\u671f\u95f4\uff0c\u539f\u88ab\u544a\u53cc\u65b9\u6309\u7167\u5f53\u5730\u4e60\u4fd7\u4e3e\u884c\u4e86\u5a5a\u793c\u9152\u5e2d\uff0c\u6309\u7167\u519c\u6751\u98ce\u4fd7\u4e60\u60ef\u4e3e\u529e\u9152\u5e2d\u539f\u544a\u65b9\u4eb2\u621a\u670b\u53cb\u968f\u793c\u7684\u793c\u91d1\u8336\u94b1\u5168\u90e8\u7531\u88ab\u544a\u6536\u53d6\u3002\u4f46\u88ab\u544a\u81f3\u4eca\u4e00\u76f4\u4ee5\u5404\u79cd\u7406\u7531\u4e0d\u4e0e\u539f\u544a\u529e\u7406\u7ed3\u5a5a\u767b\u8bb0\u3002\u539f\u544a\u4e0e\u88ab\u544a\u76f8\u8bc6\u604b\u7231\u7ed9\u4ed8\u5f69\u793c\u529e\u9152\u5e2d\u4e70\u4e09\u91d1\u90fd\u662f\u4ee5\u7f14\u7ed3\u5a5a\u59fb\u4e3a\u76ee\u7684\u7684\uff0c\u73b0\u56e0\u88ab\u544a\u4e0d\u914d\u5408\u539f\u544a\u529e\u7406\u7ed3\u5a5a\u767b\u8bb0\u624b\u7eed\u5bfc\u81f4\u539f\u544a\u7ed9\u4ed8\u5f69\u793c\u7684\u76ee\u7684\u65e0\u6cd5\u5b9e\u73b0\uff0c\u540c\u65f6\u4e5f\u4e25\u91cd\u803d\u8bef\u4e86\u539f\u544a\u7684\u7ec8\u8eab\u5927\u4e8b\u3002\u6839\u636e\u300a\u6700\u9ad8\u4eba\u6c11\u6cd5\u9662\u5173\u4e8e\u9002\u7528\uff1c\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\uff1e\u5a5a\u59fb\u5bb6\u5ead\u7f16\u7684\u89e3\u91ca\uff08\u4e00\uff09\u300b\u7b2c\u4e94\u6761\u89c4\u5b9a\uff1a\uff02\u5f53\u4e8b\u4eba\u8bf7\u6c42\u8fd4\u8fd8\u6309\u7167\u4e60\u4fd7\u7ed9\u4ed8\u7684\u5f69\u793c\u7684\uff0c\u5982\u679c\u67e5\u660e\u5c5e\u4e8e\u4ee5\u4e0b\u60c5\u5f62\uff0c\u4eba\u6c11\u6cd5\u9662\u5e94\u5f53\u4e88\u4ee5\u652f\u6301\uff1a\uff08\u4e00\uff09\u53cc\u65b9\u672a\u529e\u7406\u7ed3\u5a5a\u767b\u8bb0\u624b\u7eed\uff0e\u2026.\uff02\u7684\u89c4\u5b9a\uff0c\u88ab\u544a\u5e94\u5f53\u5411\u539f\u544a\u8fd4\u8fd8\u5168\u90e8\u5f69\u793c\u3002\u7efc\u4e0a\u6240\u8ff0\uff0c\u539f\u544a\u4ee5\u7f14\u7ed3\u5a5a\u59fb\u4e3a\u76ee\u7684\u5411\u88ab\u544a\u7ed9\u4ed8\u5f69\u793c\uff0c\u4f46\u88ab\u544a\u4e00\u76f4\u4ee5\u5404\u79cd\u7406\u7531\u62d6\u5ef6\u62d2\u7edd\u914d\u5408\u529e\u7406\u7ed3\u5a5a\u767b\u8bb0\u624b\u7eed\uff0c\u6839\u636e\u300a\u6700\u9ad8\u4eba\u6c11\u6cd5\u9662\u5173\u4e8e\u9002\u7528\uff1c\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\uff1e\u5a5a\u59fb\u5bb6\u5ead\u7f16\u7684\u89e3\u91ca\uff08\u4e00\uff09\u300b\u7b2c\u4e94\u6761\u89c4\u5b9a\uff0c\u88ab\u544a\u5e94\u5f53\u5411\u539f\u544a\u8fd4\u8fd8\u5168\u90e8\u5f69\u793c\u3002\u4e3a\u7ef4\u62a4\u539f\u544a\u7684\u5408\u6cd5\u6743\u76ca\uff0c\u539f\u544a\u4f9d\u6cd5\u5411\u8d35\u9662\u63d0\u8d77\u8bc9\u8bbc\uff0c\u613f\u4eba\u6c11\u6cd5\u9662\u4f9d\u6cd5\u652f\u6301\u539f\u544a\u7684\u5168\u90e8\u8bc9\u8bbc\u8bf7\u6c42\u3002\", \"defendant_defence\": \"\u540c\u610f\u8fd4\u8fd8\u90e8\u5206\u5f69\u793c\uff0c\u4f46\u539f\u3001\u88ab\u544a\u5171\u540c\u751f\u6d3b\u671f\u95f4\u7684\u5171\u540c\u6d88\u8d39\u90e8\u5206\u5e94\u4ece\u5f69\u793c\u4e2d\u6263\u9664\uff0c\u539f\u3001\u88ab\u544a\u5171\u540c\u751f\u6d3b\u671f\u95f4\u88ab\u544a\u66fe\u7ec8\u6b62\u598a\u5a20\uff0c\u5bf9\u8eab\u4f53\u9020\u6210\u4e00\u5b9a\u7684\u635f\u5bb3\uff0c\u8bf7\u6c42\u6cd5\u9662\u8003\u8651\uff0c\u539f\u544a\u5f53\u5ead\u589e\u52a0\u7684\u8981\u6c42\u88ab\u544a\u8fd4\u8fd8\u8336\u94b122600\u5143\uff0c\u4e0d\u5e94\u8fd4\u8fd8\u3002\", \"evidence\": {\"plaintiff_evidence\": {\"evidence_1\": {\"evidence\": \"\u539f\u544a\u8eab\u4efd\u8bc1\u590d\u5370\u4ef6\", \"dispute\": \"\"}, \"evidence_2\": {\"evidence\": \"\u88ab\u544a\u4fe1\u606f\u67e5\u8be2\", \"dispute\": \"\"}, \"evidence_3\": {\"evidence\": \"\u94f6\u884c\u8f6c\u8d26\u6d41\u6c34\", \"dispute\": \"\"}, \"evidence_4\": {\"evidence\": \"\u60c5\u51b5\u8bf4\u660e\", \"dispute\": \"\"}, \"evidence_5\": {\"evidence\": \"\u6237\u53e3\u7c3f\u590d\u5370\u4ef6\", \"dispute\": \"\"}, \"evidence_6\": {\"evidence\": \"\u7ed3\u5a5a\u7167\", \"dispute\": \"\"}, \"evidence_7\": {\"evidence\": \"\u793c\u5355\", \"dispute\": \"\"}, \"evidence_8\": {\"evidence\": \"\u5fae\u4fe1\u8f6c\u8d26\u51ed\u8bc1\", \"dispute\": \"\"}, \"evidence_9\": {\"evidence\": \"\u75c5\u5386\", \"dispute\": \"\"}, \"evidence_10\": {\"evidence\": \"\u5230\u5ead\u5f53\u4e8b\u4eba\u5f53\u5ead\u9648\u8ff0\", \"dispute\": \"\"}}, \"defendant_evidence\": {\"evidence_1\": null, \"evidence_2\": null, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null}}, \"other_statement\": {\"plaintiff\": {\"plaintiff_1\": \"\"}, \"defendant\": {\"defendant_1\": \"\"}}}\n\u6700\u540e\u5728\u65b0\u7684\u4e00\u884c\u4ee5 'Answer:' \u5f00\u5934\u7ed9\u51fa\u7b80\u6d01\u7684\u6700\u7ec8\u88c1\u5224\u4e3b\u6587\u3002",
        "correct_answer": [
            "\u88ab\u544a\u6768\u67d0\u5a1f\u81ea\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\u8fd4\u8fd8\u539f\u544a\u5f90\u67d0\u5f69\u793c\u6b3e96000\u5143",
            "\u9a73\u56de\u539f\u544a\u5f90\u67d0\u7684\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42",
            "\u6848\u4ef6\u53d7\u7406\u8d393952\u5143\uff0c\u51cf\u534a\u6536\u53d61976\u5143\uff0c\u7531\u88ab\u544a\u6768\u67d0\u5a1f\u8d1f\u62c51100\u5143\uff0c\u539f\u544a\u5f90\u67d0\u8d1f\u62c5876\u5143"
        ],
        "n": 0,
        "response": "**\u6e56\u5317\u7701\u949f\u7965\u5e02\u4eba\u6c11\u6cd5\u9662**\n\n**\u6c11\u4e8b\u5224\u51b3\u4e66**\n\n**\uff08\u6848\u53f7\uff1a2023\u91020881\u6c11\u521dXXXX\u53f7\uff09**\n\n**\u539f\u544a\uff1a**\u5f90\u67d0\uff0c\u7537\uff0c1987\u5e746\u670827\u65e5\u51fa\u751f\uff0c\u6c49\u65cf\uff0c\u4f4f\u6e56\u5317\u7701\u949f\u7965\u5e02\u3002\n**\u88ab\u544a\uff1a**\u6768\u67d0\u5a1f\uff0c\u5973\uff0c1989\u5e7410\u670817\u65e5\u51fa\u751f\uff0c\u6c49\u65cf\uff0c\u4f4f\u6e56\u5317\u7701\u949f\u7965\u5e02\u3002\n\n\u672c\u9662\u5ba1\u7406\u7684\u539f\u544a\u5f90\u67d0\u4e0e\u88ab\u544a\u6768\u67d0\u5a1f\u5a5a\u7ea6\u8d22\u4ea7\u7ea0\u7eb7\u4e00\u6848\uff0c\u73b0\u5df2\u5ba1\u7406\u7ec8\u7ed3\u3002\n\n**\u6cd5\u9662\u67e5\u660e\uff1a**\n\u539f\u3001\u88ab\u544a\u4e8e2022\u5e7410\u6708\u7ecf\u4eba\u4ecb\u7ecd\u76f8\u8bc6\u5e76\u786e\u7acb\u604b\u7231\u5173\u7cfb\u30022023\u5e742\u670821\u65e5\u53ca4\u670810\u65e5\uff0c\u539f\u544a\u65b9\u5206\u4e24\u6b21\u5411\u88ab\u544a\u652f\u4ed8\u5f69\u793c\u5171\u8ba1160,000\u5143\u30022023\u5e745\u6708\uff0c\u53cc\u65b9\u6309\u519c\u6751\u4e60\u4fd7\u4e3e\u884c\u5a5a\u793c\uff0c\u4f46\u81f3\u4eca\u672a\u529e\u7406\u7ed3\u5a5a\u767b\u8bb0\u624b\u7eed\u3002\u53cc\u65b9\u5728\u5171\u540c\u751f\u6d3b\u671f\u95f4\uff0c\u88ab\u544a\u66fe\u56e0\u6000\u5b55\u7ec8\u6b62\u598a\u5a20\u3002\u539f\u544a\u4e3b\u5f20\u88ab\u544a\u5728\u5a5a\u793c\u671f\u95f4\u6536\u53d6\u7684\u201c\u8336\u94b1\u201d\uff08\u4eb2\u53cb\u968f\u793c\uff0922,600\u5143\u4ea6\u5e94\u8fd4\u8fd8\uff0c\u88ab\u544a\u786e\u8ba4\u6536\u5230\u8be5\u7b14\u6b3e\u9879\u4f46\u4e0d\u540c\u610f\u8fd4\u8fd8\u3002\n\n**\u672c\u9662\u8ba4\u4e3a\uff1a**\n\u6839\u636e\u300a\u6700\u9ad8\u4eba\u6c11\u6cd5\u9662\u5173\u4e8e\u9002\u7528\u3008\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u3009\u5a5a\u59fb\u5bb6\u5ead\u7f16\u7684\u89e3\u91ca\uff08\u4e00\uff09\u300b\u7b2c\u4e94\u6761\u89c4\u5b9a\uff0c\u53cc\u65b9\u672a\u529e\u7406\u7ed3\u5a5a\u767b\u8bb0\u624b\u7eed\uff0c\u5f53\u4e8b\u4eba\u8bf7\u6c42\u8fd4\u8fd8\u6309\u7167\u4e60\u4fd7\u7ed9\u4ed8\u7684\u5f69\u793c\u7684\uff0c\u4eba\u6c11\u6cd5\u9662\u5e94\u5f53\u4e88\u4ee5\u652f\u6301\u3002\n\n\u672c\u6848\u4e2d\uff0c\u539f\u544a\u5411\u88ab\u544a\u7ed9\u4ed8\u5f69\u793c160,000\u5143\u4e8b\u5b9e\u6e05\u695a\uff0c\u56e0\u53cc\u65b9\u672a\u4f9d\u6cd5\u8fdb\u884c\u7ed3\u5a5a\u767b\u8bb0\uff0c\u88ab\u544a\u5e94\u5f53\u8fd4\u8fd8\u5f69\u793c\u3002\u4f46\u5728\u786e\u5b9a\u8fd4\u8fd8\u6570\u989d\u65f6\uff0c\u672c\u9662\u7efc\u5408\u8003\u91cf\u4ee5\u4e0b\u56e0\u7d20\uff1a\n1. **\u5171\u540c\u751f\u6d3b\u60c5\u51b5\uff1a** \u53cc\u65b9\u867d\u672a\u9886\u8bc1\uff0c\u4f46\u5df2\u6309\u4e60\u4fd7\u4e3e\u884c\u5a5a\u793c\u5e76\u5b9e\u9645\u5171\u540c\u751f\u6d3b\uff0c\u671f\u95f4\u4ea7\u751f\u7684\u65e5\u5e38\u5171\u540c\u5f00\u652f\u5e94\u4e88\u4ee5\u8003\u8651\u3002\n2. **\u88ab\u544a\u8eab\u4f53\u635f\u5bb3\u60c5\u51b5\uff1a** \u88ab\u544a\u5728\u5171\u540c\u751f\u6d3b\u671f\u95f4\u7ec8\u6b62\u598a\u5a20\uff0c\u5176\u8eab\u5fc3\u5065\u5eb7\u53d7\u5230\u4e00\u5b9a\u7a0b\u5ea6\u7684\u5f71\u54cd\uff0c\u4ece\u516c\u5e73\u539f\u5219\u53ca\u4eba\u6587\u5173\u6000\u89d2\u5ea6\u51fa\u53d1\uff0c\u5e94\u9002\u5f53\u51cf\u5c11\u8fd4\u8fd8\u91d1\u989d\u3002\n3. **\u5173\u4e8e\u201c\u8336\u94b1\u201d22,600\u5143\uff1a** \u8be5\u6b3e\u9879\u5c5e\u4e8e\u4eb2\u53cb\u57fa\u4e8e\u5a5a\u59fb\u795d\u798f\u800c\u7ed9\u4ed8\u7684\u793c\u91d1\uff0c\u5e26\u6709\u8d60\u4e0e\u6027\u8d28\u3002\u9274\u4e8e\u53cc\u65b9\u5e76\u672a\u5efa\u7acb\u5408\u6cd5\u7684\u5a5a\u59fb\u5173\u7cfb\uff0c\u4e14\u8be5\u6b3e\u9879\u7531\u88ab\u544a\u4e2a\u4eba\u6536\u53d6\uff0c\u8003\u8651\u5230\u5a5a\u793c\u7531\u539f\u544a\u65b9\u51fa\u8d44\u64cd\u529e\uff0c\u4f9d\u636e\u516c\u5e73\u539f\u5219\uff0c\u88ab\u544a\u5e94\u4e88\u4ee5\u90e8\u5206\u8fd4\u8fd8\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u672c\u9662\u8ba4\u4e3a\u88ab\u544a\u5e94\u5f53\u5411\u539f\u544a\u8fd4\u8fd8\u5927\u90e8\u5206\u5f69\u793c\uff0c\u5e76\u7ed3\u5408\u5176\u7ec8\u6b62\u598a\u5a20\u7684\u5b9e\u9645\u60c5\u51b5\u4e88\u4ee5\u51cf\u6263\u3002\n\n**\u88c1\u5224\u7ed3\u679c\uff1a**\n\u4f9d\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u96f6\u56db\u5341\u4e8c\u6761\u3001\u300a\u6700\u9ad8\u4eba\u6c11\u6cd5\u9662\u5173\u4e8e\u9002\u7528\u3008\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u3009\u5a5a\u59fb\u5bb6\u5ead\u7f16\u7684\u89e3\u91ca\uff08\u4e00\uff09\u300b\u7b2c\u4e94\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n\u4e00\u3001\u88ab\u544a\u6768\u67d0\u5a1f\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\u5411\u539f\u544a\u5f90\u67d0\u8fd4\u8fd8\u5f69\u793c\u6b3e130,000\u5143\uff1b\n\u4e8c\u3001\u88ab\u544a\u6768\u67d0\u5a1f\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\u5411\u539f\u544a\u5f90\u67d0\u8fd4\u8fd8\u793c\u91d1\uff08\u8336\u94b1\uff0915,000\u5143\uff1b\n\u4e09\u3001\u9a73\u56de\u539f\u544a\u5f90\u67d0\u7684\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42\u3002\n\n\u5982\u672a\u6309\u672c\u5224\u51b3\u6307\u5b9a\u7684\u671f\u95f4\u5c65\u884c\u7ed9\u4ed8\u91d1\u94b1\u4e49\u52a1\uff0c\u5e94\u5f53\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u4e8c\u767e\u516d\u5341\u6761\u4e4b\u89c4\u5b9a\uff0c\u52a0\u500d\u652f\u4ed8\u8fdf\u5ef6\u5c65\u884c\u671f\u95f4\u7684\u503a\u52a1\u5229\u606f\u3002\n\n\u6848\u4ef6\u53d7\u7406\u8d39\u53ca\u4fdd\u5168\u8d39\u7531\u539f\u3001\u88ab\u544a\u6309\u6bd4\u4f8b\u627f\u62c5\u3002\n\n\u5ba1\u5224\u957f\uff1a[\u59d3\u540d]\n\u4e8c\u3007\u4e8c\u56db\u5e74X\u6708X\u65e5\n\nAnswer: \u4e00\u3001\u88ab\u544a\u6768\u67d0\u5a1f\u5411\u539f\u544a\u5f90\u67d0\u8fd4\u8fd8\u5f69\u793c130,000\u5143\uff1b\u4e8c\u3001\u88ab\u544a\u6768\u67d0\u5a1f\u5411\u539f\u544a\u5f90\u67d0\u8fd4\u8fd8\u793c\u91d115,000\u5143\uff1b\u4e09\u3001\u9a73\u56de\u539f\u544a\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42\u3002",
        "sub_tasks_text": null
