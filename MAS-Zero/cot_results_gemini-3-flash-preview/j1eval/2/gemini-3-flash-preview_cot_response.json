[
    {
        "example_id": 2,
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u5a5a\u59fb\u5bb6\u5ead\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u656c\u67d0\u519b\", \"address\": \"\u56db\u5ddd\u7701\u5357\u90e8\u53bf\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1988\u5e741\u670816\u65e5\"}, \"defendant\": {\"name\": \"\u738b\u67d0\u8389\", \"address\": \"\u8d35\u5dde\u7701\u7d2b\u4e91\u82d7\u65cf\u5e03\u4f9d\u65cf\u81ea\u6cbb\u53bf\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u5e03\u4f9d\u65cf\", \"birth_date\": \"1981\u5e748\u67086\u65e5\"}}, \"plaintiff_claim\": [\"\u5224\u4ee4\u88ab\u544a\u652f\u4ed8\u7ecf\u6d4e\u635f\u59315\u4e07\u5143\u6574\", \"\u5224\u4ee4\u88ab\u544a\u627f\u62c5\u5168\u90e8\u8bc9\u8bbc\u8d39\u7528\"], \"plaintiff_case_details\": \"\u539f\u544a\u4e3a\u79bb\u5f02\u5bb6\u5ead\uff0c\u7ecf\u670b\u53cb\u4ecb\u7ecd\u8ba4\u8bc6\u4e86\u540c\u6837\u662f\u79bb\u5f02\u5bb6\u5ead\u7684\u88ab\u544a\uff0c\u76f8\u4e92\u4e86\u89e3\u540e\u5728\u4e00\u8d77\u540c\u5c45\u4e24\u5e74\u591a\u3002\u539f\u544a\u4e00\u5fc3\u4e3a\u7740\u7ed3\u5a5a\u7684\u76ee\u7684\uff0c\u5728\u6ca1\u6709\u89c1\u5230\u88ab\u544a\u672c\u4eba\u7684\u60c5\u51b5\u4e0b\uff0c\u539f\u544a\u53bb\u6d59\u6c5f\u628a\u88ab\u544a\u63a5\u5230\u4e86\u9f99\u5c97\u3002\u6765\u5230\u9f99\u5c97\u4e4b\u540e\uff0c\u88ab\u544a\u6ca1\u6709\u5de5\u4f5c\uff0c\u5728\u5979\u4e00\u4e2a\u670b\u53cb\u7684\u4ecb\u7ecd\u4e0b\u53bb\u4e86\u4e1c\u839e\u5de5\u4f5c\u3002\u539f\u544a\u662f\u4e0d\u540c\u610f\u7684\uff0c\u56e0\u4e3a\u4e24\u4eba\u5206\u5f00\u76f8\u8ddd\u592a\u8fdc\uff0c\u521a\u5f00\u59cb\u539f\u544a\u4e0d\u77e5\u9053\u88ab\u544a\u53bb\u4e1c\u839e\u90a3\u8fb9\u5de5\u4f5c\u7684\u6027\u8d28\uff0c\u76f8\u5904\u65f6\u95f4\u957f\u4e86\u539f\u544a\u624d\u6162\u6162\u53d1\u73b0\uff0c\u88ab\u544a\u7684\u5de5\u4f5c\u4e0d\u662f\u539f\u544a\u60f3\u7684\u90a3\u6837\uff0c\u539f\u544a\u6709\u804a\u5929\u8bb0\u5f55\u8bc1\u5b9e\u3002\u88ab\u544a\u627f\u8ba4\u5176\u5de5\u4f5c\uff0c\u539f\u544a\u529d\u5176\u8f9e\u804c\uff0c\u91cd\u65b0\u6362\u5de5\u4f5c\uff0c\u4f46\u88ab\u88ab\u544a\u62d2\u7edd\u4e86\uff0c\u539f\u544a\u53ef\u4ee5\u539f\u8c05\u88ab\u544a\uff0c\u4f46\u662f\u6ca1\u6709\u5f97\u5230\u4e00\u70b9\u70b9\u56de\u62a5\u3002\u539f\u544a\u611f\u89c9\u81ea\u5df1\u88ab\u88ab\u544a\u6b3a\u9a97\u4e86\uff0c\u5728\u6c89\u91cd\u7684\u538b\u529b\u4e0b\uff0c\u539f\u544a\u51b3\u5b9a\u548c\u88ab\u544a\u5212\u5206\u754c\u9650\uff0c\u8ba9\u88ab\u544a\u642c\u79bb\uff0c\u5206\u5f00\u5c45\u4f4f\u3002\u540c\u65f6\u4e5f\u82e6\u53e3\u5a46\u5fc3\u5730\u529d\u88ab\u544a\uff0c\u5e76\u53bb\u88ab\u544a\u4e0a\u73ed\u7684\u5730\u65b9\u627e\u88ab\u544a\uff0c\u529d\u88ab\u544a\uff0c\u4f46\u88ab\u544a\u4e5f\u542c\u4e0d\u8fdb\u53bb\uff0c\u8f9b\u8f9b\u82e6\u82e6\u4ed8\u51fa\u4e24\u5e74\u591a\uff0c\u6ca1\u6709\u5f97\u5230\u4e00\u70b9\u56de\u62a5\u3002\u540c\u65f6\u88ab\u544a\u6709\u4e00\u5973\uff0c\u5e76\u5728\u8001\u5bb6\u8d35\u5dde\u8bfb\u4e66\uff0c\u5176\u60f3\u7740\u548c\u5b69\u5b50\u5206\u5f00\u592a\u4e45\uff0c\u53c8\u4ee5\u5de5\u4f5c\u4e3a\u7531\u8d70\u4e0d\u5f00\uff0c\u53eb\u539f\u544a\u4e00\u4eba\u53bb\u8d35\u5dde\u53c8\u628a\u5b69\u5b50\u63a5\u5230\u9f99\u5c97\u8bfb\u4e66\u4e24\u5e74\u3002\u5bb6\u91cc\u7684\u5f00\u652f\u90fd\u7531\u539f\u544a\u627f\u62c5\uff0c\u65f6\u4e0d\u65f6\u5e26\u7740\u88ab\u544a\u5b69\u5b50\uff0c\u51fa\u53bb\u6d88\u8d39\u3001\u8d2d\u7269\uff0c\u539f\u544a\u4e5f\u4e3a\u8fd9\u6837\u80fd\u628a\u611f\u60c5\u5efa\u7acb\u5f88\u597d\uff0c\u53ef\u662f\u7ecf\u8fc7\u591a\u6b21\u529d\u8bf4\u53e3\u5934\u7b54\u5e94\u4e86\uff0c\u8fd8\u662f\u7528\u6b3a\u9a97\u7684\u8c0e\u8bdd\u5ffd\u60a0\u7740\u539f\u544a\u3002\", \"defendant_defence\": \"\u539f\u544a\u4e70\u7535\u52a8\u8f66\u662f\u7ed9\u5c0f\u5b69\u7528\u7684\uff0c\u5c0f\u5b69\u6765\u4e4b\u524d\u539f\u544a\u7535\u52a8\u8f66\u5c31\u5df2\u7ecf\u4e70\u4e86\uff0c\u800c\u4e14\u8fd9\u662f\u5bb6\u5ead\u5f00\u652f\uff0c\u4e5f\u4e0d\u5149\u662f\u88ab\u544a\u5c0f\u5b69\u4e00\u4e2a\u4eba\u7528\uff0c\u539f\u544a\u4e5f\u5728\u7528\uff0c\u8fd9\u4e2a\u94b1\u4e0d\u5e94\u8be5\u88ab\u544a\u6765\u652f\u4ed8\u3002\u8fd8\u6709\u4e70\u624b\u673a\u8fd9\u4e9b\u4e1c\u897f\uff0c\u624b\u673a\u786e\u5b9e\u662f\u4e70\u7ed9\u5c0f\u5b69\u4e86\uff0c\u4f46\u8fd9\u4e9b\u90fd\u662f\u5bb6\u5ead\u5f00\u652f\u3002\u539f\u3001\u88ab\u544a\u53ea\u662f\u604b\u7231\uff0c\u53ea\u662f\u8c08\u670b\u53cb\uff0c\u539f\u3001\u88ab\u544a\u6ca1\u6709\u7ed3\u5a5a\uff0c\u6ca1\u6709\u8c08\u5230\u4ec0\u4e48\u5a5a\u524d\u8d22\u4ea7\u7ea0\u7eb7\u3002\u8fd9\u4e2a\u94b1\u662f\u5bb6\u5ead\u7684\u5f00\u652f\uff0c\u88ab\u544a\u8ddf\u539f\u544a\u5728\u4e00\u8d77\u662f\u6253\u7b97\u8fc7\u65e5\u5b50\u7684\uff0c\u53cc\u65b9\u662f\u4e00\u4e2a\u5bb6\u5ead\uff0c\u88ab\u544a\u6ca1\u6709\u60f3\u8fc7\u8981\u9a97\u539f\u544a\u62ff\u94b1\u6765\u4e70\u4e1c\u897f\uff0c\u539f\u3001\u88ab\u544a\u53ea\u662f\u5728\u604b\u7231\u7684\u8fc7\u7a0b\u4e2d\u95f9\u4e86\u7ea0\u7eb7\uff0c\u4e24\u4e2a\u4eba\u5728\u4e00\u8d77\u662f\u4f60\u60c5\u6211\u613f\uff0c\u88ab\u544a\u6ca1\u6709\u5f3a\u8feb\u6027\u8ba9\u539f\u544a\u53bb\u82b1\u8fd9\u4e9b\u94b1\uff0c\u73b0\u5728\u4e24\u4eba\u8fc7\u4e0d\u4e0b\u53bb\uff0c\u6700\u540e\u8ba9\u88ab\u544a\u4e00\u4e2a\u4eba\u6765\u627f\u62c5\u8fd9\u4e9b\u94b1\uff0c\u88ab\u544a\u4e0d\u540c\u610f\u3002\", \"evidence\": {\"plaintiff_evidence\": {\"evidence_1\": {\"evidence\": \"\u5fae\u4fe1\u8f6c\u8d26\u8bb0\u5f55\u30022021\u5e745\u6708\u81f32023\u5e745\u6708\u95f4\uff0c\u539f\u544a\u901a\u8fc7\u5fae\u4fe1\u8f6c\u8d26\u6216\u53d1\u7ea2\u5305\u7684\u5f62\u5f0f\u5411\u88ab\u544a\u8f6c\u8d2629\u7b14\u5171\u8ba110457.27\u5143\uff0c\u5176\u4e2d2022\u5e747\u670830\u65e5\uff0c\u88ab\u544a\u5411\u539f\u544a\u8f6c\u8d26300\u5143\uff0c2022\u5e747\u670831\u65e5\uff0c\u539f\u544a\u5411\u88ab\u544a\u8f6c\u8d26300\u5143\uff0c2022\u5e7412\u67086\u65e5\uff0c\u88ab\u544a\u5411\u539f\u544a\u8f6c\u8d26\u4e24\u7b14\u51711000\u5143\uff0c2022\u5e7412\u67087\u65e5\uff0c\u539f\u544a\u5411\u88ab\u544a\u8f6c\u8d26\u4e24\u7b14\u51712000\u5143\uff0c\u5728\u524d\u8ff0\u539f\u544a\u5411\u88ab\u544a\u7684\u8f6c\u8d26\u91d1\u989d\u4e2d\uff0c\u6709\u4e09\u7b14\u8f6c\u8d26\u91d1\u989d\u4e3a520\u5143\uff1b2021\u5e747\u6708\u81f32023\u5e745\u6708\u95f4\uff0c\u539f\u544a\u901a\u8fc7\u5fae\u4fe1\u8f6c\u8d26\u6216\u53d1\u7ea2\u5305\u7684\u5f62\u5f0f\u5411\u6848\u5916\u4eba\u83ab\u67d0\u5609\u8f6c\u8d2631\u7b14\u5171\u8ba11208.78\u5143\uff0c2021\u5e747\u67088\u65e5\uff0c\u6848\u5916\u4eba\u83ab\u67d0\u5609\u5411\u539f\u544a\u8f6c\u8d26100\u5143\u3002\u53e6\u67092021\u5e748\u670812\u65e5\u88ab\u544a\u5411\u539f\u544a\u8f6c\u8d2612000\u5143\uff0c\u539f\u544a\u63d0\u4f9b\u5fae\u4fe1\u8d26\u5355\u663e\u793a\uff0c\u5728\u53cc\u65b9\u604b\u7231\u671f\u95f4\uff0c\u539f\u544a\u6709\u591a\u7b14\u91d1\u989d\u4ece\u51e0\u5341\u5143\u81f3\u51e0\u767e\u5143\u4e0d\u7b49\u7684\u652f\u51fa\uff0c\u5305\u62ec\u8d2d\u4e70\u6c34\u679c\u3001\u5976\u8336\u3001\u670d\u9970\u53ca\u9910\u996e\u3001\u52a0\u6cb9\u7b49\uff0c\u539f\u544a\u4e3b\u5f20\u662f\u4e3a\u88ab\u544a\u53ca\u5176\u5973\u513f\u6d88\u8d39\u3002\", \"dispute\": \"\u539f\u544a\u63d0\u4ea4\u7684\u8bc1\u636e\u4e0d\u80fd\u8bc1\u660e\u8bc9\u4e89\u6b3e\u9879\u662f\u5177\u6709\u5f69\u793c\u6027\u8d28\u7684\u7ed9\u4ed8\uff0c\u539f\u544a\u5bf9\u6b64\u5e94\u627f\u62c5\u4e3e\u8bc1\u4e0d\u80fd\u7684\u6cd5\u5f8b\u540e\u679c\u3002\u88ab\u544a\u5728\u5ead\u5ba1\u4e2d\u79f0\u83ab\u67d0\u5609\u662f\u88ab\u544a\u5973\u513f\uff0c\u8be5\u7b14\u8f6c\u8d26\u7528\u9014\u7cfb\u4e3a\u529e\u7406\u5b69\u5b50\u8f6c\u5b66\u7684\u8d39\u7528\uff0c\u56e0\u6ca1\u6709\u529e\u6210\uff0c2021\u5e748\u670819\u65e5\u539f\u544a\u5411\u88ab\u544a\u9000\u56de10000\u5143\u3002\"}, \"evidence_2\": null, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null, \"evidence_10\": null}, \"defendant_evidence\": {\"evidence_1\": null, \"evidence_2\": null, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null}}, \"other_statement\": {\"plaintiff\": {\"plaintiff_1\": \"\u539f\u3001\u88ab\u544a\u53cc\u65b9\u66fe\u4e3a\u604b\u7231\u5173\u7cfb\uff0c\u604b\u7231\u671f\u95f4\uff0c\u53cc\u65b9\u672a\u529e\u7406\u7ed3\u5a5a\u767b\u8bb0\uff0c\u4e5f\u672a\u4e3e\u529e\u5a5a\u793c\u3002\u539f\u544a\u9648\u8ff0\uff0c\u53cc\u65b9\u4e8e2021\u5e749\u6708\u5f00\u59cb\u5171\u540c\u751f\u6d3b\uff0c\u5176\u4e0e\u88ab\u544a\u53ca\u88ab\u544a\u5b69\u5b50\u5171\u540c\u751f\u6d3b\u671f\u95f4\u79df\u623f\u4f4f\uff0c\u623f\u79df\u4e3a\u6bcf\u67081300\u5143\u5de6\u53f3\uff0c\u539f\u544a\u57282023\u5e749\u6708\u63d0\u51fa\u5206\u624b\u3002\u539f\u544a\u9648\u8ff0\u5176\u63d0\u51fa\u5206\u624b\u7684\u539f\u56e0\u662f\u5176\u4e0d\u80fd\u63a5\u53d7\u88ab\u544a\u4ece\u4e8b\u7684\u5de5\u4f5c\u3002\u5173\u4e8e\u53cc\u65b9\u7684\u5de5\u4f5c\u60c5\u51b5\uff0c\u539f\u544a\u9648\u8ff0\u5176\u5728\u5b9d\u9f99\u793e\u533a\u4ece\u4e8b\u57ce\u7ba1\u804c\u4e1a\uff0c\u6708\u6536\u51654300\u5143\u5de6\u53f3\uff0c\u4e4b\u524d\u66fe\u7531\u53e6\u6709\u5176\u4ed6\u517c\u804c\u6536\u5165\"}, \"defendant\": {\"defendant_1\": \"\u88ab\u544a\u9648\u8ff0\uff0c\u53cc\u65b9\u662f\u57282021\u5e745\u6708\u5f00\u59cb\u5171\u540c\u751f\u6d3b\uff0c\u540e\u7531\u539f\u544a\u63d0\u51fa\u5206\u624b\u3002\u88ab\u544a\u5219\u9648\u8ff0\u539f\u544a\u4e00\u76f4\u6e05\u695a\u5176\u5de5\u4f5c\u5185\u5bb9\u3002\u88ab\u544a\u9648\u8ff0\u5176\u4e4b\u524d\u5728\u4e1c\u839e\u7684\u67d0\u5e97\u5de5\u4f5c\uff0c\u73b0\u5728\u5728\u6d59\u6c5f\u5de5\u4f5c\u3002\"}}}\n\u6700\u540e\u5728\u65b0\u7684\u4e00\u884c\u4ee5 'Answer:' \u5f00\u5934\u7ed9\u51fa\u7b80\u6d01\u7684\u6700\u7ec8\u88c1\u5224\u4e3b\u6587\u3002",
        "correct_answer": [
            "\u9a73\u56de\u539f\u544a\u656c\u67d0\u519b\u7684\u8bc9\u8bbc\u8bf7\u6c42\u3002",
            "\u6848\u4ef6\u53d7\u7406\u8d391050\u5143\uff08\u539f\u544a\u5df2\u9884\u4ea4\uff09\uff0c\u7531\u539f\u544a\u656c\u67d0\u519b\u8d1f\u62c5\u3002",
            "\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u4ee5\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u7167\u5bf9\u65b9\u5f53\u4e8b\u4eba\u6216\u8005\u4ee3\u8868\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u5e7f\u4e1c\u7701\u6df1\u5733\u5e02\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002"
        ],
        "n": 0,
        "response": "**\u6c11\u4e8b\u5224\u51b3\u4e66**\n\n**\u6848\u53f7\uff1a**\uff08202X\uff09\u7ca40310\u6c11\u521dXXXX\u53f7\n\n**\u539f\u544a\uff1a**\u656c\u67d0\u519b\uff0c\u7537\uff0c1988\u5e741\u670816\u65e5\u51fa\u751f\uff0c\u6c49\u65cf\uff0c\u4f4f\u56db\u5ddd\u7701\u5357\u90e8\u53bf\u3002\n**\u88ab\u544a\uff1a**\u738b\u67d0\u8389\uff0c\u5973\uff0c1981\u5e748\u67086\u65e5\u51fa\u751f\uff0c\u5e03\u4f9d\u65cf\uff0c\u4f4f\u8d35\u5dde\u7701\u7d2b\u4e91\u82d7\u65cf\u5e03\u4f9d\u65cf\u81ea\u6cbb\u53bf\u3002\n\n\u539f\u544a\u656c\u67d0\u519b\u4e0e\u88ab\u544a\u738b\u67d0\u8389\u5a5a\u7ea6\u8d22\u4ea7\u7ea0\u7eb7\u4e00\u6848\uff0c\u672c\u9662\u53d7\u7406\u540e\uff0c\u4f9d\u6cd5\u9002\u7528\u7b80\u6613\u7a0b\u5e8f\u516c\u5f00\u5f00\u5ead\u8fdb\u884c\u4e86\u5ba1\u7406\u3002\u672c\u6848\u73b0\u5df2\u5ba1\u7406\u7ec8\u7ed3\u3002\n\n**\u672c\u9662\u8ba4\u4e3a\uff1a**\n\n\u672c\u6848\u4e89\u8bae\u7684\u7126\u70b9\u5728\u4e8e\uff1a\u539f\u544a\u5728\u4e0e\u88ab\u544a\u604b\u7231\u540c\u5c45\u671f\u95f4\u4ea7\u751f\u7684\u5404\u9879\u5f00\u652f\u53ca\u8f6c\u8d26\uff0c\u662f\u5426\u5c5e\u4e8e\u5e94\u5f53\u8fd4\u8fd8\u7684\u201c\u7ecf\u6d4e\u635f\u5931\u201d\u6216\u5177\u6709\u5f69\u793c\u6027\u8d28\u7684\u7ed9\u4ed8\u3002\n\n\u9996\u5148\uff0c\u5173\u4e8e\u604b\u7231\u671f\u95f4\u7684\u8f6c\u8d26\u652f\u51fa\u3002\u6839\u636e\u6c11\u6cd5\u5178\u53ca\u76f8\u5173\u53f8\u6cd5\u89e3\u91ca\uff0c\u5728\u604b\u7231\u5173\u7cfb\u4e2d\uff0c\u4e00\u65b9\u4e3a\u4e86\u8868\u8fbe\u7231\u610f\u3001\u589e\u8fdb\u611f\u60c5\u6216\u7ef4\u6301\u5171\u540c\u751f\u6d3b\u800c\u7ed9\u4ed8\u7684\u4ef7\u503c\u8f83\u5c0f\u7684\u8d22\u7269\u3001\u65e5\u5e38\u6d88\u8d39\u652f\u51fa\uff0c\u6216\u8005\u5177\u6709\u7279\u6b8a\u7eaa\u5ff5\u610f\u4e49\u7684\u91d1\u989d\uff08\u5982\u672c\u6848\u4e2d\u51fa\u73b0\u7684\u201c520\u201d\u5143\uff09\uff0c\u901a\u5e38\u5e94\u8ba4\u5b9a\u4e3a\u8d60\u4e0e\u3002\u539f\u544a\u63d0\u4f9b\u7684\u8bc1\u636e\u663e\u793a\uff0c2021\u5e74\u81f32023\u5e74\u95f4\uff0c\u5176\u5411\u88ab\u544a\u53ca\u5176\u5973\u513f\u8f6c\u8d26\u7684\u91d1\u989d\u591a\u4e3a\u51e0\u5341\u5143\u81f3\u51e0\u767e\u5143\u4e0d\u7b49\uff0c\u5c5e\u4e8e\u96f6\u661f\u652f\u51fa\u3002\u4e14\u8bc1\u636e\u53cd\u6620\u53cc\u65b9\u4e92\u6709\u8f6c\u8d26\u5f80\u6765\uff08\u5982\u88ab\u544a\u66fe\u8f6c\u8d2612000\u5143\u7ed9\u539f\u544a\uff0c\u539f\u544a\u9000\u56de10000\u5143\uff09\uff0c\u8fd9\u8bf4\u660e\u53cc\u65b9\u5728\u540c\u5c45\u671f\u95f4\u8d22\u52a1\u5b58\u5728\u4ea4\u53c9\uff0c\u76f8\u5173\u5c0f\u989d\u8f6c\u8d26\u5e94\u89c6\u4e3a\u53cc\u65b9\u5171\u540c\u751f\u6d3b\u671f\u95f4\u7684\u81ea\u613f\u7ed9\u4ed8\u6216\u60c5\u611f\u8868\u8fbe\uff0c\u539f\u544a\u8981\u6c42\u8fd4\u8fd8\u7f3a\u4e4f\u6cd5\u5f8b\u4f9d\u636e\u3002\n\n\u5176\u6b21\uff0c\u5173\u4e8e\u5171\u540c\u751f\u6d3b\u671f\u95f4\u7684\u6d88\u8d39\u53ca\u623f\u79df\u5f00\u652f\u3002\u539f\u3001\u88ab\u544a\u540c\u5c45\u751f\u6d3b\u957f\u8fbe\u4e24\u5e74\u4e4b\u4e45\uff0c\u671f\u95f4\u4ea7\u751f\u7684\u623f\u79df\u3001\u9910\u996e\u3001\u8d2d\u7269\uff08\u5982\u8d2d\u4e70\u624b\u673a\u3001\u7535\u52a8\u8f66\u7b49\uff09\u4ee5\u53ca\u4e3a\u88ab\u544a\u5b69\u5b50\u652f\u4ed8\u7684\u8d39\u7528\uff0c\u5747\u5c5e\u4e8e\u53cc\u65b9\u5728\u5171\u540c\u751f\u6d3b\u8fc7\u7a0b\u4e2d\u7684\u5b9e\u9645\u6d88\u8017\u3002\u539f\u544a\u4f5c\u4e3a\u6210\u5e74\u4eba\uff0c\u5bf9\u540c\u5c45\u671f\u95f4\u81ea\u613f\u627f\u62c5\u751f\u6d3b\u5f00\u652f\u7684\u884c\u4e3a\u5177\u6709\u660e\u786e\u8ba4\u77e5\u3002\u5728\u6cd5\u5f8b\u4e0a\uff0c\u540c\u5c45\u671f\u95f4\u7684\u52b3\u52a1\u4ed8\u51fa\u3001\u65e5\u5e38\u6d88\u8d39\u901a\u5e38\u88ab\u89c6\u4e3a\u53cc\u65b9\u4e3a\u7ef4\u6301\u5171\u540c\u751f\u6d3b\u800c\u4ea7\u751f\u7684\u793e\u4f1a\u516c\u5fb7\u6027\u7ed9\u4ed8\uff0c\u800c\u975e\u503a\u6743\u503a\u52a1\u5173\u7cfb\u3002\u539f\u544a\u4e3b\u5f20\u8fd9\u4e9b\u652f\u51fa\u4e3a\u201c\u7ecf\u6d4e\u635f\u5931\u201d\uff0c\u4f46\u5728\u65e0\u660e\u786e\u501f\u6b3e\u534f\u8bae\u6216\u8bc1\u660e\u8be5\u652f\u51fa\u5c5e\u4e8e\u4ee5\u7ed3\u5a5a\u4e3a\u7279\u5b9a\u6761\u4ef6\u7684\u5de8\u989d\u5f69\u793c\u7ed9\u4ed8\u4e4b\u60c5\u51b5\u4e0b\uff0c\u8be5\u4e3b\u5f20\u4e0d\u7b26\u5408\u6cd5\u5f8b\u89c4\u5b9a\u3002\n\n\u6700\u540e\uff0c\u5173\u4e8e\u539f\u544a\u4e3b\u5f20\u7684\u6b3a\u8bc8\u884c\u4e3a\u3002\u539f\u544a\u4ee5\u4e0d\u80fd\u63a5\u53d7\u88ab\u544a\u5de5\u4f5c\u6027\u8d28\u4e3a\u7531\u4e3b\u5f20\u53d7\u9a97\uff0c\u8fd9\u5c5e\u4e8e\u53cc\u65b9\u5728\u60c5\u611f\u3001\u9053\u5fb7\u53ca\u4ef7\u503c\u89c2\u4e0a\u7684\u5206\u6b67\u3002\u88ab\u544a\u4ece\u4e8b\u4f55\u79cd\u804c\u4e1a\u4ee5\u53ca\u662f\u5426\u8f9e\u804c\uff0c\u5c5e\u4e8e\u88ab\u544a\u7684\u4e2a\u4eba\u6743\u5229\u8303\u7574\u3002\u611f\u60c5\u7834\u88c2\u5bfc\u81f4\u7684\u5fc3\u7406\u843d\u5dee\u4e0d\u80fd\u8f6c\u5316\u4e3a\u6cd5\u5f8b\u610f\u4e49\u4e0a\u7684\u8d22\u4ea7\u8fd4\u8fd8\u8bf7\u6c42\u6743\uff0c\u539f\u544a\u672a\u80fd\u8bc1\u660e\u88ab\u544a\u5b58\u5728\u4ee5\u7f14\u7ed3\u5a5a\u59fb\u4e3a\u8bf1\u9975\u8bc8\u53d6\u94b1\u8d22\u7684\u4e8b\u5b9e\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u539f\u544a\u8981\u6c42\u88ab\u544a\u8d54\u507f5\u4e07\u5143\u7ecf\u6d4e\u635f\u5931\uff0c\u65e2\u7f3a\u4e4f\u660e\u786e\u7684\u4e8b\u5b9e\u4f9d\u636e\uff0c\u4e5f\u65e0\u5145\u5206\u6cd5\u5f8b\u4f9d\u636e\uff0c\u672c\u9662\u4e0d\u4e88\u652f\u6301\u3002\n\n\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u516d\u767e\u4e94\u5341\u4e03\u6761\u3001\u6700\u9ad8\u4eba\u6c11\u6cd5\u9662\u5173\u4e8e\u9002\u7528\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u5a5a\u59fb\u5bb6\u5ead\u7f16\u7684\u89e3\u91ca\uff08\u4e00\uff09\u7b2c\u4e94\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n\u9a73\u56de\u539f\u544a\u656c\u67d0\u519b\u7684\u5168\u90e8\u8bc9\u8bbc\u8bf7\u6c42\u3002\n\n\u6848\u4ef6\u53d7\u7406\u8d39\u7531\u539f\u544a\u656c\u67d0\u519b\u627f\u62c5\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u