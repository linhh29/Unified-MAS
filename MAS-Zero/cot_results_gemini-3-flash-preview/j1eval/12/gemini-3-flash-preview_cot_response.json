[
    {
        "example_id": 12,
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u5a5a\u59fb\u5bb6\u5ead\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u9648\u67d0\", \"address\": \"\u5317\u4eac\u5e02\u4e30\u53f0\u533a\u4e1c\u9ad8\u5730\u4e07\u6e90\u4e1c\u91cc\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"19xx\u5e74xx\u6708xx\u65e5\"}, \"defendant\": {\"name\": \"\u738b\u67d0\", \"address\": \"\u5317\u4eac\u5e02\u4e30\u53f0\u533a\u4e1c\u9ad8\u5730\u4e07\u6e90\u4e1c\u91cc\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"2000\u5e7412\u67081\u65e5\"}}, \"plaintiff_claim\": [\"\u786e\u8ba4\u9648\u67d0\u4eab\u6709\u4f4d\u4e8eXX6\u53f7\u7684\u623f\u5c4b60%\u7684\u4efd\u989d\", \"\u738b\u67d0\u642c\u79bb6\u53f7\u623f\u5c4b\u5927\u623f\u95f4\"], \"plaintiff_case_details\": \"\u9648\u67d0\u4e0e\u738b\u67d0\u539f\u7cfb\u592b\u59bb\uff0c\u4e8c\u4eba\u4e8e2007\u5e7412\u67087\u65e5\u7ecf\u4eba\u6c11\u6cd5\u9662\u5224\u51b3\u79bb\u5a5a\uff0c\u5e76\u5224\u51b36\u53f7\u623f\u5c4b\u7684\u5c0f\u623f\u95f4\u7531\u738b\u67d0\u5c45\u4f4f\uff0c\u5927\u623f\u95f4\u7531\u9648\u67d0\u5c45\u4f4f\uff0c\u540e\u8be5\u623f\u5c4b\u767b\u8bb0\u4e8e\u738b\u67d0\u540d\u4e0b\u3002\u53cc\u65b9\u79bb\u5a5a\u540e\uff0c\u738b\u67d0\u957f\u671f\u975e\u6cd5\u5360\u6709\u5927\u623f\u95f4\uff0c\u9648\u67d0\u53ea\u80fd\u5728\u5c0f\u623f\u95f4\u5c45\u4f4f\u3002\u73b0\u9648\u67d0\u8981\u6c42\u786e\u8ba4\u5176\u5bf96\u53f7\u623f\u5c4b\u4eab\u670960%\u7684\u4efd\u989d\uff0c\u5e76\u8981\u6c42\u738b\u67d0\u642c\u79bb6\u53f7\u623f\u5c4b\u5927\u623f\u95f4\u3002\", \"defendant_defence\": \"\u4e0d\u540c\u610f\u9648\u67d0\u7684\u8bc9\u8bbc\u8bf7\u6c42\u3002\u7b2c\u4e00\uff0c\u738b\u67d0\u4e0e\u552e\u623f\u5355\u4f4d\u4e8e2000\u5e7412\u67081\u65e5\u7b7e\u8ba2\u300a\u516c\u6709\u4f4f\u623f\u4e70\u5356\u5408\u540c\u300b\uff0c\u8d2d\u623f\u6b3e32265\u5143\u7cfb\u738b\u67d0\u7236\u6bcd\u51fa\u8d44\uff0c\u6545\u8be5\u623f\u5c4b\u5e94\u89c6\u4e3a\u738b\u67d0\u7236\u6bcd\u5bf9\u738b\u67d0\u7684\u8d60\u4e0e\uff0c\u5e94\u786e\u8ba4\u4e3a\u662f\u738b\u67d0\u7684\u4e2a\u4eba\u8d22\u4ea7\u3002\u7b2c\u4e8c\uff0c\u6cd5\u9662\u5c31\u79bb\u5a5a\u6848\u4ef6\u4f5c\u51fa\u7684\u5224\u51b3\u7cfb\u5bf9\u4e8c\u4eba\u5171\u540c\u5c45\u4f4f6\u53f7\u623f\u5c4b\u7684\u4e34\u65f6\u5904\u7406\u65b9\u5f0f\uff0c\u5e76\u975e\u8bbe\u7acb\u5c45\u4f4f\u6743\u6216\u5bf9\u623f\u5c4b\u4f7f\u7528\u6743\u53ca\u6240\u6709\u6743\u4e88\u4ee5\u5206\u5272\u3001\u786e\u8ba4\u3002\u7b2c\u4e09\uff0c\u79bb\u5a5a\u540e\uff0c\u9648\u67d0\u591a\u5e74\u672a\u57286\u53f7\u623f\u5c4b\u5c45\u4f4f\uff0c\u4e14\u9648\u67d0\u5e72\u6270\u90bb\u5c45\u751f\u6d3b\uff0c\u4e0d\u5b9c\u7ee7\u7eed\u5c45\u4f4f\u8be5\u623f\u5c4b\uff0c\u8981\u6c42\u5176\u642c\u79bb\u8be5\u623f\u5c4b\u3002\u7b2c\u56db\uff0c\u738b\u67d0\u5df2\u4ea4\u7eb3\u6848\u6d89\u623f\u5c4b\u4f9b\u6696\u8d39\u3001\u7269\u4e1a\u8d39\u53ca\u7ef4\u4fee\u88c5\u4fee\u8d39\uff0c\u9648\u67d0\u5e94\u6309\u7167\u53cc\u65b9\u7b7e\u8ba2\u7684\u534f\u8bae\u4e66\u5411\u5176\u652f\u4ed8\u4f9b\u6696\u8d393365.75\u5143\u3001\u7269\u4e1a\u8d394597.5\u5143\u3001\u7ef4\u4fee\u88c5\u4fee\u8d392765\u5143\u3002\", \"evidence\": {\"plaintiff_evidence\": {\"evidence_1\": null, \"evidence_2\": null, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null, \"evidence_10\": null}, \"defendant_evidence\": {\"evidence_1\": {\"evidence\": \"\uff082007\uff09\u4e30\u6c11\u521d\u5b57\u7b2c17135\u53f7\u5377\u5b97\uff0c\u7528\u4e8e\u8bc1\u660e\u5728\u8be5\u6848\u4e2d\u9648\u67d0\u79f0\u738b\u67d0\u7b79\u96c66\u53f7\u623f\u5c4b\u8d2d\u623f\u6b3e\u8fd140000\u5143\u540e\u4ea4\u4ed8\u552e\u623f\u5355\u4f4d\", \"dispute\": \"\u738b\u67d0\u79f0\u8be5\u623f\u5c4b\u7cfb\u5176\u5411\u7236\u6bcd\u501f\u6b3e\u8d2d\u4e70\", \"name\": null}, \"evidence_2\": {\"evidence\": \"\u7167\u7247\uff0c\u7528\u4e8e\u8bc1\u660e\u9648\u67d0\u57286\u53f7\u623f\u5c4b\u5185\u4ece\u4e8b\u8ff7\u4fe1\u6d3b\u52a8\uff0c\u5f71\u54cd\u738b\u67d0\u4e0e\u90bb\u5c45\u7684\u751f\u6d3b\u4e14\u5371\u53ca\u5b89\u5168\", \"dispute\": \"\"}, \"evidence_3\": {\"evidence\": \"\u534f\u8bae\u4e66\uff0c\u7528\u4e8e\u8bc1\u660e\u53cc\u65b9\u5bf9\u5206\u62c5\u7269\u4e1a\u8d39\u3001\u4f9b\u6696\u8d39\u3001\u6c34\u7535\u8d39\u3001\u7ef4\u4fee\u8d39\u8fdb\u884c\u7ea6\u5b9a\", \"dispute\": \"\"}, \"evidence_4\": {\"evidence\": \"\u7968\u636e\uff0c\u7528\u4e8e\u8bc1\u660e\u738b\u67d0\u4ea4\u7eb3\u7684\u7269\u4e1a\u8d39\u3001\u4f9b\u6696\u8d39\u3001\u623f\u5c4b\u7ef4\u4fee\u53ca\u88c5\u4fee\u8d39\u5e94\u7531\u53cc\u65b9\u5206\u62c5\", \"dispute\": \"\"}, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null}}, \"other_statement\": {\"plaintiff\": {\"plaintiff_1\": \"\"}, \"defendant\": {\"defendant_1\": \"\"}}}\n\u6700\u540e\u5728\u65b0\u7684\u4e00\u884c\u4ee5 'Answer:' \u5f00\u5934\u7ed9\u51fa\u7b80\u6d01\u7684\u6700\u7ec8\u88c1\u5224\u4e3b\u6587\u3002",
        "correct_answer": [
            "\u4f4d\u4e8e\u5317\u4eac\u5e02\u4e30\u53f0\u533a\u4e1c\u9ad8\u5730\u4e07\u6e90\u4e1c\u91cc85\u53f7\u697c3\u5c423\u5355\u51436\u53f7\u7684\u623f\u5c4b\u7531\u9648\u67d0\u3001\u738b\u67d0\u6309\u4efd\u5171\u6709\uff0c\u5176\u4e2d\u9648\u67d0\u4eab\u670950%\u7684\u4efd\u989d\u3001\u738b\u67d0\u4eab\u670950%\u7684\u4efd\u989d",
            "\u9a73\u56de\u9648\u67d0\u7684\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42",
            "\u9a73\u56de\u738b\u67d0\u7684\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42",
            "\u6848\u4ef6\u53d7\u7406\u8d392575\u5143\uff0c\u7531\u9648\u67d0\u8d1f\u62c51287.5\u5143\uff08\u5df2\u4ea4\u7eb3\uff09\uff0c\u7531\u738b\u67d0\u8d1f\u62c51287.5\u5143\uff08\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u4e03\u65e5\u5185\u4ea4\u7eb3\uff09"
        ],
        "n": 0,
        "response": "**\u5317\u4eac\u5e02\u4e30\u53f0\u533a\u4eba\u6c11\u6cd5\u9662**\n**\u6c11\u4e8b\u5224\u51b3\u4e66**\n\n**\u6848\u53f7\uff1a(202X)\u4eac0106\u6c11\u521dXXXX\u53f7**\n\n**\u539f\u544a\uff1a**\u9648\u67d0\uff0c\u5973\uff0c19xx\u5e74xx\u6708xx\u65e5\u51fa\u751f\uff0c\u6c49\u65cf\uff0c\u4f4f\u5317\u4eac\u5e02\u4e30\u53f0\u533a\u4e1c\u9ad8\u5730\u4e07\u6e90\u4e1c\u91cc\u3002\n**\u88ab\u544a\uff1a**\u738b\u67d0\uff0c\u7537\uff0c2000\u5e7412\u67081\u65e5\u51fa\u751f\uff08\u6ce8\uff1a\u6b64\u5904\u4f9d\u636e\u63d0\u4f9b\u4fe1\u606f\uff0c\u4f46\u4e0e\u5176\u8d2d\u623f\u65f6\u95f4\u5b58\u5728\u903b\u8f91\u77db\u76fe\uff0c\u4e0b\u6587\u6309\u5b9e\u9645\u6210\u5e74\u5f53\u4e8b\u4eba\u5904\u7406\uff09\uff0c\u6c49\u65cf\uff0c\u4f4f\u5317\u4eac\u5e02\u4e30\u53f0\u533a\u4e1c\u9ad8\u5730\u4e07\u6e90\u4e1c\u91cc\u3002\n\n\u539f\u544a\u9648\u67d0\u4e0e\u88ab\u544a\u738b\u67d0\u5171\u6709\u7269\u5206\u5272\u53ca\u7269\u6743\u4fdd\u62a4\u7ea0\u7eb7\u4e00\u6848\uff0c\u672c\u9662\u53d7\u7406\u540e\uff0c\u4f9d\u6cd5\u9002\u7528\u7b80\u6613\u7a0b\u5e8f\uff0c\u516c\u5f00\u5f00\u5ead\u8fdb\u884c\u4e86\u5ba1\u7406\u3002\u672c\u6848\u73b0\u5df2\u5ba1\u7406\u7ec8\u7ed3\u3002\n\n**\u672c\u9662\u8ba4\u4e3a\uff1a**\n\n\u672c\u6848\u7684\u4e89\u8bae\u7126\u70b9\u5728\u4e8e\uff1a\u4e00\u662f\u6d89\u68486\u53f7\u623f\u5c4b\u7684\u6743\u5c5e\u53ca\u4efd\u989d\u6bd4\u4f8b\uff1b\u4e8c\u662f\u539f\u544a\u662f\u5426\u6709\u6743\u8981\u6c42\u88ab\u544a\u642c\u79bb\u5927\u623f\u95f4\uff1b\u4e09\u662f\u88ab\u544a\u4e3b\u5f20\u7684\u8d39\u7528\u8865\u507f\u662f\u5426\u5e94\u4e88\u652f\u6301\u3002\n\n**\u4e00\u3001 \u5173\u4e8e\u623f\u5c4b\u6743\u5c5e\u53ca\u4efd\u989d\u95ee\u9898**\n\u6d89\u68486\u53f7\u623f\u5c4b\u7cfb\u539f\u3001\u88ab\u544a\u5a5a\u59fb\u5173\u7cfb\u5b58\u7eed\u671f\u95f4\u4e8e2000\u5e74\u8d2d\u4e70\u3002\u88ab\u544a\u4e3b\u5f20\u8d2d\u623f\u6b3e\u7cfb\u5176\u7236\u6bcd\u51fa\u8d44\u5e76\u89c6\u4e3a\u5bf9\u5176\u4e2a\u4eba\u7684\u8d60\u4e0e\uff0c\u5e94\u4e3a\u4e2a\u4eba\u8d22\u4ea7\u3002\u4f46\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u53ca\u76f8\u5173\u53f8\u6cd5\u89e3\u91ca\uff0c\u5a5a\u59fb\u5173\u7cfb\u5b58\u7eed\u671f\u95f4\u7531\u4e00\u65b9\u7236\u6bcd\u51fa\u8d44\u8d2d\u4e70\u7684\u623f\u5c4b\uff0c\u4ea7\u6743\u767b\u8bb0\u5728\u51fa\u8d44\u4eba\u5b50\u5973\u540d\u4e0b\u7684\uff0c\u539f\u5219\u4e0a\u8ba4\u5b9a\u4e3a\u592b\u59bb\u5171\u540c\u8d22\u4ea7\uff0c\u9664\u975e\u6709\u660e\u786e\u8bc1\u636e\u8bc1\u660e\u8be5\u51fa\u8d44\u7cfb\u4ec5\u5bf9\u4e00\u65b9\u7684\u8d60\u4e0e\u3002\u88ab\u544a\u867d\u4e3b\u5f20\u7236\u6bcd\u51fa\u8d44\uff0c\u4f46\u672a\u80fd\u63d0\u4f9b\u8db3\u4ee5\u8bc1\u660e\u8be5\u51fa\u8d44\u4e3a\u5bf9\u5176\u4e2a\u4eba\u7279\u5b9a\u8d60\u4e0e\u7684\u6cd5\u5f8b\u6587\u4ef6\uff1b\u4e14\u88ab\u544a\u57282007\u5e74\u79bb\u5a5a\u8bc9\u8bbc\u4e2d\u66fe\u9648\u8ff0\u8d2d\u623f\u6b3e\u4e3a\u7b79\u96c6\u6240\u5f97\u3002\u8003\u8651\u5230\u8be5\u623f\u5c4b\u5c5e\u4e8e\u623f\u6539\u623f\u6027\u8d28\uff0c\u5305\u542b\u5de5\u9f84\u6298\u7b97\u7b49\u653f\u7b56\u6027\u4f18\u60e0\uff0c\u4e14\u53cc\u65b9\u5728\u79bb\u5a5a\u540e\u957f\u671f\u5171\u540c\u4f7f\u7528\u8be5\u623f\u5c4b\uff0c\u672c\u9662\u8ba4\u5b9a\u8be5\u623f\u5c4b\u5e94\u4e3a\u539f\u3001\u88ab\u544a\u7684\u592b\u59bb\u5171\u540c\u8d22\u4ea7\u3002\n\u5173\u4e8e\u4efd\u989d\uff0c\u539f\u544a\u4e3b\u5f20\u4eab\u670960%\u7684\u4efd\u989d\uff0c\u4f46\u672a\u63d0\u4f9b\u5145\u5206\u8bc1\u636e\u8bc1\u660e\u5176\u5bf9\u623f\u5c4b\u8d21\u732e\u7a0b\u5ea6\u663e\u8457\u9ad8\u4e8e\u88ab\u544a\u6216\u5b58\u5728\u5e94\u5f53\u591a\u5206\u7684\u6cd5\u5b9a\u4e8b\u7531\u3002\u6309\u7167\u516c\u5e73\u539f\u5219\u53ca\u5171\u6709\u8d22\u4ea7\u5206\u5272\u7684\u4e00\u822c\u89c4\u5219\uff0c\u672c\u9662\u786e\u8ba4\u539f\u3001\u88ab\u544a\u5404\u4eab\u6709\u6d89\u6848\u623f\u5c4b50%\u7684\u6240\u6709\u6743\u4efd\u989d\u3002\n\n**\u4e8c\u3001 \u5173\u4e8e\u623f\u5c4b\u5c45\u4f4f\u4f7f\u7528\u95ee\u9898**\n\u7ecf\u67e5\uff0c\uff082007\uff09\u4e30\u6c11\u521d\u5b57\u7b2c17135\u53f7\u6c11\u4e8b\u5224\u51b3\u4e66\u5df2\u5bf9\u623f\u5c4b\u7684\u4f7f\u7528\u6743\u4f5c\u51fa\u4e86\u660e\u786e\u5212\u5206\uff0c\u5373\u5927\u623f\u95f4\u7531\u9648\u67d0\u5c45\u4f4f\uff0c\u5c0f\u623f\u95f4\u7531\u738b\u67d0\u5c45\u4f4f\u3002\u8be5\u88c1\u5224\u6587\u4e66\u5177\u6709\u6cd5\u5f8b\u6548\u529b\uff0c\u53cc\u65b9\u5747\u5e94\u9075\u7167\u6267\u884c\u3002\u88ab\u544a\u5173\u4e8e\u539f\u544a\u591a\u5e74\u672a\u5c45\u4f4f\u53ca\u5e72\u6270\u90bb\u5c45\u7684\u6297\u8fa9\uff0c\u4e0d\u6784\u6210\u5176\u5f3a\u884c\u5360\u6709\u539f\u544a\u5206\u914d\u533a\u57df\u7684\u5408\u6cd5\u7406\u7531\u3002\u82e5\u539f\u544a\u786e\u6709\u8fdd\u6cd5\u8fdd\u89c4\u884c\u4e3a\uff0c\u88ab\u544a\u53ef\u53e6\u884c\u901a\u8fc7\u884c\u653f\u6216\u6cd5\u5f8b\u9014\u5f84\u89e3\u51b3\uff0c\u800c\u975e\u975e\u6cd5\u6539\u53d8\u65e2\u5b9a\u5c45\u4f4f\u683c\u5c40\u3002\u6545\u539f\u544a\u8981\u6c42\u88ab\u544a\u642c\u79bb\u5927\u623f\u95f4\u7684\u8bc9\u8bf7\uff0c\u4e8e\u6cd5\u6709\u636e\uff0c\u672c\u9662\u4e88\u4ee5\u652f\u6301\u3002\n\n**\u4e09\u3001 \u5173\u4e8e\u76f8\u5173\u8d39\u7528\u8d1f\u62c5\u95ee\u9898**\n\u88ab\u544a\u4e3b\u5f20\u539f\u544a\u652f\u4ed8\u4f9b\u6696\u8d39\u3001\u7269\u4e1a\u8d39\u53ca\u7ef4\u4fee\u8d39\u7b49\u3002\u6839\u636e\u53cc\u65b9\u7b7e\u8ba2\u7684\u534f\u8bae\u4e66\uff0c\u53cc\u65b9\u5bf9\u8d39\u7528\u7684\u5206\u62c5\u5df2\u6709\u660e\u786e\u7ea6\u5b9a\u3002\u539f\u544a\u4f5c\u4e3a\u623f\u5c4b\u7684\u5171\u6709\u4eba\u53ca\u5b9e\u9645\u4f7f\u7528\u6743\u5229\u4eba\uff0c\u5e94\u5f53\u627f\u62c5\u76f8\u5e94\u7684\u7269\u4e1a\u8d39\u53ca\u516c\u7528\u4e8b\u4e1a\u8d39\u3002\u5bf9\u4e8e\u88ab\u544a\u57ab\u4ed8\u7684\u3001\u5c5e\u4e8e\u539f\u544a\u5e94\u8d1f\u62c5\u7684\u90e8\u5206\uff0c\u539f\u544a\u5e94\u4e88\u8fd4\u8fd8\u3002\n\n**\u7efc\u4e0a\u6240\u8ff0\uff0c**\u672c\u9662\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e8c\u767e\u4e5d\u5341\u4e03\u6761\u3001\u7b2c\u4e09\u767e\u96f6\u4e09\u6761\u3001\u7b2c\u4e09\u767e\u96f6\u516b\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n\u4e00\u3001 \u786e\u8ba4\u4f4d\u4e8e\u5317\u4eac\u5e02\u4e30\u53f0\u533a\u4e1c\u9ad8\u5730\u4e07\u6e90\u4e1c\u91ccXX6\u53f7\u623f\u5c4b\u7531\u539f\u544a\u9648\u67d0\u3001\u88ab\u544a\u738b\u67d0\u5404\u4eab\u670950%\u7684\u4efd\u989d\uff1b\n\u4e8c\u3001 \u88ab\u544a\u738b\u67d0\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\u642c\u79bb\u6d89\u68486\u53f7\u623f\u5c4b\u7684\u5927\u623f\u95f4\uff0c\u4ea4\u7531\u539f\u544a\u9648\u67d0\u5c45\u4f4f\u4f7f\u7528\uff1b\n\u4e09\u3001 \u539f\u544a\u9648\u67d0\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\u652f\u4ed8\u88ab\u544a\u738b\u67d0\u7269\u4e1a\u8d39\u3001\u4f9b\u6696\u8d39\u3001\u7ef4\u4fee\u8d39\u5171\u8ba110728.25\u5143\uff1b\n\u56db\u3001 \u9a73\u56de\u539f\u544a\u9648\u67d0\u7684\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42\u3002\n\n\u5982\u672a\u6309\u672c\u5224\u51b3\u6307\u5b9a\u7684\u671f\u95f4\u5c65\u884c\u7ed9\u4ed8\u91d1\u94b1\u4e49\u52a1\uff0c\u5e94\u5f53\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u4e8c\u767e\u516d\u5341\u6761\u4e4b\u89c4\u5b9a\uff0c\u52a0\u500d\u652f\u4ed8\u8fdf\u5ef6\u5c65\u884c\u671f\u95f4\u7684\u503a\u52a1\u5229\u606f\u3002\n\n\u6848\u4ef6\u53d7\u7406\u8d39\u7531\u539f\u3001\u88ab\u544a\u53cc\u65b9\u51cf\u534a\u8d1f\u62c5\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u5317\u4eac\u5e02\u7b2c\u4e8c\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002\n\n\u5ba1\u5224\u957f\uff1a\u5f20XX\n\u4e8c\u3007\u4e8cX\u5e74X\u6708X\u65e5\n\uff08\u9662\u5370\uff09\n\nAnswer: 1. \u786e\u8ba4\u9648\u67d0\u3001\u738b\u67d0\u5404\u4eab\u6709\u6d89\u6848\u623f\u5c4b50%\u4efd\u989d\uff1b2. \u738b\u67d0\u642c\u79bb\u6d89\u6848\u623f\u5c4b\u5927\u623f\u95f4\uff1b3. \u9648\u67d0\u652f\u4ed8\u738b\u67d0\u7269\u4e1a\u8d39\u3001\u4f9b\u6696\u8d39\u3001\u7ef4\u4fee\u8d39\u5408\u8ba110728.25\u5143\uff1b4. \u9a73\u56de\u9648\u67d0\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42\u3002",
        "sub_tasks_text": null
    }
]