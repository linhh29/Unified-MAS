[
    {
        "example_id": 5,
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u5a5a\u59fb\u5bb6\u5ead\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u6768\u67d0\", \"address\": \"\u897f\u5b89\u5e02\u957f\u5b89\u533a\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1980\u5e749\u670820\u65e5\"}, \"defendant\": {\"name\": \"\u674e\u67d01\", \"address\": \"\u897f\u5b89\u5e02\u957f\u5b89\u533a\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1977\u5e744\u670828\u65e5\"}}, \"plaintiff_claim\": [\"\u5224\u4ee4\u786e\u8ba4\u539f\u3001\u88ab\u544a\u6301\u6709\u7684\u7ed3\u5a5a\u8bc1\u65e0\u6548\u3002\", \"\u5224\u4ee4\u539f\u3001\u88ab\u544a\u5a5a\u59fb\u65e0\u6548\u3002\", \"\u672c\u6848\u7684\u8bc9\u8bbc\u8d39\u7531\u88ab\u544a\u627f\u62c5\u3002\"], \"plaintiff_case_details\": \"\u539f\u3001\u88ab\u544a\u7ecf\u4eba\u4ecb\u7ecd\u76f8\u8bc61999\u5e74\u519c\u5386\u6625\u8282\u4e3e\u529e\u5a5a\u793c\uff0c1999\u5e743\u67085\u65e5\u529e\u7406\u7ed3\u5a5a\u8bc1\uff0c\u56e0\u529e\u7406\u7ed3\u5a5a\u8bc1\u65f6\u539f\u544a\u672a\u5230\u6cd5\u5b9a\u5a5a\u9f84\uff0c\u88ab\u544a\u627e\u5173\u7cfb\u529e\u7406\uff0c\u73b0\u539f\u3001\u88ab\u544a\u95f9\u77db\u76fe\u51c6\u5907\u5206\u624b\uff0c\u6545\u539f\u544a\u8bc9\u81f3\u6cd5\u9662\uff0c\u8bf7\u6c42\u5224\u4ee4\u5982\u8bc9\u6c42\u3002\", \"defendant_defence\": \"\u53cc\u65b9\u4e3e\u529e\u8fc7\u5a5a\u793c\uff0c\u5e76\u4e14\u5171\u540c\u751f\u80b2\u5b50\u5973\uff0c\u7ed3\u5a5a\u8bc1\u662f\u771f\u5b9e\u7684\uff0c\u5a5a\u59fb\u4e5f\u662f\u6709\u6548\u7684\u3002\", \"evidence\": {\"plaintiff_evidence\": {\"evidence_1\": {\"evidence\": \"\u7ed3\u5a5a\u8bc1\", \"dispute\": \"\u539f\u544a\u4e3b\u5f20\u7ed3\u5a5a\u8bc1\u4e3a\u5047\u8bc1\uff0c\u88ab\u544a\u4e3b\u5f20\u7ed3\u5a5a\u8bc1\u4e3a\u771f\u5b9e\u3002\"}, \"evidence_2\": {\"evidence\": \"\u67e5\u8be2\u8bc1\u660e\", \"dispute\": \"\u897f\u5b89\u5e02\u957f\u5b89\u533a\u6863\u6848\u9986\u51fa\u5177\u8bc1\u660e\uff0c\u5a5a\u59fb\u767b\u8bb0\u6863\u6848\u4e2d\u65e0\u6b64\u4eba\u7ed3\u5a5a\u767b\u8bb0\u4fe1\u606f\u3002\"}, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null, \"evidence_10\": null}, \"defendant_evidence\": {\"evidence_1\": null, \"evidence_2\": null, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null}}, \"other_statement\": {\"plaintiff\": {\"plaintiff_1\": \"\"}, \"defendant\": {\"defendant_1\": \"\"}}}\n\u6700\u540e\u5728\u65b0\u7684\u4e00\u884c\u4ee5 'Answer:' \u5f00\u5934\u7ed9\u51fa\u7b80\u6d01\u7684\u6700\u7ec8\u88c1\u5224\u4e3b\u6587\u3002",
        "correct_answer": [
            "\u9a73\u56de\u539f\u544a\u6768\u67d0\u8bc9\u8bbc\u8bf7\u6c42\u3002",
            "\u6848\u4ef6\u53d7\u7406\u8d39300\u5143\uff0c\u539f\u544a\u5df2\u9884\u4ea4\uff0c\u7531\u539f\u544a\u6768\u67d0\u8d1f\u62c5\u3002",
            "\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u9655\u897f\u7701\u897f\u5b89\u5e02\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002"
        ],
        "n": 0,
        "response": "**\u5ba1\u7406\u62a5\u544a\u4e0e\u5224\u51b3\u4e66**\n\n**\u6848\u53f7\uff1a**\uff08202X\uff09\u96550116\u6c11\u521dXXXX\u53f7\n\n**\u5ba1\u5224\u957f\uff1a** [\u60a8\u7684\u59d3\u540d/\u5ba1\u5224\u957f]\n**\u65e5\u671f\uff1a** 202X\u5e74X\u6708X\u65e5\n\n**\u672c\u9662\u7ecf\u5ba1\u7406\u67e5\u660e\uff1a**\n\u539f\u544a\u6768\u67d0\uff08\u5973\uff0c1980\u5e749\u670820\u65e5\u51fa\u751f\uff09\u4e0e\u88ab\u544a\u674e\u67d01\uff08\u7537\uff0c1977\u5e744\u670828\u65e5\u51fa\u751f\uff09\u4e8e1999\u5e74\u519c\u5386\u6625\u8282\u4e3e\u884c\u5a5a\u793c\uff0c\u5e76\u5f00\u59cb\u5171\u540c\u751f\u6d3b\u30021999\u5e743\u67085\u65e5\uff0c\u53cc\u65b9\u53d6\u5f97\u7ed3\u5a5a\u8bc1\u3002\u539f\u544a\u8bc9\u79f0\uff0c\u5176\u5728\u529e\u7406\u7ed3\u5a5a\u767b\u8bb0\u65f6\u5b9e\u9645\u5e74\u9f84\u4ec5\u4e3a18\u5468\u5c81\u534a\uff0c\u672a\u8fbe\u5230\u6cd5\u5b9a\u5a5a\u9f84\uff08\u597320\u5468\u5c81\uff09\uff0c\u7cfb\u88ab\u544a\u901a\u8fc7\u4e0d\u6b63\u5f53\u5173\u7cfb\u529e\u7406\u3002\u73b0\u53cc\u65b9\u4ea7\u751f\u77db\u76fe\u62df\u7ed3\u675f\u5173\u7cfb\uff0c\u539f\u544a\u5411\u672c\u9662\u63d0\u8d77\u8bc9\u8bbc\uff0c\u8bf7\u6c42\u786e\u8ba4\u8be5\u7ed3\u5a5a\u8bc1\u53ca\u5a5a\u59fb\u5173\u7cfb\u65e0\u6548\u3002\n\n**\u8bc1\u636e\u5206\u6790\uff1a**\n\u672c\u9662\u5bf9\u53cc\u65b9\u63d0\u4f9b\u7684\u8bc1\u636e\u8fdb\u884c\u4e86\u5ba1\u67e5\u3002\u539f\u544a\u63d0\u4ea4\u4e86\u897f\u5b89\u5e02\u957f\u5b89\u533a\u6863\u6848\u9986\u51fa\u5177\u7684\u8bc1\u660e\uff0c\u8bc1\u5b9e\u5176\u5a5a\u59fb\u767b\u8bb0\u6863\u6848\u4e2d\u5e76\u65e0\u539f\u3001\u88ab\u544a\u7684\u7ed3\u5a5a\u767b\u8bb0\u4fe1\u606f\u3002\u88ab\u544a\u867d\u4e3b\u5f20\u7ed3\u5a5a\u8bc1\u771f\u5b9e\u4e14\u53cc\u65b9\u5171\u540c\u751f\u6d3b\u751f\u80b2\u5b50\u5973\uff0c\u4f46\u672a\u80fd\u63d0\u4f9b\u8bc1\u636e\u63a8\u7ffb\u6863\u6848\u9986\u7684\u5b98\u65b9\u8bc1\u660e\u3002\n\n**\u672c\u9662\u8ba4\u4e3a\uff1a**\n\u4e00\u3001**\u5173\u4e8e\u6cd5\u5b9a\u5a5a\u9f84\uff1a** \u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u5a5a\u59fb\u6cd5\u300b\uff081980\u5e74\u7248\uff0c\u6848\u6d89\u884c\u4e3a\u53d1\u751f\u65f6\u9002\u7528\uff09\u7b2c\u516d\u6761\u89c4\u5b9a\uff0c\u7ed3\u5a5a\u5e74\u9f84\uff0c\u7537\u4e0d\u5f97\u65e9\u4e8e\u4e8c\u5341\u4e8c\u5468\u5c81\uff0c\u5973\u4e0d\u5f97\u65e9\u4e8e\u4e8c\u5341\u5468\u5c81\u3002\u539f\u544a\u6768\u67d0\u51fa\u751f\u4e8e1980\u5e749\u670820\u65e5\uff0c\u57281999\u5e743\u67085\u65e5\u529e\u7406\u7ed3\u5a5a\u767b\u8bb0\u65f6\uff0c\u5b9e\u9645\u5e74\u9f84\u4e0d\u6ee119\u5468\u5c81\uff0c\u786e\u672a\u8fbe\u5230\u6cd5\u5b9a\u5a5a\u9f84\u3002\n\n\u4e8c\u3001**\u5173\u4e8e\u767b\u8bb0\u7a0b\u5e8f\u7684\u5408\u6cd5\u6027\u4e0e\u771f\u5b9e\u6027\uff1a** \u7ed3\u5a5a\u8bc1\u5e94\u5f53\u7531\u5a5a\u59fb\u767b\u8bb0\u673a\u5173\u4f9d\u636e\u6cd5\u5b9a\u7a0b\u5e8f\u6838\u53d1\u3002\u672c\u6848\u4e2d\uff0c\u897f\u5b89\u5e02\u957f\u5b89\u533a\u6863\u6848\u9986\u4f5c\u4e3a\u5a5a\u59fb\u767b\u8bb0\u6863\u6848\u7684\u6cd5\u5b9a\u4fdd\u7ba1\u673a\u6784\uff0c\u51fa\u5177\u8bc1\u660e\u786e\u8ba4\u65e0\u6b64\u4e8c\u4eba\u767b\u8bb0\u4fe1\u606f\uff0c\u8fd9\u8868\u660e\u539f\u3001\u88ab\u544a\u6301\u6709\u7684\u7ed3\u5a5a\u8bc1\u5e76\u975e\u901a\u8fc7\u5408\u6cd5\u3001\u6b63\u5f0f\u7684\u7a0b\u5e8f\u5728\u6c11\u653f\u90e8\u95e8\u767b\u8bb0\u4ea7\u751f\u3002\u5373\u4fbf\u53cc\u65b9\u4e3e\u529e\u4e86\u5a5a\u793c\u5e76\u751f\u80b2\u5b50\u5973\uff0c\u57281994\u5e742\u67081\u65e5\u4ee5\u540e\uff0c\u6211\u56fd\u6cd5\u5f8b\u4e0d\u518d\u627f\u8ba4\u4e8b\u5b9e\u5a5a\u59fb\uff0c\u672a\u7ecf\u5408\u6cd5\u767b\u8bb0\u7684\u540c\u5c45\u5173\u7cfb\u4e0d\u5177\u5907\u6cd5\u5f8b\u610f\u4e49\u4e0a\u7684\u5a5a\u59fb\u6548\u529b\u3002\n\n\u4e09\u3001**\u5173\u4e8e\u5a5a\u59fb\u6548\u529b\u7684\u8ba4\u5b9a\uff1a** \u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u96f6\u4e94\u5341\u4e00\u6761\uff08\u53ca\u539f\u300a\u5a5a\u59fb\u6cd5\u300b\u76f8\u5173\u89c4\u5b9a\uff09\uff0c\u672a\u8fbe\u5230\u6cd5\u5b9a\u5a5a\u9f84\u7684\u5a5a\u59fb\u5c5e\u4e8e\u65e0\u6548\u5a5a\u59fb\u3002\u540c\u65f6\uff0c\u7531\u4e8e\u6848\u6d89\u7ed3\u5a5a\u8bc1\u5728\u5b98\u65b9\u6863\u6848\u4e2d\u65e0\u8bb0\u5f55\uff0c\u5c5e\u4e8e\u865a\u5047\u6216\u7a0b\u5e8f\u4e25\u91cd\u8fdd\u6cd5\u7684\u767b\u8bb0\uff0c\u5176\u5f62\u5f0f\u8981\u4ef6\u4ea6\u4e0d\u5b8c\u5907\u3002\u867d\u5f53\u4e8b\u4eba\u73b0\u5728\u5747\u5df2\u8fbe\u5230\u6cd5\u5b9a\u5a5a\u9f84\uff0c\u4f46\u7531\u4e8e\u521d\u59cb\u767b\u8bb0\u4fe1\u606f\u4e0d\u5b58\u5728\u4e14\u8fdd\u80cc\u6cd5\u5b9a\u7a0b\u5e8f\uff0c\u8be5\u8bc1\u4ef6\u65e0\u6cd5\u4ea7\u751f\u6cd5\u5f8b\u6548\u529b\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u539f\u3001\u88ab\u544a\u4e4b\u95f4\u7684\u5a5a\u59fb\u767b\u8bb0\u56e0\u8fdd\u53cd\u6cd5\u5b9a\u5a5a\u9f84\u8981\u6c42\u4e14\u7f3a\u4e4f\u5408\u6cd5\u767b\u8bb0\u8bb0\u5f55\uff0c\u4e0d\u5177\u6709\u6cd5\u5f8b\u7ea6\u675f\u529b\u3002\n\n**\u88c1\u5224\u5982\u4e0b\uff1a**\n\nAnswer: 1. \u786e\u8ba4\u539f\u544a\u6768\u67d0\u4e0e\u88ab\u544a\u674e\u67d01\u4e8e1999\u5e743\u67085\u65e5\u6301\u6709\u7684\u7ed3\u5a5a\u8bc1\u65e0\u6548\uff1b2. \u786e\u8ba4\u539f\u544a\u6768\u67d0\u4e0e\u88ab\u544a\u674e\u67d01\u4e4b\u95f4\u7684\u5a5a\u59fb\u5173\u7cfb\u65e0\u6548\uff1b3. \u6848\u4ef6\u53d7\u7406\u8d39\u7531\u88ab\u544a\u674e\u67d01\u627f\u62c5\u3002",
        "sub_tasks_text": null
    }
]