[
    {
        "example_id": 10,
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u5a5a\u59fb\u5bb6\u5ead\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u8bb8\u67d0\u661f\", \"address\": \"\u6cb3\u5357\u7701\u56fa\u59cb\u53bf\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"2001\u5e741\u670819\u65e5\"}, \"defendant\": {\"name\": \"\u718a\u67d0\u83ca\", \"address\": \"\u6cb3\u5357\u7701\u56fa\u59cb\u53bf\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"2001\u5e744\u670826\u65e5\"}}, \"plaintiff_claim\": [\"\u8981\u6c42\u88ab\u544a\u9000\u8fd8\u5f69\u793c102,541\u5143\", \"\u8981\u6c42\u88ab\u544a\u7ed9\u4e88\u7cbe\u795e\u635f\u5bb3\u8d54\u507f\u8d392\u4e07\u5143\", \"\u672c\u6848\u8bc9\u8bbc\u8d39\u7528\u7531\u88ab\u544a\u627f\u62c5\"], \"plaintiff_case_details\": \"\u539f\u3001\u88ab\u544a\u7ecf\u4eba\u4ecb\u7ecd\u8ba4\u8bc6\uff0c\u5e76\u8ba2\u5a5a\u30022023\u5e746\u6708\u81f32024\u5e748\u670815\u65e5\uff0c\u88ab\u544a\u591a\u6b21\u4e0d\u540c\u610f\u53c8\u53cd\u590d\u540c\u610f\uff0c\u5bf9\u539f\u544a\u4e0d\u70ed\u4e0d\u51b7\uff0c\u6ca1\u6709\u4e00\u70b9\u771f\u5fc3\u3002\u671f\u95f4\uff0c\u539f\u544a\u7236\u6bcd\u7ed9\u4ed8\u88ab\u544a\u8ba2\u5a5a\u548c\u5bf9\u88ab\u544a\u6240\u82b1\u7684\u5f69\u793c\u5171\u8ba1102,541\u5143\u3002\u73b0\u88ab\u544a\u53c8\u8981\u6c42\u9000\u5a5a\uff0c\u5bfc\u81f4\u539f\u544a\u7cbe\u795e\u4e0a\u53d7\u5230\u6781\u5927\u6253\u51fb\uff0c\u6574\u5929\u5403\u4e0d\u597d\u7761\u4e0d\u597d\uff0c\u88ab\u544a\u65e2\u4e0d\u613f\u610f\u4e0e\u539f\u544a\u7ed3\u5a5a\uff0c\u4e5f\u4e0d\u9000\u8fd8\u5f69\u793c\u3002\u56e0\u6b64\u539f\u544a\u8feb\u4e8e\u65e0\u5948\uff0c\u7279\u8bc9\u81f3\u6cd5\u9662\uff0c\u8bf7\u6c42\u6cd5\u9662\u4f9d\u6cd5\u53ca\u65f6\u5904\u7406\u3002\", \"defendant_defence\": \"\u539f\u544a\u79f0\u88ab\u544a\u610f\u89c1\u53cd\u590d\u4e0d\u662f\u4e8b\u5b9e\uff0c\u4e8b\u5b9e\u4e0a\u662f\u53cc\u65b9\u5bf9\u5a5a\u671f\u7684\u786e\u5b9a\u610f\u89c1\u4e0d\u4e00\u81f4\u3002\u539f\u544a\u8981\u6c42\u88ab\u544a\u9000\u8fd8\u5f69\u793c102,541\u5143\u53ca\u7cbe\u795e\u635f\u5bb3\u8d54\u507f\u8d39\u6ca1\u6709\u4f9d\u636e\uff0c\u7b54\u8fa9\u4eba\u6309\u7167\u98ce\u4fd7\u6536\u5230\u7684\u5f69\u793c\u662f10,001\u5143\u548c\u4e00\u679a\u6212\u6307\uff0c\u5176\u4ed6\u5f80\u6765\u662f\u53cc\u65b9\u8d60\u4e88\u884c\u4e3a\uff0c\u6ca1\u6709\u5177\u4f53\u5206\u6e05\u695a\u5404\u65b9\u8d60\u4e88\u7684\u793c\u54c1\u79cd\u7c7b\u3001\u6570\u91cf\uff0c\u88ab\u544a\u5411\u539f\u544a\u4e5f\u6709\u76f8\u5173\u7684\u82b1\u8d39\uff0c\u88ab\u544a\u53bb\u5e74\u529e\u7406\u9152\u5e2d\u82b1\u8d393,800\u5143\uff0c\u4eca\u5e74\u6b63\u6708\u529e\u7406\u9152\u5e2d\u82b1\u8d394,100\u5143\uff0c\u521d\u56db\u9152\u5e2d\u82b1\u8d391,500\u5143\uff0c\u539f\u544a\u5230\u88ab\u544a\u5bb6\u6765\u4e5f\u82b1\u4e86\u56db\u4e94\u5343\u5143\uff0c\u6b63\u6708\u88ab\u544a\u5230\u88ab\u544a\u5bb6\u62dc\u5e74\u4e5f\u5e26\u53bb\u793c\u54c1\u82b1\u8d39\u7ea63,000\u5143\u3002\u8be5\u76f8\u5173\u6b3e\u9879\u5747\u662f\u53cc\u65b9\u589e\u8fdb\u4e86\u89e3\u793c\u5c1a\u5f80\u6765\uff0c\u4e0d\u662f\u5a5a\u59fb\u5f69\u793c\u8fd4\u8fd8\u4e4b\u5217\u3002\u88ab\u544a\u540c\u610f\u8fd4\u8fd810,001\u5143\u5f69\u793c\u548c\u6212\u6307\u4e00\u679a\uff0c\u5176\u4e2d\u6709\u4e00\u4e2a8,000\u5143\u662f\u539f\u544a\u7ed9\u88ab\u544a\u4eb2\u621a\u7684\u7ea2\u5305\uff0c\u4e0d\u662f\u88ab\u544a\u4e2a\u4eba\u6536\u53d6\uff0c\u8be58,000\u5143\u662f\u5426\u5728\u5f69\u793c\u8303\u56f4\u8bf7\u6cd5\u5ead\u5ba1\u67e5\u3002\", \"evidence\": {\"plaintiff_evidence\": {\"evidence_1\": {\"evidence\": \"\u539f\u544a\u8eab\u4efd\u8bc1\u590d\u5370\u4ef6\", \"dispute\": \"\u65e0\u5f02\u8bae\"}, \"evidence_2\": {\"evidence\": \"\u5316\u5986\u54c1\u7535\u5b50\u53d1\u7968\", \"dispute\": \"\u65e0\u5f02\u8bae\"}, \"evidence_3\": {\"evidence\": \"\u6d88\u8d39\u6e05\u5355\", \"dispute\": \"\u4e0e\u672c\u6848\u6ca1\u6709\u5173\u8054\u6027\uff0c\u8be5\u53d1\u7968\u53cd\u6620\u51fa\u7cfb\u539f\u544a\u4e2a\u4eba\u6d88\u8d39\uff0c\u5e76\u4e0d\u662f\u5bf9\u88ab\u544a\u5bf9\u51c6\u7ed9\u4ed8\uff0c\u8be5\u53d1\u7968\u8f7d\u660e\u91d1\u989d\u88ab\u544a\u4e0d\u77e5\u60c5\"}, \"evidence_4\": {\"evidence\": \"\u8f6c\u8d26\u8bb0\u5f55\", \"dispute\": \"\u8ba4\u53ef\uff0c\u4f46\u662f\u8be5\u8f6c\u8d26\u662f\u53cc\u65b9\u5171\u540c\u6d88\u8d39\u6240\u9700\uff0c6\u67089\u65e5\u5fae\u4fe1\u53ef\u4ee5\u663e\u793a\u662f\u53cc\u65b9\u4ea4\u5f80\u5171\u540c\u6d88\u8d39\u7684\u9700\u8981\uff0c\u4e0d\u662f\u7ed9\u4ed8\u5f69\u793c\uff0c\u8fbe\u4e0d\u5230\u8bc1\u660e\u76ee\u7684\"}, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null, \"evidence_10\": null}, \"defendant_evidence\": {\"evidence_1\": null, \"evidence_2\": null, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null}}, \"other_statement\": {\"plaintiff\": {\"plaintiff_1\": \"\u5ead\u5ba1\u8fc7\u7a0b\u4e2d\uff0c\u88ab\u544a\u718a\u67d0\u83ca\u7684\u59d4\u6258\u8bc9\u8bbc\u4ee3\u7406\u4eba\u5c06\u6212\u6307\u539f\u7269\u8fd4\u8fd8\u539f\u544a\uff0c\u539f\u544a\u5f53\u5ead\u63a5\u53d7\u6212\u6307\u3002\"}, \"defendant\": {\"defendant_1\": \"\u5ead\u5ba1\u8fc7\u7a0b\u4e2d\uff0c\u88ab\u544a\u718a\u67d0\u83ca\u7684\u59d4\u6258\u8bc9\u8bbc\u4ee3\u7406\u4eba\u5c06\u6212\u6307\u539f\u7269\u8fd4\u8fd8\u539f\u544a\"}}}\n\u6700\u540e\u5728\u65b0\u7684\u4e00\u884c\u4ee5 'Answer:' \u5f00\u5934\u7ed9\u51fa\u7b80\u6d01\u7684\u6700\u7ec8\u88c1\u5224\u4e3b\u6587\u3002",
        "correct_answer": [
            "\u88ab\u544a\u718a\u67d0\u83ca\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\u8fd4\u8fd8\u539f\u544a\u8bb8\u67d0\u661f\u5f69\u793c\u6b3e\u4eba\u6c11\u5e0122,000\u5143",
            "\u9a73\u56de\u539f\u544a\u8bb8\u67d0\u661f\u7684\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42",
            "\u5982\u679c\u672a\u6309\u672c\u5224\u51b3\u6307\u5b9a\u7684\u671f\u95f4\u5c65\u884c\u7ed9\u4ed8\u91d1\u94b1\u4e49\u52a1\uff0c\u5e94\u5f53\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u4e8c\u767e\u516d\u5341\u56db\u6761\u89c4\u5b9a\uff0c\u52a0\u500d\u652f\u4ed8\u8fdf\u5ef6\u5c65\u884c\u671f\u95f4\u7684\u503a\u52a1\u5229\u606f",
            "\u6848\u4ef6\u53d7\u7406\u8d392,750.82\u5143\uff0c\u51cf\u534a\u6536\u53d6\u540e\u8ba11,375.41\u5143\uff0c\u7531\u8bb8\u67d0\u661f1,200.41\u5143\uff0c\u7531\u718a\u67d0\u83ca\u8d1f\u62c5175\u5143",
            "\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u4ee5\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u7167\u5bf9\u65b9\u5f53\u4e8b\u4eba\u6216\u8005\u4ee3\u8868\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u6cb3\u5357\u7701\u4fe1\u9633\u5e02\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662"
        ],
        "n": 0,
        "response": "**\u6cb3\u5357\u7701\u56fa\u59cb\u53bf\u4eba\u6c11\u6cd5\u9662**\n**\u6c11\u4e8b\u5224\u51b3\u4e66**\n\n\uff082024\uff09\u8c6b1525\u6c11\u521dXXXX\u53f7\n\n**\u539f\u544a\uff1a**\u8bb8\u67d0\u661f\uff0c\u7537\uff0c2001\u5e741\u670819\u65e5\u51fa\u751f\uff0c\u6c49\u65cf\uff0c\u4f4f\u6cb3\u5357\u7701\u56fa\u59cb\u53bf\u3002\n**\u88ab\u544a\uff1a**\u718a\u67d0\u83ca\uff0c\u5973\uff0c2001\u5e744\u670826\u65e5\u51fa\u751f\uff0c\u6c49\u65cf\uff0c\u4f4f\u6cb3\u5357\u7701\u56fa\u59cb\u53bf\u3002\n\n\u539f\u544a\u8bb8\u67d0\u661f\u4e0e\u88ab\u544a\u718a\u67d0\u83ca\u5a5a\u7ea6\u8d22\u4ea7\u7ea0\u7eb7\u4e00\u6848\uff0c\u672c\u9662\u53d7\u7406\u540e\uff0c\u4f9d\u6cd5\u7531\u5ba1\u5224\u5458\u9002\u7528\u7b80\u6613\u7a0b\u5e8f\u516c\u5f00\u5f00\u5ead\u8fdb\u884c\u4e86\u5ba1\u7406\u3002\u539f\u544a\u8bb8\u67d0\u661f\u3001\u88ab\u544a\u718a\u67d0\u83ca\u53ca\u5176\u59d4\u6258\u8bc9\u8bbc\u4ee3\u7406\u4eba\u5747\u5230\u5ead\u53c2\u52a0\u8bc9\u8bbc\u3002\u672c\u6848\u73b0\u5df2\u5ba1\u7406\u7ec8\u7ed3\u3002\n\n**\u672c\u9662\u8ba4\u4e3a\uff1a**\n\n\u672c\u6848\u7cfb\u5a5a\u7ea6\u8d22\u4ea7\u7ea0\u7eb7\u3002\u4e89\u8bae\u7126\u70b9\u5728\u4e8e\u5f69\u793c\u6570\u989d\u7684\u8ba4\u5b9a\u3001\u662f\u5426\u5e94\u5f53\u8fd4\u8fd8\u4ee5\u53ca\u7cbe\u795e\u635f\u5bb3\u8d54\u507f\u662f\u5426\u6210\u7acb\u3002\n\n\u4e00\u3001 **\u5173\u4e8e\u5f69\u793c\u6570\u989d\u7684\u8ba4\u5b9a\u53ca\u8fd4\u8fd8\u95ee\u9898**\n\u6839\u636e\u300a\u6700\u9ad8\u4eba\u6c11\u6cd5\u9662\u5173\u4e8e\u9002\u7528\u3008\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u3009\u5a5a\u59fb\u5bb6\u5ead\u7f16\u7684\u89e3\u91ca\uff08\u4e00\uff09\u300b\u4ee5\u53ca\u300a\u6700\u9ad8\u4eba\u6c11\u6cd5\u9662\u5173\u4e8e\u5ba1\u7406\u6d89\u5f69\u793c\u7ea0\u7eb7\u6848\u4ef6\u9002\u7528\u6cd5\u5f8b\u82e5\u5e72\u95ee\u9898\u7684\u89c4\u5b9a\u300b\uff0c\u5f69\u793c\u662f\u6307\u4ee5\u7ed3\u5a5a\u4e3a\u76ee\u7684\uff0c\u6309\u7167\u5f53\u5730\u98ce\u4fd7\u7ed9\u4ed8\u7684\u6570\u989d\u8f83\u5927\u7684\u8d22\u7269\u3002\n1. **\u786e\u8ba4\u7684\u5f69\u793c\u8303\u56f4\uff1a**\u88ab\u544a\u627f\u8ba4\u6536\u5230\u7684\u73b0\u91d110,001\u5143\u53ca\u6212\u6307\u4e00\u679a\uff0c\u5c5e\u4e8e\u5178\u578b\u7684\u5f69\u793c\u8303\u7574\u3002\u56e0\u6212\u6307\u5df2\u5728\u5ead\u5ba1\u8fc7\u7a0b\u4e2d\u5f53\u5ead\u8fd4\u8fd8\uff0c\u672c\u9662\u5bf9\u6b64\u4e88\u4ee5\u786e\u8ba4\u3002\n2. **\u4e89\u8bae\u76848,000\u5143\u7ea2\u5305\uff1a**\u539f\u544a\u7ed9\u4ed8\u88ab\u544a\u4eb2\u5c5e\u7684\u7ea2\u5305\uff0c\u5c5e\u4e8e\u793c\u8282\u6027\u8d60\u4e0e\uff0c\u5176\u53d7\u8d60\u4eba\u4e3a\u88ab\u544a\u4eb2\u5c5e\u800c\u975e\u88ab\u544a\u672c\u4eba\uff0c\u4e0d\u5e94\u8ba4\u5b9a\u4e3a\u88ab\u544a\u6536\u53d6\u7684\u5f69\u793c\u3002\n3. **\u4e89\u8bae\u7684\u5176\u4f59\u6b3e\u9879\u53ca\u6d88\u8d39\uff1a**\u539f\u544a\u4e3b\u5f20\u7684\u5176\u4f59\u7ea69\u4e07\u5143\u6b3e\u9879\uff0c\u5305\u542b\u5316\u5986\u54c1\u652f\u51fa\u3001\u65e5\u5e38\u8f6c\u8d26\u53ca\u6d88\u8d39\u6e05\u5355\u3002\u672c\u9662\u8ba4\u4e3a\uff0c\u53cc\u65b9\u5728\u4ea4\u5f80\u671f\u95f4\u4e3a\u589e\u8fdb\u611f\u60c5\u3001\u7ef4\u6301\u65e5\u5e38\u5171\u540c\u5f00\u652f\u800c\u4ea7\u751f\u7684\u793c\u5c1a\u5f80\u6765\u3001\u5c0f\u989d\u8d60\u4e0e\u53ca\u65e5\u5e38\u6d88\u8d39\u652f\u51fa\uff0c\u4e0d\u5c5e\u4e8e\u5f69\u793c\u6027\u8d28\uff0c\u800c\u662f\u5c5e\u4e8e\u4e3a\u4e86\u57f9\u517b\u611f\u60c5\u7684\u81ea\u613f\u8d60\u4e0e\u3002\u539f\u544a\u672a\u80fd\u8bc1\u660e\u4e0a\u8ff0\u6d88\u8d39\u662f\u57fa\u4e8e\u5f53\u5730\u98ce\u4fd7\u4e14\u5c5e\u4e8e\u5927\u989d\u8d22\u7269\u7ed9\u4ed8\uff0c\u6545\u5bf9\u4e8e\u8d85\u51fa10,001\u5143\u4ee5\u5916\u7684\u8fd4\u8fd8\u8bf7\u6c42\uff0c\u672c\u9662\u4e0d\u4e88\u652f\u6301\u3002\n4. **\u8fd4\u8fd8\u6761\u4ef6\uff1a**\u56e0\u539f\u3001\u88ab\u544a\u53cc\u65b9\u672a\u529e\u7406\u7ed3\u5a5a\u767b\u8bb0\uff0c\u73b0\u53cc\u65b9\u89e3\u9664\u5a5a\u7ea6\uff0c\u88ab\u544a\u5e94\u5f53\u8fd4\u8fd8\u5df2\u6536\u53d6\u7684\u5f69\u793c\u3002\u8003\u8651\u5230\u53cc\u65b9\u5171\u540c\u4ea4\u5f80\u7684\u65f6\u95f4\u53ca\u5b9e\u9645\u5f00\u652f\u60c5\u51b5\uff0c\u88ab\u544a\u5e94\u5411\u539f\u544a\u8fd4\u8fd8\u73b0\u91d1\u5f69\u793c10,001\u5143\u3002\n\n\u4e8c\u3001 **\u5173\u4e8e\u7cbe\u795e\u635f\u5bb3\u8d54\u507f\u95ee\u9898**\n\u539f\u544a\u4e3b\u5f20\u88ab\u544a\u56e0\u9000\u5a5a\u5bfc\u81f4\u5176\u7cbe\u795e\u53d7\u5230\u6253\u51fb\uff0c\u8981\u6c42\u8d54\u507f2\u4e07\u5143\u3002\u672c\u9662\u8ba4\u4e3a\uff0c\u5a5a\u59fb\u81ea\u7531\u662f\u6c11\u6cd5\u5178\u7684\u57fa\u672c\u539f\u5219\uff0c\u89e3\u9664\u5a5a\u7ea6\u672c\u8eab\u4e0d\u6784\u6210\u4fb5\u6743\u884c\u4e3a\u3002\u539f\u544a\u672a\u80fd\u63d0\u4f9b\u8bc1\u636e\u8bc1\u660e\u88ab\u544a\u5728\u4ea4\u5f80\u8fc7\u7a0b\u4e2d\u5b58\u5728\u4e25\u91cd\u8fdd\u53cd\u9053\u5fb7\u6216\u6cd5\u5f8b\u89c4\u5b9a\u5e76\u9020\u6210\u4e25\u91cd\u7cbe\u795e\u635f\u5bb3\u7684\u6cd5\u5b9a\u60c5\u5f62\uff0c\u6545\u5bf9\u539f\u544a\u63d0\u51fa\u7684\u7cbe\u795e\u635f\u5bb3\u8d54\u507f\u8bf7\u6c42\uff0c\u672c\u9662\u4e0d\u4e88\u652f\u6301\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u96f6\u56db\u5341\u4e8c\u6761\u3001\u300a\u6700\u9ad8\u4eba\u6c11\u6cd5\u9662\u5173\u4e8e\u9002\u7528\u3008\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u3009\u5a5a\u59fb\u5bb6\u5ead\u7f16\u7684\u89e3\u91ca\uff08\u4e00\uff09\u300b\u7b2c\u4e94\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n\u4e00\u3001\u88ab\u544a\u718a\u67d0\u83ca\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\u8fd4\u8fd8\u539f\u544a\u8bb8\u67d0\u661f\u5f69\u793c\u6b3e10,001\u5143\uff1b\n\u4e8c\u3001\u9a73\u56de\u539f\u544a\u8bb8\u67d0\u661f\u7684\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42\u3002\n\n\u5982\u679c\u672a\u6309\u672c\u5224\u51b3\u6307\u5b9a\u7684\u671f\u95f4\u5c65\u884c\u7ed9\u4ed8\u91d1\u94b1\u4e49\u52a1\uff0c\u5e94\u5f53\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u4e8c\u767e\u516d\u5341\u6761\u4e4b\u89c4\u5b9a\uff0c\u52a0\u500d\u652f\u4ed8\u8fdf\u5ef6\u5c65\u884c\u671f\u95f4\u7684\u503a\u52a1\u5229\u606f\u3002\n\u6848\u4ef6\u53d7\u7406\u8d39\u7531\u539f\u3001\u88ab\u544a\u6309\u6bd4\u4f8b\u627f\u62c5\uff08\u5177\u4f53\u91d1\u989d\u7565\uff09\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u6cb3\u5357\u7701\u4fe1\u9633\u5e02\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002\n\n\u5ba1\u5224\u957f\uff1aXXX\n\u4e8c\u3007\u4e8c\u56db\u5e74X\u6708X\u65e5\n\nAnswer: \u4e00\u3001\u88ab\u544a\u718a\u67d0\u83ca\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\u8fd4\u8fd8\u539f\u544a\u8bb8\u67d0\u661f\u5f69\u793c\u6b3e10,001\u5143\uff1b\u4e8c\u3001\u9a73\u56de\u539f\u544a\u8bb8\u67d0\u661f\u7684\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42\uff08\u5305\u62ec\u5176\u4f59\u5f69\u793c\u8fd4\u8fd8\u8bf7\u6c42\u53ca\u7cbe\u795e\u635f\u5bb3\u8d54\u507f\u8bf7\u6c42\uff09\u3002",
        "sub_tasks_text": null
    }
