        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u5a5a\u59fb\u5bb6\u5ead\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u5f90\u67d0\", \"address\": \"\u6e56\u5317\u7701\u949f\u7965\u5e02\", \"representative\": null, \"gender\": \"\u7537\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1987\u5e746\u670827\u65e5\"}, \"defendant\": {\"name\": \"\u6768\u67d0\u5a1f\", \"address\": \"\u6e56\u5317\u7701\u949f\u7965\u5e02\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1989\u5e7410\u670817\u65e5\"}}, \"plaintiff_claim\": [\"\u4f9d\u6cd5\u5224\u4ee4\u88ab\u544a\u5411\u539f\u544a\u8fd4\u8fd8\u5f69\u793c160000\u5143\", \"\u672c\u6848\u7684\u8bc9\u8bbc\u8d39\u3001\u4fdd\u5168\u8d39\u7531\u88ab\u544a\u627f\u62c5\"], \"plaintiff_case_details\": \"\u539f\u544a\u4e0e\u88ab\u544a\u4e8e2022\u5e74\u56fd\u5e86\u671f\u95f4\u901a\u8fc7\u4eb2\u621a\u4ecb\u7ecd\u76f8\u4eb2\u8ba4\u8bc6\uff0c\u4e8e2022\u5e7412\u6708\u4efd\u786e\u5b9a\u604b\u7231\u5173\u7cfb\u3002\u6309\u7167\u88ab\u544a\u63d0\u51fa\u7684\u5f69\u793c\u8981\u6c42\uff0c\u539f\u544a\u59d4\u6258\u7236\u4eb2\u5b59\u67d0\u7965\u5411\u88ab\u544a\u652f\u4ed8\u4e86\u5f69\u793c160000\u5143\uff0c\u5177\u4f53\u660e\u7ec6\u4e3a\uff1a\u4e8e2023\u5e742\u670821\u65e5\u5411\u88ab\u544a\u652f\u4ed8\u4e86\u5f69\u793c100000\u5143\uff0c\u4e8e2023\u5e744\u