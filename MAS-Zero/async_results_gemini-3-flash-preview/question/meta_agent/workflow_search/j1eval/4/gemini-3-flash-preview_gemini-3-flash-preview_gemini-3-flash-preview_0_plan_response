        "example_id": 4,
        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u5a5a\u59fb\u5bb6\u5ead\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u674e\u67d0\", \"address\": \"\u5317\u4eac\u5e02\u4e30\u53f0\u533a\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1979\u5e741\u670828\u65e5\"}, \"defendant\": {\"name\": \"\u4faf\u67d0\u82b3\", \"address\": \"\u6dc4\u535a\u5e02\u4e34\u6dc4\u533a\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1958\u5e745\u670821\u65e5\"}}, \"plaintiff_claim\": [\"\u8bf7\u6c42\u6cd5\u9662\u5224\u4ee4\u7531\u539f\u544a\u7ee7\u627f\u88ab\u7ee7\u627f\u4eba\u540d\u4e0b\u4f4d\u4e8e\u5c71\u4e1c\u7701\u6dc4\u535a\u5e02\u4e34\u6dc4\u533a**\u793e\u533a**\u53f7\u697c**\u5355\u5143**\u5c42**\u53f7\u623f\u5c4b\uff1b\uff08\u623f\u5c4b\u4ef7\u503c\u6682\u4f3010\u4e07\u5143\uff09\", \"\u8bf7\u6c42\u6cd5\u9662\u5224\u4ee4\u539f\u544a\u7ee7\u627f\u88ab\u7ee7\u627f\u4eba\u540d\u4e0b\u7684\u6240\u6709\u94f6\u884c\u5b58\u6b3e1\u4e07\u5143\uff1b\uff08\u4ee5\u5b9e\u9645\u8c03\u53d6\u7684\u91d1\u989d\u4e3a\u51c6\uff09\", \"\u8bf7\u6c42\u6cd5\u9662\u5224\u4ee4\u539f\u544a\u7ee7\u627f\u4e2d\u56fd\u67d0\u67d0\u4fdd\u9669\u80a1\u4efd\u6709\u9650\u516c\u53f8\u7684\u4fdd\u9669\u91d15\u4e07\u5143\", \"\u8bf7\u6c42\u6cd5\u9662\u5224\u4ee4\u539f\u544a\u7ee7\u627f\u88ab\u7ee7\u627f\u4eba\u7684\u4f4f\u623f\u516c\u79ef\u91d11\u4e07\u5143\uff1b\uff08\u4ee5\u5b9e\u9645\u8c03\u53d6\u7684\u91d1\u989d\u4e3a\u51c6\uff09\", \"\u8bf7\u6c42\u6cd5\u9662\u5224\u4ee4\u539f\u544a\u7ee7\u627f\u88ab\u7ee7\u627f\u4eba\u7684\u80a1\u7968\u3001\u56fd\u503a\u3001\u57fa\u91d1\u5171\u8ba11\u4e07\u5143\uff1b\uff08\u4ee5\u5b9e\u9645\u8c03\u53d6\u7684\u91d1\u989d\u4e3a\u51c6\uff09\", \"\u8bf7\u6c42\u6cd5\u9662\u5224\u4ee4\u539f\u544a\u7ee7\u627f\u72ec\u751f\u5b50\u5973\u8d39\u4e00\u6b21\u6027\u8865\u8d341\u4e07\u5143\uff08\u4ee5\u5b9e\u9645\u91d1\u989d\u4e3a\u51c6\uff09\"], \"plaintiff_case_details\": \"\u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u4e8e2022\u5e743\u670811\u65e5\u53bb\u4e16\uff0c\u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u7cfb\u539f\u544a\u674e\u67d0\u7684\u4eb2\u751f\u7236\u4eb2\uff0c\u539f\u544a\u6bcd\u4eb2\u674e\u67d0\u51e4\u4e0e\u539f\u544a\u7236\u4eb2\u4faf\u67d0\u6587\u4e8e1994\u5e741\u670819\u65e5\u8bc9\u8bbc\u8c03\u89e3\u79bb\u5a5a\u3002\u88ab\u7ee7\u627f\u4eba\u79bb\u5f02\u540e\u5e76\u672a\u518d\u5a5a\uff0c\u4ea6\u672a\u80b2\u6709\u5176\u4ed6\u5b50\u5973\u3002\u88ab\u544a\u7cfb\u88ab\u7ee7\u627f\u4eba\u7684\u4eb2\u59b9\u59b9\u3002\u88ab\u7ee7\u627f\u4eba\u53bb\u4e16\u540e\uff0c\u539f\u544a\u7236\u4eb2\u540d\u4e0b\u7684\u6d89\u6848\u623f\u5c4b\u88ab\u544a\u642c\u8fc7\u53bb\u5c45\u4f4f\uff0c\u88ab\u544a\u8ba4\u4e3a\u81ea\u5df1\u5bf9\u623f\u4ea7\u4e5f\u6709\u6743\u5229\u7ee7\u627f\u3002\u7531\u4e8e\u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u751f\u524d\u7684\u8eab\u4efd\u4fe1\u606f\u767b\u8bb0\u9519\u8bef\uff0c\u5bfc\u81f4\u539f\u544a\u65e0\u6cd5\u901a\u8fc7\u6b63\u5e38\u9014\u5f84\u67e5\u660e\u88ab\u7ee7\u627f\u4eba\u7684\u9057\u4ea7\u8303\u56f4\uff0c\u6073\u8bf7\u6cd5\u9662\u4f9d\u6cd5\u8c03\u53d6\u76f8\u5173\u9057\u4ea7\u4fe1\u606f\u3002\u73b0\u88ab\u7ee7\u627f\u4eba\u5df2\u7ecf\u53bb\u4e16\uff0c\u539f\u544a\u4f5c\u4e3a\u552f\u4e00\u7684\u5408\u6cd5\u7ee7\u627f\u4eba\u8981\u6c42\u4f9d\u6cd5\u7ee7\u627f\u7236\u4eb2\u7684\u623f\u5c4b\u3001\u94f6\u884c\u5b58\u6b3e\u3001\u4fdd\u9669\u91d1\u7b49\u9057\u4ea7\u3002\u4e3a\u6b64\uff0c\u5f62\u6210\u8bc9\u8bbc\u3002\", \"defendant_defence\": \"\u539f\u544a\u6240\u6709\u8bc9\u6c42\uff0c\u88ab\u544a\u90fd\u4e0d\u77e5\u60c5\uff0c\u90fd\u5728\u88ab\u7ee7\u627f\u4eba\u624b\u4e2d\uff0c\u623f\u5b50\u88ab\u544a\u4e5f\u672a\u5c45\u4f4f\u5360\u6709\u3002\", \"evidence\": {\"plaintiff_evidence\": {\"evidence_1\": {\"evidence\": \"\u6b7b\u4ea1\u8bc1\u660e\uff1b\u706b\u5316\u8bc1\u660e\uff1b\u8eab\u4efd\u8bc1\u590d\u5370\u4ef6\", \"dispute\": \"\"}, \"evidence_2\": {\"evidence\": \"\uff081994\uff09\u4e34\u6cd5\u9f50\u6c11\u521d\u5b57\u7b2c8\u53f7\", \"dispute\": \"\"}, \"evidence_3\": {\"evidence\": \"\u72ec\u751f\u5b50\u5973\u7236\u6bcd\u5149\u8363\u8bc1\", \"dispute\": \"\"}, \"evidence_4\": {\"evidence\": \"\u4faf\u67d0\u51ef\u6237\u53e3\u6ce8\u9500\u8bc1\u660e\uff1b\u90d1\u67d0\u5170\u6237\u53e3\u6ce8\u9500\u8bc1\u660e\", \"dispute\": \"\"}, \"evidence_5\": {\"evidence\": \"\u4ea7\u6743\u3001\u4ea7\u7c4d\u6863\u6848\u8bc1\u660e\uff1b\u56fd\u6709\u571f\u5730\u4f7f\u7528\u6743\u767b\u8bb0\u67e5\u8be2\u8bc1\u660e\", \"dispute\": \"\"}, \"evidence_6\": {\"evidence\": \"\u4e2d\u56fd\u67d0\u67d0\u4fdd\u9669\u80a1\u4efd\u6709\u9650\u516c\u53f8\u4e07\u80fd\u4fdd\u9669\u4e2a\u4eba\u4fdd\u5355\u5e74\u5ea6\u62a5\u544a\", \"dispute\": \"\"}, \"evidence_7\": {\"evidence\": \"\u674e\u67d0\u5e38\u4f4f\u4eba\u53e3\u767b\u8bb0\u5361\u4e00\u4efd\", \"dispute\": \"\"}, \"evidence_8\": {\"evidence\": \"\u4faf\u67d0\u6587\u751f\u524d1991\u5e7412\u670827\u65e5\u5728\u67d0\u67d0\u77f3\u6cb9\u5316\u5de5\u516c\u53f8\u7684\u4f4f\u623f\u8bc1\", \"dispute\": \"\"}, \"evidence_9\": null, \"evidence_10\": null}, \"defendant_evidence\": {\"evidence_1\": null, \"evidence_2\": null, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null}}, \"other_statement\": {\"plaintiff\": {\"plaintiff_1\": \"\"}, \"defendant\": {\"defendant_1\": \"\u5ead\u5ba1\u4e2d\u88ab\u544a\u4e3b\u5f20\u4e0d\u5b58\u5728\u59a8\u788d\u539f\u544a\u5b9e\u73b0\u6743\u5229\u7684\u60c5\u5f62\uff0c\u539f\u544a\u672a\u63d0\u4ea4\u8bc1\u636e\u8bc1\u5b9e\u88ab\u544a\u5bf9\u88ab\u7ee7\u627f\u4eba\u8d22\u4ea7\u5b58\u5728\u4fb5\u6743\u884c\u4e3a\uff0c\u539f\u544a\u5e94\u627f\u62c5\u4e3e\u8bc1\u4e0d\u80fd\u7684\u4e0d\u5229\u540e\u679c\u3002\"}}}\n",
        "correct_answer": [
            "\u9a73\u56de\u539f\u544a\u674e\u67d0\u7684\u5168\u90e8\u8bc9\u8bbc\u8bf7\u6c42\u3002",
            "\u6848\u4ef6\u53d7\u7406\u8d393300\u5143\uff0c\u7531\u539f\u544a\u674e\u67d0\u8d1f\u62c5\u3002",
            "\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u5c71\u4e1c\u7701\u6dc4\u535a\u5e02\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002"
        ],
        "n": 2,
        "response": "\u4f5c\u4e3a\u5ba1\u5224\u957f\uff0c\u6211\u9700\u8981\u6574\u5408\u524d\u4e09\u4e2a\u5b50\u4efb\u52a1\u7684\u7814\u7a76\u7ed3\u679c\uff0c\u7f16\u5199\u4e00\u4efd\u903b\u8f91\u4e25\u5bc6\u3001\u9002\u7528\u6cd5\u5f8b\u51c6\u786e\u7684\u5224\u51b3\u4e66\u3002\u8bf4\u7406\u90e8\u5206\u9700\u8981\u660e\u786e\uff1a1. \u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u7684\u6b7b\u4ea1\u53ca\u9057\u4ea7\u4e8b\u5b9e\uff1b2. \u539f\u544a\u674e\u67d0\u4f5c\u4e3a\u552f\u4e00\u7b2c\u4e00\u987a\u5e8f\u6cd5\u5b9a\u7ee7\u627f\u4eba\u7684\u8eab\u4efd\u786e\u8ba4\uff1b3. \u88ab\u544a\u4faf\u67d0\u82b3\u4f5c\u4e3a\u7b2c\u4e8c\u987a\u5e8f\u7ee7\u627f\u4eba\uff0c\u5728\u7b2c\u4e00\u987a\u5e8f\u7ee7\u627f\u4eba\u5b58\u5728\u7684\u60c5\u51b5\u4e0b\u4e0d\u4eab\u6709\u7ee7\u627f\u6743\uff1b4. \u5bf9\u5404\u9879\u5177\u4f53\u9057\u4ea7\uff08\u623f\u5c4b\u3001\u5b58\u6b3e\u3001\u4fdd\u9669\u91d1\u3001\u516c\u79ef\u91d1\u3001\u7406\u8d22\u53ca\u8865\u8d34\uff09\u7684\u6743\u5c5e\u5224\u5b9a\u3002\u5224\u51b3\u90e8\u5206\u9700\u9010\u4e00\u56de\u5e94\u539f\u544a\u76846\u9879\u8bc9\u8bf7\uff0c\u5e76\u53c2\u7167\u6cd5\u5f8b\u7a0b\u5e8f\u89c4\u5b9a\u5212\u5206\u8bc9\u8bbc\u8d39\u627f\u62c5\u3002\u8003\u8651\u5230\u6848\u4ef6\u8d77\u56e0\u5305\u542b\u88ab\u7ee7\u627f\u4eba\u8eab\u4efd\u4fe1\u606f\u767b\u8bb0\u9519\u8bef\u7b49\u884c\u653f\u969c\u788d\uff0c\u4e14\u88ab\u544a\u672a\u5b9e\u8d28\u6027\u4fb5\u5360\u9057\u4ea7\uff0c\u8bc9\u8bbc\u8d39\u7684\u627f\u62c5\u9700\u516c\u5e73\u5408\u7406\u3002\n\nAnswer:\u4e00\u3001\u8bf4\u7406\u5185\u5bb9\n\n\u672c\u9662\u8ba4\u4e3a\uff0c\u672c\u6848\u7cfb\u7ee7\u627f\u7ea0\u7eb7\u3002\u6848\u4ef6\u7684\u6838\u5fc3\u4e89\u8bae\u5728\u4e8e\u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u9057\u4ea7\u7684\u5408\u6cd5\u7ee7\u627f\u4eba\u786e\u5b9a\u53ca\u5404\u9879\u9057\u4ea7\u7684\u5f52\u5c5e\u3002\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u4e8c\u5341\u4e00\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u4e8c\u5341\u4e09\u6761\u53ca\u7b2c\u4e00\u5343\u4e00\u767e\u4e8c\u5341\u4e03\u6761\u4e4b\u89c4\u5b9a\uff0c\u7ee7\u627f\u81ea\u88ab\u7ee7\u627f\u4eba\u6b7b\u4ea1\u65f6\u5f00\u59cb\uff1b\u7ee7\u627f\u5f00\u59cb\u540e\uff0c\u6309\u7167\u6cd5\u5b9a\u7ee7\u627f\u529e\u7406\uff1b\u7b2c\u4e00\u987a\u5e8f\u7ee7\u627f\u4eba\u4e3a\u914d\u5076\u3001\u5b50\u5973\u3001\u7236\u6bcd\uff0c\u7b2c\u4e8c\u987a\u5e8f\u7ee7\u627f\u4eba\u4e3a\u5144\u5f1f\u59d0\u59b9\u3001\u7956\u7236\u6bcd\u3001\u5916\u7956\u7236\u6bcd\uff1b\u7ee7\u627f\u5f00\u59cb\u540e\uff0c\u7531\u7b2c\u4e00\u987a\u5e8f\u7ee7\u627f\u4eba\u7ee7\u627f\uff0c\u7b2c\u4e8c\u987a\u5e8f\u7ee7\u627f\u4eba\u4e0d\u7ee7\u627f\u3002\n\n\u9996\u5148\uff0c\u5173\u4e8e\u7ee7\u627f\u4eba\u8eab\u4efd\u7684\u8ba4\u5b9a\u3002\u6839\u636e\u539f\u544a\u63d0\u4ea4\u7684\u6237\u7c4d\u8bc1\u660e\u3001\u79bb\u5a5a\u8c03\u89e3\u4e66\u3001\u7236\u6bcd\u6ce8\u9500\u8bc1\u660e\u7b49\u8bc1\u636e\uff0c\u8db3\u4ee5\u8ba4\u5b9a\u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u4e8e2022\u5e743\u670811\u65e5\u53bb\u4e16\uff0c\u5176\u751f\u524d\u79bb\u5f02\u4e14\u672a\u518d\u5a5a\uff0c\u7236\u6bcd\u5747\u5df2\u5148\u4e8e\u5176\u6b7b\u4ea1\u3002\u539f\u544a\u674e\u67d0\u4f5c\u4e3a\u4faf\u67d0\u6587\u7684\u552f\u4e00\u4eb2\u751f\u5973\u513f\uff0c\u662f\u6cd5\u5f8b\u786e\u5b9a\u7684\u7b2c\u4e00\u987a\u5e8f\u6cd5\u5b9a\u7ee7\u627f\u4eba\u3002\u88ab\u544a\u4faf\u67d0\u82b3\u7cfb\u88ab\u7ee7\u627f\u4eba\u4e4b\u59b9\uff0c\u5c5e\u4e8e\u7b2c\u4e8c\u987a\u5e8f\u7ee7\u627f\u4eba\u3002\u56e0\u672c\u6848\u5b58\u5728\u7b2c\u4e00\u987a\u5e8f\u7ee7\u627f\u4eba\uff0c\u6545\u88ab\u544a\u4faf\u67d0\u82b3\u4e0d\u4eab\u6709\u7ee7\u627f\u6743\u3002\n\n\u5176\u6b21\uff0c\u5173\u4e8e\u9057\u4ea7\u8303\u56f4\u7684\u8ba4\u5b9a\u3002\u6839\u636e\u539f\u544a\u63d0\u4ea4\u7684\u4ea7\u6743\u4ea7\u7c4d\u8bc1\u660e\u3001\u4f4f\u623f\u8bc1\u3001\u4fdd\u5355\u5e74\u5ea6\u62a5\u544a\u3001\u72ec\u751f\u5b50\u5973\u7236\u6bcd\u5149\u8363\u8bc1\u7b49\u8bc1\u636e\uff0c\u53ef\u4ee5\u786e\u8ba4\u4f4d\u4e8e\u5c71\u4e1c\u7701\u6dc4\u535a\u5e02\u4e34\u6dc4\u533a\u6d89\u6848\u623f\u5c4b\u3001\u4fdd\u9669\u91d1\u53ca\u72ec\u751f\u5b50\u5973\u8d39\u4e00\u6b21\u6027\u8865\u8d34\u5c5e\u4e8e\u4faf\u67d0\u6587\u7684\u9057\u4ea7\u3002\u5bf9\u4e8e\u539f\u544a\u4e3b\u5f20\u7684\u94f6\u884c\u5b58\u6b3e\u3001\u4f4f\u623f\u516c\u79ef\u91d1\u3001\u80a1\u7968\u3001\u56fd\u503a\u3001\u57fa\u91d1\u7b49\u9057\u4ea7\uff0c\u867d\u76ee\u524d\u65e0\u786e\u5207\u4f59\u989d\u51ed\u8bc1\uff0c\u4f46\u5c5e\u4e8e\u88ab\u7ee7\u627f\u4eba\u540d\u4e0b\u5408\u6cd5\u8d22\u4ea7\u6743\u76ca\uff0c\u5e94\u7531\u539f\u544a\u4f9d\u6cd5\u7ee7\u627f\uff0c\u5177\u4f53\u6570\u989d\u4ee5\u76f8\u5173\u91d1\u878d\u673a\u6784\u3001\u5355\u4f4d\u5b9e\u9645\u7ed3\u7b97\u4e3a\u51c6\u3002\n\n\u6700\u540e\uff0c\u5173\u4e8e\u88ab\u544a\u63d0\u51fa\u7684\u6297\u8fa9\u3002\u88ab\u544a\u8fa9\u79f0\u672a\u5360\u6709\u6d89\u6848\u623f\u5c4b\u4e14\u5bf9\u9057\u4ea7\u4e0d\u77e5\u60c5\u3002\u672c\u9662\u8ba4\u4e3a\uff0c\u5360\u6709\u4e8b\u5b9e\u7684\u4e89\u8bae\u5e76\u4e0d\u5f71\u54cd\u539f\u544a\u57fa\u4e8e\u6cd5\u5b9a\u7ee7\u627f\u6743\u5bf9\u9057\u4ea7\u6240\u6709\u6743\u7684\u786e\u6743\u3002\u9274\u4e8e\u88ab\u7ee7\u627f\u4eba\u751f\u524d\u8eab\u4efd\u4fe1\u606f\u767b\u8bb0\u9519\u8bef\u5bfc\u81f4\u539f\u544a\u96be\u4ee5\u901a\u8fc7\u975e\u8bc9\u9014\u5f84\u529e\u7406\u7ee7\u627f\uff0c\u539f\u544a\u63d0\u8d77\u8bc9\u8bbc\u5177\u6709\u5fc5\u8981\u6027\u3002\u8003\u8651\u5230\u88ab\u544a\u672a\u63d0\u4ea4\u8bc1\u636e\u8bc1\u660e\u5176\u5bf9\u9057\u4ea7\u5177\u6709\u6cd5\u5b9a\u7ee7\u627f\u6743\uff0c\u4e14\u672c\u6848\u65e8\u5728\u786e\u6743\uff0c\u5224\u51b3\u7ed3\u679c\u5982\u4e0b\uff1a\n\n\u4e8c\u3001\u6700\u7ec8\u5224\u51b3\n\n\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u4e8c\u5341\u4e00\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u4e8c\u5341\u4e03\u6761\uff0c\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u516d\u5341\u4e03\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n1. \u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u540d\u4e0b\u4f4d\u4e8e\u5c71\u4e1c\u7701\u6dc4\u535a\u5e02\u4e34\u6dc4\u533a**\u793e\u533a**\u53f7\u697c**\u5355\u5143**\u5c42**\u53f7\u623f\u5c4b\u7531\u539f\u544a\u674e\u67d0\u7ee7\u627f\uff1b\n2. \u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u540d\u4e0b\u7684\u6240\u6709\u94f6\u884c\u5b58\u6b3e\u7531\u539f\u544a\u674e\u67d0\u7ee7\u627f\uff08\u91d1\u989d\u4ee5\u5b9e\u9645\u8c03\u53d6\u4e3a\u51c6\uff09\uff1b\n3. \u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u540d\u4e0b\u4e2d\u56fd\u67d0\u67d0\u4fdd\u9669\u80a1\u4efd\u6709\u9650\u516c\u53f8\u7684\u4fdd\u9669\u91d1\u7531\u539f\u544a\u674e\u67d0\u7ee7\u627f\uff08\u91d1\u989d\u4ee5\u5b9e\u9645\u8c03\u53d6\u4e3a\u51c6\uff09\uff1b\n4. \u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u540d\u4e0b\u7684\u4f4f\u623f\u516c\u79ef\u91d1\u7531\u539f\u544a\u674e\u67d0\u7ee7\u627f\uff08\u91d1\u989d\u4ee5\u5b9e\u9645\u7ed3\u7b97\u4e3a\u51c6\uff09\uff1b\n5. \u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u540d\u4e0b\u7684\u80a1\u7968\u3001\u56fd\u503a\u3001\u57fa\u91d1\u7531\u539f\u544a\u674e\u67d0\u7ee7\u627f\uff08\u91d1\u989d\u4ee5\u5b9e\u9645\u7ed3\u7b97\u4e3a\u51c6\uff09\uff1b\n6. \u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u4eab\u6709\u7684\u72ec\u751f\u5b50\u5973\u8d39\u4e00\u6b21\u6027\u8865\u8d34\u7531\u539f\u544a\u674e\u67d0\u7ee7\u627f\uff08\u91d1\u989d\u4ee5\u5b9e\u9645\u53d1\u653e\u4e3a\u51c6\uff09\u3002\n\n\u6848\u4ef6\u53d7\u7406\u8d39\u7531\u539f\u544a\u674e\u67d0\u8d1f\u62c5\uff08\u56e0\u6d89\u53ca\u8eab\u4efd\u4fe1\u606f\u66f4\u6b63\u53ca\u6743\u5229\u786e\u8ba4\uff0c\u7531\u53d7\u76ca\u65b9\u627f\u62c5\uff09\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u5c71\u4e1c\u7701\u6dc4\u535a\u5e02\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002",
        "sub_tasks_text": null
    },
