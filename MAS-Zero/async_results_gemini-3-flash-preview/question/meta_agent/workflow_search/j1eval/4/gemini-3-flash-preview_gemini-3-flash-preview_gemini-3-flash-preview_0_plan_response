        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u5a5a\u59fb\u5bb6\u5ead\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u674e\u67d0\", \"address\": \"\u5317\u4eac\u5e02\u4e30\u53f0\u533a\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1979\u5e741\u670828\u65e5\"}, \"defendant\": {\"name\": \"\u4faf\u67d0\u82b3\", \"address\": \"\u6dc4\u535a\u5e02\u4e34\u6dc4\u533a\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1958\u5e745\u670821\u65e5\"}}, \"plaintiff_claim\": [\"\u8bf7\u6c42\u6cd5\u9662\u5224\u4ee4\u7531\u539f\u544a\u7ee7\u627f\u88ab\u7ee7\u627f\u4eba\u540d\u4e0b\u4f4d\u4e8e\u5c71\u4e1c\u7701\u6dc4\u535a\u5e02\u4e34\u6dc4\u533a**\u793e\u533a**\u53f7\u697c**\u5355\u5143**\u5c42**\u53f7\u623f\u5c4b\uff1b\uff08\u623f\u5c4b\u4ef7\u503c\u6682\u4f3010\u4e07\u5143\uff09\", \"\u8bf7\u6c42\u6cd5\u9662\u5224\u4ee4\u539f\u544a\u7ee7\u627f\u88ab\u7ee7\u627f\u4eba\u540d\u4e0b\u7684\u6240\u6709\u94f6\u884c\u5b58\u6b3e1\u4e07\u5143\uff1b\uff08\u4ee5\u5b9e\u9645\u8c03\u53d6\u7684\u91d1\u989d\u4e3a\u51c6\uff09\", \"\u8bf7\u6c42\u6cd5\u9662\u5224\u4ee4\u539f\u544a\u7ee7\u627f\u4e2d\u56fd\u67d0\u67d0\u4fdd\u9669\u80a1\u4efd\u6709\u9650\u516c\u53f8\u7684\u4fdd\u9669\u91d15\u4e07\u5143\", \"\u8bf7\u6c42\u6cd5\u9662\u5224\u4ee4\u539f\u544a\u7e