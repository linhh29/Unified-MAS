        "\u4e00\u3001\u8bf4\u7406\u5185\u5bb9\n\n\u672c\u9662\u8ba4\u4e3a\uff0c\u672c\u6848\u7cfb\u7ee7\u627f\u7ea0\u7eb7\u3002\u6848\u4ef6\u7684\u6838\u5fc3\u4e89\u8bae\u5728\u4e8e\u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u9057\u4ea7\u7684\u5408\u6cd5\u7ee7\u627f\u4eba\u786e\u5b9a\u53ca\u5404\u9879\u9057\u4ea7\u7684\u5f52\u5c5e\u3002\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u4e8c\u5341\u4e00\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u4e8c\u5341\u4e09\u6761\u53ca\u7b2c\u4e00\u5343\u4e00\u767e\u4e8c\u5341\u4e03\u6761\u4e4b\u89c4\u5b9a\uff0c\u7ee7\u627f\u81ea\u88ab\u7ee7\u627f\u4eba\u6b7b\u4ea1\u65f6\u5f00\u59cb\uff1b\u7ee7\u627f\u5f00\u59cb\u540e\uff0c\u6309\u7167\u6cd5\u5b9a\u7ee7\u627f\u529e\u7406\uff1b\u7b2c\u4e00\u987a\u5e8f\u7ee7\u627f\u4eba\u4e3a\u914d\u5076\u3001\u5b50\u5973\u3001\u7236\u6bcd\uff0c\u7b2c\u4e8c\u987a\u5e8f\u7ee7\u627f\u4eba\u4e3a\u5144\u5f1f\u59d0\u59b9\u3001\u7956\u7236\u6bcd\u3001\u5916\u7956\u7236\u6bcd\uff1b\u7ee7\u627f\u5f00\u59cb\u540e\uff0c\u7531\u7b2c\u4e00\u987a\u5e8f\u7ee7\u627f\u4eba\u7ee7\u627f\uff0c\u7b2c\u4e8c\u987a\u5e8f\u7ee7\u627f\u4eba\u4e0d\u7ee7\u627f\u3002\n\n\u9996\u5148\uff0c\u5173\u4e8e\u7ee7\u627f\u4eba\u8eab\u4efd\u7684\u8ba4\u5b9a\u3002\u6839\u636e\u539f\u544a\u63d0\u4ea4\u7684\u6237\u7c4d\u8bc1\u660e\u3001\u79bb\u5a5a\u8c03\u89e3\u4e66\u3001\u7236\u6bcd\u6ce8\u9500\u8bc1\u660e\u7b49\u8bc1\u636e\uff0c\u8db3\u4ee5\u8ba4\u5b9a\u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u4e8e2022\u5e743\u670811\u65e5\u53bb\u4e16\uff0c\u5176\u751f\u524d\u79bb\u5f02\u4e14\u672a\u518d\u5a5a\uff0c\u7236\u6bcd\u5747\u5df2\u5148\u4e8e\u5176\u6b7b\u4ea1\u3002\u539f\u544a\u674e\u67d0\u4f5c\u4e3a\u4faf\u67d0\u6587\u7684\u552f\u4e00\u4eb2\u751f\u5973\u513f\uff0c\u662f\u6cd5\u5f8b\u786e\u5b9a\u7684\u7b2c\u4e00\u987a\u5e8f\u6cd5\u5b9a\u7ee7\u627f\u4eba\u3002\u88ab\u544a\u4faf\u67d0\u82b3\u7cfb\u88ab\u7ee7\u627f\u4eba\u4e4b\u59b9\uff0c\u5c5e\u4e8e\u7b2c\u4e8c\u987a\u5e8f\u7ee7\u627f\u4eba\u3002\u56e0\u672c\u6848\u5b58\u5728\u7b2c\u4e00\u987a\u5e8f\u7ee7\u627f\u4eba\uff0c\u6545\u88ab\u544a\u4faf\u67d0\u82b3\u4e0d\u4eab\u6709\u7ee7\u627f\u6743\u3002\n\n\u5176\u6b21\uff0c\u5173\u4e8e\u9057\u4ea7\u8303\u56f4\u7684\u8ba4\u5b9a\u3002\u6839\u636e\u539f\u544a\u63d0\u4ea4\u7684\u4ea7\u6743\u4ea7\u7c4d\u8bc1\u660e\u3001\u4f4f\u623f\u8bc1\u3001\u4fdd\u5355\u5e74\u5ea6\u62a5\u544a\u3001\u72ec\u751f\u5b50\u5973\u7236\u6bcd\u5149\u8363\u8bc1\u7b49\u8bc1\u636e\uff0c\u53ef\u4ee5\u786e\u8ba4\u4f4d\u4e8e\u5c71\u4e1c\u7701\u6dc4\u535a\u5e02\u4e34\u6dc4\u533a\u6d89\u6848\u623f\u5c4b\u3001\u4fdd\u9669\u91d1\u53ca\u72ec\u751f\u5b50\u5973\u8d39\u4e00\u6b21\u6027\u8865\u8d34\u5c5e\u4e8e\u4faf\u67d0\u6587\u7684\u9057\u4ea7\u3002\u5bf9\u4e8e\u539f\u544a\u4e3b\u5f20\u7684\u94f6\u884c\u5b58\u6b3e\u3001\u4f4f\u623f\u516c\u79ef\u91d1\u3001\u80a1\u7968\u3001\u56fd\u503a\u3001\u57fa\u91d1\u7b49\u9057\u4ea7\uff0c\u867d\u76ee\u524d\u65e0\u786e\u5207\u4f59\u989d\u51ed\u8bc1\uff0c\u4f46\u5c5e\u4e8e\u88ab\u7ee7\u627f\u4eba\u540d\u4e0b\u5408\u6cd5\u8d22\u4ea7\u6743\u76ca\uff0c\u5e94\u7531\u539f\u544a\u4f9d\u6cd5\u7ee7\u627f\uff0c\u5177\u4f53\u6570\u989d\u4ee5\u76f8\u5173\u91d1\u878d\u673a\u6784\u3001\u5355\u4f4d\u5b9e\u9645\u7ed3\u7b97\u4e3a\u51c6\u3002\n\n\u6700\u540e\uff0c\u5173\u4e8e\u88ab\u544a\u63d0\u51fa\u7684\u6297\u8fa9\u3002\u88ab\u544a\u8fa9\u79f0\u672a\u5360\u6709\u6d89\u6848\u623f\u5c4b\u4e14\u5bf9\u9057\u4ea7\u4e0d\u77e5\u60c5\u3002\u672c\u9662\u8ba4\u4e3a\uff0c\u5360\u6709\u4e8b\u5b9e\u7684\u4e89\u8bae\u5e76\u4e0d\u5f71\u54cd\u539f\u544a\u57fa\u4e8e\u6cd5\u5b9a\u7ee7\u627f\u6743\u5bf9\u9057\u4ea7\u6240\u6709\u6743\u7684\u786e\u6743\u3002\u9274\u4e8e\u88ab\u7ee7\u627f\u4eba\u751f\u524d\u8eab\u4efd\u4fe1\u606f\u767b\u8bb0\u9519\u8bef\u5bfc\u81f4\u539f\u544a\u96be\u4ee5\u901a\u8fc7\u975e\u8bc9\u9014\u5f84\u529e\u7406\u7ee7\u627f\uff0c\u539f\u544a\u63d0\u8d77\u8bc9\u8bbc\u5177\u6709\u5fc5\u8981\u6027\u3002\u8003\u8651\u5230\u88ab\u544a\u672a\u63d0\u4ea4\u8bc1\u636e\u8bc1\u660e\u5176\u5bf9\u9057\u4ea7\u5177\u6709\u6cd5\u5b9a\u7ee7\u627f\u6743\uff0c\u4e14\u672c\u6848\u65e8\u5728\u786e\u6743\uff0c\u5224\u51b3\u7ed3\u679c\u5982\u4e0b\uff1a\n\n\u4e8c\u3001\u6700\u7ec8\u5224\u51b3\n\n\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u4e8c\u5341\u4e00\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u4e8c\u5341\u4e03\u6761\uff0c\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u516d\u5341\u4e03\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n1. \u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u540d\u4e0b\u4f4d\u4e8e\u5c71\u4e1c\u7701\u6dc4\u535a\u5e02\u4e34\u6dc4\u533a**\u793e\u533a**\u53f7\u697c**\u5355\u5143**\u5c42**\u53f7\u623f\u5c4b\u7531\u539f\u544a\u674e\u67d0\u7ee7\u627f\uff1b\n2. \u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u540d\u4e0b\u7684\u6240\u6709\u94f6\u884c\u5b58\u6b3e\u7531\u539f\u544a\u674e\u67d0\u7ee7\u627f\uff08\u91d1\u989d\u4ee5\u5b9e\u9645\u8c03\u53d6\u4e3a\u51c6\uff09\uff1b\n3. \u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u540d\u4e0b\u4e2d\u56fd\u67d0\u67d0\u4fdd\u9669\u80a1\u4efd\u6709\u9650\u516c\u53f8\u7684\u4fdd\u9669\u91d1\u7531\u539f\u544a\u674e\u67d0\u7ee7\u627f\uff08\u91d1\u989d\u4ee5\u5b9e\u9645\u8c03\u53d6\u4e3a\u51c6\uff09\uff1b\n4. \u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u540d\u4e0b\u7684\u4f4f\u623f\u516c\u79ef\u91d1\u7531\u539f\u544a\u674e\u67d0\u7ee7\u627f\uff08\u91d1\u989d\u4ee5\u5b9e\u9645\u7ed3\u7b97\u4e3a\u51c6\uff09\uff1b\n5. \u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u540d\u4e0b\u7684\u80a1\u7968\u3001\u56fd\u503a\u3001\u57fa\u91d1\u7531\u539f\u544a\u674e\u67d0\u7ee7\u627f\uff08\u91d1\u989d\u4ee5\u5b9e\u9645\u7ed3\u7b97\u4e3a\u51c6\uff09\uff1b\n6. \u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u4eab\u6709\u7684\u72ec\u751f\u5b50\u5973\u8d39\u4e00\u6b21\u6027\u8865\u8d34\u7531\u539f\u544a\u674e\u67d0\u7ee7\u627f\uff08\u91d1\u989d\u4ee5\u5b9e\u9645\u53d1\u653e\u4e3a\u51c6\uff09\u3002\n\n\u6848\u4ef6\u53d7\u7406\u8d39\u7531\u539f\u544a\u674e\u67d0\u8d1f\u62c5\uff08\u56e0\u6d89\u53ca\u8eab\u4efd\u4fe1\u606f\u66f4\u6b63\u53ca\u6743\u5229\u786e\u8ba4\uff0c\u7531\u53d7\u76ca\u65b9\u627f\u62c5\uff09\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u5c71\u4e1c\u7701\u6dc4\u535a\u5e02\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002": "95% Bootstrap Confidence Interval: (0.0%, 0.0%), Median: 0.0%"
    },
    {
        "\u8bf4\u7406\u5185\u5bb9\uff1a\n\u672c\u9662\u8ba4\u4e3a\uff1a\n\u4e00\u3001\u5173\u4e8e\u7ee7\u627f\u4eba\u8d44\u683c\u7684\u8ba4\u5b9a\u3002\u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u4e8e2022\u5e743\u670811\u65e5\u53bb\u4e16\uff0c\u5176\u9057\u4ea7\u7ee7\u627f\u5e94\u4e88\u5f00\u59cb\u3002\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u4e8c\u5341\u4e03\u6761\u89c4\u5b9a\uff0c\u9057\u4ea7\u7ee7\u627f\u7684\u7b2c\u4e00\u987a\u5e8f\u7ee7\u627f\u4eba\u4e3a\u914d\u5076\u3001\u5b50\u5973\u3001\u7236\u6bcd\u3002\u672c\u6848\u4e2d\uff0c\u539f\u544a\u674e\u67d0\u7cfb\u4faf\u67d0\u6587\u7684\u4eb2\u751f\u5973\u513f\uff0c\u867d\u5176\u6bcd\u674e\u67d0\u51e4\u4e0e\u4faf\u67d0\u6587\u4e8e1994\u5e74\u7ecf\u6cd5\u9662\u8c03\u89e3\u79bb\u5a5a\uff0c\u4f46\u7236\u6bcd\u5b50\u5973\u95f4\u7684\u8840\u7f18\u5173\u7cfb\u4e0d\u56e0\u7236\u6bcd\u79bb\u5a5a\u800c\u6d88\u9664\uff0c\u539f\u544a\u674e\u67d0\u4f5c\u4e3a\u5b50\u5973\u4eab\u6709\u6cd5\u5b9a\u7684\u7b2c\u4e00\u987a\u5e8f\u7ee7\u627f\u6743\u3002\u8bc1\u636e\u663e\u793a\u4faf\u67d0\u6587\u79bb\u5f02\u540e\u672a\u518d\u5a5a\uff0c\u4ea6\u65e0\u5176\u4ed6\u5b50\u5973\uff0c\u4e14\u5176\u7236\u6bcd\u5747\u5df2\u53bb\u4e16\uff0c\u6545\u539f\u544a\u674e\u67d0\u662f\u4faf\u67d0\u6587\u552f\u4e00\u7684\u6cd5\u5b9a\u7b2c\u4e00\u987a\u5e8f\u7ee7\u627f\u4eba\u3002\u88ab\u544a\u4faf\u67d0\u82b3\u4f5c\u4e3a\u4faf\u67d0\u6587\u7684\u59b9\u59b9\uff0c\u7cfb\u7b2c\u4e8c\u987a\u5e8f\u7ee7\u627f\u4eba\uff0c\u5728\u7b2c\u4e00\u987a\u5e8f\u7ee7\u627f\u4eba\u5b58\u5728\u7684\u60c5\u51b5\u4e0b\uff0c\u88ab\u544a\u4e0d\u4eab\u6709\u7ee7\u627f\u6743\u3002\n\u4e8c\u3001\u5173\u4e8e\u9057\u4ea7\u8303\u56f4\u53ca\u88ab\u544a\u7684\u8fa9\u79f0\u3002\u672c\u6848\u6d89\u53ca\u7684\u623f\u5c4b\u3001\u4fdd\u9669\u91d1\u53ca\u72ec\u751f\u5b50\u5973\u8d39\u8865\u8d34\uff0c\u539f\u544a\u5df2\u63d0\u4ea4\u76f8\u5e94\u7684\u6743\u5c5e\u8bc1\u660e\u3001\u4fdd\u5355\u62a5\u544a\u53ca\u8bc1\u4ef6\u4e88\u4ee5\u8bc1\u5b9e\uff0c\u672c\u9662\u4f9d\u6cd5\u4e88\u4ee5\u786e\u8ba4\u3002\u5bf9\u4e8e\u94f6\u884c\u5b58\u6b3e\u3001\u516c\u79ef\u91d1\u53ca\u8bc1\u5238\u8d44\u4ea7\uff0c\u56e0\u88ab\u7ee7\u627f\u4eba\u8eab\u4efd\u4fe1\u606f\u767b\u8bb0\u5b58\u5728\u7455\u75b5\u53ca\u91d1\u878d\u9690\u79c1\u9650\u5236\uff0c\u539f\u544a\u5ba2\u89c2\u4e0a\u96be\u4ee5\u81ea\u884c\u53d6\u8bc1\uff0c\u5176\u7533\u8bf7\u672c\u9662\u4f9d\u6cd5\u8c03\u53d6\u7b26\u5408\u6cd5\u5f8b\u7a0b\u5e8f\uff0c\u88ab\u544a\u4ee5\u539f\u544a\u201c\u4e3e\u8bc1\u4e0d\u80fd\u201d\u4e3a\u7531\u5426\u5b9a\u9057\u4ea7\u7684\u5b58\u5728\uff0c\u7f3a\u4e4f\u6cd5\u5f8b\u4f9d\u636e\u3002\n\u4e09\u3001\u5173\u4e8e\u88ab\u544a\u4e3b\u5f20\u5176\u672a\u5360\u6709\u9057\u4ea7\u7684\u6cd5\u5f8b\u6548\u529b\u3002\u88ab\u544a\u4faf\u67d0\u82b3\u8fa9\u79f0\u5176\u672a\u5b9e\u9645\u5c45\u4f4f\u6216\u5360\u6709\u6d89\u6848\u623f\u5c4b\uff0c\u4e14\u4e0d\u5b58\u5728\u4fb5\u6743\u884c\u4e3a\u3002\u672c\u9662\u8ba4\u4e3a\uff0c\u7ee7\u627f\u7ea0\u7eb7\u7684\u6838\u5fc3\u5728\u4e8e\u786e\u5b9a\u7ee7\u627f\u6743\u5f52\u5c5e\u53ca\u9057\u4ea7\u4efd\u989d\uff0c\u539f\u544a\u4f5c\u4e3a\u552f\u4e00\u5408\u6cd5\u7ee7\u627f\u4eba\uff0c\u5176\u884c\u4f7f\u7ee7\u627f\u6743\u3001\u8981\u6c42\u786e\u8ba4\u9057\u4ea7\u5f52\u5c5e\uff0c\u5e76\u4e0d\u4ee5\u88ab\u544a\u662f\u5426\u5b9e\u9645\u5360\u6709\u9057\u4ea7\u6216\u662f\u5426\u5b9e\u65bd\u4fb5\u6743\u884c\u4e3a\u4e3a\u524d\u63d0\u3002\u88ab\u544a\u7684\u8fa9\u79f0\u7406\u7531\u4e0d\u80fd\u6210\u4e3a\u963b\u788d\u539f\u544a\u4f9d\u6cd5\u7ee7\u627f\u5176\u7236\u4eb2\u9057\u4ea7\u7684\u6cd5\u5b9a\u4e8b\u7531\u3002\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u539f\u544a\u674e\u67d0\u8981\u6c42\u7ee7\u627f\u4faf\u67d0\u6587\u540d\u4e0b\u7684\u623f\u5c4b\u3001\u94f6\u884c\u5b58\u6b3e\u3001\u4fdd\u9669\u91d1\u3001\u4f4f\u623f\u516c\u79ef\u91d1\u3001\u80a1\u7968\u3001\u56fd\u503a\u3001\u57fa\u91d1\u53ca\u72ec\u751f\u5b50\u5973\u8d39\u8865\u8d34\u7b49\u5168\u90e8\u9057\u4ea7\u7684\u8bc9\u8bbc\u8bf7\u6c42\uff0c\u7b26\u5408\u6cd5\u5f8b\u89c4\u5b9a\uff0c\u672c\u9662\u4e88\u4ee5\u652f\u6301\u3002\n\n\u6700\u7ec8\u5224\u51b3\uff1a\n\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u4e8c\u5341\u4e00\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u4e8c\u5341\u4e8c\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u4e8c\u5341\u4e09\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u4e8c\u5341\u4e03\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\u4e00\u3001\u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u540d\u4e0b\u4f4d\u4e8e\u5c71\u4e1c\u7701\u6dc4\u535a\u5e02\u4e34\u6dc4\u533a**\u793e\u533a**\u53f7\u697c**\u5355\u5143**\u5c42**\u53f7\u623f\u5c4b\u7531\u539f\u544a\u674e\u67d0\u7ee7\u627f\uff1b\n\u4e8c\u3001\u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u540d\u4e0b\u7684\u94f6\u884c\u5b58\u6b3e\uff08\u4ee5\u5b9e\u9645\u8c03\u53d6\u7684\u91d1\u989d\u4e3a\u51c6\uff09\u7531\u539f\u544a\u674e\u67d0\u7ee7\u627f\uff1b\n\u4e09\u3001\u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u5728\u4e2d\u56fd\u67d0\u67d0\u4fdd\u9669\u80a1\u4efd\u6709\u9650\u516c\u53f8\u7684\u4fdd\u9669\u91d1\uff08\u4ee5\u5b9e\u9645\u8c03\u53d6\u7684\u91d1\u989d\u4e3a\u51c6\uff09\u7531\u539f\u544a\u674e\u67d0\u7ee7\u627f\uff1b\n\u56db\u3001\u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u540d\u4e0b\u7684\u4f4f\u623f\u516c\u79ef\u91d1\uff08\u4ee5\u5b9e\u9645\u8c03\u53d6\u7684\u91d1\u989d\u4e3a\u51c6\uff09\u7531\u539f\u544a\u674e\u67d0\u7ee7\u627f\uff1b\n\u4e94\u3001\u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u540d\u4e0b\u7684\u80a1\u7968\u3001\u56fd\u503a\u3001\u57fa\u91d1\uff08\u4ee5\u5b9e\u9645\u8c03\u53d6\u7684\u91d1\u989d\u4e3a\u51c6\uff09\u7531\u539f\u544a\u674e\u67d0\u7ee7\u627f\uff1b\n\u516d\u3001\u88ab\u7ee7\u627f\u4eba\u4faf\u67d0\u6587\u4eab\u6709\u7684\u72ec\u751f\u5b50\u5973\u8d39\u4e00\u6b21\u6027\u8865\u8d34\uff08\u4ee5\u5b9e\u9645\u91d1\u989d\u4e3a\u51c6\uff09\u7531\u539f\u544a\u674e\u67d0\u7ee7\u627f\u3002\n\u6848\u4ef6\u53d7\u7406\u8d39\u7531\u539f\u544a