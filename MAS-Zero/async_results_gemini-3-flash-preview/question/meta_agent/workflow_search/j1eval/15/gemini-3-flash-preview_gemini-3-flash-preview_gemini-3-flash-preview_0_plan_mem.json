        "\u6cb3\u5317\u7701\u9999\u6cb3\u53bf\u4eba\u6c11\u6cd5\u9662\n\u6c11\u4e8b\u5224\u51b3\u4e66\n\n\uff082023\uff09\u51801024\u6c11\u521dXXXX\u53f7\n\n\u539f\u544a\uff1a\u5317\u4eac\u67d0\u67d0\u96c6\u56e2\u6709\u9650\u516c\u53f8\uff0c\u4f4f\u6240\u5730\u5317\u4eac\u5e02\u5927\u5174\u533a\u3002\n\u6cd5\u5b9a\u4ee3\u8868\u4eba\uff1a\u9a6c\u67d0\u8363\u3002\n\n\u88ab\u544a\uff1a\u9999\u6cb3\u53bf\u67d0\u67d0\u623f\u5730\u4ea7\u5f00\u53d1\u6709\u9650\u516c\u53f8\uff0c\u4f4f\u6240\u5730\u6cb3\u5317\u7701\u9999\u6cb3\u53bf\uff08\u534e\u590f\u57ce\u5e02\uff09\u3002\n\u6cd5\u5b9a\u4ee3\u8868\u4eba\uff1a\u5415\u67d0\u519b\u3002\n\n\u539f\u544a\u5317\u4eac\u67d0\u67d0\u96c6\u56e2\u6709\u9650\u516c\u53f8\uff08\u4ee5\u4e0b\u7b80\u79f0\u5317\u4eac\u67d0\u67d0\u516c\u53f8\uff09\u4e0e\u88ab\u544a\u9999\u6cb3\u53bf\u67d0\u67d0\u623f\u5730\u4ea7\u5f00\u53d1\u6709\u9650\u516c\u53f8\uff08\u4ee5\u4e0b\u7b80\u79f0\u9999\u6cb3\u67d0\u67d0\u516c\u53f8\uff09\u7269\u6743\u7ea0\u7eb7\uff08\u7968\u636e\u5229\u76ca\u8fd4\u8fd8\u8bf7\u6c42\u6743\u7ea0\u7eb7\uff09\u4e00\u6848\uff0c\u672c\u9662\u53d7\u7406\u540e\uff0c\u4f9d\u6cd5\u9002\u7528\u7b80\u6613\u7a0b\u5e8f\u516c\u5f00\u5f00\u5ead\u8fdb\u884c\u4e86\u5ba1\u7406\u3002\u672c\u6848\u73b0\u5df2\u5ba1\u7406\u7ec8\u7ed3\u3002\n\n\u539f\u544a\u8bc9\u79f0\uff1a2016\u5e74\u539f\u88ab\u544a\u7b7e\u8ba2\u300a\u91c7\u8d2d\u5408\u540c\u300b\uff0c\u88ab\u544a\u4e8e2020\u5e7410\u670829\u65e5\u5411\u539f\u544a\u4ea4\u4ed8\u4e00\u5f20\u91d1\u989d\u4e3a300,000\u5143\u7684\u7535\u5b50\u5546\u4e1a\u627f\u5151\u6c47\u7968\uff08\u7968\u53f7\uff1a230810000530120201030749187\uff09\u652f\u4ed8\u8d27\u6b3e\u3002\u539f\u544a\u540e\u5c06\u7968\u636e\u80cc\u4e66\u8f6c\u8ba9\u7ed9\u5317\u4eac\u67d0\u67d0\u5149\u7535\u6c14\u6709\u9650\u516c\u53f8\uff08\u4ee5\u4e0b\u7b80\u79f0\u5149\u7535\u6c14\u516c\u53f8\uff09\u3002\u6c47\u7968\u5230\u671f\u540e\u65e0\u6cd5\u627f\u5151\uff0c\u5149\u7535\u6c14\u516c\u53f8\u901a\u8fc7\u8bc9\u8bbc\u8981\u6c42\u539f\u544a\u652f\u4ed8\u8d27\u6b3e\u5e76\u83b7\u6cd5\u9662\u652f\u6301\u3002\u56e0\u7968\u636e\u6743\u5229\u5df2\u8fc7\u65f6\u6548\uff0c\u539f\u544a\u4f9d\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u7968\u636e\u6cd5\u300b\u7b2c\u5341\u516b\u6761\u8bf7\u6c42\u88ab\u544a\u652f\u4ed8\u7968\u636e\u91d1\u989d\u76f8\u5f53\u7684\u5229\u76ca300,000\u5143\u5e76\u627f\u62c5\u8bc9\u8bbc\u8d39\u3002\n\n\u88ab\u544a\u8fa9\u79f0\uff1a1. \u539f\u544a\u975e\u7968\u636e\u6700\u7ec8\u6301\u7968\u4eba\uff0c\u4e14\u672a\u8bc1\u660e\u5df2\u5411\u5149\u7535\u6c14\u516c\u53f8\u5b9e\u9645\u6e05\u507f\uff0c\u672a\u53d6\u5f97\u518d\u8ffd\u7d22\u6743\uff1b2. \u7968\u636e\u7cfb\u7edf\u663e\u793a\u6700\u7ec8\u6301\u7968\u4eba\u4e3a\u6848\u5916\u4eba\uff0c\u539f\u544a\u65e0\u6743\u4e3b\u5f20\u5229\u76ca\u8fd4\u8fd8\uff1b3. \u82e5\u5224\u4ee4\u88ab\u544a\u627f\u62c5\u8d23\u4efb\uff0c\u539f\u544a\u5e94\u9000\u56de\u7968\u636e\u4ee5\u9632\u53cc\u91cd\u652f\u4ed8\u98ce\u9669\u3002\n\n\u7ecf\u5ba1\u7406\u67e5\u660e\uff1a2016\u5e74\uff0c\u539f\u3001\u88ab\u544a\u7b7e\u8ba2\u300a\u5927\u8fd0\u6cb3\u5b54\u96c0\u57ce7.3\u671f\u914d\u7535\u7bb1\u3001\u67dc\u91c7\u8d2d\u5408\u540c\u300b\u30022020\u5e7410\u670829\u65e5\uff0c\u88ab\u544a\u51fa\u5177\u6d89\u6848\u6c47\u7968\uff0c\u91d1\u989d300,000\u5143\uff0c\u5230\u671f\u65e52021\u5e7410\u670829\u65e5\u3002\u539f\u544a\u4e8e2020\u5e7412\u670816\u65e5\u80cc\u4e66\u8f6c\u8ba9\u7ed9\u5149\u7535\u6c14\u516c\u53f8\u3002\u6c47\u7968\u5230\u671f\u540e\u672a\u83b7\u5151\u4ed8\u3002\u53e6\u67e5\u660e\uff0c\uff082022\uff09\u4eac0106\u6c11\u521d3400\u53f7\u6c11\u4e8b\u5224\u51b3\u4e66\u5224\u4ee4\u5317\u4eac\u67d0\u67d0\u516c\u53f8\u5411\u5149\u7535\u6c14\u516c\u53f8\u652f\u4ed8\u8d27\u6b3e\u3002\u76ee\u524d\uff0c\u6d89\u6848\u7968\u636e\u7cfb\u7edf\u663e\u793a\u7684\u6700\u7ec8\u6301\u7968\u4eba\u4e3a\u6848\u5916\u4eba\uff0c\u4e14\u65e0\u8ffd\u7d22\u6e05\u507f\u8bb0\u5f55\u3002\n\n\u672c\u9662\u8ba4\u4e3a\uff1a\u672c\u6848\u4e89\u8bae\u7126\u70b9\u5728\u4e8e\u539f\u544a\u662f\u5426\u4eab\u6709\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u7968\u636e\u6cd5\u300b\u7b2c\u5341\u516b\u6761\u89c4\u5b9a\u7684\u7968\u636e\u5229\u76ca\u8fd4\u8fd8\u8bf7\u6c42\u6743\u3002\u8be5\u6cd5\u6761\u89c4\u5b9a\uff0c\u6301\u7968\u4eba\u56e0\u8d85\u8fc7\u7968\u636e\u6743\u5229\u65f6\u6548\u800c\u4e27\u5931\u7968\u636e\u6743\u5229\u7684\uff0c\u53ef\u4ee5\u8bf7\u6c42\u51fa\u7968\u4eba\u8fd4\u8fd8\u5176\u4e0e\u672a\u652f\u4ed8\u7684\u7968\u636e\u91d1\u989d\u76f8\u5f53\u7684\u5229\u76ca\u3002\u539f\u544a\u4f5c\u4e3a\u4e2d\u95f4\u80cc\u4e66\u4eba\uff0c\u5728\u7968\u636e\u6743\u5229\u5931\u6548\u65f6\u5e76\u975e\u7968\u636e\u6301\u6709\u4eba\u3002\u5176\u6b32\u884c\u4f7f\u8be5\u9879\u6743\u5229\uff0c\u5fc5\u987b\u8bc1\u660e\u5176\u56e0\u88ab\u8ffd\u7d22\u800c\u5b9e\u9645\u5c65\u884c\u4e86\u6e05\u507f\u4e49\u52a1\uff0c\u4ece\u800c\u91cd\u65b0\u627f\u53d7\u4e86\u7968\u636e\u5229\u76ca\u635f\u5931\u3002\u867d\u7136\u539f\u544a\u63d0\u4ea4\u4e86\u76f8\u5173\u5224\u51b3\u4e66\u8bc1\u660e\u5176\u5b58\u5728\u4ed8\u6b3e\u4e49\u52a1\uff0c\u4f46\u5e76\u672a\u63d0\u4ea4\u94f6\u884c\u8f6c\u8d26\u6d41\u6c34\u3001\u6536\u636e\u6216\u6cd5\u9662\u6267\u884c\u7ed3\u6848\u8bc1\u660e\u7b49\u8bc1\u636e\u8bc1\u5b9e\u5176\u5df2\u5b9e\u9645\u5c65\u884c\u5224\u51b3\u5e76\u652f\u4ed8\u4e86300,000\u5143\u3002\u5728\u672a\u8bc1\u660e\u5b9e\u9645\u635f\u5931\u53d1\u751f\u7684\u60c5\u51b5\u4e0b\uff0c\u539f\u544a\u4e3b\u5f20\u8fd4\u8fd8\u7968\u636e\u5229\u76ca\u7684\u8bc1\u636e\u4e0d\u8db3\uff0c\u672c\u9662\u4e0d\u4e88\u652f\u6301\u3002\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u7968\u636e\u6cd5\u300b\u7b2c\u5341\u516b\u6761\uff0c\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u516d\u5341\u4e03\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n\u9a73\u56de\u539f\u544a\u5317\u4eac\u67d0\u67d0\u96c6\u56e2\u6709\u9650\u516c\u53f8\u7684\u8bc9\u8bbc\u8bf7\u6c42\u3002\n\n\u6848\u4ef6\u53d7\u7406\u8d39XXXX\u5143\uff0c\u7531\u539f\u544a\u5317\u4eac\u67d0\u67d0\u96c6\u56e2\u6709\u9650\u516c\u53f8\u8d1f\u62c5\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u6cb3\u5317\u7701\u5eca\u574a\u5e02\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002\n\n\u5ba1\u5224\u957f\uff1a XXX\n\u4e8c\u3007\u4e8c\u4e09\u5e74X\u6708X\u65e5\n\u4e66\u8bb0\u5458\uff1a XXX\n\n": "95% Bootstrap Confidence Interval: (0.0%, 0.0%), Median: 0.0%"
    },
    {
        "\u5317\u4eac\u5e02\u5927\u5174\u533a\u4eba\u6c11\u6cd5\u9662\n\u6c11\u4e8b\u5224\u51b3\u4e66\n\n\uff08202X\uff09\u4eac0115\u6c11\u521dXXXX\u53f7\n\n\u539f\u544a\uff1a\u5317\u4eac\u67d0\u67d0\u96c6\u56e2\u6709\u9650\u516c\u53f8\uff0c\u4f4f\u6240\u5730\u5317\u4eac\u5e02\u5927\u5174\u533a\u3002 \n\u6cd5\u5b9a\u4ee3\u8868\u4eba\uff1a\u9a6c\u67d0\u8363\u3002\n\n\u88ab\u544a\uff1a\u9999\u6cb3\u53bf\u67d0\u67d0\u623f\u5730\u4ea7\u5f00\u53d1\u6709\u9650\u516c\u53f8\uff0c\u4f4f\u6240\u5730\u6cb3\u5317\u7701\u9999\u6cb3\u53bf\uff08\u534e\u590f\u57ce\u5e02\uff09\u3002\n\u6cd5\u5b9a\u4ee3\u8868\u4eba\uff1a\u5415\u67d0\u519b\u3002\n\n\u539f\u544a\u5317\u4eac\u67d0\u67d0\u96c6\u56e2\u6709\u9650\u516c\u53f8\u4e0e\u88ab\u544a\u9999\u6cb3\u53bf\u67d0\u67d0\u623f\u5730\u4ea7\u5f00\u53d1\u6709\u9650\u516c\u53f8\u7269\u6743\u7ea0\u7eb7\u4e00\u6848\uff0c\u672c\u9662\u7acb\u6848\u540e\uff0c\u4f9d\u6cd5\u9002\u7528\u7b80\u6613\u7a0b\u5e8f\u516c\u5f00\u5f00\u5ead\u8fdb\u884c\u4e86\u5ba1\u7406\u3002\u672c\u6848\u73b0\u5df2\u5ba1\u7406\u7ec8\u7ed3\u3002\n\n\u539f\u544a\u5317\u4eac\u67d0\u67d0\u96c6\u56e2\u6709\u9650\u516c\u53f8\u5411\u672c\u9662\u63d0\u51fa\u8bc9\u8bbc\u8bf7\u6c42\uff1a1. \u5224\u4ee4\u88ab\u544a\u5411\u539f\u544a\u652f\u4ed8\u7968\u636e\u91d1\u989d\u76f8\u5f53\u7684\u5229\u76ca300,000\u5143\uff1b2. \u5224\u4ee4\u88ab\u544a\u627f\u62c5\u672c\u6848\u8bc9\u8bbc\u8d39\u7528\u3002\n\u4e8b\u5b9e\u548c\u7406\u7531\uff1a\u539f\u88ab\u544a\u4e8e2016\u5e74\u7b7e\u8ba2\u300a\u91c7\u8d2d\u5408\u540c\u300b\u30022020\u5e74\u88ab\u544a\u5411\u539f\u544a\u4ea4\u4ed8\u91d1\u989d300,000\u5143\u7684\u7535\u5b50\u5546\u4e1a\u627f\u5151\u6c47\u7968\uff08\u7968\u53f7\uff1a230810000530120201030749187\uff09\u7528\u4e8e\u652f\u4ed8\u8d27\u6b3e\u3002\u539f\u544a\u80cc\u4e66\u7ed9\u5317\u4eac\u67d0\u67d0\u5149\u7535\u6c14\u6709\u9650\u516c\u53f8\uff0c\u540e\u7968\u636e\u65e0\u6cd5\u627f\u5151\u4e14\u6743\u5229\u8fc7\u65f6\u6548\u3002\u539f\u544a\u56e0\u88ab\u8ffd\u7d22\u5df2\u88ab\u5224\u4ee4\u627f\u62c5\u652f\u4ed8\u4e49\u52a1\u3002\u73b0\u4f9d\u636e\u300a\u7968\u636e\u6cd5\u300b\u7b2c\u5341\u516b\u6761\u4e3b\u5f20\u6743\u5229\u3002\n\n\u88ab\u544a\u9999\u6cb3\u53bf\u67d0\u67d0\u623f\u5730\u4ea7\u5f00\u53d1\u6709\u9650\u516c\u53f8\u8fa9\u79f0\uff1a\u539f\u544a\u975e\u7968\u636e\u6700\u7ec8\u6301\u7968\u4eba\uff0c\u672a\u8bc1\u660e\u5df2\u5b9e\u9645\u6e05\u507f\uff0c\u4e0d\u5177\u5907\u8ffd\u7d22\u6743\u3002\u82e5\u5224\u4ee4\u627f\u62c5\u8d23\u4efb\uff0c\u539f\u544a\u5e94\u914d\u5408\u5728\u7cfb\u7edf\u4e2d\u9000\u56de\u7968\u636e\u4ee5\u9632\u53cc\u91cd\u652f\u4ed8\u3002\n\n\u672c\u9662\u7ecf\u5ba1\u7406\u8ba4\u5b9a\uff1a\u6848\u6d89\u7968\u636e\u5230\u671f\u540e\u672a\u83b7\u627f\u5151\u4e14\u5df2\u8fc7\u7968\u636e\u6743\u5229\u65f6\u6548\u3002\u539f\u544a\u867d\u80cc\u4e66\u8f6c\u8ba9\u8be5\u7968\u636e\uff0c\u4f46\u5317\u4eac\u67d0\u67d0\u5149\u7535\u6c14\u6709\u9650\u516c\u53f8\u5df2\u901a\u8fc7\u8bc9\u8bbc\u5411\u539f\u544a\u4e3b\u5f20\u8d27\u6b3e\uff0c\uff082022\uff09\u4eac0106\u6c11\u521d3400\u53f7\u5224\u51b3\u4e66\u786e\u8ba4\u4e86\u539f\u544a\u7684\u652f\u4ed8\u4e49\u52a1\u3002\u88ab\u544a\u4f5c\u4e3a\u51fa\u7968\u4eba\uff0c\u5728\u57fa\u7840\u5408\u540c\u9879\u4e0b\u7684\u4ed8\u6b3e\u4e49\u52a1\u672a\u5b9e\u9645\u5c65\u884c\uff0c\u4ecd\u5360\u6709\u4e0e\u7968\u636e\u91d1\u989d\u76f8\u5f53\u7684\u5229\u76ca\u3002\n\n\u672c\u9662\u8ba4\u4e3a\uff1a\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u7968\u636e\u6cd5\u300b\u7b2c\u5341\u516b\u6761\uff0c\u6301\u7968\u4eba\u56e0\u8d85\u8fc7\u7968\u636e\u6743\u5229\u65f6\u6548\u800c\u4e27\u5931\u7968\u636e\u6743\u5229\u7684\uff0c\u4ecd\u4eab\u6709\u6c11\u4e8b\u6743\u5229\uff0c\u53ef\u4ee5\u8bf7\u6c42\u51fa\u7968\u4eba\u8fd4\u8fd8\u5176\u4e0e\u672a\u652f\u4ed8\u7684\u7968\u636e\u91d1\u989d\u76f8\u5f53\u7684\u5229\u76ca\u3002\u539f\u544a\u867d\u975e\u7cfb\u7edf\u6700\u7ec8\u6301\u7968\u4eba\uff0c\u4f46\u5176\u5b9e\u9645\u627f\u62c5\u4e86\u7968\u636e\u4e0d\u83b7\u652f\u4ed8\u7684\u8d22\u52a1\u635f\u5931\uff0c\u7cfb\u8be5\u5229\u76ca\u8fd4\u8fd8\u8bf7\u6c42\u6743\u7684\u9002\u683c\u6743\u5229\u4eba\u3002\u88ab\u544a\u5173\u4e8e\u53cc\u91cd\u652f\u4ed8\u98ce\u9669\u7684\u6297\u8fa9\u5177\u6709\u5408\u7406\u6027\uff0c\u539f\u544a\u5e94\u914d\u5408\u529e\u7406\u76f8\u5173\u7968\u636e\u6838\u9500\u624b\u7eed\u3002\n\n\u5224\u51b3\u5982\u4e0b\uff1a\n\u4e00\u3001\u88ab\u544a\u9999\u6cb3\u53bf\u67d0\u67d0\u623f\u5730\u4ea7\u5f00\u53d1\u6709\u9650\u516c\u53f8\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\u5411\u539f\u544a\u5317\u4eac\u67d0\u67d0\u96c6\u56e2\u6709\u9650\u516c\u53f8\u8fd4\u8fd8\u7968\u636e\u5229\u76ca300,000\u5143\uff1b\n\u4e8c\u3001\u539f\u544a\u5317\u4eac\u67d0\u67d0\u96c6\u56e2\u6709\u9650\u516c\u53f8\u5e94\u4e8e\u672c\u5224\u51b3\u751f\u6548\u540e\uff0c\u914d\u5408\u88ab\u544a\u9999\u6cb3\u53bf\u67d0\u67d0\u623f\u5730\u4ea7\u5f00\u53d1\u6709\u9650\u516c\u53f8\u5728\u7535\u5b50\u5546\u4e1a\u6c47\u7968\u7cfb\u7edf\u4e2d\u529e\u7406\u6848\u6d89\u7968\u636e\uff08\u7968\u53f7230810000530120201030749187\uff09\u7684\u9000\u56de\u3001\u6ce8\u9500\u6216\u76f8\u5173\u7684\u6743\u5229\u56de\u8f6c\u64cd\u4f5c\uff1b\n\u4e09\u3001\u9a73\u56de\u539f\u3001\u88ab\u544a\u7684\u5176\u4ed6\u8bc9\u8fa9\u4e3b\u5f20\u3002\n\n\u5982\u679c\u88ab\u544a\u672a\u6309\u672c\u5224\u51b3\u6307\u5b9a\u7684\u671f\u95f4\u5c65\u884c\u7ed9\u4ed8\u91d1\u94b1\u4e49\u52a1\uff0c\u5e94\u5f53\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u4e8c\u767e\u516d\u5341\u6761\u4e4b\u89c4\u5b9a\uff0c\u52a0\u500d\u652f\u4ed8\u8fdf\u5ef6\u5c65\u884c\u671f\u95f4\u7684\u503a\u52a1\u5229\u606f\u3002\n\n\u6848\u4ef6\u53d7\u7406\u8d39\u7531\u88ab\u544a\u8d1f\u62c5\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u5317\u4eac\u5e02\u7b2c\u4e00\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002\n\n\u5ba1\u5224\u957f\uff1aXXX\n\u4e8c\u3007\u4e8cX\u5e74X\u6708X\u65e5\n\u4e66\u8bb0\u5458\uff1aXXX": "95% Bootstrap Confidence Interval: (0.0%, 0.0%), Median: 0.0%"
    },
