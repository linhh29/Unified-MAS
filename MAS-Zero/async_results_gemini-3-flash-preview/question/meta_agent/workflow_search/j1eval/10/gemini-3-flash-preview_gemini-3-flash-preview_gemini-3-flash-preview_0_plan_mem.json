        "\u6cb3\u5357\u7701\u56fa\u59cb\u53bf\u4eba\u6c11\u6cd5\u9662\n\u6c11\u4e8b\u5224\u51b3\u4e66\n\n\uff082024\uff09\u8c6b1525\u6c11\u521dXXXX\u53f7\n\n\u539f\u544a\uff1a\u8bb8\u67d0\u661f\uff0c\u7537\uff0c2001\u5e741\u670819\u65e5\u51fa\u751f\uff0c\u6c49\u65cf\uff0c\u4f4f\u6cb3\u5357\u7701\u56fa\u59cb\u53bf\u3002\n\u88ab\u544a\uff1a\u718a\u67d0\u83ca\uff0c\u5973\uff0c2001\u5e744\u670826\u65e5\u51fa\u751f\uff0c\u6c49\u65cf\uff0c\u4f4f\u6cb3\u5357\u7701\u56fa\u59cb\u53bf\u3002\n\n\u539f\u544a\u8bb8\u67d0\u661f\u4e0e\u88ab\u544a\u718a\u67d0\u83ca\u5a5a\u7ea6\u8d22\u4ea7\u7ea0\u7eb7\u4e00\u6848\uff0c\u672c\u9662\u53d7\u7406\u540e\uff0c\u4f9d\u6cd5\u7531\u5ba1\u5224\u5458\u72ec\u4efb\u5ba1\u5224\uff0c\u516c\u5f00\u5f00\u5ead\u8fdb\u884c\u4e86\u5ba1\u7406\u3002\u672c\u6848\u73b0\u5df2\u5ba1\u7406\u7ec8\u7ed3\u3002\n\n\u539f\u544a\u8bc9\u79f0\uff1a\u539f\u3001\u88ab\u544a\u7ecf\u4eba\u4ecb\u7ecd\u8ba4\u8bc6\u8ba2\u5a5a\u30022023\u5e746\u6708\u81f32024\u5e748\u6708\u95f4\uff0c\u539f\u544a\u53ca\u7236\u6bcd\u4e3a\u88ab\u544a\u652f\u4ed8\u5f69\u793c\u53ca\u5404\u9879\u8d39\u7528\u5171\u8ba1102,541\u5143\u3002\u540e\u88ab\u544a\u591a\u6b21\u53cd\u590d\u5e76\u8981\u6c42\u9000\u5a5a\uff0c\u4e14\u4e0d\u9000\u8fd8\u5f69\u793c\uff0c\u5bfc\u81f4\u539f\u544a\u7cbe\u795e\u53d7\u635f\u3002\u6545\u8bc9\u8bf7\uff1a1.\u5224\u4ee4\u88ab\u544a\u9000\u8fd8\u5f69\u793c102,541\u5143\uff1b2.\u5224\u4ee4\u88ab\u544a\u8d54\u507f\u7cbe\u795e\u635f\u5bb3\u629a\u6170\u91d120,000\u5143\uff1b3.\u8bc9\u8bbc\u8d39\u7531\u88ab\u544a\u627f\u62c5\u3002\n\n\u88ab\u544a\u8fa9\u79f0\uff1a\u539f\u544a\u4e3b\u5f20\u7684\u91d1\u989d\u5305\u542b\u5927\u91cf\u604b\u7231\u671f\u95f4\u7684\u65e5\u5e38\u5f00\u652f\u3002\u88ab\u544a\u5b9e\u9645\u6536\u5230\u7684\u5f69\u793c\u4ec5\u4e3a10,001\u5143\u548c\u6212\u6307\u4e00\u679a\u30028,000\u5143\u7ea2\u5305\u7cfb\u7ed9\u4eb2\u621a\u7684\uff0c\u5e76\u975e\u88ab\u544a\u4e2a\u4eba\u6536\u53d6\u3002\u5176\u4ed6\u6d88\u8d39\u5c5e\u4e8e\u53cc\u65b9\u793c\u5c1a\u5f80\u6765\u53ca\u5171\u540c\u6d88\u8d39\uff0c\u4e0d\u5e94\u8fd4\u8fd8\u3002\u6212\u6307\u5df2\u5f53\u5ead\u8fd4\u8fd8\uff0c\u88ab\u544a\u540c\u610f\u8fd4\u8fd810,001\u5143\u3002\n\n\u672c\u9662\u7ecf\u5ba1\u7406\u8ba4\u5b9a\u4e8b\u5b9e\u5982\u4e0b\uff1a2023\u5e746\u6708\uff0c\u539f\u3001\u88ab\u544a\u7ecf\u4ecb\u7ecd\u8ba4\u8bc6\u5e76\u5efa\u7acb\u5a5a\u7ea6\u5173\u7cfb\uff0c\u53cc\u65b9\u672a\u529e\u7406\u7ed3\u5a5a\u767b\u8bb0\u3002\u5728\u4ea4\u5f80\u671f\u95f4\uff0c\u539f\u544a\u65b9\u7ed9\u4ed8\u88ab\u544a\u8ba2\u5a5a\u793c\u91d110,001\u5143\u3001\u6212\u6307\u4e00\u679a\u3002\u53e6\u5728\u8ba2\u5a5a\u8fc7\u7a0b\u4e2d\u7ed9\u4ed8\u88ab\u544a\u4eb2\u621a\u7ea2\u53058,000\u5143\u3002\u539f\u544a\u53e6\u6709\u901a\u8fc7\u5fae\u4fe1\u8f6c\u8d26\u53ca\u8d2d\u4e70\u5316\u5986\u54c1\u7b49\u6d88\u8d39\u884c\u4e3a\u3002\u5ead\u5ba1\u8fc7\u7a0b\u4e2d\uff0c\u88ab\u544a\u65b9\u5df2\u5c06\u6212\u6307\u539f\u7269\u8fd4\u8fd8\u539f\u544a\uff0c\u539f\u544a\u5f53\u5ead\u7b7e\u6536\u3002\n\n\u672c\u9662\u8ba4\u4e3a\uff1a\n\u4e00\u3001\u5173\u4e8e\u5f69\u793c\u7684\u8ba4\u5b9a\u53ca\u8fd4\u8fd8\u3002\u5f69\u793c\u662f\u6839\u636e\u5f53\u5730\u98ce\u4fd7\u4e60\u60ef\uff0c\u4ee5\u7ed3\u5a5a\u4e3a\u76ee\u7684\u7ed9\u4ed8\u7684\u5927\u989d\u8d22\u7269\u3002\u672c\u6848\u4e2d\uff0c\u8ba2\u5a5a\u793c\u91d110,001\u5143\u53ca\u6212\u6307\uff08\u5df2\u8fd4\u8fd8\uff09\u5c5e\u4e8e\u5178\u578b\u7684\u5f69\u793c\u3002\u5bf9\u4e8e\u7ed9\u4ed8\u4eb2\u621a\u76848,000\u5143\u7ea2\u5305\uff0c\u867d\u975e\u88ab\u544a\u76f4\u63a5\u6536\u53d6\uff0c\u4f46\u7cfb\u57fa\u4e8e\u5a5a\u7ea6\u98ce\u4fd7\u4e14\u7531\u539f\u544a\u65b9\u652f\u51fa\uff0c\u5177\u6709\u660e\u663e\u7684\u5f69\u793c\u6027\u8d28\uff0c\u5e94\u8ba1\u5165\u5f69\u793c\u8303\u56f4\u3002\u5173\u4e8e\u539f\u544a\u4e3b\u5f20\u7684\u5176\u4ed684,540\u5143\u652f\u51fa\uff0c\u5305\u542b\u5316\u5986\u54c1\u6d88\u8d39\u3001\u65e5\u5e38\u8f6c\u8d26\u53ca\u9910\u996e\u5f00\u652f\uff0c\u6b64\u7c7b\u652f\u51fa\u591a\u53d1\u751f\u5728\u604b\u7231\u4ea4\u5f80\u671f\u95f4\uff0c\u7cfb\u4e3a\u589e\u8fdb\u611f\u60c5\u7684\u81ea\u613f\u8d60\u4e0e\u6216\u5171\u540c\u6d88\u8d39\uff0c\u4e0d\u7b26\u5408\u5f69\u793c\u201c\u5927\u989d\u7ed9\u4ed8\u201d\u4e14\u201c\u4ee5\u7ed3\u5a5a\u4e3a\u524d\u63d0\u201d\u7684\u6cd5\u5b9a\u7279\u5f81\uff0c\u4e0d\u4e88\u8ba4\u5b9a\u4e3a\u5f69\u793c\uff0c\u672c\u9662\u5bf9\u5176\u8fd4\u8fd8\u8bf7\u6c42\u4e0d\u4e88\u652f\u6301\u3002\n\u4e8c\u3001\u5173\u4e8e\u7cbe\u795e\u635f\u5bb3\u8d54\u507f\u3002\u539f\u544a\u4e3b\u5f20\u88ab\u544a\u9000\u5a5a\u7ed9\u5176\u9020\u6210\u7cbe\u795e\u6253\u51fb\uff0c\u4f46\u5a5a\u7ea6\u4e0d\u5177\u6709\u6cd5\u5f8b\u5f3a\u5236\u7ea6\u675f\u529b\uff0c\u89e3\u9664\u5a5a\u7ea6\u672c\u8eab\u5e76\u4e0d\u6784\u6210\u5bf9\u4ed6\u4eba\u7684\u4fb5\u6743\u884c\u4e3a\u3002\u672c\u6848\u4e2d\u88ab\u544a\u7684\u884c\u4e3a\u672a\u8fbe\u5230\u4e25\u91cd\u4fb5\u5bb3\u539f\u544a\u4eba\u683c\u6743\u7684\u7a0b\u5ea6\uff0c\u6545\u5bf9\u539f\u544a\u8981\u6c42\u8d54\u507f\u7cbe\u795e\u635f\u5bb3\u91d120,000\u5143\u7684\u8bc9\u8bbc\u8bf7\u6c42\uff0c\u672c\u9662\u4e0d\u4e88\u652f\u6301\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u96f6\u56db\u5341\u4e8c\u6761\u3001\u300a\u6700\u9ad8\u4eba\u6c11\u6cd5\u9662\u5173\u4e8e\u5ba1\u7406\u6d89\u5f69\u793c\u7ea0\u7eb7\u6848\u4ef6\u9002\u7528\u6cd5\u5f8b\u82e5\u5e72\u95ee\u9898\u7684\u89c4\u5b9a\u300b\u7b2c\u4e09\u6761\u3001\u7b2c\u516d\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n\u4e00\u3001\u88ab\u544a\u718a\u67d0\u83ca\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\u8fd4\u8fd8\u539f\u544a\u8bb8\u67d0\u661f\u5f69\u793c\u5171\u8ba118,001\u5143\uff1b\n\u4e8c\u3001\u9a73\u56de\u539f\u544a\u8bb8\u67d0\u661f\u7684\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42\u3002\n\n\u5982\u679c\u88ab\u544a\u672a\u6309\u672c\u5224\u51b3\u6307\u5b9a\u7684\u671f\u95f4\u5c65\u884c\u7ed9\u4ed8\u91d1\u94b1\u4e49\u52a1\uff0c\u5e94\u5f53\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u4e8c\u767e\u516d\u5341\u56db\u6761\u4e4b\u89c4\u5b9a\uff0c\u52a0\u500d\u652f\u4ed8\u8fdf\u5ef6\u5c65\u884c\u671f\u95f4\u7684\u503a\u52a1\u5229\u606f\u3002\n\n\u6848\u4ef6\u53d7\u7406\u8d39\uff08\u6309\u5b9e\u9645\u91d1\u989d\u6838\u7b97\uff09\uff0c\u7531\u539f\u544a\u8d1f\u62c5XX\u5143\uff0c\u88ab\u544a\u8d1f\u62c5XX\u5143\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u6cb3\u5357\u7701\u4fe1\u9633\u5e02\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002\n\n\u5ba1\u5224\u957f\uff1aXXX\n\u4e8c\u3007\u4e8c\u56db\u5e74X\u6708X\u65e5\n\u4e66\u8bb0\u5458\uff1aXXX": "95% Bootstrap Confidence Interval: (0.0%, 0.0%), Median: 0.0%"
