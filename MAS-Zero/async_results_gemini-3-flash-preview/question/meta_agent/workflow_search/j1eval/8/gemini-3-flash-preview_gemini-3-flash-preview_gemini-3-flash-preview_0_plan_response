        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u4eba\u683c\u6743\u7ea0\u7eb7\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u5eb7\u67d0\u7532\", \"address\": \"\u7518\u8083\u7701\u6f33\u53bf\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1980\u5e741\u670818\u65e5\"}, \"defendant\": {\"name\": \"\u5eb7\u67d0\u4e59\", \"address\": \"\u7518\u8083\u7701\u6f33\u53bf\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1986\u5e7410\u670819\u65e5\"}}, \"plaintiff_claim\": [\"\u4f9d\u6cd5\u5224\u4ee4\u88ab\u544a\u8d54\u507f\u539f\u544a\u5404\u9879\u7ecf\u6d4e\u635f\u5931\u4eba\u6c11\u5e0111478.45\u5143\uff0c\u5176\u4e2d\u533b\u7597\u8d392922.94\u5143\uff0c\u8bef\u5de5\u8d395070.47\u5143\uff0823\u5929\u00d7220.47\u5143\uff09\uff0c\u62a4\u7406\u8d391984.23\u5143\uff089\u5929\u00d7220.47\u5143\uff09\uff0c\u8425\u517b\u8d39180\u5143\uff0c\u4ea4\u901a\u8d39200\u5143\u3002\", \"\u672c\u6848\u8bc9\u8bbc\u8d39\u7531\u88ab\u544a\u627f\u62c5\u3002\"], \"plaintiff_case_details\": \"\u539f\u544a\u7cfb\u88ab\u544a\u7684\u59d0\u59d0\u3002\u539f\u544a\u6bcd\u4eb2\u53bb\u4e16\u540e\uff0c\u56e0\u539f\u544a\u7236\u4eb2\u7231\u9157\u9152\uff0c\u539f\u544a\u4f5c\u4e3a\u5bb6\u4e2d\u957f\u5973\u627f\u62c5\u8d77\u7167\u987e\u5168\u90e8\u5bb6\u4eba\u7684\u8d