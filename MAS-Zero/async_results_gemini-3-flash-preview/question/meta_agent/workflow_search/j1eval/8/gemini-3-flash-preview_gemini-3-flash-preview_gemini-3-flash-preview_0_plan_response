        "problem": "\u4f60\u662f\u4e00\u540d\u4e25\u8c28\u3001\u516c\u6b63\u7684\u5ba1\u5224\u957f\uff0c\u4f60\u7684\u4efb\u52a1\u662f\uff1a\u6839\u636e\u539f\u544a\u548c\u88ab\u544a\u7684\u9648\u8ff0\u4ee5\u53ca\u4e00\u4e9b\u989d\u5916\u7684\u4fe1\u606f\uff0c\u751f\u6210\u76f8\u5e94\u7684\u8bf4\u7406\u5185\u5bb9\uff0c\u7ed9\u51fa\u6700\u7ec8\u5224\u51b3\u3002\u8bf7\u4f60\u59cb\u7ec8\u4fdd\u6301\u4e2d\u7acb\u3001\u4e13\u4e1a\u3001\u516c\u6b63\u7684\u5ba1\u5224\u98ce\u683c\uff0c\u4e0d\u5f97\u504f\u8892\u4efb\u4f55\u4e00\u65b9\u3002\u8bf7\u7528\u4e2d\u6587\u8f93\u51fa\u4f60\u7684\u5185\u5bb9\u3002\n\u4f60\u53ef\u4ee5\u83b7\u5f97\u5230\u7684\u4fe1\u606f\uff1a{\"category\": \"\u4eba\u683c\u6743\u7ea0\u7eb7\", \"specific_characters\": {\"plaintiff\": {\"name\": \"\u5eb7\u67d0\u7532\", \"address\": \"\u7518\u8083\u7701\u6f33\u53bf\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1980\u5e741\u670818\u65e5\"}, \"defendant\": {\"name\": \"\u5eb7\u67d0\u4e59\", \"address\": \"\u7518\u8083\u7701\u6f33\u53bf\", \"representative\": null, \"gender\": \"\u5973\", \"ethnicity\": \"\u6c49\u65cf\", \"birth_date\": \"1986\u5e7410\u670819\u65e5\"}}, \"plaintiff_claim\": [\"\u4f9d\u6cd5\u5224\u4ee4\u88ab\u544a\u8d54\u507f\u539f\u544a\u5404\u9879\u7ecf\u6d4e\u635f\u5931\u4eba\u6c11\u5e0111478.45\u5143\uff0c\u5176\u4e2d\u533b\u7597\u8d392922.94\u5143\uff0c\u8bef\u5de5\u8d395070.47\u5143\uff0823\u5929\u00d7220.47\u5143\uff09\uff0c\u62a4\u7406\u8d391984.23\u5143\uff089\u5929\u00d7220.47\u5143\uff09\uff0c\u8425\u517b\u8d39180\u5143\uff0c\u4ea4\u901a\u8d39200\u5143\u3002\", \"\u672c\u6848\u8bc9\u8bbc\u8d39\u7531\u88ab\u544a\u627f\u62c5\u3002\"], \"plaintiff_case_details\": \"\u539f\u544a\u7cfb\u88ab\u544a\u7684\u59d0\u59d0\u3002\u539f\u544a\u6bcd\u4eb2\u53bb\u4e16\u540e\uff0c\u56e0\u539f\u544a\u7236\u4eb2\u7231\u9157\u9152\uff0c\u539f\u544a\u4f5c\u4e3a\u5bb6\u4e2d\u957f\u5973\u627f\u62c5\u8d77\u7167\u987e\u5168\u90e8\u5bb6\u4eba\u7684\u8d23\u4efb\uff0c\u64cd\u52b3\u5bb6\u4e2d\u5927\u5c0f\u4e8b\u52a1\uff0c\u4e3a\u5bb6\u5ead\u53ef\u8c13\u662f\u5455\u5fc3\u6ca5\u8840\u3001\u8f9b\u52b3\u4ed8\u51fa\u3002\u539f\u544a\u7ed3\u5a5a\u540e\uff0c\u4e5f\u548c\u5176\u4e08\u592b\u4e00\u8d77\u7ee7\u7eed\u5206\u62c5\u8d77\u4e86\u5a18\u5bb6\u7684\u5bb6\u52a1\uff0c\u5e76\u64cd\u52b3\u59b9\u59b9\u4eec\u7684\u51fa\u5ac1\u4e8b\u5b9c\u3002\u968f\u7740\u539f\u544a\u7236\u4eb2\u5e74\u8fc8\uff0c\u539f\u544a\u7ecf\u5e38\u7ed9\u539f\u544a\u7236\u4eb2\u94b1\u6b3e\u548c\u8d2d\u4e70\u4e1c\u897f\u30022023\u5e745\u6708\u4efd\uff0c\u539f\u544a\u7236\u4eb2\u751f\u75c5\uff0c\u539f\u544a\u5e26\u539f\u544a\u7236\u4eb2\u770b\u75c5\uff0c\u539f\u544a\u7236\u4eb2\u5728\u539f\u544a\u5bb6\u4f11\u517b\u4e00\u6708\uff0c\u8eab\u4f53\u75ca\u6108\u4e4b\u540e\u4fbf\u56de\u6f33\u53bf\u8001\u5bb6\u751f\u6d3b\u3002\u540e\u88ab\u544a\u79f0\u539f\u544a\u65e0\u6743\u62e8\u6253\u539f\u544a\u7236\u4eb2\u7535\u8bdd\uff0c\u6b64\u540e\u539f\u544a\u7236\u4eb2\u7684\u7535\u8bdd\u4fbf\u65e0\u6cd5\u6253\u901a\u3002\u540e\u539f\u544a\u4ecd\u7136\u5bf9\u81ea\u5df1\u7684\u7236\u4eb2\u5c3d\u8d61\u517b\u4e49\u52a1\uff0c\u4f46\u88ab\u544a\u7ecf\u5e38\u53d1\u77ed\u4fe1\u8fb1\u9a82\u539f\u544a\uff0c\u5bf9\u539f\u544a\u975e\u5e38\u4ec7\u89c6\u30022024\u5e74\u519c\u5386\u6b63\u6708\u521d\u516d\uff0c\u88ab\u544a\u5c06\u539f\u544a\u7236\u4eb2\u63a5\u5230\u5979\u5bb6\u751f\u6d3b\u4e86\u51e0\u4e2a\u6708\u30022024\u5e746\u6708\u4efd\uff0c\u539f\u544a\u7236\u4eb2\u5728\u6587\u5cf0\u9547\u5f00\u53d1\u533a\u79df\u623f\u5c45\u4f4f\u30022024\u5e746\u670826\u65e5\uff0c\u539f\u544a\u5728\u51fa\u79df\u5c4b\u770b\u671b\u539f\u544a\u7236\u4eb2\uff0c\u88ab\u544a\u56de\u6765\u540e\u770b\u89c1\u539f\u544a\uff0c\u4fbf\u8fb1\u9a82\u539f\u544a\uff0c\u539f\u544a\u4e0d\u60f3\u4e0e\u5176\u53d1\u751f\u4e89\u6267\uff0c\u51c6\u5907\u79bb\u5f00\u65f6\uff0c\u88ab\u544a\u62c9\u7740\u539f\u544a\u7684\u80f3\u818a\u4e0d\u8ba9\u539f\u544a\u79bb\u5f00\u3002\u4e3a\u4e86\u6446\u8131\u88ab\u544a\u7684\u7ea0\u7f20\uff0c\u539f\u544a\u7528\u529b\u6323\u624e\u88ab\u544a\u62c9\u626f\u65f6\uff0c\u88ab\u544a\u5f00\u59cb\u6bb4\u6253\u539f\u544a\uff0c\u5bf9\u539f\u544a\u811a\u8e22\u62f3\u6253\uff0c\u81f4\u4f7f\u539f\u544a\u9762\u90e8\u3001\u9888\u90e8\u7b49\u591a\u5904\u53d7\u4f24\u3002\u539f\u544a\u6323\u8131\u88ab\u544a\u7684\u6bb4\u6253\u540e\u8dd1\u51fa\u4e86\u51fa\u79df\u5c4b\uff0c\u968f\u540e\u62e8\u6253110\u62a5\u8b66\u3002\u540e\u539f\u544a\u5230\u9647\u897f\u53bf\u7b2c\u4e00\u4eba\u6c11\u533b\u9662\u4f4f\u9662\u6cbb\u7597\uff0c\u7ecf\u533b\u751f\u8bca\u65ad\uff0c\u539f\u544a\u5168\u8eab\u591a\u5904\u8f6f\u7ec4\u7ec7\u635f\u4f24\uff0c\u539f\u544a\u4f4f\u9662\u6cbb\u75979\u5929\u3002\u75c5\u60c5\u7a0d\u5fae\u597d\u8f6c\u540e\uff0c\u539f\u544a\u51fa\u9662\uff0c\u533b\u5631\u539f\u544a\u51fa\u9662\u540e\u4f11\u517b14\u5929\uff0c\u539f\u544a\u4fbf\u7ee7\u7eed\u5728\u5bb6\u4f11\u517b\u6cbb\u7597\u3002\u539f\u544a\u6cbb\u7597\u671f\u95f4\u548c\u4f11\u517b\u671f\u95f4\uff0c\u88ab\u544a\u672a\u652f\u4ed8\u4efb\u4f55\u8d39\u7528\uff0c\u4e5f\u672a\u63a2\u671b\u8fc7\u539f\u544a\u3002\u540e\u7ecf\u9647\u897f\u53bf\u516c\u5b89\u5c40\u53f8\u6cd5\u9274\u5b9a\u4e2d\u5fc3\u9274\u5b9a\uff0c\u539f\u544a\u7684\u4f24\u60c5\u4e3a\u8f7b\u5fae\u4f24\uff0c\u9647\u897f\u53bf\u516c\u5b89\u5c40\u6587\u5cf0\u6d3e\u51fa\u6240\u5bf9\u88ab\u544a\u8fdb\u884c\u884c\u653f\u5904\u7f5a\uff0c\u7f5a\u6b3e500\u5143\u3002\u56e0\u4f24\u60c5\u5f71\u54cd\u539f\u544a\u4e00\u76f4\u8bef\u5de5\u81f3\u4eca\u3002\u88ab\u544a\u4e0d\u4f46\u4e0d\u611f\u6069\u539f\u544a\u7684\u8f9b\u52b3\u4ed8\u51fa\uff0c\u8fd8\u6069\u5c06\u4ec7\u62a5\uff0c\u5bf9\u539f\u544a\u5404\u79cd\u62a5\u590d\u3002\u7efc\u4e0a\uff0c\u88ab\u544a\u5bf9\u539f\u544a\u6784\u6210\u4e86\u4e25\u91cd\u4fb5\u6743\uff0c\u81f4\u4f7f\u539f\u544a\u8eab\u4f53\u906d\u5230\u635f\u4f24\uff0c\u88ab\u544a\u4f9d\u6cd5\u5e94\u5f53\u8d54\u507f\u539f\u544a\u7684\u7ecf\u6d4e\u635f\u5931\uff0c\u4e3a\u4e86\u7ef4\u62a4\u539f\u544a\u7684\u5408\u6cd5\u6743\u76ca\uff0c\u4f9d\u6cd5\u63d0\u8d77\u6c11\u4e8b\u8bc9\u8bbc\u3002\", \"defendant_defence\": \"\u7cfb\u539f\u544a\u5148\u52a8\u624b\u5c06\u5176\u53e3\u90e8\u6253\u4f24\uff0c\u4e4b\u540e\u53cc\u65b9\u53d1\u751f\u6495\u6253\uff0c\u5176\u5728\u539f\u544a\u9762\u90e8\u6293\u4e86\u51e0\u4e0b\uff0c\u5c06\u539f\u544a\u6293\u4f24\uff0c\u539f\u544a\u5bf9\u81ea\u5df1\u53d7\u4f24\u4e5f\u8d1f\u6709\u8d23\u4efb\uff0c\u5176\u53ea\u540c\u610f\u8d54\u507f\u539f\u544a\u7684\u533b\u7597\u8d39\u7b49\u8d39\u7528\u5171\u8ba15000\u5143\uff0c\u6848\u4ef6\u53d7\u7406\u8d39\u539f\u544a\u4e0e\u5176\u5404\u627f\u62c550\u5143\u3002\", \"evidence\": {\"plaintiff_evidence\": {\"evidence_1\": {\"evidence\": \"\u539f\u544a\u63d0\u4f9b\u7684\u533b\u9662\u8bca\u65ad\u8bc1\u660e\u548c\u4f4f\u9662\u75c5\u5386\", \"dispute\": \"\u88ab\u544a\u5bf9\u539f\u544a\u53d7\u4f24\u81ea\u5df1\u6709\u8d23\u4efb\"}, \"evidence_2\": null, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null, \"evidence_10\": null}, \"defendant_evidence\": {\"evidence_1\": {\"evidence\": \"\u5eb7\u67d0\u4e59\u8be2\u95ee\u7b14\u5f55\", \"dispute\": \"\u539f\u544a\u6301\u5f02\u8bae\", \"name\": null}, \"evidence_2\": null, \"evidence_3\": null, \"evidence_4\": null, \"evidence_5\": null, \"evidence_6\": null, \"evidence_7\": null, \"evidence_8\": null, \"evidence_9\": null}}, \"other_statement\": {\"plaintiff\": {\"plaintiff_1\": \"\"}, \"defendant\": {\"defendant_1\": \"\"}}}\n",
