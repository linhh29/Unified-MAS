        "\u4e0a\u6d77\u5e02\u9759\u5b89\u533a\u4eba\u6c11\u6cd5\u9662\n\u6c11\u4e8b\u5224\u51b3\u4e66\n\n\uff082023\uff09\u6caa0106\u6c11\u521d1024\u53f7\n\n\u539f\u544a\uff1a\u7a0b\u67d01\uff0c\u5973\uff0c\u6c49\u65cf\uff0c1979\u5e743\u67083\u65e5\u51fa\u751f\uff0c\u4f4f\u4e0a\u6d77\u5e02\u677e\u6c5f\u533a\u3002\n\u88ab\u544a\uff1a\u7a0b\u67d02\uff0c\u7537\uff0c\u6c49\u65cf\uff0c1974\u5e747\u670829\u65e5\u51fa\u751f\uff0c\u4f4f\u4e0a\u6d77\u5e02\u9ec4\u6d66\u533a\u3002\n\n\u539f\u544a\u7a0b\u67d01\u4e0e\u88ab\u544a\u7a0b\u67d02\u7ee7\u627f\u7ea0\u7eb7\u4e00\u6848\uff0c\u672c\u9662\u4e8e2023\u5e74\u4f9d\u6cd5\u53d7\u7406\u540e\uff0c\u7531\u5ba1\u5224\u5458\u738b\u5e73\u72ec\u4efb\u5ba1\u5224\uff0c\u516c\u5f00\u5f00\u5ead\u8fdb\u884c\u4e86\u5ba1\u7406\u3002\u539f\u544a\u7a0b\u67d01\u3001\u88ab\u544a\u7a0b\u67d02\u5230\u5ead\u53c2\u52a0\u8bc9\u8bbc\u3002\u672c\u6848\u73b0\u5df2\u5ba1\u7406\u7ec8\u7ed3\u3002\n\n\u539f\u544a\u7a0b\u67d01\u5411\u672c\u9662\u63d0\u51fa\u8bc9\u8bbc\u8bf7\u6c42\uff1a\u8981\u6c42\u7ee7\u627f\u88ab\u7ee7\u627f\u4eba\u7a0b\u67d03\u3001\u5f20\u67d02\u5728\u4e0a\u6d77\u5e02\u9759\u5b89\u533a\u623f\u5c4b\u4e2d\u7684\u5404\u4e09\u5206\u4e4b\u4e00\u4ea7\u6743\u4efd\u989d\uff0c\u7531\u539f\u544a\u53d6\u5f97\u623f\u5c4b\uff0c\u5e76\u7ed9\u4ed8\u88ab\u544a\u623f\u5c4b\u6298\u4ef7\u6b3e855,334\u5143\u3002\n\n\u672c\u9662\u7ecf\u5ba1\u7406\u67e5\u660e\uff1a\n\u88ab\u7ee7\u627f\u4eba\u7a0b\u67d03\u4e0e\u5f20\u67d02\u7cfb\u592b\u59bb\u5173\u7cfb\uff0c\u4e24\u4eba\u5171\u80b2\u6709\u4e24\u540d\u5b50\u5973\uff0c\u5373\u539f\u544a\u7a0b\u67d01\u4e0e\u88ab\u544a\u7a0b\u67d02\u3002\u4f4d\u4e8e\u4e0a\u6d77\u5e02\u9759\u5b89\u533a\u7684\u7cfb\u4e89\u623f\u5c4b\u4ea7\u6743\u539f\u767b\u8bb0\u5728\u88ab\u7ee7\u627f\u4eba\u7a0b\u67d03\u3001\u5f20\u67d02\u53ca\u539f\u544a\u7a0b\u67d01\u540d\u4e0b\uff0c\u4e09\u4eba\u5404\u5360\u4e09\u5206\u4e4b\u4e00\u4ea7\u6743\u4efd\u989d\u3002\n\u7a0b\u67d03\u4e8e\u53bb\u4e16\u524d\u7acb\u6709\u81ea\u4e66\u9057\u5631\u4e00\u4efd\uff0c\u8f7d\u660e\u5c06\u5176\u540d\u4e0b\u7684\u623f\u4ea7\u4efd\u989d\u7531\u539f\u544a\u7a0b\u67d01\u7ee7\u627f\u3002\u88ab\u544a\u867d\u5bf9\u8be5\u9057\u5631\u4e2d\u89c1\u8bc1\u4eba\u843d\u6b3e\u65e5\u671f\u4e0d\u4e00\u81f4\u63d0\u51fa\u5f02\u8bae\uff0c\u4f46\u5e76\u672a\u5426\u8ba4\u8be5\u9057\u5631\u7cfb\u7a0b\u67d03\u4eb2\u7b14\u4e66\u5199\u3002\u5f20\u67d02\u7acb\u6709\u516c\u8bc1\u9057\u5631\u4e00\u4efd\uff0c\u8f7d\u660e\u5c06\u5176\u540d\u4e0b\u7684\u623f\u4ea7\u4efd\u989d\u7531\u88ab\u544a\u7a0b\u67d02\u7ee7\u627f\u3002\u73b0\u4e24\u540d\u88ab\u7ee7\u627f\u4eba\u5747\u5df2\u8fc7\u4e16\u3002\u7ecf\u8bc4\u4f30\uff0c\u7cfb\u4e89\u623f\u5c4b\u4e09\u5206\u4e4b\u4e00\u4efd\u989d\u7684\u6298\u4ef7\u6b3e\u4e3a855,334\u5143\u3002\n\n\u672c\u9662\u8ba4\u4e3a\uff1a\n\u5173\u4e8e\u7a0b\u67d03\u7684\u81ea\u4e66\u9057\u5631\uff0c\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u4e09\u5341\u56db\u6761\u89c4\u5b9a\uff0c\u81ea\u4e66\u9057\u5631\u7531\u9057\u5631\u4eba\u4eb2\u7b14\u4e66\u5199\uff0c\u7b7e\u540d\uff0c\u6ce8\u660e\u5e74\u3001\u6708\u3001\u65e5\u5373\u53ef\u6210\u7acb\u3002\u6cd5\u5f8b\u5e76\u672a\u5f3a\u5236\u6027\u8981\u6c42\u81ea\u4e66\u9057\u5631\u5fc5\u987b\u6709\u89c1\u8bc1\u4eba\uff0c\u6545\u5373\u4f7f\u89c1\u8bc1\u4eba\u843d\u6b3e\u65e5\u671f\u5b58\u5728\u7455\u75b5\uff0c\u53ea\u8981\u8be5\u9057\u5631\u7cfb\u9057\u5631\u4eba\u4eb2\u7b14\u4e66\u5199\u5e76\u7b7e\u540d\u3001\u6ce8\u660e\u65e5\u671f\uff0c\u5373\u5e94\u8ba4\u5b9a\u4e3a\u6709\u6548\u3002\u672c\u9662\u8ba4\u5b9a\u7a0b\u67d03\u7684\u81ea\u4e66\u9057\u5631\u5408\u6cd5\u6709\u6548\uff0c\u5176\u6301\u6709\u7684\u4e09\u5206\u4e4b\u4e00\u4efd\u989d\u5f52\u539f\u544a\u7ee7\u627f\u3002\n\u5173\u4e8e\u5f20\u67d02\u7684\u516c\u8bc1\u9057\u5631\uff0c\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u4e09\u5341\u4e5d\u6761\u89c4\u5b9a\uff0c\u516c\u8bc1\u9057\u5631\u7531\u9057\u5631\u4eba\u7ecf\u516c\u8bc1\u673a\u6784\u529e\u7406\u3002\u8be5\u9057\u5631\u5f62\u5f0f\u5408\u6cd5\uff0c\u53cc\u65b9\u5bf9\u5176\u771f\u5b9e\u6027\u65e0\u5f02\u8bae\uff0c\u672c\u9662\u4e88\u4ee5\u786e\u8ba4\uff0c\u5f20\u67d02\u6301\u6709\u7684\u4e09\u5206\u4e4b\u4e00\u4efd\u989d\u5f52\u88ab\u544a\u7ee7\u627f\u3002\n\u7efc\u4e0a\uff0c\u539f\u544a\u7a0b\u67d01\u5171\u8ba1\u6301\u6709\u7cfb\u4e89\u623f\u5c4b\u4e09\u5206\u4e4b\u4e8c\u4ea7\u6743\u4efd\u989d\uff0c\u88ab\u544a\u7a0b\u67d02\u6301\u6709\u4e09\u5206\u4e4b\u4e00\u4ea7\u6743\u4efd\u989d\u3002\u539f\u544a\u4e3b\u5f20\u53d6\u5f97\u623f\u5c4b\u6240\u6709\u6743\u5e76\u7ed9\u4ed8\u88ab\u544a\u6298\u4ef7\u6b3e\uff0c\u7b26\u5408\u6cd5\u5f8b\u89c4\u5b9a\u53ca\u516c\u5e73\u539f\u5219\uff0c\u672c\u9662\u4e88\u4ee5\u652f\u6301\u3002\n\n\u636e\u6b64\uff0c\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u4e8c\u5341\u4e00\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u4e8c\u5341\u4e09\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u4e09\u5341\u56db\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u4e09\u5341\u4e5d\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n\u4e00\u3001 \u767b\u8bb0\u5728\u88ab\u7ee7\u627f\u4eba\u7a0b\u67d03\u3001\u5f20\u67d02\u540d\u4e0b\u7684\u4e0a\u6d77\u5e02\u9759\u5b89\u533a\u623f\u5c4b\u4ea7\u6743\u4efd\u989d\u7531\u539f\u544a\u7a0b\u67d01\u3001\u88ab\u544a\u7a0b\u67d02\u6309\u4e0a\u8ff0\u7406\u7531\u7ee7\u627f\u3002\u7ee7\u627f\u540e\uff0c\u4f4d\u4e8e\u4e0a\u6d77\u5e02\u9759\u5b89\u533a\u7684\u7cfb\u4e89\u623f\u5c4b\u4ea7\u6743\u5f52\u539f\u544a\u7a0b\u67d01\u6240\u6709\uff1b\n\u4e8c\u3001 \u539f\u544a\u7a0b\u67d01\u5e94\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u4e09\u5341\u65e5\u5185\u7ed9\u4ed8\u88ab\u544a\u7a0b\u67d02\u623f\u5c4b\u6298\u4ef7\u6b3e\u4eba\u6c11\u5e01855,334\u5143\uff1b\n\u4e09\u3001 \u88ab\u544a\u7a0b\u67d02\u5e94\u4e8e\u6536\u5230\u4e0a\u8ff0\u6b3e\u9879\u540e\u5341\u4e94\u65e5\u5185\u914d\u5408\u539f\u544a\u7a0b\u67d01\u529e\u7406\u623f\u5c4b\u4ea7\u6743\u53d8\u66f4\u767b\u8bb0\u624b\u7eed\uff0c\u76f8\u5173\u7a0e\u8d39\u7531\u539f\u544a\u7a0b\u67d01\u627f\u62c5\u3002\n\n\u6848\u4ef6\u53d7\u7406\u8d39\u3001\u8bc4\u4f30\u8d39\u7531\u539f\u3001\u88ab\u544a\u53cc\u65b9\u6309\u6bd4\u4f8b\u8d1f\u62c5\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u4e0a\u6d77\u5e02\u7b2c\u4e8c\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002\n\n\u5ba1\u5224\u5458  \u738b\u5e73\n\u4e8c\u3007\u4e8c\u4e09\u5e74\u5341\u6708\u4e8c\u5341\u4e03\u65e5\n\u4e66\u8bb0\u5458  \u9648\u5f3a": "95% Bootstrap Confidence Interval: (0.0%, 0.0%), Median: 0.0%"
    },
    {
        "\u4e0a\u6d77\u5e02\u9759\u5b89\u533a\u4eba\u6c11\u6cd5\u9662\n\u6c11\u4e8b\u5224\u51b3\u4e66\n\n\uff082023\uff09\u6caa0106\u6c11\u521d8892\u53f7\n\n\u539f\u544a\uff1a\u7a0b\u67d01\uff0c\u5973\uff0c1979\u5e743\u67083\u65e5\u51fa\u751f\uff0c\u6c49\u65cf\uff0c\u4f4f\u4e0a\u6d77\u5e02\u677e\u6c5f\u533a\u3002\n\u88ab\u544a\uff1a\u7a0b\u67d02\uff0c\u7537\uff0c1974\u5e747\u670829\u65e5\u51fa\u751f\uff0c\u6c49\u65cf\uff0c\u4f4f\u4e0a\u6d77\u5e02\u9ec4\u6d66\u533a\u3002\n\n\u539f\u544a\u7a0b\u67d01\u4e0e\u88ab\u544a\u7a0b\u67d02\u7ee7\u627f\u7ea0\u7eb7\u4e00\u6848\uff0c\u672c\u9662\u53d7\u7406\u540e\uff0c\u4f9d\u6cd5\u9002\u7528\u7b80\u6613\u7a0b\u5e8f\uff0c\u516c\u5f00\u5f00\u5ead\u8fdb\u884c\u4e86\u5ba1\u7406\u3002\u672c\u6848\u73b0\u5df2\u5ba1\u7406\u7ec8\u7ed3\u3002\n\n\u3010\u8bf4\u7406\u5185\u5bb9\u3011\n\u672c\u9662\u8ba4\u4e3a\uff0c\u9057\u4ea7\u662f\u81ea\u7136\u4eba\u6b7b\u4ea1\u65f6\u9057\u7559\u7684\u4e2a\u4eba\u5408\u6cd5\u8d22\u4ea7\u3002\u7ee7\u627f\u5f00\u59cb\u540e\uff0c\u6709\u9057\u5631\u7684\uff0c\u6309\u7167\u9057\u5631\u7ee7\u627f\u6216\u8005\u9057\u8d60\u529e\u7406\u3002\u672c\u6848\u4e89\u8bae\u7126\u70b9\u5728\u4e8e\u4e24\u540d\u88ab\u7ee7\u627f\u4eba\u9057\u5631\u7684\u6548\u529b\u8ba4\u5b9a\u53ca\u7cfb\u4e89\u623f\u5c4b\u7684\u5206\u5272\u65b9\u5f0f\u3002\n\n\u5173\u4e8e\u88ab\u7ee7\u627f\u4eba\u7a0b\u67d03\u7684\u81ea\u4e66\u9057\u5631\u3002\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u4e09\u5341\u56db\u6761\u4e4b\u89c4\u5b9a\uff0c\u81ea\u4e66\u9057\u5631\u7531\u9057\u5631\u4eba\u4eb2\u7b14\u4e66\u5199\u3001\u7b7e\u540d\uff0c\u5e76\u6ce8\u660e\u5e74\u3001\u6708\u3001\u65e5\u3002\u81ea\u4e66\u9057\u5631\u5e76\u4e0d\u4ee5\u89c1\u8bc1\u4eba\u89c1\u8bc1\u4e3a\u6cd5\u5b9a\u751f\u6548\u8981\u4ef6\uff0c\u6545\u88ab\u544a\u8fa9\u79f0\u56e0\u89c1\u8bc1\u4eba\u843d\u6b3e\u65e5\u671f\u4e0d\u4e00\u81f4\u5bfc\u81f4\u9057\u5631\u65e0\u6548\u7684\u610f\u89c1\uff0c\u7f3a\u4e4f\u6cd5\u5f8b\u4f9d\u636e\uff0c\u672c\u9662\u4e0d\u4e88\u91c7\u7eb3\u3002\u8be5\u81ea\u4e66\u9057\u5631\u5408\u6cd5\u6709\u6548\uff0c\u7a0b\u67d03\u6301\u6709\u7684\u7cfb\u4e89\u623f\u5c4b\u4e09\u5206\u4e4b\u4e00\u4efd\u989d\u5e94\u7531\u539f\u544a\u7ee7\u627f\u3002\n\n\u5173\u4e8e\u88ab\u7ee7\u627f\u4eba\u5f20\u67d02\u7684\u516c\u8bc1\u9057\u5631\u3002\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u4e09\u5341\u4e5d\u6761\u4e4b\u89c4\u5b9a\uff0c\u516c\u8bc1\u9057\u5631\u7531\u9057\u5631\u4eba\u7ecf\u516c\u8bc1\u673a\u6784\u529e\u7406\u3002\u8be5\u9057\u5631\u5f62\u5f0f\u5408\u6cd5\uff0c\u53cc\u65b9\u5bf9\u5176\u6548\u529b\u5747\u65e0\u5f02\u8bae\uff0c\u672c\u9662\u4e88\u4ee5\u786e\u8ba4\u3002\u5f20\u67d02\u6301\u6709\u7684\u4e09\u5206\u4e4b\u4e00\u4efd\u989d\u7531\u88ab\u544a\u7ee7\u627f\u3002\n\n\u5173\u4e8e\u623f\u5c4b\u5206\u5272\u3002\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u4e94\u5341\u516d\u6761\u4e4b\u89c4\u5b9a\uff0c\u9057\u4ea7\u5206\u5272\u5e94\u5f53\u6709\u5229\u4e8e\u751f\u4ea7\u548c\u751f\u6d3b\u9700\u8981\uff0c\u4e0d\u635f\u5bb3\u9057\u4ea7\u7684\u6548\u7528\u3002\u4e0d\u5b9c\u5206\u5272\u7684\u9057\u4ea7\uff0c\u53ef\u4ee5\u91c7\u53d6\u6298\u4ef7\u3001\u9002\u5f53\u8865\u507f\u6216\u8005\u5171\u6709\u7b49\u65b9\u6cd5\u5904\u7406\u3002\u672c\u6848\u4e2d\uff0c\u539f\u544a\u539f\u5df2\u6301\u6709\u7cfb\u4e89\u623f\u5c4b\u4e09\u5206\u4e4b\u4e00\u4ea7\u6743\u4efd\u989d\uff0c\u7ed3\u5408\u7ee7\u627f\u4efd\u989d\u540e\u5171\u8ba1\u6301\u6709\u4e09\u5206\u4e4b\u4e8c\u4efd\u989d\uff0c\u88ab\u544a\u6301\u6709\u4e09\u5206\u4e4b\u4e00\u4efd\u989d\u3002\u539f\u544a\u4e3b\u5f20\u53d6\u5f97\u623f\u5c4b\u6240\u6709\u6743\u5e76\u7ed9\u4ed8\u88ab\u544a\u6298\u4ef7\u6b3e\uff0c\u65e2\u7b26\u5408\u4efd\u989d\u591a\u6570\u539f\u5219\uff0c\u4e5f\u5229\u4e8e\u623f\u5c4b\u4ef7\u503c\u7684\u53d1\u6325\u53ca\u751f\u6d3b\u7a33\u5b9a\u3002\u7ecf\u6838\u7b97\uff0c\u88ab\u544a\u5e94\u5f97\u7684\u6298\u4ef7\u6b3e\u4e3a855,334\u5143\uff0c\u6570\u989d\u5408\u7406\uff0c\u672c\u9662\u4e88\u4ee5\u652f\u6301\u3002\n\n\u636e\u6b64\uff0c\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u4e09\u5341\u56db\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u4e09\u5341\u4e5d\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u4e94\u5341\u516d\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n\u3010\u6700\u7ec8\u5224\u51b3\u3011\n\u4e00\u3001 \u767b\u8bb0\u5728\u88ab\u7ee7\u627f\u4eba\u7a0b\u67d03\u3001\u5f20\u67d02\u53ca\u539f\u544a\u7a0b\u67d01\u540d\u4e0b\u7684\u4e0a\u6d77\u5e02\u9759\u5b89\u533a\u623f\u5c4b\uff08\u4ea7\u6743\u4efd\u989d\u5404\u5360\u4e09\u5206\u4e4b\u4e00\uff09\u7531\u539f\u544a\u7a0b\u67d01\u7ee7\u627f\u6240\u6709\uff1b\n\u4e8c\u3001 \u539f\u544a\u7a0b\u67d01\u5e94\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\u652f\u4ed8\u88ab\u544a\u7a0b\u67d02\u623f\u5c4b\u6298\u4ef7\u6b3e\u4eba\u6c11\u5e01855,334\u5143\uff1b\n\u4e09\u3001 \u88ab\u544a\u7a0b\u67d02\u5e94\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\u914d\u5408\u539f\u544a\u7a0b\u67d01\u529e\u7406\u4e0a\u8ff0\u623f\u5c4b\u7684\u6743\u5c5e\u53d8\u66f4\u767b\u8bb0\u624b\u7eed\uff0c\u76f8\u5173\u7a0e\u8d39\u6309\u56fd\u5bb6\u89c4\u5b9a\u7531\u539f\u3001\u88ab\u544a\u5404\u81ea\u627f\u62c5\u3002\n\n\u5982\u679c\u672a\u6309\u672c\u5224\u51b3\u6307\u5b9a\u7684\u671f\u95f4\u5c65\u884c\u7ed9\u4ed8\u91d1\u94b1\u4e49\u52a1\uff0c\u5e94\u5f53\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u4e8c\u767e\u516d\u5341\u6761\u4e4b\u89c4\u5b9a\uff0c\u52a0\u500d\u652f\u4ed8\u8fdf\u5ef6\u5c65\u884c\u671f\u95f4\u7684\u503a\u52a1\u5229\u606f\u3002\n\n\u6848\u4ef6\u53d7\u7406\u8d39\u4eba\u6c11\u5e0112,353\u5143\uff0c\u7531\u539f\u544a\u7a0b\u67d01\u8d1f\u62c56,176.5\u5143\uff0c\u88ab\u544a\u7a0b\u67d02\u8d1f\u62c56,176.5\u5143\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u4ee5\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u4e0a\u6d77\u5e02\u7b2c\u4e8c\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002\n\n\u5ba1\u5224\u5458  \u738b\u5e73\n\u4e8c\u3007\u4e8c\u4e09\u5e74\u5341\u6708\u4e8c\u5341\u4e03\u65e5\n\u4e66\u8bb0\u5458  \u674e\u6653": "95% Bootstrap Confidence Interval: (0.0%, 0.0%), Median: 0.0%"
    },
    {
        "\u4e0a\u6d77\u5e02\u9759\u5b89\u533a\u4eba\u6c11\u6cd5\u9662\n\u6c11\u4e8b\u5224\u51b3\u4e66\n\n\u3010\u672c\u9662\u8ba4\u4e3a\u3011\n\u672c\u9662\u8ba4\u4e3a\uff0c\u9057\u4ea7\u662f\u81ea\u7136\u4eba\u6b7b\u4ea1\u65f6\u9057\u7559\u7684\u4e2a\u4eba\u5408\u6cd5\u8d22\u4ea7\u3002\u7ee7\u627f\u5f00\u59cb\u540e\uff0c\u6309\u7167\u6cd5\u5b9a\u7ee7\u627f\u529e\u7406\uff1b\u6709\u9057\u5631\u7684\uff0c\u6309\u7167\u9057\u5631\u7ee7\u627f\u6216\u8005\u9057\u8d60\u529e\u7406\u3002\u672c\u6848\u4e2d\uff0c\u7cfb\u4e89\u623f\u5c4b\u539f\u767b\u8bb0\u4e8e\u7a0b\u67d03\u3001\u5f20\u67d02\u53ca\u7a0b\u67d01\u540d\u4e0b\uff0c\u5404\u5360\u4e09\u5206\u4e4b\u4e00\u4ea7\u6743\u4efd\u989d\u3002\u7a0b\u67d03\u4e0e\u5f20\u67d02\u6b7b\u4ea1\u540e\uff0c\u5176\u5404\u81ea\u6301\u6709\u7684\u4e09\u5206\u4e4b\u4e00\u4ea7\u6743\u4efd\u989d\u5c5e\u4e8e\u9057\u4ea7\u3002 \n\n\u5173\u4e8e\u7a0b\u67d03\u7684\u9057\u4ea7\u7ee7\u627f\u3002\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u4e09\u5341\u56db\u6761\u89c4\u5b9a\uff0c\u81ea\u4e66\u9057\u5631\u7531\u9057\u5631\u4eba\u4eb2\u7b14\u4e66\u5199\uff0c\u7b7e\u540d\uff0c\u6ce8\u660e\u5e74\u3001\u6708\u3001\u65e5\u3002\u7a0b\u67d03\u6240\u7acb\u81ea\u4e66\u9057\u5631\u7b26\u5408\u4e0a\u8ff0\u5f62\u5f0f\u8981\u4ef6\uff0c\u867d\u88ab\u544a\u4e3b\u5f20\u89c1\u8bc1\u4eba\u843d\u6b3e\u65e5\u671f\u4e0d\u4e00\u81f4\uff0c\u4f46\u6cd5\u5f8b\u5e76\u672a\u5f3a\u5236\u8981\u6c42\u81ea\u4e66\u9057\u5631\u987b\u6709\u89c1\u8bc1\u4eba\u7b7e\u540d\u65b9\u4e3a\u6709\u6548\uff0c\u6545\u8be5\u7455\u75b5\u4e0d\u8db3\u4ee5\u5426\u5b9a\u81ea\u4e66\u9057\u5631\u7684\u6548\u529b\u3002\u672c\u9662\u786e\u8ba4\u7a0b\u67d03\u540d\u4e0b\u7684\u4e09\u5206\u4e4b\u4e00\u4ea7\u6743\u4efd\u989d\u7531\u539f\u544a\u7a0b\u67d01\u7ee7\u627f\u3002\n\n\u5173\u4e8e\u5f20\u67d02\u7684\u9057\u4ea7\u7ee7\u627f\u3002\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u4e09\u5341\u4e5d\u6761\u89c4\u5b9a\uff0c\u516c\u8bc1\u9057\u5631\u7531\u9057\u5631\u4eba\u7ecf\u516c\u8bc1\u673a\u6784\u529e\u7406\u3002\u5f20\u67d02\u6240\u7acb\u516c\u8bc1\u9057\u5631\u5408\u6cd5\u6709\u6548\uff0c\u4e14\u539f\u3001\u88ab\u544a\u5747\u65e0\u5f02\u8bae\u3002\u672c\u9662\u786e\u8ba4\u5f20\u67d02\u540d\u4e0b\u7684\u4e09\u5206\u4e4b\u4e00\u4ea7\u6743\u4efd\u989d\u7531\u88ab\u544a\u7a0b\u67d02\u7ee7\u627f\u3002\n\n\u5173\u4e8e\u7cfb\u4e89\u623f\u5c4b\u7684\u5206\u5272\u3002\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u4e94\u5341\u516d\u6761\u89c4\u5b9a\uff0c\u9057\u4ea7\u5206\u5272\u5e94\u5f53\u6709\u5229\u4e8e\u751f\u4ea7\u548c\u751f\u6d3b\u9700\u8981\uff0c\u4e0d\u635f\u5bb3\u9057\u4ea7\u7684\u6548\u7528\u3002\u4e0d\u5b9c\u5206\u5272\u7684\u9057\u4ea7\uff0c\u53ef\u4ee5\u91c7\u53d6\u6298\u4ef7\u3001\u9002\u5f53\u8865\u507f\u6216\u8005\u5171\u6709\u7b49\u65b9\u6cd5\u5904\u7406\u3002\u672c\u6848\u4e2d\uff0c\u539f\u544a\u7a0b\u67d01\u672c\u5373\u6301\u6709\u623f\u5c4b\u4e09\u5206\u4e4b\u4e00\u4efd\u989d\uff0c\u901a\u8fc7\u7ee7\u627f\u540e\u518d\u53d6\u5f97\u7a0b\u67d03\u7684\u4e09\u5206\u4e4b\u4e00\u4efd\u989d\uff0c\u5171\u8ba1\u6301\u6709\u4e09\u5206\u4e4b\u4e8c\u4efd\u989d\uff1b\u88ab\u544a\u7a0b\u67d02\u7ee7\u627f\u53d6\u5f97\u4e09\u5206\u4e4b\u4e00\u4efd\u989d\u3002\u8003\u8651\u5230\u539f\u544a\u6240\u5360\u4ea7\u6743\u4efd\u989d\u8f83\u5927\u4e14\u6709\u53d6\u5f97\u623f\u5c4b\u6240\u6709\u6743\u7684\u610f\u613f\uff0c\u672c\u9662\u5224\u4ee4\u7cfb\u4e89\u623f\u5c4b\u5f52\u539f\u544a\u7a0b\u67d01\u6240\u6709\uff0c\u7531\u539f\u544a\u6309\u8bc4\u4f30\u4ef7\u683c\u5411\u88ab\u544a\u7a0b\u67d02\u652f\u4ed8\u5bf9\u5e94\u4efd\u989d\u7684\u6298\u4ef7\u6b3e\u4eba\u6c11\u5e01855,334\u5143\u3002\n\n\u3010\u5224\u51b3\u7ed3\u679c\u3011\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u4e09\u5341\u56db\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u4e09\u5341\u4e5d\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u4e94\u5341\u516d\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n\u4e00\u3001 \u88ab\u7ee7\u627f\u4eba\u7a0b\u67d03\u6301\u6709\u7684\u4e0a\u6d77\u5e02\u9759\u5b89\u533a\u623f\u5c4b\u4e09\u5206\u4e4b\u4e00\u4ea7\u6743\u4efd\u989d\u7531\u539f\u544a\u7a0b\u67d01\u7ee7\u627f\uff1b\n\u4e8c\u3001 \u88ab\u7ee7\u627f\u4eba\u5f20\u67d02\u6301\u6709\u7684\u4e0a\u6d77\u5e02\u9759\u5b89\u533a\u623f\u5c4b\u4e09\u5206\u4e4b\u4e00\u4ea7\u6743\u4efd\u989d\u7531\u88ab\u544a\u7a0b\u67d02\u7ee7\u627f\uff1b\n\u4e09\u3001 \u7ee7\u627f\u5b8c\u6210\u540e\uff0c\u4e0a\u8ff0\u4e0a\u6d77\u5e02\u9759\u5b89\u533a\u623f\u5c4b\u4ea7\u6743\u5f52\u539f\u544a\u7a0b\u67d01\u6240\u6709\uff1b\n\u56db\u3001 \u539f\u544a\u7a0b\u67d01\u5e94\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u4e09\u5341\u65e5\u5185\u652f\u4ed8\u88ab\u544a\u7a0b\u67d02\u623f\u5c4b\u6298\u4ef7\u6b3e\u4eba\u6c11\u5e01855,334\u5143\uff1b\n\u4e94\u3001 \u88ab\u544a\u7a0b\u67d02\u5e94\u4e8e\u6536\u5230\u4e0a\u8ff0\u6b3e\u9879\u540e\u5341\u4e94\u65e5\u5185\u534f\u52a9\u539f\u544a\u7a0b\u67d01\u529e\u7406\u4e0a\u8ff0\u623f\u5c4b\u7684\u4ea7\u6743\u53d8\u66f4\u767b\u8bb0\u624b\u7eed\uff0c\u76f8\u5173\u7a0e\u8d39\u6309\u56fd\u5bb6\u89c4\u5b9a\u7531\u539f\u3001\u88ab\u544a\u5404\u81ea\u627f\u62c5\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u4ee5\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\uff0c\u5e76\u6309\u5bf9\u65b9\u5f53\u4e8b\u4eba\u7684\u4eba\u6570\u63d0\u51fa\u526f\u672c\uff0c\u4e0a\u8bc9\u4e8e\u4e0a\u6d77\u5e02\u7b2c\u4e8c\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002": "95% Bootstrap Confidence Interval: (0.0%, 0.0%), Median: 0.0%"
    }
