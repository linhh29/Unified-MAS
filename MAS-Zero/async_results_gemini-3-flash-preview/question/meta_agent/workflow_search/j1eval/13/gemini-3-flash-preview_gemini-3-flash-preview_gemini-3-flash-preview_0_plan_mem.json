[
    {
        "\u3010\u8bf4\u7406\u5185\u5bb9\u3011\n\n\u672c\u9662\u8ba4\u4e3a\uff0c\u672c\u6848\u7cfb\u8d22\u4ea7\u635f\u5bb3\u8d54\u507f\u7ea0\u7eb7\u3002\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u516d\u5341\u4e94\u6761\u4e4b\u89c4\u5b9a\uff0c\u884c\u4e3a\u4eba\u56e0\u8fc7\u9519\u4fb5\u5bb3\u4ed6\u4eba\u6c11\u4e8b\u6743\u76ca\uff0c\u5e94\u5f53\u627f\u62c5\u4fb5\u6743\u8d23\u4efb\u3002\u5173\u4e8e\u672c\u6848\u7684\u4e89\u8bae\u7126\u70b9\uff0c\u672c\u9662\u8bc4\u5224\u5982\u4e0b\uff1a\n\n\u9996\u5148\uff0c\u5173\u4e8e\u4fb5\u6743\u884c\u4e3a\u53ca\u8d23\u4efb\u8ba4\u5b9a\u3002\u539f\u544a\u63d0\u4f9b\u7684\u300a\u62a5\u8b66\u56de\u6267\u300b\u53ca\u73b0\u573a\u635f\u5bb3\u7167\u7247\u663e\u793a\uff0c\u539f\u544a\u623f\u95e8\u786e\u5b9e\u5b58\u5728\u7269\u7406\u635f\u574f\uff0c\u4e14\u4e8b\u53d1\u540e\u88ab\u544a\u88ab\u8b66\u65b9\u5e26\u8d70\u8c03\u67e5\uff0c\u8db3\u4ee5\u5f62\u6210\u88ab\u544a\u5728\u73b0\u573a\u5b9e\u65bd\u4e86\u635f\u5bb3\u884c\u4e3a\u7684\u9ad8\u5ea6\u76d6\u7136\u6027\u3002\u88ab\u544a\u8fa9\u79f0\u5176\u56e0\u80a2\u4f53\u6b8b\u75be\u4e0d\u5177\u5907\u635f\u5bb3\u80fd\u529b\uff0c\u4f46\u672a\u63d0\u4ea4\u6b8b\u75be\u7b49\u7ea7\u8bc1\u660e\u6216\u533b\u5b66\u9274\u5b9a\u4ee5\u8bc1\u5b9e\u5176\u5b8c\u5168\u4e27\u5931\u884c\u52a8\u80fd\u529b\uff0c\u4e14\u8eab\u4f53\u6b8b\u75be\u5e76\u4e0d\u6392\u9664\u5229\u7528\u5de5\u5177\u635f\u574f\u8d22\u7269\u7684\u53ef\u80fd\u6027\uff0c\u6545\u5bf9\u5176\u8fa9\u79f0\u610f\u89c1\uff0c\u672c\u9662\u4e0d\u4e88\u91c7\u4fe1\u3002\u672c\u9662\u8ba4\u5b9a\u88ab\u544a\u5189\u67d0\u7684\u884c\u4e3a\u6784\u6210\u4fb5\u6743\uff0c\u5e94\u627f\u62c5\u8d54\u507f\u8d23\u4efb\u3002\n\n\u5176\u6b21\uff0c\u5173\u4e8e\u635f\u5931\u6570\u989d\u7684\u8ba4\u5b9a\u3002\u4f9d\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u201c\u8c01\u4e3b\u5f20\u8c01\u4e3e\u8bc1\u201d\u7684\u539f\u5219\uff0c\u539f\u544a\u4e3b\u5f20\u635f\u5931\u91d1\u989d\u4e3a4000\u5143\uff0c\u7406\u5e94\u63d0\u4f9b\u8d2d\u4e70\u53d1\u7968\u3001\u7ef4\u4fee\u62a5\u4ef7\u5355\u6216\u8bc4\u4f30\u62a5\u544a\u4e88\u4ee5\u8bc1\u5b9e\u3002\u73b0\u539f\u544a\u672a\u80fd\u63d0\u4f9b\u4e0a\u8ff0\u8bc1\u636e\uff0c\u5176\u4e3b\u5f20\u7684\u6570\u989d\u7f3a\u4e4f\u4e8b\u5b9e\u4f9d\u636e\u3002\u7136\u800c\uff0c\u9274\u4e8e\u623f\u95e8\u53d7\u635f\u4e8b\u5b9e\u5ba2\u89c2\u5b58\u5728\uff0c\u4e14\u786e\u6709\u66f4\u6362\u6216\u7ef4\u4fee\u4e4b\u5fc5\u8981\uff0c\u672c\u9662\u6839\u636e\u516c\u5e73\u539f\u5219\uff0c\u7ed3\u5408\u53d7\u635f\u7167\u7247\u663e\u793a\u7684\u7834\u635f\u7a0b\u5ea6\u3001\u5f53\u5730\u5e02\u573a\u4e00\u822c\u9632\u76d7\u95e8\u4ef7\u683c\u53ca\u6298\u65e7\u60c5\u51b5\uff0c\u914c\u60c5\u8ba4\u5b9a\u8d22\u4ea7\u635f\u5931\u91d1\u989d\u3002\n\n\u3010\u5224\u51b3\u7ed3\u679c\u3011\n\n\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u516d\u5341\u4e94\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u516b\u5341\u56db\u6761\uff0c\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u516d\u5341\u4e03\u6761\u7b2c\u4e00\u6b3e\uff0c\u300a\u6700\u9ad8\u4eba\u6c11\u6cd5\u9662\u5173\u4e8e\u9002\u7528\u3008\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u3009\u7684\u89e3\u91ca\u300b\u7b2c\u4e5d\u5341\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n\u4e00\u3001\u88ab\u544a\u5189\u67d0\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\u8d54\u507f\u539f\u544a\u5189\u67d0\u67d0\u9632\u76d7\u95e8\u635f\u5931\u5171\u8ba12000\u5143\uff08\u6b64\u4e3a\u672c\u9662\u914c\u5b9a\u91d1\u989d\uff09\uff1b\n\n\u4e8c\u3001\u9a73\u56de\u539f\u544a\u5189\u67d0\u67d0\u7684\u5176\u4ed6\u8bc9\u8bbc\u8bf7\u6c42\u3002\n\n\u5982\u679c\u88ab\u544a\u672a\u6309\u672c\u5224\u51b3\u6307\u5b9a\u7684\u671f\u95f4\u5c65\u884c\u7ed9\u4ed8\u91d1\u94b1\u4e49\u52a1\uff0c\u5e94\u5f53\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u4e8c\u767e\u516d\u5341\u6761\u4e4b\u89c4\u5b9a\uff0c\u52a0\u500d\u652f\u4ed8\u8fdf\u5ef6\u5c65\u884c\u671f\u95f4\u7684\u503a\u52a1\u5229\u606f\u3002\n\n\u6848\u4ef6\u53d7\u7406\u8d39\u7531\u88ab\u544a\u5189\u67d0\u8d1f\u62c5\uff08\u672c\u9662\u914c\u60c5\u51b3\u5b9a\u627f\u62c5\u6bd4\u4f8b\uff09\u3002\n\n\u5982\u4e0d\u670d\u672c\u5224\u51b3\uff0c\u53ef\u5728\u5224\u51b3\u4e66\u9001\u8fbe\u4e4b\u65e5\u8d77\u5341\u4e94\u65e5\u5185\uff0c\u5411\u672c\u9662\u9012\u4ea4\u4e0a\u8bc9\u72b6\u3002\n\n": "95% Bootstrap Confidence Interval: (0.0%, 0.0%), Median: 0.0%"
    },
    {
        "\u3010\u8bf4\u7406\u5185\u5bb9\u3011\n\n\u672c\u9662\u8ba4\u4e3a\uff0c\u672c\u6848\u7cfb\u8d22\u4ea7\u635f\u5bb3\u8d54\u507f\u7ea0\u7eb7\u3002\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u516d\u5341\u4e94\u6761\u4e4b\u89c4\u5b9a\uff0c\u884c\u4e3a\u4eba\u56e0\u8fc7\u9519\u4fb5\u5bb3\u4ed6\u4eba\u6c11\u4e8b\u6743\u76ca\u9020\u6210\u635f\u5bb3\u7684\uff0c\u5e94\u5f53\u627f\u62c5\u4fb5\u6743\u8d23\u4efb\u3002 \n\n\u9996\u5148\uff0c\u5173\u4e8e\u4fb5\u6743\u884c\u4e3a\u7684\u8ba4\u5b9a\u3002\u539f\u544a\u4e3e\u793a\u7684\u62a5\u8b66\u56de\u6267\u8bb0\u5f55\u4e86\u6848\u53d1\u5f53\u65f6\u8b66\u65b9\u51fa\u8b66\u5e76\u5c06\u88ab\u544a\u5e26\u8d70\u8c03\u67e5\u7684\u4e8b\u5b9e\uff0c\u73b0\u573a\u623f\u95e8\u635f\u574f\u7167\u7247\u76f4\u89c2\u53cd\u6620\u4e86\u635f\u5bb3\u7ed3\u679c\u3002\u88ab\u544a\u867d\u8fa9\u79f0\u5176\u56e0\u80a2\u4f53\u6b8b\u75be\u65e0\u529b\u5b9e\u65bd\u7834\u574f\uff0c\u4f46\u5176\u672a\u80fd\u63d0\u4f9b\u8bc1\u636e\u8bc1\u660e\u5176\u8eab\u4f53\u72b6\u51b5\u5df2\u8fbe\u5230\u4e27\u5931\u57fa\u672c\u7269\u7406\u884c\u52a8\u80fd\u529b\u7684\u7a0b\u5ea6\uff0c\u4e14\u5176\u51fa\u73b0\u5728\u6848\u53d1\u73b0\u573a\u5e76\u88ab\u8b66\u65b9\u63a7\u5236\u7684\u4e8b\u5b9e\u4e0e\u5176\u6297\u8fa9\u7406\u7531\u76f8\u77db\u76fe\u3002\u56e0\u6b64\uff0c\u672c\u9662\u5bf9\u88ab\u544a\u7684\u6297\u8fa9\u610f\u89c1\u4e0d\u4e88\u91c7\u4fe1\uff0c\u8ba4\u5b9a\u88ab\u544a\u5189\u67d0\u5b9e\u65bd\u4e86\u635f\u6bc1\u539f\u544a\u9632\u76d7\u95e8\u7684\u4fb5\u6743\u884c\u4e3a\u3002\n\n\u5176\u6b21\uff0c\u5173\u4e8e\u8d54\u507f\u91d1\u989d\u7684\u8ba4\u5b9a\u3002\u539f\u544a\u4e3b\u5f20\u9632\u76d7\u95e8\u635f\u5931\u4e3a4000\u5143\u3002\u867d\u7136\u539f\u544a\u672a\u63d0\u4ea4\u6b63\u5f0f\u7684\u635f\u5931\u9274\u5b9a\u610f\u89c1\u6216\u7ef4\u4fee\u53d1\u7968\uff0c\u4f46\u5176\u4e3b\u5f20\u7684\u91d1\u989d\u5728\u9632\u76d7\u95e8\u66f4\u6362\u53ca\u5b89\u88c5\u6210\u672c\u7684\u5408\u7406\u5e02\u573a\u8303\u56f4\u4e4b\u5185\u3002\u88ab\u544a\u5728\u8bc9\u8bbc\u4e2d\u4ec5\u5426\u8ba4\u5176\u5b9e\u65bd\u4e86\u7834\u574f\u884c\u4e3a\uff0c\u5e76\u672a\u5bf9\u539f\u544a\u4e3b\u5f20\u76844000\u5143\u635f\u5931\u6570\u989d\u63d0\u51fa\u5177\u4f53\u7684\u5f02\u8bae\uff0c\u4ea6\u672a\u7533\u8bf7\u8fdb\u884c\u4ef7\u683c\u8bc4\u4f30\u3002\u9274\u4e8e\u88ab\u544a\u7684\u4fb5\u6743\u884c\u4e3a\u5df2\u7ecf\u8ba4\u5b9a\uff0c\u4e14\u5176\u672a\u5bf9\u53d7\u635f\u8d22\u7269\u7684\u5177\u4f53\u4ef7\u503c\u5c3d\u5230\u53cd\u9a73\u53ca\u4e3e\u8bc1\u8d23\u4efb\uff0c\u4e3a\u4fdd\u62a4\u53d7\u5bb3\u4eba\u7684\u5408\u6cd5\u6743\u76ca\uff0c\u672c\u9662\u5bf9\u539f\u544a\u4e3b\u5f20\u76844000\u5143\u635f\u5931\u4e88\u4ee5\u652f\u6301\u3002\n\n\u3010\u6700\u7ec8\u5224\u51b3\u3011\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u516d\u5341\u4e94\u6761\u3001\u7b2c\u4e00\u5343\u4e00\u767e\u516b\u5341\u56db\u6761\uff0c\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u516d\u5341\u4e03\u6761\u4e4b\u89c4\u5b9a\uff0c\u5224\u51b3\u5982\u4e0b\uff1a\n\n\u4e00\u3001\u88ab\u544a\u5189\u67d0\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\u8d54\u507f\u539f\u544a\u5189\u67d0\u67d0\u9632\u76d7\u95e8\u635f\u59314000\u5143\uff1b\n\n\u4e8c\u3001\u672c\u6848\u8bc9\u8bbc\u8d39\u7531\u88ab\u544a\u5189\u67d0\u627f\u62c5\u3002\n\n\u5982\u672a\u6309\u672c\u5224\u51b3\u6307\u5b9a\u7684\u671f\u95f4\u5c65\u884c\u7ed9\u4ed8\u91d1\u94b1\u4e49\u52a1\uff0c\u5e94\u5f53\u4f9d\u7167\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u4e8b\u8bc9\u8bbc\u6cd5\u300b\u7b2c\u4e8c\u767e\u516d\u5341\u6761\u4e4b\u89c4\u5b9a\uff0c\u52a0\u500d\u652f\u4ed8\u8fdf\u5ef6\u5c65\u884c\u671f\u95f4\u7684\u503a\u52a1\u5229\u606f\u3002": "95% Bootstrap Confidence Interval: (0.0%, 0.0%), Median: 0.0%"
    },
    {
        "\u8bf4\u7406\u5185\u5bb9\uff1a\u672c\u9662\u8ba4\u4e3a\uff0c\u5f53\u4e8b\u4eba\u5bf9\u81ea\u5df1\u63d0\u51fa\u7684\u8bc9\u8bbc\u8bf7\u6c42\u6240\u4f9d\u636e\u7684\u4e8b\u5b9e\u6709\u8d23\u4efb\u63d0\u4f9b\u8bc1\u636e\u52a0\u4ee5\u8bc1\u660e\uff0c\u6ca1\u6709\u8bc1\u636e\u6216\u8005\u8bc1\u636e\u4e0d\u8db3\u4ee5\u8bc1\u660e\u5f53\u4e8b\u4eba\u7684\u4e8b\u5b9e\u4e3b\u5f20\u7684\uff0c\u7531\u8d1f\u6709\u4e3e\u8bc1\u8d23\u4efb\u7684\u5f53\u4e8b\u4eba\u627f\u62c5\u4e0d\u5229\u540e\u679c\u3002\u672c\u6848\u4e2d\uff0c\u539f\u544a\u5189\u67d0\u67d0\u4e3b\u5f20\u88ab\u544a\u5189\u67d0\u5c06\u5176\u9632\u76d7\u95e8\u780d\u574f\uff0c\u8981\u6c42\u5176\u8d54\u507f\u635f\u5931\u3002\u4f46\u539f\u544a\u63d0\u4ea4\u7684\u300a\u62a5\u8b66\u56de\u6267\u300b\u4ec5\u80fd\u8bc1\u660e\u5176\u5411\u516c\u5b89\u673a\u5173\u62a5\u6848\u7684\u4e8b\u5b9e\uff0c\u623f\u95e8\u53d7\u635f\u7167\u7247\u4ec5\u80fd\u8bc1\u660e\u9632\u76d7\u95e8\u53d7\u635f\u7684\u73b0\u72b6\uff0c\u524d\u8ff0\u8bc1\u636e\u5747\u65e0\u6cd5\u8bc1\u660e\u88ab\u544a\u5b9e\u65bd\u4e86\u780d\u574f\u623f\u95e8\u7684\u884c\u4e3a\uff0c\u4ea6\u65e0\u6cd5\u8bc1\u660e\u88ab\u544a\u884c\u4e3a\u4e0e\u635f\u5bb3\u540e\u679c\u4e4b\u95f4\u5b58\u5728\u56e0\u679c\u5173\u7cfb\u3002\u88ab\u544a\u5189\u67d0\u5bf9\u539f\u544a\u7684\u4e3b\u5f20\u4e88\u4ee5\u5426\u8ba4\uff0c\u5e76\u63d0\u51fa\u5176\u7cfb\u80a2\u4f53\u6b8b\u75be\uff0c\u65e0\u635f\u5bb3\u80fd\u529b\u7684\u6297\u8fa9\u3002\u5728\u539f\u544a\u672a\u80fd\u63d0\u4f9b\u5176\u4ed6\u76f4\u63a5\u8bc1\u636e\uff08\u5982\u73b0\u573a\u76d1\u63a7\u3001\u516c\u5b89\u673a\u5173\u8be2\u95ee\u7b14\u5f55\u3001\u5904\u7f5a\u51b3\u5b9a\u7b49\uff09\u8bc1\u660e\u88ab\u544a\u5b58\u5728\u4fb5\u6743\u884c\u4e3a\u7684\u60c5\u51b5\u4e0b\uff0c\u539f\u544a\u4e3b\u5f20\u88ab\u544a\u4fb5\u6743\u7684\u4e8b\u5b9e\u8bc1\u636e\u4e0d\u8db3\uff0c\u5176\u8bc9\u8bbc\u8bf7\u6c42\u7f3a\u4e4f\u4e8b\u5b9e\u548c\u6cd5\u5f8b\u4f9d\u636e\uff0c\u672c\u9662\u4e0d\u4e88\u652f\u6301\u3002\n\u6700\u7ec8\u5224\u51b3\uf