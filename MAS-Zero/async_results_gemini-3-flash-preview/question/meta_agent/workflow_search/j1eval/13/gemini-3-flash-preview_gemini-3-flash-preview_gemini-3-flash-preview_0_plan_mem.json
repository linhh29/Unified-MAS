    {
        "\u8bf4\u7406\u5185\u5bb9\uff1a\u672c\u9662\u8ba4\u4e3a\uff0c\u884c\u4e3a\u4eba\u56e0\u8fc7\u9519\u4fb5\u5bb3\u4ed6\u4eba\u6c11\u4e8b\u6743\u76ca\u9020\u6210\u635f\u5bb3\u7684\uff0c\u5e94\u5f53\u627f\u62c5\u4fb5\u6743\u8d23\u4efb\u3002\u672c\u6848\u4e2d\uff0c\u539f\u544a\u4e3e\u793a\u7684\u62a5\u8b66\u56de\u6267\u53ca\u623f\u95e8\u635f\u5bb3\u7167\u7247\u80fd\u591f\u5f62\u6210\u8bc1\u636e\u94fe\uff0c\u8bc1\u5b9e\u88ab\u544a\u5189\u67d0\u4e8e2024\u5e741\u670825\u65e5\u665a\u5728\u539f\u544a\u4f4f\u6240\u5916\u95f9\u4e8b\u5e76\u5c06\u9632\u76d7\u95e8\u635f\u6bc1\u7684\u4e8b\u5b9e\u3002\u88ab\u544a\u867d\u8fa9\u79f0\u5176\u56e0\u80a2\u4f53\u6b8b\u75be\u65e0\u80fd\u529b\u9020\u6210\u635f\u5bb3\uff0c\u4f46\u672a\u80fd\u63d0\u4ea4\u8bc1\u636e\u8bc1\u660e\u5176\u6b8b\u75be\u7a0b\u5ea6\u53ca\u4e27\u5931\u884c\u4e3a\u80fd\u529b\u7684\u60c5\u51b5\uff0c\u5bf9\u5176\u8fa9\u79f0\u7406\u7531\u672c\u9662\u4e0d\u4e88\u91c7\u4fe1\u3002\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u516d\u5341\u4e94\u6761\u4e4b\u89c4\u5b9a\uff0c\u88ab\u544a\u5e94\u5f53\u627f\u62c5\u4fb5\u6743\u8d54\u507f\u8d23\u4efb\u3002\u5173\u4e8e\u635f\u5931\u91d1\u989d\uff0c\u539f\u544a\u4e3b\u5f20\u9632\u76d7\u95e8\u635f\u59314000\u5143\uff0c\u88ab\u544a\u5728\u8bc9\u8bbc\u4e2d\u867d\u5426\u8ba4\u4fb5\u6743\uff0c\u4f46\u5e76\u672a\u5bf9\u635f\u5bb3\u91d1\u989d\u672c\u8eab\u63d0\u51fa\u5177\u4f53\u7684\u5f02\u8bae\u6216\u53cd\u8bc1\uff0c\u4ea6\u672a\u7533\u8bf7\u5bf9\u53d7\u635f\u9632\u76d7\u95e8\u8fdb\u884c\u4ef7\u503c\u9274\u5b9a\u3002\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u516b\u5341\u56db\u6761\u89c4\u5b9a\uff0c\u4fb5\u5bb3\u4ed6\u4eba\u8d22\u4ea7\u7684\uff0c\u8d22\u4ea7\u635f\u5931\u6309\u7167\u635f\u5931\u53d1\u751f\u65f6\u7684\u5e02\u573a\u4ef7\u683c\u6216\u8005\u5176\u4ed6\u5408\u7406\u65b9\u5f0f\u8ba1\u7b97\u3002\u7ed3\u5408\u539f\u544a\u7684\u8bc9\u8bf7