        "correct_answer": [
            "\u9a73\u56de\u539f\u544a\u5189\u67d0\u67d0\u7684\u8bc9\u8bbc\u8bf7\u6c42",
            "\u6848\u4ef6\u53d7\u7406\u8d3950\u5143\uff0c\u56e0\u9002\u7528\u5c0f\u989d\u8bc9\u8bbc\u5ba1\u7406\u630940%\u6536\u53d620\u5143\uff0c\u7531\u539f\u544a\u5189\u67d0\u67d0\u8d1f\u62c5\u3002",
            "\u672c\u5224\u51b3\u4e3a\u7ec8\u5ba1\u5224\u51b3"
        ],
        "n": 4,
        "response": "\u4f5c\u4e3a\u5ba1\u5224\u957f\uff0c\u672c\u6848\u7684\u6838\u5fc3\u5728\u4e8e\u8d22\u4ea7\u635f\u5bb3\u8d54\u507f\u3002\u6839\u636e\u5b50\u4efb\u52a11\u548c2\u7684\u7ed3\u8bba\uff0c\u88ab\u544a\u5189\u67d0\u7684\u4fb5\u6743\u884c\u4e3a\u5df2\u7ecf\u7531\u62a5\u8b66\u56de\u6267\u548c\u73b0\u573a\u7167\u7247\u7b49\u8bc1\u636e\u8bc1\u5b9e\uff0c\u4e14\u5176\u63d0\u51fa\u7684\u201c\u80a2\u4f53\u6b8b\u75be\u201d\u6297\u8fa9\u56e0\u672a\u4e3e\u8bc1\u4e14\u4e0d\u5408\u903b\u8f91\u800c\u4e0d\u4e88\u91c7\u4fe1\u3002\u5173\u4e8e\u8d54\u507f\u91d1\u989d\uff0c\u539f\u544a\u4e3b\u5f204000\u5143\uff0c\u88ab\u544a\u867d\u5bf9\u4fb5\u6743\u884c\u4e3a\u6709\u5f02\u8bae\uff0c\u4f46\u5e76\u672a\u5bf9\u623f\u5c4b\u635f\u5931\u7684\u5177\u4f53\u91d1\u989d\u63d0\u51fa\u4e13\u9879\u6297\u8fa9\u6216\u7533\u8bf7\u4ef7\u683c\u9274\u5b9a\u3002\u5728\u6392\u96642000\u5143\u30011200\u5143\u53ca\u9a73\u56de\u8bc9\u8bbc\u8bf7\u6c42\u7684\u9009\u9879\u540e\uff0c\u7ed3\u5408\u300a\u6c11\u6cd5\u5178\u300b\u7b2c1184\u6761\u5173\u4e8e\u8d22\u4ea7\u635f\u5931\u8ba1\u7b97\u7684\u89c4\u5b9a\uff0c\u4ee5\u53ca\u88ab\u544a\u672a\u5c31\u6570\u989d\u63d0\u51fa\u6709\u6548\u53cd\u9a73\u7684\u4e8b\u5b9e\uff0c\u672c\u9662\u4f9d\u6cd5\u652f\u6301\u539f\u544a4000\u5143\u7684\u8d54\u507f\u8bf7\u6c42\u3002\u5224\u51b3\u4f9d\u636e\u5305\u62ec\u300a\u6c11\u6cd5\u5178\u300b\u7b2c1165\u6761\uff08\u8fc7\u9519\u8d23\u4efb\uff09\u548c\u7b2c1184\u6761\uff08\u8d22\u4ea7\u635f\u5bb3\u8d54\u507f\u6807\u51c6\uff09\u3002\n\nAnswer:\u8bf4\u7406\u5185\u5bb9\uff1a\u672c\u9662\u8ba4\u4e3a\uff0c\u884c\u4e3a\u4eba\u56e0\u8fc7\u9519\u4fb5\u5bb3\u4ed6\u4eba\u6c11\u4e8b\u6743\u76ca\u9020\u6210\u635f\u5bb3\u7684\uff0c\u5e94\u5f53\u627f\u62c5\u4fb5\u6743\u8d23\u4efb\u3002\u672c\u6848\u4e2d\uff0c\u539f\u544a\u4e3e\u793a\u7684\u62a5\u8b66\u56de\u6267\u53ca\u623f\u95e8\u635f\u5bb3\u7167\u7247\u80fd\u591f\u5f62\u6210\u8bc1\u636e\u94fe\uff0c\u8bc1\u5b9e\u88ab\u544a\u5189\u67d0\u4e8e2024\u5e741\u670825\u65e5\u665a\u5728\u539f\u544a\u4f4f\u6240\u5916\u95f9\u4e8b\u5e76\u5c06\u9632\u76d7\u95e8\u635f\u6bc1\u7684\u4e8b\u5b9e\u3002\u88ab\u544a\u867d\u8fa9\u79f0\u5176\u56e0\u80a2\u4f53\u6b8b\u75be\u65e0\u80fd\u529b\u9020\u6210\u635f\u5bb3\uff0c\u4f46\u672a\u80fd\u63d0\u4ea4\u8bc1\u636e\u8bc1\u660e\u5176\u6b8b\u75be\u7a0b\u5ea6\u53ca\u4e27\u5931\u884c\u4e3a\u80fd\u529b\u7684\u60c5\u51b5\uff0c\u5bf9\u5176\u8fa9\u79f0\u7406\u7531\u672c\u9662\u4e0d\u4e88\u91c7\u4fe1\u3002\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u516d\u5341\u4e94\u6761\u4e4b\u89c4\u5b9a\uff0c\u88ab\u544a\u5e94\u5f53\u627f\u62c5\u4fb5\u6743\u8d54\u507f\u8d23\u4efb\u3002\u5173\u4e8e\u635f\u5931\u91d1\u989d\uff0c\u539f\u544a\u4e3b\u5f20\u9632\u76d7\u95e8\u635f\u59314000\u5143\uff0c\u88ab\u544a\u5728\u8bc9\u8bbc\u4e2d\u867d\u5426\u8ba4\u4fb5\u6743\uff0c\u4f46\u5e76\u672a\u5bf9\u635f\u5bb3\u91d1\u989d\u672c\u8eab\u63d0\u51fa\u5177\u4f53\u7684\u5f02\u8bae\u6216\u53cd\u8bc1\uff0c\u4ea6\u672a\u7533\u8bf7\u5bf9\u53d7\u635f\u9632\u76d7\u95e8\u8fdb\u884c\u4ef7\u503c\u9274\u5b9a\u3002\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u4e00\u767e\u516b\u5341\u56db\u6761\u89c4\u5b9a\uff0c\u4fb5\u5bb3\u4ed6\u4eba\u8d22\u4ea7\u7684\uff0c\u8d22\u4ea7\u635f\u5931\u6309\u7167\u635f\u5931\u53d1\u751f\u65f6\u7684\u5e02\u573a\u4ef7\u683c\u6216\u8005\u5176\u4ed6\u5408\u7406\u65b9\u5f0f\u8ba1\u7b97\u3002\u7ed3\u5408\u539f\u544a\u7684\u8bc9\u8bf7\u53ca\u672c\u6848\u5b9e\u9645\u60c5\u51b5\uff0c\u672c\u9662\u5bf9\u539f\u544a\u8981\u6c42\u88ab\u544a\u8d54\u507f4000\u5143\u7684\u8bc9\u8bbc\u8bf7\u6c42\u4e88\u4ee5\u652f\u6301\u3002\u6700\u7ec8\u5224\u51b3\uff1a\u4e00\u3001\u88ab\u544a\u5189\u67d0\u4e8e\u672c\u5224\u51b3\u751f\u6548\u4e4b\u65e5\u8d77\u5341\u65e5\u5185\u8d54\u507f\u539f\u544a\u5189\u67d0\u67d0\u9632\u76d7\u95e8\u635f\u59314000\u5143\uff1b\u4e8c\u3001\u672c\u6848\u8bc9\u8bbc\u8d39\u7531\u88ab\u544a\u5189\u67d0\u627f\u62c5\u3002",
